# HosAlivio local environment.
# Copy this file to `.env` (gitignored) and fill in real values.
# Reloaded on each `bin/rails s` restart via dotenv-rails.

# Anthropic API key. Primary brain for HosalivioBrain.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key. Used as a fallback if the Claude call fails (bad key,
# out of credits, timeout, outage). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the HosAlivio Claude model. Default is claude-sonnet-4-6.
# Other options: claude-opus-4-7 (smartest), claude-haiku-4-5-20251001 (fastest).
# HOSALIVIO_BRAIN_MODEL=claude-sonnet-4-6

# Optional: override the OpenAI fallback model. Default is gpt-4o.
# HOSALIVIO_LUCIA_OPENAI_MODEL=gpt-4o

# Optional: override the JWT secret used for OpenClaw agent API tokens.
# Defaults to Rails.application.secret_key_base if unset.
# HOSALIVIO_JWT_SECRET=your-32-byte-random-string
