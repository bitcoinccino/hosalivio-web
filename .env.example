# HosAlivio local environment.
# Copy this file to `.env` (gitignored) and fill in real values.
# Reloaded on each `bin/rails s` restart via dotenv-rails.

# Anthropic API key. Primary brain for HosalivioBrain.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key. Used as a fallback if the Claude call fails (bad key,
# out of credits, timeout, outage). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the HosAlivio Claude model. Default is claude-sonnet-4-6.
# Other options: claude-opus-4-7 (smartest), claude-haiku-4-5-20251001 (fastest).
# HOSALIVIO_BRAIN_MODEL=claude-sonnet-4-6

# Optional: override the OpenAI fallback model. Default is gpt-4o.
# HOSALIVIO_LUCIA_OPENAI_MODEL=gpt-4o

# Optional: override the JWT secret used for OpenClaw agent API tokens.
# Defaults to Rails.application.secret_key_base if unset.
# HOSALIVIO_JWT_SECRET=your-32-byte-random-string

# ── External EMR sync (VITAS portal) ────────────────────────────────
# Outbound push of certified pre-admit evals (VitasEmrSyncJob). The pipeline
# stays DORMANT until BOTH values are present — MD certification and the
# manual "Sync to VITAS now" action no-op safely while these are blank, so
# leave them commented until you have real gateway credentials. Setting a
# placeholder URL would make the job POST to a dead endpoint and the eval's
# sync chip would flip to "Sync failed".
#
#   - VITAS_GATEWAY_URL: the REST/FHIR endpoint payloads are POSTed to.
#   - VITAS_API_BEARER_TOKEN: sent as `Authorization: Bearer <token>`.
#     (The agency UUID is sent automatically as X-Tenant-Provider-ID.)
#
# VITAS_GATEWAY_URL=https://vitas-gateway.example.com/fhir/Encounter
# VITAS_API_BEARER_TOKEN=
