<% content_for :title, "Enter your sign-in code · HosAlivio" %>

<div class="min-h-screen bg-[#FBF9F5] px-6 py-12 flex items-center justify-center">
  <div class="w-full max-w-md">
    <%= link_to new_passwordless_path, class: "inline-flex items-center gap-2 text-[#6B665F] hover:text-[#1D1C1A] text-[12px] mb-6" do %>
      <i class="ri-arrow-left-line"></i> Use a different email
    <% end %>

    <div class="bg-white rounded-3xl border border-[#EFECE6] p-8 shadow-sm">
      <div class="w-12 h-12 rounded-full bg-[#FFF3EC] flex items-center justify-center mb-5">
        <i class="ri-key-2-line text-[#D97757] text-[22px]"></i>
      </div>

      <h1 class="font-serif text-[24px] text-[#1D1C1A] leading-tight">Check your email</h1>
      <p class="text-[13px] text-[#6B665F] mt-2 leading-relaxed">
        If <span class="font-medium text-[#1D1C1A]"><%= @email %></span> matches a HosAlivio account,
        we just sent a 6-digit code. It expires in 15 minutes.
      </p>

      <% if flash[:alert] %>
        <div class="mt-4 text-[12px] text-[#C1403A] bg-[#FFF3EC] border border-[#D97757] rounded-lg px-3 py-2">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: verify_passwordless_path, method: :post, local: true, html: { class: "space-y-4 mt-5" } do %>
        <div>
          <label class="block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1">6-digit code</label>
          <input type="text" name="code" required autofocus
                 inputmode="numeric" pattern="[0-9]{6}" maxlength="6" autocomplete="one-time-code"
                 placeholder="123456"
                 class="w-full px-3 py-3 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[22px] font-mono tracking-[0.3em] text-center">
        </div>

        <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-6 py-2.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium transition">
          <i class="ri-login-box-line"></i> Sign in
        </button>
      <% end %>

      <%= form_with url: passwordless_path, method: :post, local: true, html: { class: "mt-4" } do %>
        <input type="hidden" name="email" value="<%= @email %>">
        <button type="submit" class="w-full text-[12px] text-[#6B665F] hover:text-[#D97757]">
          Didn't get the email? Send a new code
        </button>
      <% end %>
    </div>
  </div>
</div>
