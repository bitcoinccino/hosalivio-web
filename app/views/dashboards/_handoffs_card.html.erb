<%# Card body for the Handoffs Waiting section. Locals:
    `pending_handoffs` (AgentEvent collection) and `viewer_user_id`. %>
<%= turbo_frame_tag "dashboard-handoffs-#{viewer_user_id}", target: "_top" do %>
  <% sorted_handoffs = pending_handoffs.sort_by { |ev|
       u = ev.change_set.is_a?(Hash) ? ev.change_set["urgency"].to_s : ""
       rank = { "crisis" => 0, "urgent" => 1 }[u] || 2
       [rank, -(ev.happened_at&.to_i || 0)]
     } %>
  <section data-controller="card-collapse" class="rounded-2xl bg-white border border-[#EFECE6] overflow-hidden">
    <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between gap-2">
      <h3 class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold"><i class="ri-send-plane-2-line"></i> Handoffs waiting for you (<%= sorted_handoffs.size %>)</h3>
      <button type="button" data-action="card-collapse#toggle" aria-label="Collapse card"
              class="md:hidden w-6 h-6 -mr-1 rounded-full text-[#6B665F] hover:bg-[#FBF9F5] flex items-center justify-center flex-shrink-0">
        <i data-card-collapse-target="chevron" class="ri-arrow-down-s-line text-[18px] transition-transform"></i>
      </button>
    </div>
    <div data-card-collapse-target="body" class="md:block">
    <% if sorted_handoffs.empty? %>
      <div class="px-5 py-6 text-center text-[12px] text-[#6B665F]">Nothing pending.</div>
    <% else %>
      <ul class="divide-y divide-[#EFECE6]">
        <% sorted_handoffs.each do |ev| %>
          <%
            change       = ev.change_set.is_a?(Hash) ? ev.change_set : {}
            intent_label = (change["intent"] || "handoff").to_s.tr("_", " ").capitalize
            resolved_patient = if ev.subject.is_a?(Patient)
                                 ev.subject
                               elsif ev.subject.respond_to?(:patient)
                                 ev.subject.patient
                               end
            patient_name = resolved_patient&.full_name.presence ||
                           change["patient_name"].presence ||
                           "Unknown patient"
            detail_bits = []
            detail_bits << "ICD #{change['primary_icd10']}" if change["primary_icd10"].present?
            detail_bits << "drug: #{change['drug']}"        if change["drug"].present?
            if change["blockers"].is_a?(Array) && change["blockers"].any?
              detail_bits << "needs #{change['blockers'].first}"
            end
            urgency   = change["urgency"].to_s
            deep_link = if resolved_patient
                          patient_path(resolved_patient)
                        elsif ev.subject.respond_to?(:patient_id) && ev.subject.patient_id
                          patient_path(ev.subject.patient_id)
                        else
                          "#"
                        end

            # Find the originating note: most recent family/clinician
            # message for this patient within 5 min before the handoff.
            # Provides the body excerpt + raised-by attribution that
            # turns the queue from "stack of identical alarms" into a
            # triageable list.
            origin_note = nil
            if resolved_patient
              window_start = (ev.happened_at || Time.current) - 5.minutes
              window_end   = (ev.happened_at || Time.current) + 30.seconds
              origin_note = resolved_patient.notes
                                            .where(created_at: window_start..window_end)
                                            .where.not(author_role: "admissions")
                                            .where.not(source: "system")
                                            .order(created_at: :desc)
                                            .first
            end
            raised_by_name =
              origin_note&.author_user&.full_name.presence ||
              change["raised_by"].presence
            raised_by_relation =
              origin_note&.author_user&.relationship.presence ||
              (origin_note&.author_role.to_s == "family" ? "Family" : nil) ||
              origin_note&.author_role&.to_s&.tr("_", " ")&.titleize

            body_excerpt = origin_note&.body.to_s.strip
            body_excerpt = nil if body_excerpt.blank?
            body_excerpt = body_excerpt && body_excerpt.length > 110 ? "#{body_excerpt[0, 110].rstrip}…" : body_excerpt
          %>
          <li class="px-5 py-3 hover:bg-[#FBF9F5] transition">
            <div class="flex items-start gap-3">
              <%= link_to deep_link, class: "flex-1 min-w-0 block" do %>
                <div class="flex items-baseline justify-between gap-2">
                  <div class="text-[13px] font-medium text-[#1D1C1A] truncate"><%= patient_name %></div>
                  <span class="text-[10px] text-[#6B665F] font-mono flex-shrink-0"><%= ev.happened_at&.strftime("%-l:%M %p") %></span>
                </div>
                <div class="text-[12px] text-[#3A3936] mt-0.5 truncate">
                  <%= intent_label %><% if detail_bits.any? %> · <%= detail_bits.join(" · ") %><% end %>
                </div>
                <% if body_excerpt %>
                  <div class="text-[12px] text-[#1D1C1A] mt-1 italic line-clamp-2">
                    "<%= body_excerpt %>"
                  </div>
                <% end %>
                <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                  <% if %w[crisis urgent].include?(urgency) %>
                    <span class="text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded <%= urgency == 'crisis' ? 'bg-[#C1403A] text-white' : 'bg-[#D97757] text-white' %>">
                      <%= urgency %>
                    </span>
                  <% end %>
                  <% if raised_by_name %>
                    <span class="text-[10px] text-[#6B665F]">
                      from <strong class="text-[#1D1C1A] font-medium"><%= raised_by_name %></strong><% if raised_by_relation %> · <%= raised_by_relation %><% end %>
                    </span>
                  <% end %>
                </div>
              <% end %>
              <%= button_to handoff_acknowledgment_path(agent_event_id: ev.id),
                    method: :post,
                    data: { turbo_confirm: "Mark this #{intent_label.downcase} acknowledged?" },
                    form: { class: "flex-shrink-0" },
                    class: "inline-flex items-center gap-1 text-[11px] px-3 py-1.5 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white font-medium" do %>
                <i class="ri-check-line"></i> Got it
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
    </div>
  </section>
<% end %>
