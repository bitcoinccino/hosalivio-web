<%# One activity row, redesigned: category-colored avatar, a bold headline
    (the patient, or the actor when there's no patient), an actor+action
    subline, and a small meta line. Rows about a patient link to the chart. %>
<%
  persona   = story.persona
  patient   = story.patient
  ev        = story.event
  pulses    = local_assigns.fetch(:unresolved_note_ids, []).include?(ev.subject_id)
  is_crisis = story.urgency_crisis?

  category = activity_category(ev)
  _key, cat_label, cat_color = activity_lane_meta(category)

  headline = patient ? patient.full_name : story.source_label
  action   = story.action_label
  subline  = patient ? "#{story.source_label} #{action}" : action
  initials = patient ? patient.full_name.to_s.split.map(&:first).first(2).join.upcase : persona[:initials]

  row_class = [ "group/story flex items-start gap-2.5 rounded-xl px-2 py-1.5 -mx-2 transition" ]
  row_class << "hover:bg-[#FBF9F5]" if patient
  row_class << "bg-[#FFF3EC]"       if pulses
  attrs = { "data-story": "", "data-category": category, class: row_class.join(" ") }
  attrs[:href] = patient_path(patient) if patient
%>
<%= content_tag(patient ? :a : :div, attrs) do %>
  <!-- Category-colored avatar (patient or actor initials) -->
  <span class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-white font-medium text-[11px]"
        style="background: <%= cat_color %>;" title="<%= cat_label %>"><%= initials %></span>

  <div class="min-w-0 flex-1">
    <div class="text-[13px] font-semibold text-[#1D1C1A] truncate <%= 'group-hover/story:text-[#D97757]' if patient %>"><%= headline %></div>
    <div class="text-[12px] text-[#6B665F] leading-snug"><%= subline %></div>
    <div class="mt-0.5 flex items-center gap-2 text-[10px] text-[#9A938A]">
      <time datetime="<%= ev.happened_at.iso8601 %>" class="font-mono"><%= ev.happened_at.strftime("%-l:%M %p") %></time>
      <% if is_crisis %>
        <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-[#C1403A] text-white tracking-wider">CRISIS</span>
      <% end %>
      <% if patient %>
        <span class="font-mono">· <%= patient.mrn %></span>
      <% end %>
    </div>
  </div>
<% end %>
