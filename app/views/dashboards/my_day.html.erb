<% content_for :title, "My Day · HosAlivio" %>
<%
  role  = current_user.role_names.first
  greet = (Time.current.hour < 12 ? "Good morning" : (Time.current.hour < 18 ? "Good afternoon" : "Good evening"))
  role_color = {
    "rn" => "#2F6F4E", "md" => "#2B4A7A", "social_worker" => "#7A4A8C",
    "chaplain" => "#8C6A2F", "aide" => "#AD7340"
  }[role] || "#6B665F"
%>
<div class="flex h-screen" data-controller="sidebar" data-sidebar-storage-key-value="myDaySidebar">
  <!-- Left rail -->
  <aside data-sidebar-target="sidebar" data-collapsed="false"
         class="group/sb w-72 data-[collapsed=true]:w-16 bg-[#EFECE6] border-r border-[#D9D5CD] flex flex-col justify-between p-6 data-[collapsed=true]:p-3 transition-[width,padding] duration-200">
    <div>
      <div class="flex items-center justify-between group-data-[collapsed=true]/sb:flex-col group-data-[collapsed=true]/sb:gap-2">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-full bg-[#D97757] text-white flex items-center justify-center flex-shrink-0">
            <i class="ri-heart-pulse-line text-sm"></i>
          </div>
          <h1 class="text-xs uppercase tracking-[0.2em] text-[#6B665F] font-bold group-data-[collapsed=true]/sb:hidden">HosAlivio</h1>
        </div>
        <button type="button" data-action="click->sidebar#toggle"
                class="w-7 h-7 rounded-full hover:bg-[#D9D5CD] text-[#6B665F] flex items-center justify-center flex-shrink-0 transition">
          <i class="ri-side-bar-line text-[15px]"></i>
        </button>
      </div>
      <nav class="mt-8 space-y-1.5 text-sm">
        <a href="/dashboard" title="My Day"
           class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[#D9D5CD] text-[#1D1C1A] font-medium group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-sun-line"></i><span class="group-data-[collapsed=true]/sb:hidden">My Day</span>
        </a>
        <a href="/calendar" title="Calendar"
           class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-calendar-line"></i><span class="group-data-[collapsed=true]/sb:hidden">Calendar</span>
        </a>
        <% unread_count = (Notification.where(user: current_user, read_at: nil).count rescue 0) %>
        <a href="/notifications" title="Notifications"
           class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-notification-3-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">Notifications</span>
          <% if unread_count > 0 %>
            <span class="ml-auto text-[10px] font-bold px-2 py-0.5 rounded-full bg-[#D97757] text-white group-data-[collapsed=true]/sb:hidden"><%= unread_count %></span>
          <% end %>
        </a>
      </nav>
    </div>
    <div class="mt-3">
      <%= render "shared/user_menu", direction: :up %>
    </div>
  </aside>

  <!-- Main -->
  <main class="flex-1 flex flex-col overflow-hidden">
    <header class="px-8 py-5 border-b border-[#EFECE6] bg-white">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-xl font-serif font-bold text-[#1D1C1A]"><%= greet %>, <%= current_user.full_name.to_s.split.first %>.</h2>
          <div class="text-xs text-[#6B665F] mt-0.5"><%= Date.current.strftime("%A, %B %-d") %> · <%= role&.tr("_", " ")&.upcase %> at <%= @agency&.name %></div>
        </div>
        <% if @my_license_status == :expired || @my_license_status == :expiring %>
          <div class="text-[11px] px-3 py-1.5 rounded-full bg-[#FFF3EC] border border-[#D97757] text-[#C1403A]">
            <i class="ri-shield-cross-line"></i> License <%= @my_license_status == :expired ? "EXPIRED" : "expires soon" %>
          </div>
        <% end %>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto">
      <div class="w-full max-w-[1400px] mx-auto px-4 md:px-8 py-6 space-y-6">

        <!-- Open crises tile (only when there are any) -->
        <% if @open_crises.any? %>
          <section class="rounded-2xl border-2 border-[#C1403A] bg-[#FFF3EC] overflow-hidden">
            <div class="bg-[#C1403A] text-white px-4 py-2 flex items-center gap-2">
              <i class="ri-alarm-warning-fill"></i>
              <span class="font-bold tracking-wider text-[12px]">OPEN CRISES ON YOUR CASELOAD (<%= @open_crises.size %>)</span>
            </div>
            <div class="divide-y divide-[#EFECE6]">
              <% @open_crises.each do |note| %>
                <%= link_to patient_path(note.patient), class: "block px-4 py-3 hover:bg-[#FFEDE2] transition" do %>
                  <div class="flex items-start gap-3">
                    <i class="ri-alarm-warning-line text-[#C1403A] mt-0.5"></i>
                    <div class="flex-1 min-w-0">
                      <div class="text-[13px] text-[#1D1C1A] truncate"><%= note.patient.full_name %></div>
                      <div class="text-[12px] text-[#3A3936] italic truncate">"<%= note.body.to_s[0, 100] %>"</div>
                      <div class="text-[10px] text-[#6B665F] font-mono mt-0.5"><%= note.created_at.strftime("%-l:%M %p") %></div>
                    </div>
                    <i class="ri-arrow-right-line text-[#6B665F]"></i>
                  </div>
                <% end %>
              <% end %>
            </div>
          </section>
        <% end %>

        <!-- Role-specific priority panel (appears above shared sections) -->
        <% role_partial = "dashboards/my_day_#{@primary_role}" %>
        <% if lookup_context.exists?(role_partial, [], true) %>
          <%= render role_partial %>
        <% end %>

        <!-- Today's visits -->
        <section class="rounded-2xl bg-white border border-[#EFECE6] overflow-hidden">
          <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between">
            <h3 class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold"><i class="ri-calendar-line"></i> Today's visits (<%= @todays_visits.size %>)</h3>
            <%= link_to "Full calendar", calendar_path, class: "text-[11px] text-[#D97757] hover:underline" %>
          </div>
          <% if @todays_visits.empty? %>
            <div class="px-5 py-10 text-center text-[13px] text-[#6B665F]">
              Nothing scheduled for today. Enjoy the calm.
            </div>
          <% else %>
            <ul class="divide-y divide-[#EFECE6]">
              <% @todays_visits.each do |v| %>
                <li class="flex items-center gap-3 px-5 py-3 hover:bg-[#FBF9F5] transition">
                  <div class="text-[13px] font-mono text-[#1D1C1A] w-20 flex-shrink-0"><%= v.anchor_start&.strftime("%-l:%M %p") %></div>
                  <%= link_to patient_path(v.patient), class: "flex-1 min-w-0" do %>
                    <div class="text-[14px] text-[#1D1C1A] truncate"><%= v.patient&.full_name %></div>
                    <div class="text-[11px] text-[#6B665F] truncate">
                      <%= v.visit_type.to_s.tr("_", " ") %>
                      <% if v.service_location.to_s != "home" %>
                        · <%= v.service_location.to_s.tr("_", " ") %>
                        <% if v.facility_name.present? %> (<%= v.facility_name %>)<% end %>
                      <% else %>
                        · home
                      <% end %>
                    </div>
                  <% end %>
                  <% if v.agent_authored %>
                    <span title="AI-scheduled" class="text-[#6B665F] flex-shrink-0">🤖</span>
                  <% end %>
                  <% if v.ended_at %>
                    <%= link_to edit_visit_path(v),
                          class: "inline-flex items-center gap-1 text-[11px] px-3 py-1.5 rounded-full border border-[#D9D5CD] text-[#1D1C1A] hover:bg-white font-medium flex-shrink-0" do %>
                      <i class="ri-edit-2-line"></i> Completed
                    <% end %>
                  <% elsif v.started_at %>
                    <%= link_to edit_visit_path(v),
                          class: "inline-flex items-center gap-1 text-[11px] px-3 py-1.5 rounded-full bg-[#C1403A] hover:bg-[#a5342f] text-white font-medium flex-shrink-0",
                          title: "Continue recording this visit" do %>
                      <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span> Recording
                    <% end %>
                  <% else %>
                    <%= button_to begin_visit_path(v), method: :post,
                          form: { class: "inline" },
                          class: "inline-flex items-center gap-1 text-[11px] px-3 py-1.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white font-medium flex-shrink-0",
                          title: "Start timer + open documentation" do %>
                      <i class="ri-mic-line"></i> Start visit
                    <% end %>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% end %>
        </section>

        <!-- Two-column: handoffs + overdue meds -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Pending handoffs -->
          <section class="rounded-2xl bg-white border border-[#EFECE6] overflow-hidden">
            <div class="px-5 py-3 border-b border-[#EFECE6]">
              <h3 class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold"><i class="ri-send-plane-2-line"></i> Handoffs waiting for you (<%= @pending_handoffs.size %>)</h3>
            </div>
            <% if @pending_handoffs.empty? %>
              <div class="px-5 py-8 text-center text-[12px] text-[#6B665F]">Nothing pending.</div>
            <% else %>
              <ul class="divide-y divide-[#EFECE6]">
                <% @pending_handoffs.each do |ev| %>
                  <%
                    change = ev.change_set.is_a?(Hash) ? ev.change_set : {}
                    intent_label = (change["intent"] || "handoff").to_s.tr("_", " ").capitalize
                    patient_name = change["patient_name"].presence || "—"
                    # Build a clinical one-liner from whatever keys the change_set carries.
                    detail_bits = []
                    detail_bits << "ICD #{change['primary_icd10']}" if change["primary_icd10"].present?
                    detail_bits << "drug: #{change['drug']}"        if change["drug"].present?
                    if change["blockers"].is_a?(Array) && change["blockers"].any?
                      detail_bits << "needs #{change['blockers'].first}"
                    end
                    raised_by = change["raised_by"].presence
                    urgency   = change["urgency"].to_s
                    deep_link = if ev.subject.is_a?(Patient)
                                  patient_path(ev.subject)
                                elsif ev.subject.respond_to?(:patient_id) && ev.subject.patient_id
                                  patient_path(ev.subject.patient_id)
                                else
                                  "#"
                                end
                  %>
                  <li>
                    <%= link_to deep_link, class: "block px-5 py-3 hover:bg-[#FBF9F5] transition" do %>
                      <div class="flex items-baseline justify-between gap-2">
                        <div class="text-[13px] font-medium text-[#1D1C1A] truncate"><%= patient_name %></div>
                        <span class="text-[10px] text-[#6B665F] font-mono flex-shrink-0"><%= ev.happened_at&.strftime("%-l:%M %p") %></span>
                      </div>
                      <div class="text-[12px] text-[#3A3936] mt-0.5 truncate">
                        <%= intent_label %><% if detail_bits.any? %> · <%= detail_bits.join(" · ") %><% end %>
                      </div>
                      <div class="flex items-center gap-2 mt-1">
                        <% if %w[crisis urgent].include?(urgency) %>
                          <span class="text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded <%= urgency == 'crisis' ? 'bg-[#C1403A] text-white' : 'bg-[#D97757] text-white' %>">
                            <%= urgency %>
                          </span>
                        <% end %>
                        <% if raised_by %>
                          <span class="text-[10px] text-[#6B665F]">from <%= raised_by %></span>
                        <% end %>
                      </div>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </section>

          <!-- Overdue comfort meds -->
          <section class="rounded-2xl bg-white border border-[#EFECE6] overflow-hidden">
            <div class="px-5 py-3 border-b border-[#EFECE6]">
              <h3 class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold"><i class="ri-capsule-line"></i> Overdue comfort meds (<%= @overdue_meds.size %>)</h3>
            </div>
            <% if @overdue_meds.empty? %>
              <div class="px-5 py-8 text-center text-[12px] text-[#6B665F]">All meds on time.</div>
            <% else %>
              <ul class="divide-y divide-[#EFECE6]">
                <% @overdue_meds.each do |row| %>
                  <% o = row[:order]; s = row[:schedule] %>
                  <li class="px-5 py-3">
                    <div class="flex items-baseline justify-between gap-2 mb-1">
                      <%= link_to patient_path(o.patient), class: "text-[13px] text-[#1D1C1A] truncate hover:underline" do %>
                        <%= o.drug_name %> <%= o.dose %>
                      <% end %>
                      <div class="text-[11px] text-[#C1403A] font-bold flex-shrink-0"><%= s[:label] %></div>
                    </div>
                    <div class="text-[11px] text-[#6B665F] truncate"><%= o.patient.full_name %> · <%= o.route.upcase %> · <%= o.frequency %></div>
                    <div class="mt-2 flex items-center gap-2">
                      <%= button_to medication_logs_path(medication_order_id: o.id),
                            method: :post,
                            data: { turbo_confirm: "Log #{o.drug_name} #{o.dose} as given to #{o.patient.full_name} right now?" },
                            class: "inline-flex items-center gap-1 text-[11px] px-3 py-1 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white font-medium" do %>
                        <i class="ri-check-line"></i> Mark as given
                      <% end %>
                      <%= button_to escalate_medication_logs_path(medication_order_id: o.id),
                            method: :post,
                            class: "inline-flex items-center gap-1 text-[11px] px-3 py-1 rounded-full border border-[#D9D5CD] text-[#1D1C1A] hover:bg-[#FBF9F5]" do %>
                        <i class="ri-stethoscope-line"></i> Escalate to MD
                      <% end %>
                    </div>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </section>
        </div>

        <!-- My caseload -->
        <section class="rounded-2xl bg-white border border-[#EFECE6] overflow-hidden">
          <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between">
            <h3 class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold">
              <i class="ri-team-line"></i> My caseload (<%= @caseload.count %><% if current_user.max_caseload.to_i > 0 %>/<%= current_user.max_caseload %><% end %>)
            </h3>
          </div>
          <% if @caseload.empty? %>
            <div class="px-5 py-8 text-center text-[12px] text-[#6B665F]">No assigned patients.</div>
          <% else %>
            <ul class="divide-y divide-[#EFECE6]">
              <% @caseload.each do |p| %>
                <%
                  last_visit = p.visits.where("started_at IS NOT NULL").order(started_at: :desc).first
                  last_seen  = last_visit&.started_at&.strftime("%b %-d")
                %>
                <li>
                  <%= link_to patient_path(p), class: "flex items-center gap-3 px-5 py-3 hover:bg-[#FBF9F5] transition" do %>
                    <div class="w-10 h-10 rounded-full overflow-hidden flex-shrink-0 bg-[#EFECE6] text-[#1D1C1A] text-[12px] font-bold flex items-center justify-center">
                      <%= p.full_name.to_s.split.map(&:first).first(2).join.upcase %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2">
                        <span class="text-[14px] text-[#1D1C1A] truncate"><%= p.full_name %></span>
                        <% if p.dnr? || p.dnr_dni? %>
                          <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-[#C1403A] text-white tracking-wider">DNR</span>
                        <% end %>
                      </div>
                      <div class="text-[11px] text-[#6B665F] truncate">
                        <span class="font-mono"><%= p.mrn %></span>
                        <% if p.primary_diagnosis.present? %> · <%= p.primary_diagnosis.to_s[0, 50] %><% end %>
                      </div>
                    </div>
                    <div class="text-right flex-shrink-0">
                      <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Last seen</div>
                      <div class="text-[11px] font-mono text-[#1D1C1A]"><%= last_seen || "—" %></div>
                    </div>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% end %>
        </section>
      </div>
    </div>
  </main>
</div>
