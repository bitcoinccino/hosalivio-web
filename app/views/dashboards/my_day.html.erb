<% content_for :title, "My Day · HosAlivio" %>
<%
  role  = current_user.role_names.first
  greet = (Time.current.hour < 12 ? "Good morning" : (Time.current.hour < 18 ? "Good afternoon" : "Good evening"))
  role_color = {
    "rn" => "#2F6F4E", "md" => "#2B4A7A", "social_worker" => "#7A4A8C",
    "chaplain" => "#8C6A2F", "aide" => "#AD7340"
  }[role] || "#6B665F"
%>
<div class="flex h-screen" data-controller="sidebar" data-sidebar-storage-key-value="myDaySidebar">
  <!-- Left rail (hidden on mobile; replaced by bottom tab bar) -->
  <aside data-sidebar-target="sidebar" data-collapsed="false"
         class="group/sb hidden md:flex w-72 data-[collapsed=true]:w-16 bg-[#EFECE6] border-r border-[#D9D5CD] flex-col justify-between p-6 data-[collapsed=true]:p-3 transition-[width,padding] duration-200">
    <div>
      <div class="flex items-center justify-between group-data-[collapsed=true]/sb:justify-center">
        <div class="flex items-center gap-2 group-data-[collapsed=true]/sb:hidden">
          <div class="w-7 h-7 rounded-full bg-[#D97757] text-white flex items-center justify-center flex-shrink-0">
            <i class="ri-heart-pulse-line text-sm"></i>
          </div>
          <h1 class="text-xs uppercase tracking-[0.2em] text-[#6B665F] font-bold group-data-[collapsed=true]/sb:hidden">HosAlivio</h1>
        </div>
        <button type="button" data-action="click->sidebar#toggle"
                class="w-7 h-7 rounded-full hover:bg-[#D9D5CD] text-[#6B665F] flex items-center justify-center flex-shrink-0 transition">
          <i class="ri-side-bar-line text-[15px]"></i>
        </button>
      </div>
      <nav class="mt-8 space-y-1.5 text-sm">
        <a href="/dashboard" title="My Day"
           class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[#D9D5CD] text-[#1D1C1A] font-medium group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-sun-line"></i><span class="group-data-[collapsed=true]/sb:hidden">My Day</span>
        </a>
        <a href="/calendar" title="Calendar"
           class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-calendar-line"></i><span class="group-data-[collapsed=true]/sb:hidden">Calendar</span>
        </a>
        <a href="/channels" title="Team chat"
           class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-chat-3-line"></i><span class="group-data-[collapsed=true]/sb:hidden">Team chat</span>
        </a>
        <% unread_count = (Notification.where(user: current_user, read_at: nil).count rescue 0) %>
        <a href="/notifications" title="Notifications"
           class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-notification-3-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">Notifications</span>
          <% if unread_count > 0 %>
            <span class="ml-auto text-[10px] font-bold px-2 py-0.5 rounded-full bg-[#D97757] text-white group-data-[collapsed=true]/sb:hidden"><%= unread_count %></span>
          <% end %>
        </a>
      </nav>
    </div>
    <div class="mt-3">
      <%= render "shared/user_menu", direction: :up %>
    </div>
  </aside>

  <!-- Main -->
  <main class="flex-1 flex flex-col overflow-hidden pb-14 md:pb-0">
    <header class="px-8 py-5 border-b border-[#EFECE6] bg-white">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-xl font-serif font-bold text-[#1D1C1A]"><%= greet %>, <%= current_user.full_name.to_s.split.first %>.</h2>
          <div class="text-xs text-[#6B665F] mt-0.5"><%= Date.current.strftime("%A, %B %-d") %> · <%= role&.tr("_", " ")&.upcase %> at <%= @agency&.name %></div>
        </div>
        <div class="flex items-center gap-3">
          <% if (current_user.role_names & %w[admin don admissions]).any? %>
            <%= link_to coordination_path,
                  class: "text-[11px] px-3 py-1.5 rounded-full border border-[#D97757] text-[#D97757] hover:bg-[#FFF3EC] inline-flex items-center gap-1.5 font-medium transition" do %>
              <i class="ri-inbox-line"></i> Coordination
            <% end %>
          <% end %>
          <% if (current_user.role_names & %w[rn md don admissions admin]).any? %>
            <%= link_to admissions_queue_path,
                  class: "text-[11px] px-3 py-1.5 rounded-full border border-[#2B4A7A] text-[#2B4A7A] hover:bg-[#F0F4FA] inline-flex items-center gap-1.5 font-medium transition" do %>
              <i class="ri-folder-history-line"></i> Admissions queue
            <% end %>
          <% end %>
          <% if @my_license_status == :expired || @my_license_status == :expiring %>
            <div class="text-[11px] px-3 py-1.5 rounded-full bg-[#FFF3EC] border border-[#D97757] text-[#C1403A]">
              <i class="ri-shield-cross-line"></i> License <%= @my_license_status == :expired ? "EXPIRED" : "expires soon" %>
            </div>
          <% end %>
        </div>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto">
      <div class="w-full max-w-[1400px] mx-auto px-4 md:px-8 py-6 space-y-6">

        <!-- Open crises tile (only when there are any) -->
        <% if @open_crises.any? %>
          <section class="rounded-2xl border-2 border-[#C1403A] bg-[#FFF3EC] overflow-hidden">
            <div class="bg-[#C1403A] text-white px-4 py-2 flex items-center gap-2">
              <i class="ri-alarm-warning-fill"></i>
              <span class="font-bold tracking-wider text-[12px]">OPEN CRISES ON YOUR CASELOAD (<%= @open_crises.size %>)</span>
            </div>
            <div class="divide-y divide-[#EFECE6]">
              <% @open_crises.each do |note| %>
                <%= link_to patient_path(note.patient), class: "block px-4 py-3 hover:bg-[#FFEDE2] transition" do %>
                  <div class="flex items-start gap-3">
                    <i class="ri-alarm-warning-line text-[#C1403A] mt-0.5"></i>
                    <div class="flex-1 min-w-0">
                      <div class="text-[13px] text-[#1D1C1A] truncate"><%= note.patient.full_name %></div>
                      <div class="text-[12px] text-[#3A3936] italic truncate">"<%= note.body.to_s[0, 100] %>"</div>
                      <div class="text-[10px] text-[#6B665F] font-mono mt-0.5"><%= note.created_at.strftime("%-l:%M %p") %></div>
                    </div>
                    <i class="ri-arrow-right-line text-[#6B665F]"></i>
                  </div>
                <% end %>
              <% end %>
            </div>
          </section>
        <% end %>

        <!-- Role-specific priority panel (appears above shared sections) -->
        <% role_partial = "dashboards/my_day_#{@primary_role}" %>
        <% if lookup_context.exists?(role_partial, [], true) %>
          <%= render role_partial %>
        <% end %>

        <%# Subscribe this dashboard to live broadcasts. Each card
            below is a turbo-frame; AgentEvent / MedicationLog /
            Visit after_commit hooks broadcast turbo_stream.replace
            to dashboard:user:<id> targeting the matching frame so
            the card refreshes itself without a full page reload. %>
        <%= turbo_stream_from "dashboard:user:#{current_user.id}" %>

        <%# MDs don't record bedside visits or administer/log meds, so the
            "Today's visits" and "Overdue meds" cards below are hidden for
            them — their dashboard centers on certifications + caseload. The
            remaining cards go full-width when the bedside card is dropped. %>
        <% is_md = @primary_role == "md" %>

        <%# ── Daily context row (top) ───────────────────────────
            Today's visits + My caseload — what an RN opens the app
            to see first ("what am I doing today, who am I
            responsible for"). MD: caseload only, full width. %>
        <div class="grid grid-cols-1 <%= is_md ? "" : "lg:grid-cols-2" %> gap-4">
          <% unless is_md %>
            <%= render "dashboards/todays_visits_card",
                  todays_visits:  @todays_visits,
                  viewer_user_id: current_user.id %>
          <% end %>

          <%# Caseload card — kept inline (no partial yet) since it
              doesn't have a live broadcast hook. Same visual shape
              as the other cards. %>
          <section id="my-patients" data-controller="card-collapse" class="rounded-2xl bg-white border border-[#EFECE6] overflow-hidden scroll-mt-20">
            <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between">
              <h3 class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold">
                <i class="ri-team-line"></i> My patients (<%= @caseload.count %><% if current_user.max_caseload.to_i > 0 %>/<%= current_user.max_caseload %><% end %>)
              </h3>
              <button type="button" data-action="card-collapse#toggle" aria-label="Collapse card"
                      class="md:hidden w-6 h-6 -mr-1 rounded-full text-[#6B665F] hover:bg-[#FBF9F5] flex items-center justify-center flex-shrink-0">
                <i data-card-collapse-target="chevron" class="ri-arrow-down-s-line text-[18px] transition-transform"></i>
              </button>
            </div>
            <div data-card-collapse-target="body" class="md:block">
            <% if @caseload.empty? %>
              <div class="px-5 py-8 text-center text-[12px] text-[#6B665F]">No assigned patients.</div>
            <% else %>
              <ul class="divide-y divide-[#EFECE6]">
                <% @caseload.each do |p| %>
                  <%
                    last_visit = p.visits.where("started_at IS NOT NULL").order(started_at: :desc).first
                    last_seen  = last_visit&.started_at&.strftime("%b %-d")
                    days_since_seen = last_visit&.started_at ? ((Time.current - last_visit.started_at) / 1.day).floor : nil
                    patient_crisis = @open_crises.any? { |note| note.patient_id == p.id }
                    med_overdue = @overdue_meds.any? { |row| row[:order].patient_id == p.id }
                    handoff_waiting = @pending_handoffs.any? { |ev|
                      ev.subject == p || (ev.subject.respond_to?(:patient_id) && ev.subject.patient_id == p.id)
                    }
                    recert_days = p.cert_period_end ? (p.cert_period_end - Date.current).to_i : nil
                  %>
                  <li>
                    <%= link_to patient_path(p), class: "flex items-center gap-3 px-5 py-3 hover:bg-[#FBF9F5] transition" do %>
                      <div class="w-10 h-10 rounded-full overflow-hidden flex-shrink-0 bg-[#EFECE6] text-[#1D1C1A] text-[12px] font-bold flex items-center justify-center">
                        <%= p.full_name.to_s.split.map(&:first).first(2).join.upcase %>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                          <span class="text-[14px] text-[#1D1C1A] truncate"><%= p.full_name %></span>
                          <% if p.dnr? || p.dnr_dni? %>
                            <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-[#C1403A] text-white tracking-wider">DNR</span>
                          <% end %>
                        </div>
                        <div class="text-[11px] text-[#6B665F] truncate">
                          <span class="font-mono"><%= p.mrn %></span>
                          <% if p.primary_diagnosis.present? %> · <%= p.primary_diagnosis.to_s[0, 50] %><% end %>
                        </div>
                        <div class="mt-1.5 flex flex-wrap gap-1.5">
                          <% if patient_crisis %>
                            <span class="rounded-full bg-[#C1403A] px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-white">Crisis</span>
                          <% end %>
                          <%# MD-relevant cert status (no extra queries — uses preloaded id sets). %>
                          <% if is_md && @md_cert_pending_pids&.include?(p.id) %>
                            <span class="rounded-full bg-[#2B4A7A] px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-white">Cert pending</span>
                          <% end %>
                          <% if is_md && @md_revision_pids&.include?(p.id) %>
                            <span class="rounded-full border border-[#F3D7C8] bg-[#FFF7F2] px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-[#8A4B2F]">Awaiting revision</span>
                          <% end %>
                          <%# Med administration + "not seen" are bedside RN signals — hide for MD. %>
                          <% if med_overdue && !is_md %>
                            <span class="rounded-full border border-[#F3D7C8] bg-[#FFF3EC] px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-[#C1403A]">Med overdue</span>
                          <% end %>
                          <% if handoff_waiting %>
                            <span class="rounded-full border border-[#F3D7C8] bg-[#FFF7F2] px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-[#8A4B2F]">Team request</span>
                          <% end %>
                          <% if recert_days && recert_days <= 14 %>
                            <span class="rounded-full border border-[#C8DDD6] bg-[#E6F0EE] px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-[#2F6F4E]">Recert <%= recert_days %>d</span>
                          <% end %>
                          <% if days_since_seen && days_since_seen >= 5 && !is_md %>
                            <span class="rounded-full border border-[#EFECE6] bg-[#FBF9F5] px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-[#6B665F]">Not seen <%= days_since_seen %>d</span>
                          <% end %>
                        </div>
                      </div>
                      <div class="text-right flex-shrink-0">
                        <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Last seen</div>
                        <div class="text-[11px] font-mono text-[#1D1C1A]"><%= last_seen || "—" %></div>
                      </div>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            <% end %>
            </div>
          </section>
        </div>

        <%# ── Action / alerts row (bottom) ─────────────────────
            Overdue meds + Handoffs. Exception alerts. MD: handoffs only
            (overdue-med administration isn't an MD action), full width. %>
        <div class="grid grid-cols-1 <%= is_md ? "" : "lg:grid-cols-2" %> gap-4">
          <% unless is_md %>
            <%= render "dashboards/overdue_meds_card",
                  overdue_meds:   @overdue_meds,
                  viewer_user_id: current_user.id %>
          <% end %>
          <%= render "dashboards/handoffs_card",
                pending_handoffs: @pending_handoffs,
                viewer_user_id:   current_user.id %>
        </div>
      </div>
    </div>
  </main>

  <!-- Mobile bottom tab bar (visible only below md) -->
  <div class="md:hidden fixed bottom-0 inset-x-0 z-40">
    <%= render "shared/mobile_tab_bar", active: :my_day %>
  </div>
</div>
