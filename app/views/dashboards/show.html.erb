<% content_for :title, "HosAlivio · Mission Stage" %>

<div class="flex h-screen" data-controller="sidebar mission-mobile" data-sidebar-storage-key-value="dashboardSidebar">
  <!-- ─── Left rail: nav ───────────────────────────────────────── -->
  <aside data-sidebar-target="sidebar" data-collapsed="false"
         data-mission-mobile-target="tab" data-tab-name="census"
         class="group/sb w-72 data-[collapsed=true]:w-16 bg-[#EFECE6] border-r border-[#D9D5CD] flex flex-col p-6 data-[collapsed=true]:p-3 transition-[width,padding] duration-200
                hidden md:flex data-[mobile-active=true]:flex data-[mobile-active=true]:absolute data-[mobile-active=true]:inset-0 data-[mobile-active=true]:z-30 data-[mobile-active=true]:w-full">
    <div class="flex-shrink-0">
      <div class="flex items-center justify-between group-data-[collapsed=true]/sb:justify-center">
        <div class="flex items-center gap-2 group-data-[collapsed=true]/sb:hidden">
          <div class="w-7 h-7 rounded-full bg-[#D97757] text-white flex items-center justify-center flex-shrink-0">
            <i class="ri-heart-pulse-line text-sm"></i>
          </div>
          <h1 class="text-xs uppercase tracking-[0.2em] text-[#6B665F] font-bold group-data-[collapsed=true]/sb:hidden">HosAlivio</h1>
        </div>
        <button type="button" data-action="click->sidebar#toggle"
                title="Toggle sidebar"
                class="w-7 h-7 rounded-full hover:bg-[#D9D5CD] text-[#6B665F] hover:text-[#1D1C1A] flex items-center justify-center flex-shrink-0 transition">
          <i class="ri-side-bar-line text-[15px]"></i>
        </button>
      </div>
      <%
        nav_item  = "flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0"
        nav_group = "mt-4 mb-1 px-3 text-[10px] uppercase tracking-widest text-[#B9B3A9] font-bold group-data-[collapsed=true]/sb:hidden"
        manager_roles = %w[admin admissions]
        is_mgr_nav    = (current_user.role_names & manager_roles).any?
      %>
      <nav class="mt-8 space-y-1 text-sm">
        <%# Oversight %>
        <a href="/dashboard" title="Mission Stage"
           class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[#D9D5CD] text-[#1D1C1A] font-medium group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-radar-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">Mission Stage</span>
        </a>

        <%# Admission funnel: Referrals (inbound) → Admissions (in-flight) → Patients (managed). %>
        <% if is_mgr_nav %>
          <div class="<%= nav_group %>">Admissions</div>
          <a href="<%= inquiries_path %>" title="Referrals<%= " · #{@pending_inquiries} new" if @pending_inquiries.to_i.positive? %>" class="<%= nav_item %>">
            <i class="ri-inbox-line"></i><span class="group-data-[collapsed=true]/sb:hidden">Referrals</span>
            <% if @pending_inquiries.to_i.positive? %>
              <span class="ml-auto group-data-[collapsed=true]/sb:hidden inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-[#D97757] text-white text-[10px] font-bold leading-none"><%= @pending_inquiries %></span>
            <% end %>
          </a>
          <a href="<%= admissions_queue_path %>" title="Admissions" class="<%= nav_item %>">
            <i class="ri-folder-history-line"></i><span class="group-data-[collapsed=true]/sb:hidden">Admissions</span>
          </a>
          <a href="<%= patients_path %>" title="Patients" class="<%= nav_item %>">
            <i class="ri-team-line"></i><span class="group-data-[collapsed=true]/sb:hidden">Patients</span>
          </a>
        <% end %>

        <%# Schedule & comms %>
        <div class="<%= nav_group %>">Schedule</div>
        <a href="/calendar" title="Calendar" class="<%= nav_item %>">
          <i class="ri-calendar-line"></i><span class="group-data-[collapsed=true]/sb:hidden">Calendar</span>
        </a>
        <%# Notifications moved into the right-column tabs (Live activity | Team chat | Notifications). %>

        <%# Organization %>
        <% if is_mgr_nav %>
          <div class="<%= nav_group %>">Organization</div>
          <a href="/branches" title="Branches" class="<%= nav_item %>">
            <i class="ri-map-pin-line"></i><span class="group-data-[collapsed=true]/sb:hidden">Branches</span>
          </a>
          <a href="/team_members" title="Team" class="<%= nav_item %>">
            <i class="ri-team-line"></i><span class="group-data-[collapsed=true]/sb:hidden">Team</span>
          </a>

          <%# Settings — where an admin configures the agency. %>
          <div class="<%= nav_group %>">Settings</div>
          <a href="<%= edit_agency_features_path %>" title="Agency features" class="<%= nav_item %>">
            <i class="ri-toggle-line text-[13px]"></i><span class="group-data-[collapsed=true]/sb:hidden">Features</span>
          </a>
        <% end %>

        <div class="<%= nav_group %>">Reports</div>
        <div title="IDG Review (soon)"
             class="flex items-center gap-2 px-3 py-2 text-[#9A938A] group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-group-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">IDG Review</span>
          <span class="text-[10px] ml-auto italic group-data-[collapsed=true]/sb:hidden">soon</span>
        </div>
        <div title="Census Report (soon)"
             class="flex items-center gap-2 px-3 py-2 text-[#9A938A] group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-file-list-3-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">Census Report</span>
          <span class="text-[10px] ml-auto italic group-data-[collapsed=true]/sb:hidden">soon</span>
        </div>
      </nav>
    </div>

    <%# Active Census lives on its own Patients page now — the sidebar just
        keeps the nav, so a spacer pins the user menu to the bottom. %>
    <div class="flex-1"></div>

    <div class="mt-3 flex-shrink-0">
      <%= render "shared/user_menu", direction: :up %>
    </div>
  </aside>

  <!-- ─── Main Stage: banner + at-a-glance + Ask HosAlivio ──────── -->
  <main data-mission-mobile-target="tab" data-tab-name="stage"
        class="flex-1 flex flex-col min-w-0 overflow-hidden pb-14 md:pb-0">
    <% if @agency.nil? %>
      <div class="flex-1 flex items-center justify-center text-sm text-[#6B665F]">
        No agency yet — run <code class="font-mono text-[#1D1C1A]">bin/rails db:seed</code>.
      </div>
    <% else %>
      <%
        manager_roles = %w[admin admissions]
        is_manager    = (current_user.role_names & manager_roles).any?
        noe_soon      = @noe_overdue.size + @noe_due_today.size
        quick_stats = [
          { label: "Active patients", value: @active_patient_count,        urgent: false },
          { label: "Pending reviews", value: @pending_certifications.size, urgent: false },
          { label: "Open blockers",   value: @open_blockers,               urgent: @open_blockers.to_i.positive? },
          { label: "NOE deadlines",   value: noe_soon,                     urgent: @noe_overdue.any? }
        ]
      %>

      <!-- Banner -->
      <header class="px-6 py-4 border-b border-[#EFECE6] bg-white">
        <div class="flex items-center gap-4">
          <!-- Icon -->
          <div class="w-12 h-12 rounded-full bg-[#D97757] text-white flex items-center justify-center flex-shrink-0">
            <i class="ri-radar-line text-xl"></i>
          </div>

          <!-- Identity block -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <h2 class="font-serif text-xl text-[#1D1C1A] truncate">Mission Stage</h2>
              <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-[#EFECE6] text-[#1D1C1A] tracking-wider uppercase truncate max-w-[200px]"><%= @agency.name %></span>
            </div>
            <div class="text-[12px] text-[#6B665F] mt-0.5">Agency-wide live agent activity</div>
          </div>

          <!-- Right-side stat chips (managers only; hidden on small screens) -->
          <% if is_manager %>
            <div class="hidden lg:flex items-center gap-2 flex-shrink-0">
              <% quick_stats.each do |s| %>
                <div class="px-3 py-1.5 rounded-xl text-center <%= s[:urgent] ? 'bg-[#FFF3EC] border border-[#D97757]' : 'bg-[#FBF9F5]' %>">
                  <div class="text-[9px] uppercase tracking-widest <%= s[:urgent] ? 'text-[#C1403A] font-bold' : 'text-[#6B665F]' %>"><%= s[:label] %></div>
                  <div class="text-lg font-serif leading-none mt-0.5 <%= s[:urgent] ? 'text-[#C1403A]' : 'text-[#1D1C1A]' %>"><%= s[:value] %></div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- Status line + quick links -->
        <div class="mt-2 flex items-center justify-between gap-3">
          <div class="text-[11px] text-[#6B665F] flex items-center gap-1.5">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            <span>Care Team ↔ HosAlivio · <span id="cable-status" class="font-mono">connecting…</span></span>
          </div>
          <%# The admission funnel: Referrals (inbound) → Admissions (in-flight) → Patients (managed). %>
          <div class="hidden sm:flex items-center gap-2">
            <%= link_to inquiries_path, class: "inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full border border-[#D97757] text-[#D97757] hover:bg-[#FFF3EC] font-medium transition" do %>
              <i class="ri-inbox-line"></i> Referrals
              <% if @pending_inquiries.to_i.positive? %>
                <span class="inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-[#D97757] text-white text-[10px] font-bold leading-none"><%= @pending_inquiries %></span>
              <% end %>
            <% end %>
            <%= link_to admissions_queue_path, class: "inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full border border-[#2B4A7A] text-[#2B4A7A] hover:bg-[#F0F4FA] font-medium transition" do %>
              <i class="ri-folder-history-line"></i> Admissions
            <% end %>
            <%= link_to patients_path, class: "inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white font-medium" do %>
              <i class="ri-team-line"></i> Patients
            <% end %>
          </div>
        </div>
      </header>

      <!-- Pinned NOE-overdue strip (the agency's standing "open crisis") -->
      <% if is_manager && @noe_overdue.any? %>
        <div class="px-6 pt-4">
          <div class="rounded-2xl border-2 border-[#C1403A] bg-[#FFF3EC] overflow-hidden">
            <div class="bg-[#C1403A] text-white px-4 py-2 flex items-center gap-2">
              <i class="ri-pushpin-fill"></i>
              <span class="font-bold tracking-wider text-[12px]">PINNED · NOE OVERDUE</span>
              <span class="ml-auto text-[10px] opacity-80">Past the 5-day filing deadline — Medicare revenue at risk.</span>
            </div>
            <div class="px-4 py-3 flex items-center gap-3">
              <i class="ri-alarm-warning-fill text-[#C1403A]"></i>
              <div class="text-[13px] text-[#1D1C1A]">
                <strong class="text-[#C1403A]"><%= @noe_overdue.size %></strong>
                election<%= @noe_overdue.size == 1 ? "" : "s" %> awaiting NOE filing.
              </div>
              <a href="<%= admissions_queue_path %>" class="ml-auto text-[11px] text-[#C1403A] font-medium hover:underline whitespace-nowrap">Open queue →</a>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Stage body — the Ask HosAlivio conversation + at-a-glance -->
      <div id="assistant-stage" class="flex-1 overflow-y-auto px-6 py-6 space-y-5">
        <%
          has_glance = @pending_certifications.any? || @noe_overdue.any? || @noe_due_today.any? ||
                       @licenses_expired.to_i.positive? || @licenses_expiring.to_i.positive? ||
                       @mission_visits.any?
        %>
        <%# Only surfaces when there's something to flag — otherwise the Stage
            stays clean (the banner stats already say "all zero"). %>
        <% if has_glance %>
          <div class="max-w-2xl">
            <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-2">At a glance</div>
            <div class="rounded-2xl border border-[#EFECE6] bg-white overflow-hidden divide-y divide-[#EFECE6]">
              <!-- Awaiting MD certification -->
              <% if @pending_certifications.any? %>
                <details class="group" open>
                  <%= acc_header("ri-stethoscope-line", "Awaiting MD Cert", @pending_certifications.size.to_s) %>
                  <div class="px-5 pb-4 pt-2 text-[12px] text-[#6B665F] space-y-1">
                    <% @pending_certifications.first(6).each do |pae| %>
                      <div class="truncate">· <%= pae.patient.full_name %> — <%= pae.primary_icd10.presence || "dx pending" %></div>
                    <% end %>
                  </div>
                </details>
              <% end %>

              <!-- NOE deadlines -->
              <% if @noe_overdue.any? || @noe_due_today.any? %>
                <details class="group" <%= "open" if @noe_overdue.any? %>>
                  <%= acc_header("ri-alarm-warning-line", "NOE Deadlines", (@noe_overdue.size + @noe_due_today.size).to_s) %>
                  <div class="px-5 pb-4 pt-2 text-[12px] space-y-1.5">
                    <% if @noe_overdue.any? %>
                      <div class="text-[#C1403A] font-bold"><i class="ri-alarm-warning-fill"></i> <%= @noe_overdue.size %> overdue — file immediately</div>
                    <% end %>
                    <% @noe_due_today.first(6).each do |pae| %>
                      <div class="text-[#6B665F] truncate">· <%= pae.patient.full_name %> — due <%= pae.noe_deadline_at&.strftime("%b %-d") %></div>
                    <% end %>
                  </div>
                </details>
              <% end %>

              <!-- Compliance risk -->
              <% if @licenses_expired.to_i > 0 || @licenses_expiring.to_i > 0 %>
                <details class="group">
                  <%= acc_header("ri-shield-cross-line", "Compliance Risk", (@licenses_expired.to_i + @licenses_expiring.to_i).to_s) %>
                  <div class="px-5 pb-4 pt-2 text-[12px] text-[#6B665F] space-y-1">
                    <% if @licenses_expired.to_i > 0 %>
                      <div><strong class="text-[#C1403A]"><%= @licenses_expired %></strong> license<%= @licenses_expired == 1 ? "" : "s" %> already expired</div>
                    <% end %>
                    <% if @licenses_expiring.to_i > 0 %>
                      <div><strong class="text-[#D97757]"><%= @licenses_expiring %></strong> expiring within 60 days</div>
                    <% end %>
                    <a href="/team_members" class="inline-flex items-center gap-1 text-[11px] text-[#D97757] font-medium hover:underline mt-1">See who <i class="ri-arrow-right-line"></i></a>
                  </div>
                </details>
              <% end %>

              <%# New inquiries live in the dedicated Referrals inbox (sidebar → /inquiries),
                  not in the at-a-glance stage. %>

              <!-- Visits · recent & upcoming -->
              <% if @mission_visits.any? %>
                <details class="group">
                  <%= acc_header("ri-calendar-check-line", "Visits · Recent & Upcoming", @mission_visits.size.to_s) %>
                  <div class="pb-2">
                    <% @mission_visits.each do |v| %>
                      <%
                        if v.completed_visit?
                          status_label, status_cls = "Completed", "bg-[#F0F7F2] text-[#2F6F4E]"
                        elsif v.currently_in_progress?
                          status_label, status_cls = "In progress", "bg-[#FFF3EC] text-[#D97757]"
                        else
                          status_label, status_cls = "Scheduled", "bg-[#F2EEE7] text-[#6B665F]"
                        end
                      %>
                      <%= link_to patient_path(v.patient), class: "flex items-center gap-3 px-5 py-2 text-[12px] hover:bg-[#FBF9F5] transition" do %>
                        <div class="w-14 flex-shrink-0 text-[10px] text-[#6B665F] font-mono leading-tight">
                          <%= v.anchor_start&.strftime("%a %-d") %><br><%= v.anchor_start&.strftime("%-l:%M %p") %>
                        </div>
                        <div class="flex-1 min-w-0">
                          <div class="text-[#1D1C1A] font-medium truncate"><%= v.patient&.full_name %></div>
                          <div class="text-[10px] text-[#6B665F] truncate"><%= v.discipline.to_s.upcase %> · <%= v.visit_type_label %></div>
                        </div>
                        <span class="text-[9px] uppercase tracking-wider px-2 py-0.5 rounded-full flex-shrink-0 <%= status_cls %>"><%= status_label %></span>
                      <% end %>
                    <% end %>
                  </div>
                </details>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Ask HosAlivio conversation — question + answer bubbles append here
            during the session (ephemeral; cleared on reload). %>
        <div id="assistant-thread" class="space-y-3 max-w-2xl"></div>
      </div>

      <!-- Input Bar — composer (Ask HosAlivio ⇄ team chat) (managers only) -->
      <% if is_manager %>
        <div class="px-6 pb-6 pt-3 bg-[#FBF9F5]"
             data-controller="composer mention-autocomplete"
             data-mention-autocomplete-items-value="<%= @mentionables.to_json %>"
             data-composer-ask-url-value="<%= admin_assistant_ask_path %>"
             data-composer-ask-placeholder-value="Ask HosAlivio anything — today's priorities, patients needing attention, new referrals…">

          <%# One-tap oversight questions — each runs an Admin::Overview command
              and renders its answer into the same assistant-answer frame. %>
          <% quick_asks = [
               { label: "Today's priorities",       q: "today's priorities",         icon: "ri-flashlight-line" },
               { label: "Patients needing attention", q: "patients needing attention", icon: "ri-alert-line" },
               { label: "Compliance status",        q: "compliance status",          icon: "ri-shield-check-line" },
               { label: "New referrals",            q: "new referrals",              icon: "ri-inbox-unarchive-line" },
               { label: "Daily report",             q: "daily report",               icon: "ri-file-list-3-line" }
             ] %>
          <div data-composer-target="quickAsks" class="mb-2.5 flex items-center gap-2 flex-wrap">
            <% quick_asks.each do |a| %>
              <%= button_to admin_assistant_ask_path, params: { q: a[:q] }, method: :post,
                    form: { class: "inline-block" },
                    class: "inline-flex items-center gap-1.5 text-[13px] px-4 py-2 rounded-full border border-[#EFECE6] bg-white text-[#6B665F] hover:bg-[#EFECE6] hover:text-[#1D1C1A] transition" do %>
                <i class="<%= a[:icon] %> text-[15px]"></i> <%= a[:label] %>
              <% end %>
            <% end %>
          </div>

          <%# Team-chat mode chip — hidden until a channel is picked. %>
          <div data-composer-target="chip" class="hidden mb-2 flex items-center gap-2">
            <span class="inline-flex items-center gap-1.5 text-[12px] px-3 py-1 rounded-full bg-[#EAF1F7] text-[#2B4A7A] border border-[#CADCEC]">
              <i class="ri-chat-3-line"></i>
              <span data-composer-target="chipLabel"># general</span>
              <button type="button" data-action="composer#ask" title="Back to Ask HosAlivio" class="ml-1 hover:text-[#1D1C1A]"><i class="ri-close-line"></i></button>
            </span>
            <span class="text-[11px] text-[#6B665F]">Team-chat mode — your message posts to this channel.</span>
          </div>

          <%= form_with url: admin_assistant_ask_path, method: :post, data: { composer_target: "form" } do %>
            <div class="relative">
              <%# @-mention autocomplete dropdown (populated by JS, opens above the input). %>
              <div data-mention-autocomplete-target="menu"
                   class="hidden absolute bottom-full left-0 mb-2 w-72 max-h-64 overflow-y-auto rounded-2xl border border-[#EFECE6] bg-white shadow-lg py-1 z-50"></div>
            <div class="flex items-center gap-3 bg-white rounded-3xl pl-3 pr-2 py-2 border border-[#EFECE6] shadow-sm">
              <%# "+" menu — a popover (same pattern as the patient composer's
                  quick-actions dropdown), moved here from the sidebar. %>
              <div class="relative flex-shrink-0" data-controller="quick-actions">
                <button type="button" data-action="click->quick-actions#toggle" title="Team channels"
                        class="w-9 h-9 rounded-full bg-[#FBF9F5] hover:bg-[#EFECE6] text-[#D97757] text-lg flex items-center justify-center transition">
                  <i class="ri-add-line"></i>
                </button>
                <%
                  channel_blurbs = {
                    "general"   => "Team announcements and general discussion",
                    "admission" => "Referrals, pre-admit evals, blockers, and scheduling."
                  }
                %>
                <div data-quick-actions-target="panel"
                     class="hidden absolute left-0 bottom-full mb-2 w-72 rounded-2xl bg-white border border-[#EFECE6] shadow-lg overflow-hidden z-50">
                  <div class="px-4 py-2 border-b border-[#EFECE6]">
                    <div class="text-[10px] uppercase tracking-[0.2em] text-[#6B665F] font-bold">Team channels</div>
                    <div class="text-[12px] text-[#1D1C1A] mt-0.5">Post to a channel</div>
                  </div>
                  <div class="py-1">
                    <% if @channels.blank? %>
                      <div class="px-4 py-3 text-[12px] text-[#6B665F] italic">No channels yet.</div>
                    <% else %>
                      <% @channels.each do |c| %>
                        <% blurb = channel_blurbs[c.slug] || "Team channel" %>
                        <% if c.postable_by?(current_user) %>
                          <%# Flip the composer into team-chat mode for this channel. %>
                          <button type="button"
                                  data-action="composer#channel quick-actions#close"
                                  data-channel-slug="<%= c.slug %>"
                                  data-channel-url="<%= channel_messages_path(c, return_to: "dashboard") %>"
                                  class="flex items-center gap-3 w-full px-4 py-2.5 text-left hover:bg-[#FBF9F5] transition cursor-pointer">
                            <span class="w-8 h-8 rounded-full bg-[#FBF9F5] flex items-center justify-center flex-shrink-0 text-[#2B4A7A]">
                              <i class="ri-hashtag"></i>
                            </span>
                            <span class="min-w-0 flex-1">
                              <span class="block text-[13px] text-[#1D1C1A]"># <%= c.name %></span>
                              <span class="block text-[11px] text-[#6B665F]"><%= blurb %></span>
                            </span>
                          </button>
                        <% else %>
                          <%= link_to channel_path(c), data: { action: "quick-actions#close" },
                                class: "flex items-center gap-3 w-full px-4 py-2.5 hover:bg-[#FBF9F5] transition" do %>
                            <span class="w-8 h-8 rounded-full bg-[#FBF9F5] flex items-center justify-center flex-shrink-0 text-[#6B665F]">
                              <i class="ri-hashtag"></i>
                            </span>
                            <span class="min-w-0 flex-1">
                              <span class="flex items-center gap-2">
                                <span class="block text-[13px] text-[#1D1C1A]"># <%= c.name %></span>
                                <span class="text-[9px] uppercase tracking-wider text-[#6B665F] inline-flex items-center gap-1"><i class="ri-lock-line"></i> read-only</span>
                              </span>
                              <span class="block text-[11px] text-[#6B665F]"><%= blurb %></span>
                            </span>
                          <% end %>
                        <% end %>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
              <input type="text" name="q" autocomplete="off"
                     data-composer-target="input" data-mention-autocomplete-target="input"
                     placeholder="Ask HosAlivio anything — today's priorities, patients needing attention, new referrals…"
                     class="flex-1 w-full bg-transparent border-0 focus:outline-none text-[15px] placeholder-[#6B665F] py-2">
              <button type="submit"
                      title="Send"
                      class="flex-shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white shadow-sm active:scale-95 transition">
                <i class="ri-send-plane-fill text-[16px]"></i>
              </button>
            </div>
            </div>
          <% end %>

          <div data-composer-target="hint" class="mt-2 text-[11px] text-[#6B665F] text-center">
            HosAlivio answers from your agency's live data. Nothing here is written to a patient's chart.
          </div>
        </div>
      <% end %>
    <% end %>
  </main>

  <!-- ─── Right Rail: Live agent-activity feed ─────────────────── -->
  <% if @agency %>
    <aside data-mission-mobile-target="tab" data-tab-name="activity" data-controller="tabs"
           class="hidden md:flex w-96 bg-white border-l border-[#EFECE6] flex-col overflow-hidden
                  data-[mobile-active=true]:flex data-[mobile-active=true]:absolute data-[mobile-active=true]:inset-0 data-[mobile-active=true]:z-30 data-[mobile-active=true]:w-full">
      <%# Two live surfaces share this column: the agent-activity feed and the
          team-chat thread. Both stay mounted (Team stays Turbo-subscribed even
          while hidden) so replies append live regardless of the active tab. %>
      <div class="px-4 py-2.5 border-b border-[#EFECE6] flex items-center gap-1.5 flex-wrap flex-shrink-0">
        <button type="button" data-tabs-target="tab" data-action="tabs#show" data-tabs-index-param="0" data-on="true"
                class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-widest px-2.5 py-1 rounded-full text-[#6B665F] hover:bg-[#FBF9F5] transition data-[on=true]:bg-[#1D1C1A] data-[on=true]:text-white">
          <span class="relative flex h-1.5 w-1.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#2F6F4E] opacity-70"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-[#2F6F4E]"></span>
          </span>
          Live activity
        </button>
        <button type="button" data-tabs-target="tab" data-action="tabs#show" data-tabs-index-param="1" data-on="false"
                class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-widest px-2.5 py-1 rounded-full text-[#6B665F] hover:bg-[#FBF9F5] transition data-[on=true]:bg-[#1D1C1A] data-[on=true]:text-white">
          <i class="ri-chat-3-line"></i> Team chat
        </button>
        <% unread_notifs = @my_notifications.count { |n| n.read_at.nil? } %>
        <button type="button" data-tabs-target="tab" data-action="tabs#show" data-tabs-index-param="2" data-on="false"
                class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-widest px-2.5 py-1 rounded-full text-[#6B665F] hover:bg-[#FBF9F5] transition data-[on=true]:bg-[#1D1C1A] data-[on=true]:text-white">
          <i class="ri-notification-3-line"></i> Notifications
          <% if unread_notifs > 0 %>
            <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-[#D97757] text-white"><%= unread_notifs %></span>
          <% end %>
        </button>
        <% open_crises = @unresolved_note_ids.size %>
        <% if open_crises > 0 %>
          <span class="ml-auto inline-flex items-center gap-1 text-[10px] font-bold px-2 py-0.5 rounded-full bg-[#C1403A] text-white tracking-wider animate-pulse">
            <i class="ri-alarm-warning-line"></i> <%= open_crises %> OPEN
          </span>
        <% end %>
      </div>

      <%# ── Pane 0: agent-activity feed ─────────────────────────── %>
      <div data-tabs-target="pane" class="flex-1 flex flex-col min-h-0 overflow-hidden">

      <%#
        Chronological, day-grouped stream (oldest → newest, newest at the
        bottom, like the patient chat). Everything before the latest day
        collapses behind a "Show earlier messages" toggle; the latest day
        stays open and is where live events append. Date-divider pills mark
        each day; the current day's divider is tagged data-today-divider so
        the live WebSocket insert can find (or create) it.
      %>
      <%# Lane filter chips — split the stream by type (Admissions / Clinical / Family / Ops). %>
      <% if @stories.any? %>
        <% lane_counts = @stories.group_by { |s| activity_category(s.event) }.transform_values(&:size) %>
        <div class="px-4 py-2 border-b border-[#EFECE6] flex items-center gap-1.5 flex-wrap flex-shrink-0">
          <button type="button" data-lane-chip="all" data-on="true"
                  class="inline-flex items-center gap-1 text-[10px] px-2.5 py-1 rounded-full border border-[#EFECE6] bg-white text-[#6B665F] hover:bg-[#FBF9F5] transition data-[on=true]:bg-[#1D1C1A] data-[on=true]:text-white data-[on=true]:border-[#1D1C1A]">
            All <span class="font-mono opacity-70"><%= @stories.size %></span>
          </button>
          <% MissionStageHelper::ACTIVITY_LANES.each do |key, label, color| %>
            <button type="button" data-lane-chip="<%= key %>" data-on="false"
                    class="inline-flex items-center gap-1 text-[10px] px-2.5 py-1 rounded-full border border-[#EFECE6] bg-white text-[#6B665F] hover:bg-[#FBF9F5] transition data-[on=true]:bg-[#1D1C1A] data-[on=true]:text-white data-[on=true]:border-[#1D1C1A]">
              <span class="w-1.5 h-1.5 rounded-full" style="background: <%= color %>;"></span><%= label %> <span class="font-mono opacity-70"><%= lane_counts[key] || 0 %></span>
            </button>
          <% end %>
        </div>
      <% end %>

      <div id="event-feed" class="flex-1 overflow-y-auto px-5 py-5 space-y-4">
        <% if @stories.empty? %>
          <div data-feed-empty class="min-h-full flex flex-col items-center justify-center text-center text-sm text-[#6B665F]">
            <i class="ri-checkbox-circle-line text-3xl text-[#2F6F4E] mb-2"></i>
            <p class="max-w-xs">No recent activity — you're all caught up.</p>
          </div>
        <% else %>
          <%
            tz          = Time.zone
            stories_asc = @stories.sort_by { |s| s.event.happened_at }
            latest_date = stories_asc.last.event.happened_at.in_time_zone(tz).to_date
            earlier, recent = stories_asc.partition { |s| s.event.happened_at.in_time_zone(tz).to_date < latest_date }
          %>

          <%# Everything before the latest day, collapsed until expanded. %>
          <% if earlier.any? %>
            <details class="group/earlier" data-earlier>
              <summary data-earlier-summary class="list-none cursor-pointer flex items-center justify-center [&::-webkit-details-marker]:hidden">
                <span class="inline-flex items-center gap-1 px-3 py-1 text-[11px] text-[#6B665F] bg-[#FBF9F5] border border-[#EFECE6] rounded-full hover:bg-[#EFECE6] transition">
                  <i class="ri-arrow-up-s-line group-open/earlier:rotate-180 transition-transform"></i>
                  <span class="group-open/earlier:hidden">Show earlier messages</span>
                  <span class="hidden group-open/earlier:inline">Hide earlier messages</span>
                </span>
              </summary>
              <div class="space-y-4 mt-4">
                <% last_date = nil %>
                <% earlier.each do |story| %>
                  <% d = story.event.happened_at.in_time_zone(tz).to_date %>
                  <% if d != last_date %>
                    <div data-day-pill class="flex items-center justify-center pt-2 pb-1">
                      <div class="px-3 py-1 text-[10px] uppercase tracking-[0.18em] text-[#6B665F] bg-[#FBF9F5] border border-[#EFECE6] rounded-full font-medium"><%= relative_date_label(d) %></div>
                    </div>
                    <% last_date = d %>
                  <% end %>
                  <%= render "event_story", story: story, unresolved_note_ids: @unresolved_note_ids %>
                <% end %>
              </div>
            </details>
          <% end %>

          <%# The latest day — live events append here. %>
          <div data-feed-recent class="space-y-4">
            <% last_date = nil %>
            <% recent.each do |story| %>
              <% d = story.event.happened_at.in_time_zone(tz).to_date %>
              <% if d != last_date %>
                <div data-day-pill class="flex items-center justify-center pt-2 pb-1" <%= "data-today-divider" if d == Date.current %>>
                  <div class="px-3 py-1 text-[10px] uppercase tracking-[0.18em] text-[#6B665F] bg-[#FBF9F5] border border-[#EFECE6] rounded-full font-medium"><%= relative_date_label(d) %></div>
                </div>
                <% last_date = d %>
              <% end %>
              <%= render "event_story", story: story, unresolved_note_ids: @unresolved_note_ids %>
            <% end %>
          </div>
        <% end %>
      </div>
      <%# ── end Pane 0 ─────────────────────────────────────────── %>

      <%# ── Pane 1: live team-chat thread (same panel every role sees) ── %>
      <div data-tabs-target="pane" class="flex-1 flex flex-col min-h-0 overflow-hidden hidden">
        <%= render "shared/team_chat_panel", threads: @team_threads, mentionables: @mentionables %>
      </div>

      <%# ── Pane 2: my notifications (moved off the sidebar) ── %>
      <div data-tabs-target="pane" class="flex-1 min-h-0 overflow-y-auto px-3 py-3 space-y-2 hidden">
        <% if @my_notifications.any? %>
          <%= render @my_notifications %>
        <% else %>
          <p class="px-2 py-8 text-center text-[13px] text-[#6B665F]">No notifications.</p>
        <% end %>
        <div class="pt-1 text-center">
          <a href="/notifications" class="text-[11px] text-[#6B665F] hover:text-[#1D1C1A] hover:underline">See all notifications →</a>
        </div>
      </div>
    </aside>
  <% end %>

  <!-- ─── Mobile bottom tab bar (below md) ──────────────────────── -->
  <% if @agency %>
    <nav class="md:hidden fixed bottom-0 inset-x-0 bg-white border-t border-[#EFECE6] z-40 flex items-stretch">
      <%
        mobile_tabs = [
          { name: "census",   icon: "ri-team-line",     label: "Census" },
          { name: "stage",    icon: "ri-radar-line",    label: "Stage" },
          { name: "activity", icon: "ri-pulse-line",    label: "Activity" }
        ]
      %>
      <% mobile_tabs.each do |t| %>
        <button type="button"
                data-action="click->mission-mobile#activate"
                data-tab-name="<%= t[:name] %>"
                data-mission-mobile-target="button"
                data-mobile-active="<%= t[:name] == 'stage' ? 'true' : 'false' %>"
                class="flex-1 flex flex-col items-center justify-center py-2 text-[10px] text-[#6B665F] data-[mobile-active=true]:text-[#D97757] data-[mobile-active=true]:bg-[#FBF9F5] transition">
          <i class="<%= t[:icon] %> text-lg"></i>
          <span class="uppercase tracking-wider mt-0.5"><%= t[:label] %></span>
        </button>
      <% end %>
    </nav>
  <% end %>
</div>

<% if @agency %>
  <script>
    // Bound once for the tab's lifetime, and run on `turbo:load` — which fires
    // on the initial load AND on every Turbo Drive visit. The old
    // DOMContentLoaded hook only fired on a full page load, so reaching the
    // Mission Stage via an in-app (Turbo) link left the socket unbuilt and the
    // status stuck on "connecting…".
    (function () {
      if (window.__missionStageBound) return;
      window.__missionStageBound = true;

      function initMissionStage() {
      const statusEl = document.getElementById("cable-status");
      const feedEl   = document.getElementById("event-feed");
      // Navigated away from the Mission Stage — tear down any live socket.
      if (!statusEl || !feedEl) {
        if (window.__missionStageWS) { try { window.__missionStageWS.close(); } catch (_) {} window.__missionStageWS = null; }
        return;
      }
      // Re-entering — drop any stale socket from a previous visit.
      if (window.__missionStageWS) { try { window.__missionStageWS.close(); } catch (_) {} window.__missionStageWS = null; }
      const agencyId = "<%= @agency.id %>";

      // --- Live-feed helpers: append newest at the bottom, under a "Today" pill ---
      function recentContainer() {
        let el = feedEl.querySelector("[data-feed-recent]");
        if (!el) {
          const empty = feedEl.querySelector("[data-feed-empty]");
          if (empty) empty.remove();
          el = document.createElement("div");
          el.className = "space-y-4 peer-open/earlier:hidden";
          el.setAttribute("data-feed-recent", "");
          feedEl.appendChild(el);
        }
        return el;
      }
      function ensureTodayDivider(recentEl) {
        let div = recentEl.querySelector("[data-today-divider]");
        if (div) return div;
        div = document.createElement("div");
        div.className = "flex items-center justify-center pt-2 pb-1";
        div.setAttribute("data-today-divider", "");
        div.setAttribute("data-day-pill", "");
        div.innerHTML = `<div class="px-3 py-1 text-[10px] uppercase tracking-[0.18em] text-[#6B665F] bg-[#FBF9F5] border border-[#EFECE6] rounded-full font-medium">Today</div>`;
        if (activeLane !== "all") div.classList.add("hidden");
        recentEl.appendChild(div);
        return div;
      }
      const nearBottom = () => (feedEl.scrollHeight - feedEl.scrollTop - feedEl.clientHeight) < 140;

      // --- Lane (type-category) filtering — mirrors MissionStageHelper#activity_category ---
      const LANE_COLOR = { admissions: "#2B4A7A", clinical: "#2F6F4E", family: "#D97757", ops: "#6B665F" };
      const LANE_LABEL = { admissions: "Admissions", clinical: "Clinical", family: "Family", ops: "Ops" };
      function categorize(p) {
        const r = p.agent_id, s = p.subject_type, a = p.event;
        if (r === "admissions") return "admissions";
        if (s === "Inquiry" || (s === "Patient" && a === "create")) return "admissions";
        if (r === "family" || r === "front_door_inbound") return "family";
        if (["pharmacy", "dme", "insurance", "billing", "don", "system"].includes(r)) return "ops";
        if (["rn", "md", "aide", "social_worker", "chaplain"].includes(r)) return "clinical";
        return "ops";
      }
      let activeLane = "all";
      const laneChips = Array.from(document.querySelectorAll("[data-lane-chip]"));
      const matchesLane = (cat) => activeLane === "all" || cat === activeLane;
      function applyLane(lane) {
        activeLane = lane;
        laneChips.forEach((c) => { c.dataset.on = (c.dataset.laneChip === lane) ? "true" : "false"; });
        feedEl.querySelectorAll("[data-story]").forEach((el) => {
          el.classList.toggle("hidden", !matchesLane(el.dataset.category));
        });
        // A specific lane spans all of history: reveal the earlier group and
        // drop the per-day pills so it reads as one filtered list.
        const filtering = lane !== "all";
        feedEl.querySelectorAll("[data-day-pill]").forEach((el) => el.classList.toggle("hidden", filtering));
        const earlier = feedEl.querySelector("[data-earlier]");
        const summary = feedEl.querySelector("[data-earlier-summary]");
        if (earlier) earlier.open = filtering;
        if (summary) summary.classList.toggle("hidden", filtering);
      }
      laneChips.forEach((c) => c.addEventListener("click", () => applyLane(c.dataset.laneChip)));

      // Open scrolled to the newest activity.
      feedEl.scrollTop = feedEl.scrollHeight;

      const proto = location.protocol === "https:" ? "wss:" : "ws:";
      const ws = new WebSocket(`${proto}//${location.host}/cable`);
      window.__missionStageWS = ws;

      ws.onopen  = () => {
        statusEl.textContent = "connected";
        statusEl.classList.remove("text-[#6B665F]");
        statusEl.classList.add("text-[#2F6F4E]");
        ws.send(JSON.stringify({
          command: "subscribe",
          identifier: JSON.stringify({ channel: "MissionStageChannel", agency_id: agencyId })
        }));
      };
      ws.onclose = () => { statusEl.textContent = "disconnected"; statusEl.classList.add("text-[#C1403A]"); };
      // Persona for live rendering — keep in sync with app/services/event_narrator.rb
      const PERSONA = {
        admissions:         { name: "HosAlivio",  title: "Admissions",    initials: "H", color: "#1D1C1A" },
        front_door_inbound: { name: "Care Portal",title: "Family-facing", initials: "⌂", color: "#D97757" },
        rn:                 { name: "Pascal",     title: "RN",            initials: "P", color: "#2F6F4E" },
        md:                 { name: "Dr. Esther", title: "MD",            initials: "E", color: "#2B4A7A" },
        don:                { name: "Diaphnie",   title: "DON",           initials: "D", color: "#8B5A2B" },
        social_worker:      { name: "Nickla",     title: "Social Worker", initials: "N", color: "#7A4A8C" },
        chaplain:           { name: "Geoginio",   title: "Chaplain",      initials: "G", color: "#8C6A2F" },
        pharmacy:           { name: "Simone",     title: "Pharmacy",      initials: "S", color: "#5A2F7A" },
        dme:                { name: "Marcus",     title: "DME",           initials: "M", color: "#3E5D5D" },
        insurance:          { name: "Kendra",     title: "Insurance",     initials: "K", color: "#3A3936" },
        billing:            { name: "Wolfwide",   title: "Billing",       initials: "W", color: "#6B665F" },
        aide:               { name: "Flore",      title: "Aide",          initials: "F", color: "#AD7340" },
        family:             { name: "Family",     title: "Care Portal",   initials: "♥", color: "#D97757" },
        system:             { name: "HosAlivio",  title: "System",        initials: "•", color: "#6B665F" }
      };
      const ROLE_LABEL = {
        rn: "RN", md: "MD", don: "DON", aide: "Aide",
        social_worker: "Social Work", chaplain: "Chaplain",
        pharmacy: "Pharmacy", dme: "DME", insurance: "Insurance",
        billing: "Billing", admissions: "Admissions"
      };

      // Must mirror EventNarrator#narrate in app/services/event_narrator.rb
      function narrate(p) {
        const s = p.subject_type, a = p.event, r = p.agent_id;
        if (r === "admissions" && a === "handoff" && s === "Patient") {
          const t = p.handoff_role ? (ROLE_LABEL[p.handoff_role] || p.handoff_role) : "team";
          return { before: "assigned", after: `to the ${t} team`, icon: "ri-send-plane-2-line" };
        }
        if (r === "admissions" && a === "create" && s === "Note")
          return { before: "posted a triage update for", after: p.urgency === "crisis" ? " (crisis triage)" : "", icon: "ri-chat-3-line" };
        if (r === "front_door_inbound" && a === "create" && s === "Note")
          return { before: "logged a new concern from", after: p.urgency === "crisis" ? "'s family — marked CRISIS" : "'s family", icon: "ri-feedback-line" };
        if (a === "create" && s === "MedicationOrder")
          return { before: `authorized a new medication order${p.drug_name ? ` (${p.drug_name})` : ""} for`, after: "", icon: "ri-capsule-line" };
        if (a === "update" && s === "MedicationOrder")    return { before: "updated a medication order for", after: "", icon: "ri-capsule-line" };
        if (a === "create" && s === "MedicationLog")      return { before: "administered a scheduled dose to", after: "", icon: "ri-syringe-line" };
        if (a === "create" && s === "Visit")              return { before: `started a${p.visit_type ? " " + p.visit_type.replace(/_/g, ' ') : ""} bedside visit with`, after: "", icon: "ri-nurse-line" };
        if (a === "create" && s === "PharmacyDelivery")   return { before: "requested a pharmacy delivery for", after: "", icon: "ri-truck-line" };
        if (a === "update" && s === "PharmacyDelivery")   return { before: "updated a pharmacy delivery for", after: "", icon: "ri-truck-line" };
        if (a === "create" && s === "DmeOrder")           return { before: `ordered${p.equipment_type ? " a " + p.equipment_type.replace(/_/g, ' ') : " equipment"} for`, after: "", icon: "ri-tools-line" };
        if (a === "create" && s === "Patient")            return { before: "admitted", after: "as a new referral", icon: "ri-user-add-line" };
        if (a === "update" && s === "Patient")            return { before: "updated", after: "'s chart", icon: "ri-edit-2-line" };
        if (a === "update" && s === "Note")               return { before: "acknowledged a note on", after: "'s chart", icon: "ri-check-line" };
        if (a === "inquiry_received" && s === "Inquiry") {
          const firstName = p.first_name || "Someone";
          const zip       = p.zip_prefix || "unknown";
          const qualifier = p.is_general ? "general inquiry" : "targeted inquiry";
          const source    = (p.source_prompt || "").replace(/_/g, " ");
          const hint      = source ? ` via ${source}` : "";
          return { before: `received a ${qualifier} from ${firstName} (ZIP ${zip}xx)${hint}`, after: "", icon: "ri-mail-add-line" };
        }
        if (a === "inquiry_converted" && s === "Inquiry") {
          const firstName = p.first_name || "the family";
          const mrn       = p.patient_mrn;
          const who       = p.converted_by;
          let suffix = mrn ? `into an active referral (${mrn})` : "into an active referral";
          if (who) suffix += ` — converted by ${who}`;
          return { before: `converted ${firstName}'s inquiry`, after: suffix, icon: "ri-user-add-line" };
        }
        return { before: `${a}d a ${(s||"record").replace(/([A-Z])/g, " $1").trim().toLowerCase()} for`, after: "", icon: "ri-settings-3-line" };
      }

      // --- Card helpers (mirror EventNarrator::Story#action_label / #source_label) ---
      function esc(s) { const d = document.createElement("div"); d.textContent = s == null ? "" : String(s); return d.innerHTML; }
      function initialsOf(name) { return (name || "").split(/\s+/).filter(Boolean).map((w) => w[0]).slice(0, 2).join("").toUpperCase() || "?"; }
      function actionLabel(phrase) {
        let before = (phrase.before || "").trim();
        const after = (phrase.after || "").trim();
        if (after.startsWith("'s")) return `${before} the${after.slice(2)}`.trim();
        before = before.replace(/\s+(?:for|with|to|from|about|of|on)$/i, "");
        return [before, after].filter(Boolean).join(" ").trim();
      }

      ws.onmessage = (msg) => {
        const data = JSON.parse(msg.data);
        if (["ping", "welcome", "confirm_subscription"].includes(data.type)) return;
        const p = data.message;
        if (!p) return;

        const persona = PERSONA[p.agent_id] || { name: p.agent_id, title: "", initials: (p.agent_id||"?")[0].toUpperCase(), color: "#6B665F" };
        const phrase  = narrate(p);
        const isCrisis = p.urgency === "crisis";
        const cat      = categorize(p);
        const catColor = LANE_COLOR[cat] || "#6B665F";
        const catLabel = LANE_LABEL[cat] || "Ops";
        const source     = persona.title ? `${persona.name} (${persona.title})` : persona.name;
        const action     = actionLabel(phrase);
        const hasPatient = !!p.patient_id;
        const headline   = hasPatient ? (p.patient_name || source) : source;
        const initials   = hasPatient && p.patient_name ? initialsOf(p.patient_name) : (persona.initials || "?");
        const crisisPill = isCrisis
          ? `<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-[#C1403A] text-white tracking-wider">CRISIS</span>`
          : "";
        const flash = isCrisis ? "bg-[#FFF3EC]" : "bg-[#FFFBEB]";

        const row = document.createElement(hasPatient ? "a" : "div");
        row.className = `group/story flex items-start gap-2.5 rounded-lg border-l-[3px] pl-2.5 pr-2 py-1.5 -mx-2 transition ${hasPatient ? "hover:bg-[#FBF9F5]" : ""} ${flash}`;
        row.style.borderLeftColor = catColor;
        row.setAttribute("data-story", "");
        row.setAttribute("data-category", cat);
        if (hasPatient) row.setAttribute("href", `/patients/${p.patient_id}`);
        row.innerHTML = `
          <span class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-white font-medium text-[11px]"
                style="background: ${catColor};" title="${esc(catLabel)}">${esc(initials)}</span>
          <div class="min-w-0 flex-1">
            <div class="text-[13px] font-semibold text-[#1D1C1A] truncate ${hasPatient ? "group-hover/story:text-[#D97757]" : ""}">${esc(headline)}</div>
            <div class="text-[12px] text-[#6B665F] leading-snug">${hasPatient ? esc(source) + " " : ""}${esc(action)}</div>
            <div class="mt-0.5 flex items-center gap-2 text-[10px] text-[#9A938A]">
              <time class="font-mono">${new Date().toLocaleTimeString([], { hour: "numeric", minute: "2-digit" })}</time>
              ${crisisPill}
              ${p.patient_mrn ? `<span class="font-mono">· ${esc(p.patient_mrn)}</span>` : ""}
            </div>
          </div>
        `;
        if (!matchesLane(cat)) row.classList.add("hidden");
        const recentEl = recentContainer();
        ensureTodayDivider(recentEl);
        const stick = nearBottom();
        recentEl.appendChild(row);
        if (stick && matchesLane(cat)) feedEl.scrollTop = feedEl.scrollHeight;
        if (!isCrisis) {
          setTimeout(() => { row.classList.remove("bg-[#FFFBEB]"); }, 1800);
        }
      };
      }  // end initMissionStage

      document.addEventListener("turbo:load", initMissionStage);

      // --- Ask HosAlivio: optimistic question bubble + typing indicator ---
      const isAskForm = (form) => form && String(form.action || "").includes("/assistant/ask");
      const askStageScroll = () => {
        const stage = document.getElementById("assistant-stage");
        if (stage) requestAnimationFrame(() => { stage.scrollTop = stage.scrollHeight; });
      };

      // On submit: show the question immediately + a "typing…" bubble, so the
      // manager sees HosAlivio working before the answer (esp. the LLM path).
      document.addEventListener("turbo:submit-start", (e) => {
        const form = e.detail?.formSubmission?.formElement || e.target;
        if (!isAskForm(form)) return;
        const q = (form.querySelector('input[name="q"]')?.value || "").trim();
        const thread = document.getElementById("assistant-thread");
        if (!thread || !q) return;
        window.__askStartedAt = Date.now();

        const question = document.createElement("div");
        question.className = "flex justify-end";
        const qb = document.createElement("div");
        qb.className = "max-w-[85%] rounded-2xl rounded-tr-sm bg-[#E9F1FB] text-[#1D1C1A] px-3.5 py-2 text-[13px] whitespace-pre-wrap break-words";
        qb.textContent = q;
        question.appendChild(qb);
        thread.appendChild(question);

        const typing = document.createElement("div");
        typing.id = "assistant-typing";
        typing.className = "flex items-start gap-2";
        typing.innerHTML = `
          <span class="w-7 h-7 rounded-full bg-[#FFF3EC] text-[#D97757] flex items-center justify-center flex-shrink-0"><i class="ri-sparkling-2-line text-[14px]"></i></span>
          <div class="rounded-2xl rounded-tl-sm bg-[#FFF3EC] px-3.5 py-3">
            <span class="flex gap-1">
              <span class="w-1.5 h-1.5 rounded-full bg-[#B9B3A9] animate-bounce"></span>
              <span class="w-1.5 h-1.5 rounded-full bg-[#B9B3A9] animate-bounce" style="animation-delay:0.15s"></span>
              <span class="w-1.5 h-1.5 rounded-full bg-[#B9B3A9] animate-bounce" style="animation-delay:0.3s"></span>
            </span>
          </div>`;
        thread.appendChild(typing);
        askStageScroll();
      });

      // On completion: clear the composer input, drop any lingering typing
      // indicator, and scroll to the newest bubble.
      document.addEventListener("turbo:submit-end", (e) => {
        const form = e.detail?.formSubmission?.formElement || e.target;
        if (!isAskForm(form)) return;
        const input = document.querySelector('input[data-composer-target="input"]');
        if (input && input.name === "q") input.value = "";
        // On success the (delayed) turbo stream removes the typing bubble; only
        // clean it up here if the request actually failed.
        if (e.detail && e.detail.success === false) document.getElementById("assistant-typing")?.remove();
        askStageScroll();
      });

      // Keep the "thinking…" bubble visible for a beat even when the answer is
      // instant (the deterministic reports), so HosAlivio always looks like
      // she's working before she replies. Slow LLM answers aren't padded.
      const MIN_THINK_MS = 800;
      document.addEventListener("turbo:before-stream-render", (e) => {
        const target = e.target.getAttribute && e.target.getAttribute("target");
        if (target !== "assistant-thread" && target !== "assistant-typing") return;
        const wait = Math.max(0, MIN_THINK_MS - (Date.now() - (window.__askStartedAt || 0)));
        if (wait <= 0) return;
        const defaultRender = e.detail.render;
        e.detail.render = (streamElement) => new Promise((resolve) => {
          setTimeout(async () => { await defaultRender(streamElement); askStageScroll(); resolve(); }, wait);
        });
      });
    })();
  </script>
<% end %>
