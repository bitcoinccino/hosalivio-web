<% content_for :title, "HosAlivio · Mission Stage" %>

<div class="flex h-screen" data-controller="sidebar" data-sidebar-storage-key-value="dashboardSidebar">
  <!-- Left rail -->
  <aside data-sidebar-target="sidebar" data-collapsed="false"
         class="group/sb w-72 data-[collapsed=true]:w-16 bg-[#EFECE6] border-r border-[#D9D5CD] flex flex-col justify-between p-6 data-[collapsed=true]:p-3 transition-[width,padding] duration-200">
    <div>
      <div class="flex items-center justify-between group-data-[collapsed=true]/sb:justify-center">
        <div class="flex items-center gap-2 group-data-[collapsed=true]/sb:hidden">
          <div class="w-7 h-7 rounded-full bg-[#D97757] text-white flex items-center justify-center flex-shrink-0">
            <i class="ri-heart-pulse-line text-sm"></i>
          </div>
          <h1 class="text-xs uppercase tracking-[0.2em] text-[#6B665F] font-bold group-data-[collapsed=true]/sb:hidden">HosAlivio</h1>
        </div>
        <button type="button" data-action="click->sidebar#toggle"
                title="Toggle sidebar"
                class="w-7 h-7 rounded-full hover:bg-[#D9D5CD] text-[#6B665F] hover:text-[#1D1C1A] flex items-center justify-center flex-shrink-0 transition">
          <i class="ri-side-bar-line text-[15px]"></i>
        </button>
      </div>
      <nav class="mt-8 space-y-1.5 text-sm">
        <a href="/dashboard" title="Mission Stage"
           class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[#D9D5CD] text-[#1D1C1A] font-medium group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-radar-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">Mission Stage</span>
        </a>
        <a href="/calendar" title="Calendar"
           class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-calendar-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">Calendar</span>
        </a>
        <a href="/channels" title="Team chat"
           class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-chat-3-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">Team chat</span>
        </a>
        <% unread_count = (Notification.where(user: current_user, read_at: nil).count rescue 0) %>
        <a href="/notifications" title="Notifications"
           class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0 relative">
          <i class="ri-notification-3-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">Notifications</span>
          <% if unread_count > 0 %>
            <span class="ml-auto text-[10px] font-bold px-2 py-0.5 rounded-full bg-[#D97757] text-white group-data-[collapsed=true]/sb:hidden"><%= unread_count %></span>
            <span class="hidden group-data-[collapsed=true]/sb:block absolute top-1 right-1 w-2 h-2 bg-[#D97757] rounded-full"></span>
          <% end %>
        </a>
        <% manager_roles = %w[admin don admissions] %>
        <% if (current_user.role_names & manager_roles).any? %>
          <a href="<%= admissions_queue_path %>" title="Admissions queue"
             class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
            <i class="ri-folder-history-line"></i>
            <span class="group-data-[collapsed=true]/sb:hidden">Admissions queue</span>
          </a>
          <a href="/branches" title="Branches"
             class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
            <i class="ri-map-pin-line"></i>
            <span class="group-data-[collapsed=true]/sb:hidden">Branches</span>
          </a>
          <a href="/team_members" title="Team"
             class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
            <i class="ri-team-line"></i>
            <span class="group-data-[collapsed=true]/sb:hidden">Team</span>
          </a>
          <a href="<%= edit_agency_features_path %>" title="Agency features"
             class="flex items-center gap-2 px-3 py-2 text-[#6B665F] hover:text-[#1D1C1A] hover:bg-[#D9D5CD] rounded-lg group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
            <i class="ri-toggle-line"></i>
            <span class="group-data-[collapsed=true]/sb:hidden">Features</span>
          </a>
        <% end %>
        <div class="mt-3 mb-1 px-3 text-[10px] uppercase tracking-widest text-[#B9B3A9] font-bold group-data-[collapsed=true]/sb:hidden">Reports</div>
        <div title="IDG Review (soon)"
             class="flex items-center gap-2 px-3 py-2 text-[#9A938A] group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-group-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">IDG Review</span>
          <span class="text-[10px] ml-auto italic group-data-[collapsed=true]/sb:hidden">soon</span>
        </div>
        <div title="Census Report (soon)"
             class="flex items-center gap-2 px-3 py-2 text-[#9A938A] group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <i class="ri-file-list-3-line"></i>
          <span class="group-data-[collapsed=true]/sb:hidden">Census Report</span>
          <span class="text-[10px] ml-auto italic group-data-[collapsed=true]/sb:hidden">soon</span>
        </div>
      </nav>
    </div>
    <div class="mt-3">
      <%= render "shared/user_menu", direction: :up %>
    </div>
  </aside>

  <!-- Main -->
  <main class="flex-1 flex flex-col overflow-hidden">
    <header class="px-8 py-5 border-b border-[#EFECE6] bg-white flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div>
          <h2 class="text-xl font-serif font-bold text-[#1D1C1A]">Mission Stage</h2>
          <div class="text-xs text-[#6B665F] mt-0.5">Agency-wide live agent activity</div>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to coordination_path, class: "inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full border border-[#D97757] text-[#D97757] hover:bg-[#FFF3EC] font-medium transition" do %>
          <i class="ri-inbox-line"></i> Coordination
        <% end %>
        <%= link_to admissions_queue_path, class: "inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full border border-[#2B4A7A] text-[#2B4A7A] hover:bg-[#F0F4FA] font-medium transition" do %>
          <i class="ri-folder-history-line"></i> Admissions queue
        <% end %>
        <% if (current_user.role_names & %w[admin don admissions]).any? %>
          <%= link_to new_patient_path, class: "inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white font-medium" do %>
            <i class="ri-user-add-line"></i> New patient
          <% end %>
        <% end %>
        <div id="cable-status" class="font-mono text-xs text-[#6B665F]">connecting…</div>
      </div>
    </header>

    <div class="flex-1 flex flex-col overflow-hidden">
      <div class="w-full max-w-[1400px] mx-auto flex-1 flex flex-col overflow-hidden px-4 md:px-8">
    <% if @agency.nil? %>
      <div class="flex-1 flex items-center justify-center text-sm text-[#6B665F]">
        No agency yet — run <code class="font-mono text-[#1D1C1A]">bin/rails db:seed</code>.
      </div>
    <% else %>
      <% manager_roles = %w[admin don admissions] %>
      <% is_manager = (current_user.role_names & manager_roles).any? %>

      <%# Quick stats — an instant pulse of the agency. %>
      <% if is_manager %>
        <%
          noe_soon = @noe_overdue.size + @noe_due_today.size
          quick_stats = [
            { label: "Active patients", value: @active_patient_count,        urgent: false },
            { label: "Pending reviews", value: @pending_certifications.size, urgent: false },
            { label: "Open blockers",   value: @open_blockers,               urgent: @open_blockers.to_i.positive? },
            { label: "NOE deadlines",   value: noe_soon,                     urgent: @noe_overdue.any? }
          ]
        %>
        <section class="mx-6 mt-6 grid grid-cols-2 md:grid-cols-4 gap-3">
          <% quick_stats.each do |s| %>
            <div class="rounded-2xl border p-4 <%= s[:urgent] ? "border-[#C1403A] bg-[#FFF3EC]" : "border-[#EFECE6] bg-white" %>">
              <div class="text-[10px] uppercase tracking-widest font-bold <%= s[:urgent] ? "text-[#C1403A]" : "text-[#6B665F]" %>"><%= s[:label] %></div>
              <div class="text-[26px] font-serif leading-none mt-1 <%= s[:urgent] ? "text-[#C1403A]" : "text-[#1D1C1A]" %>"><%= s[:value] %></div>
            </div>
          <% end %>
        </section>
      <% end %>

      <%# Agency-level "Ask HosAlivio" — oversight questions, answered ephemerally
          into the turbo-frame below (never written to a patient's chart). %>
      <% if is_manager %>
        <section class="mx-6 mt-4">
          <div class="rounded-2xl bg-white border border-[#EFECE6] p-4">
            <div class="flex items-center gap-2 mb-2.5">
              <span class="w-7 h-7 rounded-full bg-[#FBF9F5] text-[#D97757] flex items-center justify-center"><i class="ri-sparkling-2-line text-[15px]"></i></span>
              <div class="text-[13px] text-[#1D1C1A] font-semibold">Ask HosAlivio</div>
            </div>
            <%= form_with url: admin_assistant_ask_path, method: :post, data: { turbo_frame: "assistant-answer" }, class: "flex gap-2" do %>
              <input type="text" name="q" autocomplete="off"
                     placeholder="Ask anything — e.g. today's priorities, patients needing attention, new referrals…"
                     class="flex-1 text-[14px] rounded-xl border border-[#EFECE6] bg-white px-4 py-2.5 text-[#1D1C1A] focus:outline-none focus:ring-1 focus:ring-[#D97757]">
              <button type="submit" class="rounded-full bg-[#D97757] hover:bg-[#c56647] text-white px-5 py-2.5 text-[13px] font-medium whitespace-nowrap">Ask</button>
            <% end %>
            <%= turbo_frame_tag "assistant-answer" %>
          </div>
        </section>
      <% end %>

      <% if is_manager && (@pending_certifications.any? || @pending_noe.any?) %>
        <section class="mx-6 mt-6 grid grid-cols-1 md:grid-cols-3 gap-3">
          <% if @pending_certifications.any? %>
            <div class="rounded-2xl border border-[#2B4A7A] bg-[#F0F4FA] p-4">
              <div class="flex items-center gap-2">
                <i class="ri-stethoscope-line text-[#2B4A7A] text-lg"></i>
                <div class="text-[11px] uppercase tracking-widest text-[#2B4A7A] font-bold">Awaiting MD certification</div>
              </div>
              <div class="text-[22px] font-serif text-[#1D1C1A] mt-1 leading-none"><%= @pending_certifications.size %></div>
              <div class="text-[11px] text-[#6B665F] mt-1 space-y-0.5">
                <% @pending_certifications.first(3).each do |pae| %>
                  <div class="truncate">· <%= pae.patient.full_name %> — <%= pae.primary_icd10.presence || "dx pending" %></div>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if @noe_overdue.any? %>
            <div class="rounded-2xl border-2 border-[#C1403A] bg-[#FFF3EC] p-4">
              <div class="flex items-center gap-2">
                <i class="ri-alarm-warning-fill text-[#C1403A] text-lg"></i>
                <div class="text-[11px] uppercase tracking-widest text-[#C1403A] font-bold">NOE OVERDUE</div>
              </div>
              <div class="text-[22px] font-serif text-[#C1403A] mt-1 leading-none"><%= @noe_overdue.size %></div>
              <div class="text-[11px] text-[#6B665F] mt-1">Past the 5-day filing deadline. Medicare revenue at risk.</div>
            </div>
          <% end %>

          <% if @noe_due_today.any? %>
            <div class="rounded-2xl border border-[#D97757] bg-[#FFF3EC] p-4">
              <div class="flex items-center gap-2">
                <i class="ri-time-line text-[#D97757] text-lg"></i>
                <div class="text-[11px] uppercase tracking-widest text-[#D97757] font-bold">NOE due today / tomorrow</div>
              </div>
              <div class="text-[22px] font-serif text-[#1D1C1A] mt-1 leading-none"><%= @noe_due_today.size %></div>
              <div class="text-[11px] text-[#6B665F] mt-1 space-y-0.5">
                <% @noe_due_today.first(3).each do |pae| %>
                  <div class="truncate">· <%= pae.patient.full_name %> — <%= pae.noe_deadline_at.strftime("%b %-d") %></div>
                <% end %>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>

      <% if is_manager && (@licenses_expired.to_i > 0 || @licenses_expiring.to_i > 0) %>
        <section class="mx-6 mt-6">
          <a href="/team_members" class="block rounded-2xl border border-[#D97757] bg-[#FFF3EC] p-4 hover:bg-[#FFEDE2] transition">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-[#D97757] text-white flex items-center justify-center flex-shrink-0">
                <i class="ri-shield-cross-line text-lg"></i>
              </div>
              <div class="flex-1">
                <div class="text-[11px] uppercase tracking-widest text-[#C1403A] font-bold">Compliance risk</div>
                <div class="text-[14px] text-[#1D1C1A] mt-0.5">
                  <% if @licenses_expired.to_i > 0 %>
                    <strong class="text-[#C1403A]"><%= @licenses_expired %></strong> license<%= @licenses_expired == 1 ? "" : "s" %> already expired
                  <% end %>
                  <% if @licenses_expired.to_i > 0 && @licenses_expiring.to_i > 0 %> · <% end %>
                  <% if @licenses_expiring.to_i > 0 %>
                    <strong class="text-[#D97757]"><%= @licenses_expiring %></strong> expiring within 60 days
                  <% end %>
                </div>
                <div class="text-[11px] text-[#6B665F] mt-0.5">Renewals block Medicare billing. Click to see who.</div>
              </div>
              <i class="ri-arrow-right-line text-[#6B665F]"></i>
            </div>
          </a>
        </section>
      <% end %>

      <% if @open_inquiries.any? %>
        <section class="mx-6 mt-6 rounded-2xl border border-[#EFECE6] bg-white overflow-hidden">
          <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between">
            <h3 class="text-[11px] uppercase tracking-widest text-[#6B665F]"><i class="ri-inbox-unarchive-line"></i> Landing-page inquiries</h3>
            <span class="text-[10px] text-[#6B665F] font-mono"><%= @open_inquiries.size %> open</span>
          </div>
          <div class="divide-y divide-[#EFECE6]">
            <% @open_inquiries.each do |inq| %>
              <div class="flex items-center gap-3 px-5 py-3 text-[13px]">
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-white"
                     style="background: <%= inq.is_general ? '#6B665F' : '#D97757' %>;">
                  <i class="<%= inq.is_general ? 'ri-megaphone-line' : 'ri-send-plane-2-line' %>"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-[#1D1C1A] font-medium">
                    <%= inq.first_name.presence || "Anonymous" %>
                    <span class="text-[11px] text-[#6B665F] font-mono">· ZIP <%= inq.zip_prefix %>xx</span>
                    <% unless inq.is_general %>
                      <span class="text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-[#FFF3EC] text-[#D97757] ml-1">Targeted</span>
                    <% end %>
                    <% if inq.status_claimed? %>
                      <span class="text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-[#F0F7F2] text-[#2F6F4E] ml-1">Claimed · <%= inq.claimed_by&.full_name&.split&.first %></span>
                    <% end %>
                  </div>
                  <div class="text-[11px] text-[#6B665F] mt-0.5">
                    <%= inq.contact %>
                    <% if inq.question.present? %> · <span class="italic">"<%= truncate(inq.question, length: 90) %>"</span><% end %>
                  </div>
                </div>
                <div class="flex items-center gap-1.5">
                  <% if inq.status_new_lead? %>
                    <%= button_to claim_inquiry_path(inq), class: "text-[11px] px-3 py-1 rounded-full bg-[#D97757] text-white hover:bg-[#c46a4b]" do %>
                      <i class="ri-hand-heart-line"></i> Claim
                    <% end %>
                  <% elsif inq.status_claimed? %>
                    <%= button_to mark_contacted_inquiry_path(inq), class: "text-[11px] px-3 py-1 rounded-full bg-[#2F6F4E] text-white hover:bg-[#265a3d]" do %>
                      <i class="ri-phone-fill"></i> Contacted
                    <% end %>
                    <%= link_to convert_inquiry_path(inq), class: "inline-flex items-center gap-1 text-[11px] px-3 py-1 rounded-full bg-[#1D1C1A] text-white hover:bg-[#3A3936]" do %>
                      <i class="ri-user-add-line"></i> Convert
                    <% end %>
                  <% else %>
                    <%= link_to convert_inquiry_path(inq), class: "inline-flex items-center gap-1 text-[11px] px-3 py-1 rounded-full bg-[#1D1C1A] text-white hover:bg-[#3A3936]" do %>
                      <i class="ri-user-add-line"></i> Convert
                    <% end %>
                  <% end %>
                  <%= button_to dismiss_inquiry_path(inq), class: "text-[11px] px-2 py-1 rounded-full text-[#6B665F] hover:bg-[#EFECE6]" do %>
                    <i class="ri-close-line"></i>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <% if is_manager && @mission_visits.any? %>
        <section class="mx-6 mt-6 rounded-2xl border border-[#EFECE6] bg-white overflow-hidden">
          <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between">
            <h3 class="text-[11px] uppercase tracking-widest text-[#6B665F]"><i class="ri-calendar-check-line"></i> Visits · recent &amp; upcoming</h3>
            <span class="text-[10px] text-[#6B665F] font-mono"><%= @mission_visits.size %></span>
          </div>
          <div class="divide-y divide-[#EFECE6] max-h-72 overflow-y-auto">
            <% @mission_visits.each do |v| %>
              <%
                if v.completed_visit?
                  status_label, status_cls = "Completed", "bg-[#F0F7F2] text-[#2F6F4E]"
                elsif v.currently_in_progress?
                  status_label, status_cls = "In progress", "bg-[#FFF3EC] text-[#D97757]"
                else
                  status_label, status_cls = "Scheduled", "bg-[#F2EEE7] text-[#6B665F]"
                end
              %>
              <%= link_to patient_path(v.patient), class: "flex items-center gap-3 px-5 py-2.5 text-[13px] hover:bg-[#FBF9F5] transition" do %>
                <div class="w-16 flex-shrink-0 text-[11px] text-[#6B665F] font-mono leading-tight">
                  <%= v.anchor_start&.strftime("%a %-d") %><br><%= v.anchor_start&.strftime("%-l:%M %p") %>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-[#1D1C1A] font-medium truncate"><%= v.patient&.full_name %></div>
                  <div class="text-[11px] text-[#6B665F] truncate">
                    <%= v.discipline.to_s.upcase %> · <%= v.visit_type_label %>
                    <% if v.user %> · <%= v.user.full_name %><% end %>
                  </div>
                </div>
                <span class="text-[10px] uppercase tracking-wider px-2 py-0.5 rounded-full flex-shrink-0 <%= status_cls %>"><%= status_label %></span>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>

      <div class="flex-1 grid grid-cols-2 gap-6 p-6 overflow-hidden">
        <!-- Census -->
        <section class="bg-white rounded-2xl border border-[#EFECE6] overflow-hidden flex flex-col">
          <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between">
            <h3 class="text-[11px] uppercase tracking-widest text-[#6B665F]">Active Census</h3>
            <span class="text-xs text-[#1D1C1A] font-mono"><%= @patients.size %></span>
          </div>
          <div class="flex-1 overflow-y-auto">
            <% if @patients.empty? %>
              <div class="p-6 text-sm text-[#6B665F]">No patients yet.</div>
            <% else %>
              <table class="w-full text-sm">
                <thead class="bg-[#FBF9F5] text-[11px] uppercase tracking-widest text-[#6B665F]">
                  <tr>
                    <th class="text-left px-4 py-2 font-medium">MRN</th>
                    <th class="text-left px-4 py-2 font-medium">Name</th>
                    <th class="text-left px-4 py-2 font-medium">Status</th>
                    <th class="text-left px-4 py-2 font-medium">Code</th>
                  </tr>
                </thead>
                <tbody>
                  <% @patients.each do |p| %>
                    <tr class="border-t border-[#EFECE6] hover:bg-[#FBF9F5] transition">
                      <td class="px-4 py-2 font-mono text-[#1D1C1A]"><%= p.mrn %></td>
                      <td class="px-4 py-2">
                        <a href="/patients/<%= p.id %>" class="text-[#D97757] hover:underline">
                          <%= p.full_name %>
                        </a>
                      </td>
                      <td class="px-4 py-2 text-[#6B665F]"><%= p.status %></td>
                      <td class="px-4 py-2">
                        <% if p.dnr? || p.dnr_dni? %>
                          <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-[#C1403A] text-white tracking-wider"><%= p.code_status.to_s.upcase.tr("_", "/") %></span>
                        <% else %>
                          <span class="text-[10px] text-[#6B665F]"><%= p.code_status.to_s.upcase %></span>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            <% end %>
          </div>
        </section>

        <!-- Event feed -->
        <section class="bg-white rounded-2xl border border-[#EFECE6] overflow-hidden flex flex-col">
          <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between">
            <h3 class="text-[11px] uppercase tracking-widest text-[#6B665F]">Agent Event Feed · live</h3>
            <% open_crises = @unresolved_note_ids.size %>
            <% if open_crises > 0 %>
              <span class="inline-flex items-center gap-1 text-[10px] font-bold px-2 py-0.5 rounded-full bg-[#C1403A] text-white tracking-wider animate-pulse">
                <i class="ri-alarm-warning-line"></i> <%= open_crises %> OPEN
              </span>
            <% end %>
          </div>

          <div id="event-feed" class="flex-1 overflow-y-auto text-[12px] p-3 space-y-1.5">
            <% if @stories.empty? %>
              <div class="text-[#6B665F] p-2">No events yet. Waiting for agents…</div>
            <% else %>
              <% @stories.each do |story| %>
                <%= render "event_story", story: story, unresolved_note_ids: @unresolved_note_ids %>
              <% end %>
            <% end %>
          </div>
        </section>
      </div>
    <% end %>
      </div>
    </div>
  </main>
</div>

<% if @agency %>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const statusEl = document.getElementById("cable-status");
      const feedEl   = document.getElementById("event-feed");
      const agencyId = "<%= @agency.id %>";

      const proto = location.protocol === "https:" ? "wss:" : "ws:";
      const ws = new WebSocket(`${proto}//${location.host}/cable`);

      ws.onopen  = () => {
        statusEl.textContent = "connected";
        statusEl.classList.remove("text-[#6B665F]");
        statusEl.classList.add("text-[#2F6F4E]");
        ws.send(JSON.stringify({
          command: "subscribe",
          identifier: JSON.stringify({ channel: "MissionStageChannel", agency_id: agencyId })
        }));
      };
      ws.onclose = () => { statusEl.textContent = "disconnected"; statusEl.classList.add("text-[#C1403A]"); };
      // Persona for live rendering — keep in sync with app/services/event_narrator.rb
      const PERSONA = {
        admissions:         { name: "HosAlivio",  title: "Admissions",    initials: "H", color: "#1D1C1A" },
        front_door_inbound: { name: "Care Portal",title: "Family-facing", initials: "⌂", color: "#D97757" },
        rn:                 { name: "Pascal",     title: "RN",            initials: "P", color: "#2F6F4E" },
        md:                 { name: "Dr. Esther", title: "MD",            initials: "E", color: "#2B4A7A" },
        don:                { name: "Diaphnie",   title: "DON",           initials: "D", color: "#8B5A2B" },
        social_worker:      { name: "Nickla",     title: "Social Worker", initials: "N", color: "#7A4A8C" },
        chaplain:           { name: "Geoginio",   title: "Chaplain",      initials: "G", color: "#8C6A2F" },
        pharmacy:           { name: "Simone",     title: "Pharmacy",      initials: "S", color: "#5A2F7A" },
        dme:                { name: "Marcus",     title: "DME",           initials: "M", color: "#3E5D5D" },
        insurance:          { name: "Kendra",     title: "Insurance",     initials: "K", color: "#3A3936" },
        billing:            { name: "Wolfwide",   title: "Billing",       initials: "W", color: "#6B665F" },
        aide:               { name: "Flore",      title: "Aide",          initials: "F", color: "#AD7340" },
        family:             { name: "Family",     title: "Care Portal",   initials: "♥", color: "#D97757" },
        system:             { name: "HosAlivio",  title: "System",        initials: "•", color: "#6B665F" }
      };
      const ROLE_LABEL = {
        rn: "RN", md: "MD", don: "DON", aide: "Aide",
        social_worker: "Social Work", chaplain: "Chaplain",
        pharmacy: "Pharmacy", dme: "DME", insurance: "Insurance",
        billing: "Billing", admissions: "Admissions"
      };

      // Must mirror EventNarrator#narrate in app/services/event_narrator.rb
      function narrate(p) {
        const s = p.subject_type, a = p.event, r = p.agent_id;
        if (r === "admissions" && a === "handoff" && s === "Patient") {
          const t = p.handoff_role ? (ROLE_LABEL[p.handoff_role] || p.handoff_role) : "team";
          return { before: "assigned", after: `to the ${t} team`, icon: "ri-send-plane-2-line" };
        }
        if (r === "admissions" && a === "create" && s === "Note")
          return { before: "posted a triage update for", after: p.urgency === "crisis" ? " (crisis triage)" : "", icon: "ri-chat-3-line" };
        if (r === "front_door_inbound" && a === "create" && s === "Note")
          return { before: "logged a new concern from", after: p.urgency === "crisis" ? "'s family — marked CRISIS" : "'s family", icon: "ri-feedback-line" };
        if (a === "create" && s === "MedicationOrder")
          return { before: `authorized a new medication order${p.drug_name ? ` (${p.drug_name})` : ""} for`, after: "", icon: "ri-capsule-line" };
        if (a === "update" && s === "MedicationOrder")    return { before: "updated a medication order for", after: "", icon: "ri-capsule-line" };
        if (a === "create" && s === "MedicationLog")      return { before: "administered a scheduled dose to", after: "", icon: "ri-syringe-line" };
        if (a === "create" && s === "Visit")              return { before: `started a${p.visit_type ? " " + p.visit_type.replace(/_/g, ' ') : ""} bedside visit with`, after: "", icon: "ri-nurse-line" };
        if (a === "create" && s === "PharmacyDelivery")   return { before: "requested a pharmacy delivery for", after: "", icon: "ri-truck-line" };
        if (a === "update" && s === "PharmacyDelivery")   return { before: "updated a pharmacy delivery for", after: "", icon: "ri-truck-line" };
        if (a === "create" && s === "DmeOrder")           return { before: `ordered${p.equipment_type ? " a " + p.equipment_type.replace(/_/g, ' ') : " equipment"} for`, after: "", icon: "ri-tools-line" };
        if (a === "create" && s === "Patient")            return { before: "admitted", after: "as a new referral", icon: "ri-user-add-line" };
        if (a === "update" && s === "Patient")            return { before: "updated", after: "'s chart", icon: "ri-edit-2-line" };
        if (a === "update" && s === "Note")               return { before: "acknowledged a note on", after: "'s chart", icon: "ri-check-line" };
        if (a === "inquiry_received" && s === "Inquiry") {
          const firstName = p.first_name || "Someone";
          const zip       = p.zip_prefix || "unknown";
          const qualifier = p.is_general ? "general inquiry" : "targeted inquiry";
          const source    = (p.source_prompt || "").replace(/_/g, " ");
          const hint      = source ? ` via ${source}` : "";
          return { before: `received a ${qualifier} from ${firstName} (ZIP ${zip}xx)${hint}`, after: "", icon: "ri-mail-add-line" };
        }
        if (a === "inquiry_converted" && s === "Inquiry") {
          const firstName = p.first_name || "the family";
          const mrn       = p.patient_mrn;
          const who       = p.converted_by;
          let suffix = mrn ? `into an active referral (${mrn})` : "into an active referral";
          if (who) suffix += ` — converted by ${who}`;
          return { before: `converted ${firstName}'s inquiry`, after: suffix, icon: "ri-user-add-line" };
        }
        return { before: `${a}d a ${(s||"record").replace(/([A-Z])/g, " $1").trim().toLowerCase()} for`, after: "", icon: "ri-settings-3-line" };
      }

      ws.onmessage = (msg) => {
        const data = JSON.parse(msg.data);
        if (["ping", "welcome", "confirm_subscription"].includes(data.type)) return;
        const p = data.message;
        if (!p) return;

        const persona = PERSONA[p.agent_id] || { name: p.agent_id, title: "", initials: (p.agent_id||"?")[0].toUpperCase(), color: "#6B665F" };
        const phrase  = narrate(p);
        const isCrisis = p.urgency === "crisis";

        const patientLink = p.patient_id && p.patient_name
          ? `<a href="/patients/${p.patient_id}" class="font-medium text-[#D97757] hover:underline">${p.patient_name}</a>`
          : "";
        const crisisPill = isCrisis
          ? `<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-[#C1403A] text-white tracking-wider">CRISIS</span>`
          : "";

        const row = document.createElement("div");
        const base = "flex items-start gap-3 px-3 py-2.5 rounded-lg border transition-all duration-700";
        const highlight = isCrisis
          ? "border-[#D97757] bg-[#FFF3EC] animate-pulse"
          : "border-[#FFEB99] bg-[#FFFBEB]";
        row.className = `${base} ${highlight}`;
        row.innerHTML = `
          <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-white font-medium text-[11px]"
               style="background: ${persona.color};" title="${persona.name} · ${persona.title}">${persona.initials}</div>
          <div class="flex-1 min-w-0">
            <div class="text-[13px] leading-tight">${(() => {
              const titleSpan = persona.title ? `<span class="text-[11px] text-[#6B665F]"> (${persona.title})</span>` : "";
              const afterHtml = phrase.after
                ? (phrase.after.startsWith("'")
                    ? `<span class="text-[#3A3936]">${phrase.after}</span>`
                    : `<span class="text-[#3A3936]"> ${phrase.after}</span>`)
                : "";
              return `<i class="${phrase.icon} text-[#6B665F] mr-1"></i><span class="font-bold text-[#1D1C1A]">${persona.name}</span>${titleSpan} <span class="text-[#3A3936]">${phrase.before}</span>${patientLink ? " " + patientLink : ""}${afterHtml}`;
            })()}</div>
            <div class="mt-1 flex items-center gap-2 text-[10px] text-[#6B665F]">
              <time class="font-mono">${new Date().toLocaleTimeString([], { hour: "numeric", minute: "2-digit" })}</time>
              ${crisisPill}
              ${p.patient_mrn ? `<span class="font-mono">· ${p.patient_mrn}</span>` : ""}
            </div>
          </div>
        `;
        feedEl.insertBefore(row, feedEl.firstChild);
        if (!isCrisis) {
          setTimeout(() => {
            row.classList.remove("border-[#FFEB99]", "bg-[#FFFBEB]");
            row.classList.add("border-transparent");
          }, 1800);
        }
      };
    });
  </script>
<% end %>
