<% content_for :title, "Start a Prior Authorization Review" %>
<% if turbo_frame_request? %>
  <%# Opened from the quick-actions "Prior-auth review" link (data-turbo-frame).
      modal_controller#close clears this frame on backdrop/X. %>
  <%= turbo_frame_tag "pa-modal" do %>
    <div class="fixed inset-0 z-50 bg-[#1D1C1A]/45 backdrop-blur-sm flex items-start justify-center overflow-y-auto px-4 py-6 md:py-10"
         data-controller="modal" data-action="click->modal#closeFromBackdrop">
      <div class="w-full max-w-lg rounded-2xl bg-white border border-[#EFECE6] shadow-2xl overflow-hidden">
        <div class="flex items-center justify-between px-5 py-3 border-b border-[#EFECE6] bg-[#FBF9F5]">
          <div>
            <div class="text-[10px] uppercase tracking-[0.2em] text-[#6B665F] font-bold">Prior authorization</div>
            <div class="font-serif text-[16px] text-[#1D1C1A] leading-tight">Start a Prior Authorization Review</div>
          </div>
          <button type="button" data-action="click->modal#close" aria-label="Close"
                  class="w-8 h-8 rounded-full inline-flex items-center justify-center text-[#6B665F] hover:text-[#1D1C1A] hover:bg-white">
            <i class="ri-close-line text-lg"></i>
          </button>
        </div>
        <div class="p-5">
          <% if flash[:alert].present? %>
            <div class="rounded-lg bg-[#FFF3EC] border border-[#C1403A] px-3 py-2 text-[12px] text-[#C1403A] mb-3"><%= flash[:alert] %></div>
          <% end %>
          <%= render "form", cancel: :modal %>
        </div>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="min-h-screen bg-[#FBF9F5] py-8 px-4 sm:px-6">
    <div class="max-w-lg mx-auto">
      <a href="<%= dashboard_path %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
        <i class="ri-arrow-left-line"></i> Back to dashboard
      </a>

      <div class="mb-1">
        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold">Prior authorization</div>
        <h1 class="font-serif text-2xl text-[#1D1C1A] leading-tight">Start a Prior Authorization Review</h1>
        <div class="text-[12px] text-[#6B665F] mt-0.5">Medicare only · public HCPCS codes</div>
      </div>

      <div class="rounded-2xl bg-white border border-[#EFECE6] p-5 shadow-sm mt-5">
        <% if flash[:alert].present? %>
          <div class="rounded-lg bg-[#FFF3EC] border border-[#C1403A] px-3 py-2 text-[12px] text-[#C1403A] mb-3"><%= flash[:alert] %></div>
        <% end %>
        <%= render "form" %>
      </div>
    </div>
  </div>
<% end %>
