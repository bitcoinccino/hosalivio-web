<% content_for :title, "Prior-auth review · #{@review.patient.full_name}" %>
<%
  signed  = @review.status_signed?
  rbg, rborder, rfg, rlabel = prior_auth_recommendation_style(@review.recommendation)
%>
<div class="min-h-screen bg-[#FBF9F5] py-8 px-4 sm:px-6">
  <div class="max-w-3xl mx-auto">
    <a href="<%= dashboard_path %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to dashboard
    </a>

    <%# ── Header ─────────────────────────────────────────────── %>
    <div class="flex items-start justify-between gap-3 flex-wrap mb-1">
      <div>
        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold">Prior-authorization review</div>
        <h1 class="font-serif text-2xl text-[#1D1C1A] leading-tight"><%= @review.patient.full_name %></h1>
        <div class="text-[12px] text-[#6B665F] mt-0.5">
          <% if @review.procedure_hcpcs.present? %>HCPCS <span class="font-mono"><%= @review.procedure_hcpcs %></span> · <% end %>
          <%= @review.coverage_policy.citation %>
          <% if @review.provider_npi.present? %> · NPI <span class="font-mono"><%= @review.provider_npi %></span><% end %>
        </div>
      </div>
      <span class="text-[10px] uppercase tracking-widest font-bold px-2.5 py-1 rounded-full border
                   <%= signed ? "border-[#2F6F4E] text-[#2F6F4E] bg-[#E6F0EA]" : "border-[#D9D5CD] text-[#6B665F] bg-white" %>">
        <%= @review.status.humanize %>
      </span>
    </div>

    <%# ── Recommendation banner ──────────────────────────────── %>
    <div class="rounded-2xl border p-4 mt-4 flex items-start gap-3" style="background: <%= rbg %>; border-color: <%= rborder %>;">
      <i class="ri-scales-3-line text-lg mt-0.5" style="color: <%= rfg %>;"></i>
      <div class="flex-1 min-w-0">
        <div class="text-[11px] uppercase tracking-widest font-bold" style="color: <%= rfg %>;">Recommendation · <%= rlabel %></div>
        <div class="text-[12px] text-[#1D1C1A] mt-1">
          <%= pluralize(@review.criterion_results.count { |r| r.met? }, "criterion") %> met of
          <%= @review.criterion_results.size %> · <%= @review.gaps.size %> gap<%= "s" unless @review.gaps.size == 1 %>.
          Auto-derived from grounded evidence — the reviewer confirms below.
        </div>
      </div>
    </div>

    <%# ── Criteria ───────────────────────────────────────────── %>
    <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mt-6 mb-2 px-1">Policy criteria</div>
    <div class="space-y-2">
      <% @results.each do |r| %>
        <% bg, fg, label = prior_auth_verdict_badge(r.verdict, r.verified) %>
        <% ev = r.evidence %>
        <% doc = ev && @documents[ev["doc_id"]] %>
        <div class="rounded-xl border border-[#EFECE6] bg-white p-4">
          <div class="flex items-start justify-between gap-3">
            <div class="text-[13px] text-[#1D1C1A] font-medium min-w-0"><%= r.policy_criterion.label %></div>
            <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded font-bold whitespace-nowrap" style="background: <%= bg %>; color: <%= fg %>;"><%= label %></span>
          </div>

          <% if ev.present? %>
            <div class="mt-2 rounded-lg bg-[#FBF9F5] border border-[#EFECE6] px-3 py-2">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-1 flex items-center gap-1.5">
                <% if r.verified %>
                  <i class="ri-checkbox-circle-line text-[#2F6F4E]"></i> Verified evidence
                <% else %>
                  <i class="ri-error-warning-line text-[#8C6A2F]"></i> Unverified — model cited this, not found in source
                <% end %>
              </div>
              <blockquote class="text-[12px] text-[#1D1C1A] italic">&ldquo;<%= ev["quote"] %>&rdquo;</blockquote>
              <div class="text-[11px] text-[#6B665F] mt-1">
                <% if doc&.file&.attached? %>
                  <%= link_to "#{doc.title} · p.#{ev["page"]}", rails_blob_path(doc.file) + "#page=#{ev["page"]}",
                        class: "text-[#2B4A7A] hover:underline", target: "_blank", rel: "noopener" %>
                <% else %>
                  source doc <span class="font-mono"><%= ev["doc_id"].to_s.first(8) %></span> · p.<%= ev["page"] %>
                <% end %>
              </div>
            </div>
          <% elsif r.gap? %>
            <div class="text-[11px] text-[#8C6A2F] mt-1.5"><i class="ri-file-search-line"></i> No supporting documentation found — gap.</div>
          <% end %>

          <% if r.rationale.present? %>
            <div class="text-[11px] text-[#6B665F] mt-1.5"><%= r.rationale %></div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# ── Sign-off ───────────────────────────────────────────── %>
    <div class="rounded-2xl border border-[#EFECE6] bg-white p-5 shadow-sm mt-6">
      <% if signed %>
        <div class="text-[12px] text-[#1D1C1A] flex items-center gap-2">
          <i class="ri-shield-check-line text-[#2F6F4E] text-lg"></i>
          Signed off as <strong><%= rlabel %></strong>
          <% if @review.reviewed_by %> by <%= @review.reviewed_by.full_name %><% end %>
          on <%= @review.updated_at.strftime("%b %-d, %Y · %-l:%M %p") %>.
        </div>
      <% else %>
        <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-3">Reviewer sign-off</div>
        <%= form_with url: sign_off_prior_auth_review_path(@review), method: :post, data: { turbo: false },
              class: "flex flex-col sm:flex-row sm:items-end gap-3" do %>
          <div class="flex-1">
            <label class="block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1">Determination</label>
            <select name="recommendation" class="w-full text-[13px] rounded-lg border border-[#EFECE6] bg-white px-3 py-2 text-[#1D1C1A] focus:outline-none focus:ring-1 focus:ring-[#D97757]">
              <% %w[approve gap deny].each do |opt| %>
                <option value="<%= opt %>" <%= "selected" if @review.recommendation == opt %>><%= opt.humanize %></option>
              <% end %>
            </select>
          </div>
          <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white px-6 py-2.5 text-[13px] font-medium">
            <i class="ri-quill-pen-line"></i> Sign review
          </button>
        <% end %>
        <p class="text-[11px] text-[#9A938A] mt-2">Applies your electronic signature and locks this determination. HosAlivio informs — it does not decide.</p>
      <% end %>
    </div>
  </div>
</div>
