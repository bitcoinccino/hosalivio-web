<%# One team-channel message as a left-aligned chat bubble (matches patient/RN
    chat). Locals: message, reply: (a threaded reply renders tighter/smaller). %>
<%
  is_reply = local_assigns.fetch(:reply, false)
  author   = message.user
  role     = author ? team_primary_role(author) : nil
  color    = team_role_color(role)
  avatar   = is_reply ? "w-7 h-7 text-[10px]" : "w-9 h-9 text-[11px]"
%>
<div data-channel-message-id="<%= message.id %>" class="flex items-start gap-2.5 px-4 <%= is_reply ? 'py-1' : 'py-2' %> hover:bg-[#FBF9F5]">
  <!-- Avatar -->
  <div class="flex-shrink-0 <%= avatar %> rounded-full flex items-center justify-center text-white font-medium"
       style="background: <%= color %>;" title="<%= author&.full_name %>">
    <%= author ? team_avatar_initials(author) : "?" %>
  </div>

  <div class="min-w-0 flex-1">
    <!-- Name + role + time -->
    <div class="flex items-baseline gap-2 flex-wrap">
      <span class="text-[13px] font-semibold text-[#1D1C1A]"><%= author&.full_name.presence || "Someone" %></span>
      <% if role %>
        <span class="text-[10px] uppercase tracking-wider" style="color: <%= color %>;"><%= team_role_label(role) %></span>
      <% end %>
      <span class="text-[10px] text-[#9A938A] font-mono"><%= message.created_at.strftime("%b %-d · %-l:%M %p") %></span>
    </div>

    <!-- Bubble -->
    <div class="mt-1 inline-block max-w-full rounded-2xl rounded-tl-sm border border-[#CADCEC] bg-[#E9F1FB] px-3.5 py-2">
      <% if message.body.present? %>
        <div class="text-[13px] leading-snug text-[#1D1C1A] whitespace-pre-wrap break-words"><%= team_format_body(message.body) %></div>
      <% end %>
      <% if message.audio.attached? %>
        <audio src="<%= rails_blob_path(message.audio) %>" controls preload="none"
               class="mt-1 w-full max-w-[260px] h-9"></audio>
      <% end %>
    </div>
  </div>
</div>
