<%# Global mobile bottom tab bar (My Day · Calendar · Inbox · Profile).
    Position-agnostic — the caller wraps it in a fixed/sticky container so it
    can stack above other footers (e.g. the calendar's week nav). Pass
    `active:` (:my_day | :calendar | :inbox | :profile) to highlight a tab. %>
<%
  active = local_assigns[:active]
  base   = "flex-1 flex flex-col items-center justify-center py-2 text-[10px]"
  on     = "text-[#D97757] bg-[#FBF9F5]"
  off    = "text-[#6B665F]"
%>
<nav class="flex items-stretch bg-white border-t border-[#EFECE6]">
  <a href="/dashboard" class="<%= base %> <%= active == :my_day ? on : off %>">
    <i class="ri-sun-line text-lg"></i>
    <span class="uppercase tracking-wider mt-0.5">My Day</span>
  </a>
  <a href="/calendar" class="<%= base %> <%= active == :calendar ? on : off %>">
    <i class="ri-calendar-line text-lg"></i>
    <span class="uppercase tracking-wider mt-0.5">Calendar</span>
  </a>
  <a href="/notifications" class="<%= base %> <%= active == :inbox ? on : off %> relative">
    <i class="ri-notification-3-line text-lg"></i>
    <span class="uppercase tracking-wider mt-0.5">Inbox</span>
    <%= render "notifications/bell_badge" %>
  </a>
  <%= link_to edit_profile_path, class: "#{base} #{active == :profile ? on : off}" do %>
    <i class="ri-user-line text-lg"></i>
    <span class="uppercase tracking-wider mt-0.5">Profile</span>
  <% end %>
</nav>
