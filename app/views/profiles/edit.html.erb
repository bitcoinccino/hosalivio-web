<% content_for :title, "Profile · HosAlivio" %>
<%
  u = @user
  role = u.role_names.first
  role_color = {
    "rn" => "#2F6F4E", "md" => "#2B4A7A", "sw" => "#7A4A8C",
    "social_worker" => "#7A4A8C", "chaplain" => "#8C6A2F",
    "aide" => "#AD7340", "don" => "#8B5A2B", "admissions" => "#C96F3F",
    "admin" => "#1D1C1A", "family" => "#D97757",
    "insurance" => "#3A6B7A", "billing" => "#5A6B3A",
    "dme" => "#7A6B5A", "pharmacy" => "#4A6B8C"
  }[role] || "#6B665F"
  clinical = %w[rn md don admissions sw social_worker chaplain aide insurance billing dme pharmacy].include?(role)
  input_cls = "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]"
  label_cls = "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1"
%>
<div class="min-h-screen bg-[#FBF9F5] py-10 px-4">
  <div class="max-w-2xl mx-auto">
    <a href="/dashboard" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Dashboard
    </a>
    <h1 class="font-serif text-2xl text-[#1D1C1A] mb-1">Your profile</h1>
    <div class="text-[12px] text-[#6B665F] mb-6"><%= u.agency&.name %> · <%= role&.tr("_", " ")&.upcase %></div>

    <% if flash[:notice] %>
      <div class="mb-4 px-4 py-3 rounded-lg bg-[#EEF5EC] border border-[#9BBF93] text-[#2F6F4E] text-[13px]"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="mb-4 px-4 py-3 rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[#C1403A] text-[13px]"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with model: u, url: profile_path, method: :patch, local: true, html: { multipart: true, class: "space-y-5" } do |f| %>

      <!-- Photo -->
      <section class="rounded-2xl bg-white border border-[#EFECE6] p-5">
        <h2 class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-3">Photo</h2>
        <div class="flex items-center gap-4">
          <div class="w-28 h-28 rounded-full overflow-hidden flex items-center justify-center text-white text-2xl font-bold flex-shrink-0"
               style="background: <%= role_color %>;">
            <% if u.has_avatar? %>
              <%= image_tag u.avatar.variant(resize_to_fill: [320, 320]).processed, class: "w-full h-full object-cover" %>
            <% else %>
              <%= u.initials %>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <%= f.label :avatar, "Upload a new photo", class: label_cls %>
            <%= f.file_field :avatar, accept: "image/jpeg,image/png,image/webp,image/gif",
                  class: "block w-full text-[12px] text-[#6B665F] file:mr-3 file:px-3 file:py-1.5 file:rounded-full file:border-0 file:bg-[#D97757] file:text-white file:text-[12px] file:font-medium hover:file:bg-[#c46a4b] file:cursor-pointer" %>
            <div class="text-[10px] text-[#6B665F] mt-1">JPEG, PNG, WebP, or GIF · under 5 MB</div>
            <% if u.has_avatar? %>
              <%= button_to avatar_profile_path, method: :delete,
                    data: { turbo_confirm: "Remove your profile photo?" },
                    class: "mt-2 inline-flex items-center gap-1 text-[11px] text-[#C1403A] hover:underline" do %>
                <i class="ri-delete-bin-line"></i> Remove photo
              <% end %>
            <% end %>
          </div>
        </div>
      </section>

      <!-- Identity -->
      <section class="rounded-2xl bg-white border border-[#EFECE6] p-5">
        <h2 class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-3">Identity</h2>
        <div class="space-y-3">
          <div>
            <%= f.label :full_name, class: label_cls %>
            <%= f.text_field :full_name, class: input_cls %>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <%= f.label :email, class: label_cls %>
              <%= f.email_field :email, class: input_cls %>
            </div>
            <div>
              <%= f.label :phone_number, "Phone", class: label_cls %>
              <%= f.telephone_field :phone_number, placeholder: "+1 407 555 0110", class: input_cls %>
              <div class="text-[10px] text-[#6B665F] mt-1">Used for SMS visit reminders and after-hours alerts.</div>
            </div>
          </div>
          <div>
            <%= f.label :timezone, class: label_cls %>
            <%= f.select :timezone,
                  ActiveSupport::TimeZone.us_zones.map { |z| [z.name, z.name] },
                  { selected: u.timezone },
                  class: input_cls %>
          </div>
        </div>
      </section>

      <% if clinical %>
        <!-- Professional (clinical-role only) -->
        <section class="rounded-2xl bg-white border border-[#EFECE6] p-5">
          <h2 class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-3">Professional</h2>
          <div class="space-y-3">
            <% if %w[md].include?(role) %>
              <div>
                <%= f.label :npi, "NPI (10 digits)", class: label_cls %>
                <%= f.text_field :npi, maxlength: 10, placeholder: "1234567890", class: "#{input_cls} font-mono" %>
              </div>
            <% end %>
            <div>
              <%= f.label :service_zips, "Service ZIPs within my branch (optional)", class: label_cls %>
              <%= f.text_area :service_zips,
                    value: Array(u.service_zips).join(", "),
                    rows: 2,
                    placeholder: "32801, 32802  — leave blank to cover the entire branch",
                    class: input_cls %>
              <div class="text-[10px] text-[#6B665F] mt-1">
                Comma-separated. Empty = full branch coverage.
              </div>
            </div>
          </div>
        </section>

        <!-- Read-only DON-controlled -->
        <section class="rounded-2xl bg-[#FBF9F5] border border-[#EFECE6] p-5">
          <h2 class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-3">Managed by your DON</h2>
          <div class="text-[11px] text-[#6B665F] mb-3">These are read-only here. To update, ask your Director of Nursing.</div>
          <div class="grid grid-cols-2 gap-3 text-[13px]">
            <div>
              <div class="<%= label_cls %>">State license #</div>
              <div class="font-mono text-[#1D1C1A]"><%= u.license_number.presence || "—" %></div>
            </div>
            <div>
              <div class="<%= label_cls %>">License expires on</div>
              <div class="font-mono <%= u.license_expired? ? 'text-[#C1403A]' : (u.license_expiring_soon?(within: 60) ? 'text-[#D97757]' : 'text-[#1D1C1A]') %>">
                <%= u.license_expires_on&.strftime("%b %-d, %Y") || "—" %>
              </div>
            </div>
            <div>
              <div class="<%= label_cls %>">Caseload cap</div>
              <div class="font-mono text-[#1D1C1A]"><%= u.current_caseload %>/<%= u.max_caseload %></div>
            </div>
            <div>
              <div class="<%= label_cls %>">On-call</div>
              <div class="<%= u.on_call ? 'text-[#2B4A7A] font-medium' : 'text-[#6B665F]' %>">
                <%= u.on_call ? "Yes · part of rotation" : "No" %>
              </div>
            </div>
            <div>
              <div class="<%= label_cls %>">Employment type</div>
              <div class="text-[#1D1C1A]"><%= u.employment_type&.tr("_", " ")&.capitalize || "—" %></div>
            </div>
            <div>
              <div class="<%= label_cls %>">Branch</div>
              <div class="text-[#1D1C1A]"><%= u.branch&.name || "Unassigned" %></div>
            </div>
          </div>
        </section>
      <% end %>

      <!-- Password -->
      <%# ── Out-of-app notifications ────────────────────────────
          Channels HosAlivio uses to ping the clinician when they
          aren't in the web app. Messages are PHI-free; the patient
          context stays behind the deeplink + an authenticated
          session. Quiet hours suppress all but crisis pings. %>
      <% nc = u.notification_channels.is_a?(Hash) ? u.notification_channels : {} %>
      <section class="rounded-2xl bg-white border border-[#EFECE6] p-5">
        <h2 class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-1">Out-of-app notifications</h2>
        <p class="text-[12px] text-[#6B665F] mb-4">Where should HosAlivio reach you when you're not in the app? Pings are PHI-free; tap the link to sign in and read the actual message.</p>

        <div class="space-y-3">
          <%# Telegram %>
          <% tg = nc["telegram"] || {} %>
          <div class="flex items-center gap-3 p-3 rounded-lg bg-[#FBF9F5] border border-[#EFECE6]">
            <i class="ri-telegram-line text-[#0088cc] text-[20px] flex-shrink-0"></i>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <input type="checkbox" name="user[notification_channels][telegram][enabled]" value="1" <%= "checked" if tg["enabled"] %> class="accent-[#D97757]">
                <span class="text-[13px] font-medium text-[#1D1C1A]">Telegram</span>
              </div>
              <input type="text" name="user[notification_channels][telegram][chat_id]"
                     value="<%= tg["chat_id"] %>"
                     placeholder="Telegram chat ID (DM @hosalivio_bot to get yours)"
                     class="<%= input_cls %> mt-2 text-[12px]">
            </div>
          </div>

          <%# WhatsApp %>
          <% wa = nc["whatsapp"] || {} %>
          <div class="flex items-center gap-3 p-3 rounded-lg bg-[#FBF9F5] border border-[#EFECE6]">
            <i class="ri-whatsapp-line text-[#25D366] text-[20px] flex-shrink-0"></i>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <input type="checkbox" name="user[notification_channels][whatsapp][enabled]" value="1" <%= "checked" if wa["enabled"] %> class="accent-[#D97757]">
                <span class="text-[13px] font-medium text-[#1D1C1A]">WhatsApp</span>
              </div>
              <input type="tel" name="user[notification_channels][whatsapp][phone]"
                     value="<%= wa["phone"] %>"
                     placeholder="+1 555 123 4567"
                     class="<%= input_cls %> mt-2 text-[12px]">
            </div>
          </div>

          <%# SMS %>
          <% sms = nc["sms"] || {} %>
          <div class="flex items-center gap-3 p-3 rounded-lg bg-[#FBF9F5] border border-[#EFECE6]">
            <i class="ri-message-3-line text-[#1D1C1A] text-[20px] flex-shrink-0"></i>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <input type="checkbox" name="user[notification_channels][sms][enabled]" value="1" <%= "checked" if sms["enabled"] %> class="accent-[#D97757]">
                <span class="text-[13px] font-medium text-[#1D1C1A]">SMS</span>
              </div>
              <input type="tel" name="user[notification_channels][sms][phone]"
                     value="<%= sms["phone"] %>"
                     placeholder="+1 555 123 4567"
                     class="<%= input_cls %> mt-2 text-[12px]">
            </div>
          </div>

          <%# Email %>
          <% em = nc["email"] || {} %>
          <div class="flex items-center gap-3 p-3 rounded-lg bg-[#FBF9F5] border border-[#EFECE6]">
            <i class="ri-mail-line text-[#6B665F] text-[20px] flex-shrink-0"></i>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <input type="checkbox" name="user[notification_channels][email][enabled]" value="1" <%= "checked" if em["enabled"] %> class="accent-[#D97757]">
                <span class="text-[13px] font-medium text-[#1D1C1A]">Email <span class="text-[11px] text-[#6B665F] font-normal">to <%= u.email %></span></span>
              </div>
            </div>
          </div>
        </div>

        <%# Quiet hours %>
        <% qh = nc["quiet_hours"] || {} %>
        <div class="mt-5 pt-5 border-t border-[#EFECE6]">
          <h3 class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-2">Quiet hours</h3>
          <p class="text-[11px] text-[#6B665F] mb-3">Suppresses non-crisis pings during this window. Crisis-level messages always page through.</p>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="<%= label_cls %>">From</label>
              <input type="time" name="user[notification_channels][quiet_hours][start]" value="<%= qh["start"] %>" class="<%= input_cls %> font-mono">
            </div>
            <div>
              <label class="<%= label_cls %>">To</label>
              <input type="time" name="user[notification_channels][quiet_hours][end]" value="<%= qh["end"] %>" class="<%= input_cls %> font-mono">
            </div>
            <div>
              <label class="<%= label_cls %>">Timezone</label>
              <input type="text" name="user[notification_channels][quiet_hours][timezone]" value="<%= qh["timezone"].presence || u.timezone %>" class="<%= input_cls %> text-[12px]">
            </div>
          </div>
        </div>
      </section>

      <section class="rounded-2xl bg-white border border-[#EFECE6] p-5">
        <h2 class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-3">Password</h2>
        <div class="text-[12px] text-[#6B665F]">
          Password changes live in
          <%= link_to "Settings", edit_user_registration_path, class: "text-[#D97757] hover:underline" %>
          (Devise-managed for security).
        </div>
      </section>

      <div class="flex items-center justify-end">
        <%= f.submit "Save changes",
              class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
