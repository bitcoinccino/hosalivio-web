<% content_for :title, "My signature · HosAlivio" %>

<div class="min-h-screen bg-[#FBF9F5] px-6 py-8">
  <div class="max-w-2xl mx-auto">
    <a href="<%= edit_profile_path %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to profile
    </a>

    <div class="rounded-2xl bg-white border border-[#EFECE6] shadow-sm p-6"
         data-controller="signature-pad"
         data-signature-pad-url-value="<%= signature_profile_path %>">
      <h1 class="font-serif text-2xl text-[#1D1C1A] mb-1">My signature</h1>
      <p class="text-[12px] text-[#6B665F] mb-5 leading-relaxed">
        Draw your signature once. It'll be applied with a single
        checkbox on every chart sign-off (route to MD, eval
        certification, late-entry notes). Each application is
        audit-logged with timestamp + IP.
      </p>

      <% if @user.signature_registered? %>
        <div class="mb-5 rounded-xl border border-[#2F6F4E] bg-[#E6F0EE] p-4 flex items-start gap-3">
          <i class="ri-shield-check-line text-[#2F6F4E] text-lg mt-0.5"></i>
          <div class="flex-1 min-w-0">
            <div class="text-[11px] uppercase tracking-widest text-[#2F6F4E] font-bold">Signature on file</div>
            <div class="text-[12px] text-[#1D1C1A] mt-0.5">
              Registered <%= @user.signature_registered_at.strftime("%b %-d, %Y · %-l:%M %p") %>.
              Drawing a new one below replaces it.
            </div>
            <div class="mt-3 inline-block bg-white rounded-lg border border-[#EFECE6] p-2">
              <%= image_tag @user.signature, class: "h-28 max-w-[500px] object-contain", data: { signature_pad_target: "preview" } %>
            </div>
            <%= button_to signature_profile_path, method: :delete,
                  data: { turbo_confirm: "Remove your registered signature? Future sign-offs will need an inline draw." },
                  class: "mt-3 inline-flex items-center gap-1.5 text-[11px] px-3 py-1.5 rounded-full text-[#C1403A] hover:bg-[#FFF3EC] font-medium" do %>
              <i class="ri-delete-bin-line"></i> Remove signature
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-1">
        <%= @user.signature_registered? ? "Replace signature" : "Draw your signature" %>
      </div>
      <div class="rounded-xl border-2 border-dashed border-[#D9D5CD] bg-[#FBF9F5] overflow-hidden mb-3" style="touch-action: none;">
        <canvas data-signature-pad-target="canvas"
                class="w-full h-[180px] block bg-white"></canvas>
      </div>

      <div class="flex items-center justify-between gap-3 flex-wrap">
        <div class="text-[11px] text-[#6B665F]">
          Use a stylus or trackpad. We'll smooth the strokes for you.
        </div>
        <div class="flex items-center gap-2">
          <button type="button"
                  data-signature-pad-target="clearButton"
                  data-action="click->signature-pad#clear"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[12px] text-[#6B665F] hover:bg-[#FBF9F5] border border-[#D9D5CD]">
            <i class="ri-eraser-line"></i> Clear
          </button>
          <button type="button"
                  data-signature-pad-target="saveButton"
                  data-action="click->signature-pad#save"
                  class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-[12px] font-semibold text-white bg-[#2F6F4E] hover:bg-[#265a3d]">
            <i class="ri-save-line"></i> Save signature
          </button>
        </div>
      </div>

      <div data-signature-pad-target="status" class="text-[11px] mt-3 min-h-[16px] text-[#6B665F]"></div>
    </div>
  </div>
</div>
