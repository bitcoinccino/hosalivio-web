<% content_for :title, "Reset password · HosAlivio" %>

<div class="min-h-screen flex items-center justify-center px-4 bg-[#FBF9F5]">
  <div class="w-full max-w-md">
    <div class="flex items-center justify-center gap-2 mb-8">
      <div class="w-9 h-9 rounded-full bg-[#D97757] text-white flex items-center justify-center">
        <i class="ri-heart-pulse-line text-lg"></i>
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.2em] text-[#6B665F] font-bold">HosAlivio</div>
        <div class="text-[11px] text-[#6B665F] italic -mt-0.5">Comfort Care on the Go</div>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-[#EFECE6] p-8">
      <h2 class="font-serif text-2xl text-[#1D1C1A] mb-1">Reset your password</h2>
      <p class="text-sm text-[#6B665F] mb-6">Enter the email you signed up with. We'll send a reset link.</p>

      <% if flash[:alert].present? %>
        <div class="mb-4 px-3 py-2 rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[#C1403A] text-sm">
          <i class="ri-error-warning-line mr-1"></i><%= flash[:alert] %>
        </div>
      <% end %>
      <% if flash[:notice].present? %>
        <div class="mb-4 px-3 py-2 rounded-lg bg-[#F0F7F2] border border-[#2F6F4E] text-[#2F6F4E] text-sm">
          <i class="ri-check-line mr-1"></i><%= flash[:notice] %>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
                class: "w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[15px]" %>
        </div>

        <%= f.submit "Send reset instructions",
              class: "w-full px-4 py-2.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white font-medium transition cursor-pointer" %>
      <% end %>

      <% if Rails.env.development? %>
        <div class="mt-5 pt-4 border-t border-[#EFECE6] text-[11px] text-[#6B665F]">
          <i class="ri-information-line mr-1"></i>
          <strong>Dev tip:</strong> the reset email will pop in a new browser tab via letter_opener — no real SMTP needed.
        </div>
      <% end %>
    </div>

    <div class="mt-6 text-center space-y-2">
      <div class="text-sm text-[#6B665F]">
        <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-[#D97757] font-medium hover:underline" %>
      </div>
      <div class="text-xs text-[#6B665F]">
        <%= link_to "← Back to HosAlivio", root_path, class: "hover:text-[#1D1C1A]" %>
      </div>
    </div>
  </div>
</div>
