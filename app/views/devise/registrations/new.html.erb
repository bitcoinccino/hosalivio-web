<% content_for :title, "Create an account · HosAlivio" %>

<div class="min-h-screen flex items-center justify-center px-4 bg-[#FBF9F5] py-10">
  <div class="w-full max-w-md">
    <div class="flex items-center justify-center gap-2 mb-8">
      <div class="w-9 h-9 rounded-full bg-[#D97757] text-white flex items-center justify-center">
        <i class="ri-heart-pulse-line text-lg"></i>
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.2em] text-[#6B665F] font-bold">HosAlivio</div>
        <div class="text-[11px] text-[#6B665F] italic -mt-0.5">Comfort Care on the Go</div>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-[#EFECE6] p-8">
      <h2 class="font-serif text-2xl text-[#1D1C1A] mb-1">Create an account</h2>
      <p class="text-sm text-[#6B665F] mb-6">For families who've been invited into care.</p>

      <div class="mb-5 px-3 py-2.5 rounded-lg bg-[#FBF9F5] border border-[#EFECE6] text-[11px] text-[#6B665F]">
        <i class="ri-information-line mr-1"></i>
        In production, family accounts are invited by admissions and tied to a specific patient. This page exists for demo exploration — use <span class="font-mono text-[#1D1C1A]">family@hosalivio.test</span> / <span class="font-mono text-[#1D1C1A]">hello123</span> to sign in as Carlos (Maria's son).
      </div>

      <% if resource.errors.any? %>
        <div class="mb-4 px-3 py-2 rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[#C1403A] text-sm">
          <ul class="list-none space-y-0.5">
            <% resource.errors.full_messages.each do |msg| %>
              <li><i class="ri-error-warning-line mr-1"></i><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <div>
          <%= f.label :full_name, "Your full name", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
          <%= f.text_field :full_name, autofocus: true, required: true,
                class: "w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[15px]",
                placeholder: "e.g. Carlos Alvarez" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
          <%= f.email_field :email, autocomplete: "email", required: true,
                class: "w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[15px]" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
          <%= f.password_field :password, autocomplete: "new-password", required: true,
                class: "w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[15px]" %>
          <% if @minimum_password_length %>
            <div class="text-[11px] text-[#6B665F] mt-1"><%= @minimum_password_length %> characters minimum</div>
          <% end %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm password", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true,
                class: "w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[15px]" %>
        </div>

        <%= f.submit "Create account",
              class: "w-full px-4 py-2.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white font-medium transition cursor-pointer" %>
      <% end %>
    </div>

    <div class="mt-6 text-center space-y-2">
      <div class="text-sm text-[#6B665F]">
        Already have an account?
        <%= link_to "Sign in", new_session_path(resource_name), class: "text-[#D97757] font-medium hover:underline" %>
      </div>
      <div class="text-xs text-[#6B665F]">
        <%= link_to "← Back to HosAlivio", root_path, class: "hover:text-[#1D1C1A]" %>
      </div>
    </div>
  </div>
</div>
