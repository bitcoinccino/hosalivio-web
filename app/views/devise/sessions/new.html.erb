<% content_for :title, "Sign in · HosAlivio" %>

<div class="min-h-screen flex items-center justify-center px-4 bg-[#FBF9F5]">
  <div class="w-full max-w-md">
    <!-- Brand -->
    <div class="flex items-center justify-center gap-2 mb-8">
      <div class="w-9 h-9 rounded-full bg-[#D97757] text-white flex items-center justify-center">
        <i class="ri-heart-pulse-line text-lg"></i>
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.2em] text-[#6B665F] font-bold">HosAlivio</div>
        <div class="text-[11px] text-[#6B665F] italic -mt-0.5">Comfort Care on the Go</div>
      </div>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-[#EFECE6] p-8">
      <h2 class="font-serif text-2xl text-[#1D1C1A] mb-1">Welcome back</h2>
      <p class="text-sm text-[#6B665F] mb-6">Sign in to reach your care team.</p>

      <% if flash[:alert].present? %>
        <div class="mb-4 px-3 py-2 rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[#C1403A] text-sm">
          <i class="ri-error-warning-line mr-1"></i><%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                required: true,
                class: "w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[15px]" %>
        </div>

        <div>
          <div class="flex items-baseline justify-between mb-1">
            <%= f.label :password, class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium" %>
            <% if devise_mapping.recoverable? && controller_name != 'passwords' %>
              <%= link_to "Forgot?", new_password_path(resource_name), class: "text-[11px] text-[#D97757] hover:underline" %>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: "current-password",
                required: true,
                class: "w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[15px]" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <label class="flex items-center gap-2 text-sm text-[#3A3936] cursor-pointer">
            <%= f.check_box :remember_me, class: "rounded border-[#D9D5CD] text-[#D97757] focus:ring-[#D97757]" %>
            Remember me
          </label>
        <% end %>

        <%= f.submit "Sign in", class: "w-full px-4 py-2.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white font-medium transition cursor-pointer" %>
      <% end %>
    </div>

    <!-- Footer links -->
    <div class="mt-6 text-center space-y-2">
      <% if devise_mapping.registerable? && controller_name != 'registrations' %>
        <div class="text-sm text-[#6B665F]">
          New here?
          <%= link_to "Create an account", new_registration_path(resource_name), class: "text-[#D97757] font-medium hover:underline" %>
        </div>
      <% end %>
      <div class="text-xs text-[#6B665F]">
        <%= link_to "← Back to HosAlivio", root_path, class: "hover:text-[#1D1C1A]" %>
      </div>
    </div>
  </div>
</div>
