<% content_for :title, "#{@patient.full_name} · HosAlivio" %>

<div class="flex h-screen" data-controller="sidebar patient-chat-mobile" data-sidebar-storage-key-value="patientChatSidebar">
  <!-- ─── Left Rail: IDG Roster ─────────────────────────────────── -->
  <aside data-sidebar-target="sidebar" data-collapsed="false"
         data-patient-chat-mobile-target="tab" data-tab-name="team"
         class="group/sb hidden md:flex w-72 data-[collapsed=true]:w-16 bg-[#EFECE6] border-r border-[#D9D5CD] flex-col justify-between p-6 data-[collapsed=true]:p-3 transition-[width,padding] duration-200
                data-[mobile-active=true]:flex data-[mobile-active=true]:absolute data-[mobile-active=true]:inset-0 data-[mobile-active=true]:z-30 data-[mobile-active=true]:w-full">
    <div>
      <div class="flex items-center justify-between group-data-[collapsed=true]/sb:flex-col group-data-[collapsed=true]/sb:gap-2">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-full bg-[#D97757] text-white flex items-center justify-center flex-shrink-0">
            <i class="ri-heart-pulse-line text-sm"></i>
          </div>
          <h1 class="text-xs uppercase tracking-[0.2em] text-[#6B665F] font-bold group-data-[collapsed=true]/sb:hidden">HosAlivio</h1>
        </div>
        <button type="button" data-action="click->sidebar#toggle"
                title="Toggle sidebar"
                class="w-7 h-7 rounded-full hover:bg-[#D9D5CD] text-[#6B665F] hover:text-[#1D1C1A] flex items-center justify-center flex-shrink-0 transition">
          <i class="ri-side-bar-line text-[15px]"></i>
        </button>
      </div>

      <div class="mt-6 pb-5 border-b border-[#D9D5CD] group-data-[collapsed=true]/sb:hidden">
        <div class="text-[11px] uppercase tracking-widest text-[#6B665F]">Patient</div>
        <div class="mt-1 font-serif text-lg text-[#1D1C1A]"><%= @patient.full_name %></div>
        <div class="text-xs text-[#6B665F] mt-0.5 font-mono"><%= @patient.mrn %></div>
        <% if @patient.dnr? || @patient.dnr_dni? %>
          <div class="mt-2 inline-block text-[10px] font-bold px-2 py-0.5 rounded bg-[#C1403A] text-white tracking-wider">
            <%= @patient.code_status.to_s.upcase.tr("_", "/") %>
          </div>
        <% end %>
      </div>

      <div class="mt-6 pb-5 border-b border-[#D9D5CD] group-data-[collapsed=true]/sb:hidden">
        <div class="flex items-center justify-between mb-2">
          <div class="text-[11px] uppercase tracking-widest text-[#6B665F]">Family</div>
          <% if @can_invite_family %>
            <%= link_to new_patient_family_path(@patient),
                  class: "text-[11px] text-[#D97757] hover:underline inline-flex items-center gap-0.5" do %>
              <i class="ri-user-add-line text-[12px]"></i> Invite
            <% end %>
          <% end %>
        </div>
        <% if @family_users.empty? %>
          <div class="text-[11px] text-[#6B665F] italic">No family linked yet.</div>
        <% else %>
          <div class="space-y-2">
            <% @family_users.each do |fu| %>
              <div class="flex items-center gap-2 <%= 'opacity-50' unless fu.active %>">
                <div class="w-7 h-7 rounded-full bg-[#D97757] text-white text-[10px] font-bold flex items-center justify-center flex-shrink-0">
                  <%= fu.full_name.to_s.split.map(&:first).first(2).join.upcase %>
                </div>
                <div class="min-w-0 flex-1">
                  <div class="text-[12px] text-[#1D1C1A] truncate"><%= fu.full_name %></div>
                  <div class="text-[10px] text-[#6B665F] truncate">
                    <%= fu.relationship.presence ? "#{fu.relationship.capitalize} of #{@patient.first_name}" : "Family member" %>
                  </div>
                </div>
                <% if @can_invite_family && fu.active %>
                  <%= button_to patient_family_path(@patient, fu), method: :delete,
                        form: { class: "inline" },
                        data: { turbo_confirm: "Revoke family access for #{fu.full_name}?" },
                        class: "text-[10px] text-[#C1403A] hover:bg-[#FFF3EC] rounded-full w-6 h-6 flex items-center justify-center",
                        title: "Revoke access" do %>
                    <i class="ri-close-line"></i>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <nav class="mt-6 space-y-3">
        <div class="text-[11px] uppercase tracking-widest text-[#6B665F] mb-2 group-data-[collapsed=true]/sb:hidden">IDG Team</div>
        <% @idg_roster.each do |row| %>
          <%
            # Presence dot: green = on call now, grey = assigned but off,
            # no dot = slot unassigned. Don't show a dot at all when there's
            # no clinician to be 'present'.
            user_first = row[:user]&.full_name.to_s.split.first
            dot_title  = row[:user].nil? ? "Unassigned"
                       : (row[:present]  ? "#{user_first} is on call now"
                                         : "#{user_first} — assigned, not on call right now")
          %>
          <div class="flex items-center gap-3 text-sm group-data-[collapsed=true]/sb:justify-center" title="<%= row[:name] %> (<%= row[:role].tr("_", " ") %>)">
            <span class="relative flex items-center justify-center w-7 h-7 rounded-full bg-white border border-[#D9D5CD] text-[#6B665F] flex-shrink-0">
              <i class="<%=
                {
                  'rn'            => 'ri-nurse-line',
                  'md'            => 'ri-stethoscope-line',
                  'social_worker' => 'ri-team-line',
                  'chaplain'      => 'ri-hand-heart-line'
                }.fetch(row[:role], 'ri-user-line') %> text-sm"></i>
              <% if row[:user] %>
                <span title="<%= dot_title %>"
                      class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 rounded-full border border-[#EFECE6] <%= row[:present] ? 'bg-emerald-500' : 'bg-[#B9B4AB]' %>"></span>
              <% end %>
            </span>
            <div class="group-data-[collapsed=true]/sb:hidden">
              <div class="text-[13px] text-[#1D1C1A] leading-tight"><%= row[:name] %></div>
              <div class="text-[11px] text-[#6B665F] uppercase tracking-wider"><%= row[:role].tr("_", " ") %></div>
            </div>
          </div>
        <% end %>
      </nav>
    </div>

    <div>
      <%= render "shared/user_menu", direction: :up %>
    </div>
  </aside>

  <!-- ─── Main Stage ────────────────────────────────────────────── -->
  <%
    lang_map = {
      "en" => "en-US", "es" => "es-US", "ht" => "ht-HT",
      "pt" => "pt-BR", "zh" => "zh-CN", "fr" => "fr-FR"
    }
    spoken_lang = lang_map[@patient.preferred_language.to_s.downcase] || "en-US"
  %>
  <main class="flex-1 flex flex-col min-w-0 pb-14 md:pb-0"
        data-controller="patient-chat"
        data-patient-chat-patient-id-value="<%= @patient.id %>"
        data-patient-chat-lang-value="<%= spoken_lang %>"
        data-patient-chat-timezone-value="<%= patient_timezone(@patient) %>"
        data-patient-chat-mobile-target="tab" data-tab-name="chat">
    <!-- Patient Banner -->
    <header class="px-6 py-4 border-b border-[#EFECE6] bg-white">
      <div class="flex items-center gap-4">
        <!-- Avatar -->
        <div class="w-12 h-12 rounded-full bg-[#EFECE6] text-[#1D1C1A] font-serif text-lg flex items-center justify-center flex-shrink-0">
          <%= @patient.full_name.to_s.split.map(&:first).first(2).join.upcase %>
        </div>

        <!-- Identity block -->
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap">
            <h2 class="font-serif text-xl text-[#1D1C1A] truncate"><%= @patient.full_name %></h2>
            <% if @patient.dnr? || @patient.dnr_dni? %>
              <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-[#C1403A] text-white tracking-wider">
                <%= @patient.code_status.to_s.upcase.tr("_", "/") %>
              </span>
            <% else %>
              <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-[#EFECE6] text-[#1D1C1A] tracking-wider uppercase">
                <%= @patient.code_status.to_s.tr("_", " ") %>
              </span>
            <% end %>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-[#EFECE6] text-[#1D1C1A] tracking-wider uppercase">
              <%= @patient.status %>
            </span>
            <% fam = current_user.family_access? %>
            <%
              ad_tip = if fam
                "Advance Directive: a legal document where #{@patient.first_name} wrote down the kind of care she wants — or doesn't want — if she cannot speak for herself. It's her wishes."
              else
                "Advance Directive on file"
              end
              polst_tip = if fam
                "POLST — Physician Orders for Life-Sustaining Treatment. A doctor's signed order that turns #{@patient.first_name}'s wishes into followable instructions for paramedics and nurses, like 'do not resuscitate.'"
              else
                "POLST on file"
              end
            %>
            <% if @patient.advance_directive_on_file %>
              <span class="text-[10px] text-[#2F6F4E] inline-flex items-center gap-0.5 <%= 'cursor-help underline decoration-dotted decoration-[#2F6F4E] underline-offset-2' if fam %>"
                    tabindex="<%= fam ? 0 : -1 %>"
                    <% if fam %>
                      data-controller="tooltip"
                      data-tooltip-content-value="<%= ad_tip %>"
                      data-action="mouseenter->tooltip#show mouseleave->tooltip#hide focus->tooltip#show blur->tooltip#hide click->tooltip#toggle"
                    <% else %>
                      title="<%= ad_tip %>"
                    <% end %>>
                <i class="ri-file-shield-line"></i> AD
              </span>
            <% end %>
            <% if @patient.polst_on_file %>
              <span class="text-[10px] text-[#2F6F4E] inline-flex items-center gap-0.5 <%= 'cursor-help underline decoration-dotted decoration-[#2F6F4E] underline-offset-2' if fam %>"
                    tabindex="<%= fam ? 0 : -1 %>"
                    <% if fam %>
                      data-controller="tooltip"
                      data-tooltip-content-value="<%= polst_tip %>"
                      data-action="mouseenter->tooltip#show mouseleave->tooltip#hide focus->tooltip#show blur->tooltip#hide click->tooltip#toggle"
                    <% else %>
                      title="<%= polst_tip %>"
                    <% end %>>
                <i class="ri-file-shield-2-line"></i> POLST
              </span>
            <% end %>
          </div>
          <div class="text-[12px] text-[#6B665F] mt-0.5 flex items-center gap-1.5 flex-wrap">
            <span><%= @patient.age_years %>yo</span>
            <span>·</span>
            <span><%= @patient.gender %></span>
            <% if @patient.primary_diagnosis.present? %>
              <span>·</span>
              <span class="text-[#1D1C1A]"><%= explain_icd(@patient.primary_diagnosis) %></span>
            <% end %>
            <span class="font-mono text-[10px]">· <%= @patient.mrn %></span>
          </div>
        </div>

        <!-- Right-side stat chips (hidden on small screens; essential info is in banner text) -->
        <div class="hidden lg:flex items-center gap-2 flex-shrink-0">
          <% if @unresolved_crisis.to_i > 0 %>
            <div class="px-3 py-1.5 rounded-xl bg-[#FFF3EC] border border-[#D97757] text-center">
              <div class="text-[9px] uppercase tracking-widest text-[#C1403A] font-bold">Crisis</div>
              <div class="text-lg font-serif text-[#C1403A] leading-none mt-0.5"><%= @unresolved_crisis %></div>
            </div>
          <% end %>
          <div class="px-3 py-1.5 rounded-xl bg-[#FBF9F5] text-center">
            <div class="text-[9px] uppercase tracking-widest text-[#6B665F]">Days in hospice</div>
            <div class="text-lg font-serif text-[#1D1C1A] leading-none mt-0.5"><%= @days_in_hospice || "—" %></div>
          </div>
          <% if @patient.benefit_period.present? %>
            <% bp_family = current_user.family_access? %>
            <div class="px-3 py-1.5 rounded-xl bg-[#FBF9F5] text-center <%= 'cursor-help' if bp_family %>"
                 <% if bp_family %>
                   tabindex="0"
                   data-controller="tooltip"
                   data-tooltip-content-value="<%= benefit_period_explanation(@patient.benefit_period, @patient.first_name) %>"
                   data-action="mouseenter->tooltip#show mouseleave->tooltip#hide focus->tooltip#show blur->tooltip#hide click->tooltip#toggle"
                 <% end %>>
              <div class="text-[9px] uppercase tracking-widest text-[#6B665F] <%= 'underline decoration-dotted decoration-[#6B665F] underline-offset-2' if bp_family %>">
                <%= benefit_period_label(@patient.benefit_period) %>
              </div>
              <div class="text-[11px] font-mono mt-0.5 <%= @days_to_recert && @days_to_recert <= 7 ? 'text-[#C1403A]' : 'text-[#1D1C1A]' %>">
                <%= @days_to_recert ? "#{@days_to_recert}d recert" : "—" %>
              </div>
            </div>
          <% end %>
          <% if @headline_order %>
            <% s = @order_schedules[@headline_order] %>
            <div class="px-3 py-1.5 rounded-xl border <%= s[:status] == :overdue ? 'bg-[#FFF3EC] border-[#D97757]' : 'bg-[#FBF9F5] border-[#EFECE6]' %>">
              <div class="text-[9px] uppercase tracking-widest <%= s[:status] == :overdue ? 'text-[#C1403A] font-bold' : 'text-[#6B665F]' %>">Next comfort med</div>
              <div class="text-[11px] font-mono text-[#1D1C1A] leading-tight mt-0.5 truncate max-w-[200px]">
                <%= @headline_order.drug_name %> <%= @headline_order.dose %>
              </div>
              <div class="text-[10px] <%= {overdue: 'text-[#C1403A] font-bold', available: 'text-[#D97757]', upcoming: 'text-[#2F6F4E]', unknown: 'text-[#6B665F]'}[s[:status]] %>">
                <%= s[:label] %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Status line -->
      <div class="mt-2 text-[11px] text-[#6B665F] flex items-center gap-1.5">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span>Family ↔ Care Team · <span data-patient-chat-target="status">connecting…</span></span>
      </div>
    </header>

    <!-- Pinned crisis strip -->
    <%
      pinned = @notes.select { |n| n.urgency_crisis? && n.read_at.nil? && n.author_role == "family" }.last(2)
    %>
    <% if pinned.any? %>
      <div class="px-6 pt-4">
        <div class="rounded-2xl border-2 border-[#C1403A] bg-[#FFF3EC] overflow-hidden">
          <div class="bg-[#C1403A] text-white px-4 py-2 flex items-center gap-2">
            <i class="ri-pushpin-fill"></i>
            <span class="font-bold tracking-wider text-[12px]">PINNED · OPEN CRISIS<%= "ES" if pinned.size > 1 %></span>
            <span class="ml-auto text-[10px] opacity-80">Stays at the top until the care team responds.</span>
          </div>
          <div class="divide-y divide-[#EFECE6]">
            <% pinned.each do |pn| %>
              <div class="px-4 py-3 flex items-start gap-3">
                <i class="ri-alarm-warning-fill text-[#C1403A] mt-0.5"></i>
                <div class="flex-1 min-w-0">
                  <div class="text-[13px] text-[#1D1C1A] break-words"><%= pn.body %></div>
                  <div class="text-[10px] text-[#6B665F] font-mono mt-0.5">
                    <%= in_patient_zone(pn.created_at, @patient, "%a %b %-d · %-l:%M %p") %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Message Feed -->
    <div class="flex-1 overflow-y-auto px-6 py-6 space-y-5"
         data-patient-chat-target="feed"
         data-last-date="<%= @notes.last&.created_at&.in_time_zone(patient_timezone(@patient))&.to_date&.iso8601 %>">
      <% if @notes.empty? %>
        <div class="text-center text-sm text-[#6B665F] py-20">
          No messages yet. Tap <i class="ri-add-line text-[#D97757]"></i> or <i class="ri-mic-line text-[#D97757]"></i> to start.
        </div>
      <% else %>
        <% last_date = nil %>
        <% @notes.each do |note| %>
          <% note_date = note.created_at.to_date %>
          <%
            # Anchor the day-boundary to the patient's branch timezone so a
            # midnight-Eastern message doesn't get a "Yesterday" pill for a
            # clinician viewing in Pacific.
            note_local_date = note.created_at.in_time_zone(patient_timezone(@patient)).to_date
          %>
          <% if note_local_date != last_date %>
            <div class="flex items-center justify-center pt-2 pb-1">
              <div class="px-3 py-1 text-[10px] uppercase tracking-[0.18em] text-[#6B665F] bg-[#FBF9F5] border border-[#EFECE6] rounded-full font-medium">
                <%= relative_date_label(note_local_date) %>
              </div>
            </div>
            <% last_date = note_local_date %>
          <% end %>
          <%= render "message_bubble", note: note %>
        <% end %>
      <% end %>
    </div>

    <!-- Input Bar -->
    <div class="px-6 pb-6 pt-3 bg-[#FBF9F5]">
      <% if current_user.family_access? %>
        <!-- Family-only quick-reply chips: phrasing assumes a family voice
             ("She's resting", "Need comfort kit refill"), so clinicians
             never see them. -->
        <div class="mb-2 flex gap-1.5 flex-wrap">
          <button type="button" data-action="click->patient-chat#quickAction" data-urgency="crisis"
                  data-template="Pain is out of control. She's hurting badly.">
            <span class="inline-flex items-center gap-1 text-[11px] px-3 py-1 rounded-full bg-[#FFF3EC] border border-[#D97757] text-[#C1403A] hover:bg-[#FFEDE2] transition">
              <i class="ri-alarm-warning-line"></i> Pain still bad
            </span>
          </button>
          <button type="button" data-action="click->patient-chat#quickAction" data-urgency="normal"
                  data-template="She's resting now, breathing is calm.">
            <span class="inline-flex items-center gap-1 text-[11px] px-3 py-1 rounded-full bg-white border border-[#EFECE6] text-[#1D1C1A] hover:bg-[#EFECE6] transition">
              <i class="ri-moon-line"></i> She's resting now
            </span>
          </button>
          <button type="button" data-action="click->patient-chat#quickAction" data-urgency="urgent"
                  data-template="Please call me as soon as you can.">
            <span class="inline-flex items-center gap-1 text-[11px] px-3 py-1 rounded-full bg-white border border-[#EFECE6] text-[#1D1C1A] hover:bg-[#EFECE6] transition">
              <i class="ri-phone-line"></i> Call me
            </span>
          </button>
          <button type="button" data-action="click->patient-chat#quickAction" data-urgency="urgent"
                  data-template="We're running low on comfort kit supplies — please send a refill.">
            <span class="inline-flex items-center gap-1 text-[11px] px-3 py-1 rounded-full bg-white border border-[#EFECE6] text-[#1D1C1A] hover:bg-[#EFECE6] transition">
              <i class="ri-medicine-bottle-line"></i> Need comfort kit refill
            </span>
          </button>
        </div>

        <!-- Expandable full quick-action bar (urgency-flagged templates) -->
        <div class="mb-2 hidden" data-patient-chat-target="quickActions">
          <div class="flex gap-2 flex-wrap">
            <button type="button" data-action="click->patient-chat#quickAction" data-urgency="normal"
                    data-template="Requesting chaplain / spiritual support.">
              <span class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full bg-[#EFECE6] text-[#1D1C1A] hover:bg-[#D9D5CD] transition">
                <i class="ri-hand-heart-line"></i> Spiritual support
              </span>
            </button>
            <button type="button" data-action="click->patient-chat#quickAction" data-urgency="normal"
                    data-template="Quick status check — how is everything going?">
              <span class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full bg-[#EFECE6] text-[#1D1C1A] hover:bg-[#D9D5CD] transition">
                <i class="ri-chat-3-line"></i> Status check
              </span>
            </button>
          </div>
        </div>
      <% end %>

      <% unless current_user.family_access? %>
        <%# Audience toggle: clinician chooses family-facing or team-only.
            State lives on the Stimulus controller; styling flips when armed. %>
        <div class="mb-2 flex items-center justify-end gap-2 text-[11px]">
          <span class="text-[#6B665F]">Visibility</span>
          <button type="button"
                  data-action="click->patient-chat#toggleAudience"
                  data-patient-chat-target="audienceToggle"
                  data-audience="family"
                  class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border transition
                         data-[audience=family]:bg-[#FFF3EC] data-[audience=family]:border-[#D97757] data-[audience=family]:text-[#C1403A]
                         data-[audience=team]:bg-[#FBF9F5] data-[audience=team]:border-[#B9B4AB] data-[audience=team]:text-[#3A3936]"
                  title="Click to change who can see this message">
            <i class="ri-user-heart-line data-[audience=team]:hidden"></i>
            <i class="ri-team-line hidden data-[audience=team]:inline"></i>
            <span class="data-[audience=team]:hidden">Visible to family &amp; team</span>
            <span class="hidden data-[audience=team]:inline">Internal team only</span>
          </button>
        </div>
      <% end %>

      <%# Composer wrapper — Stimulus flips data-recording between 'false'
          and 'true'; the form is hidden and the 'Living Wave' recording
          bar takes its place while audio capture is active. %>
      <div data-patient-chat-target="composer" data-recording="false" class="group/composer">

      <form data-action="submit->patient-chat#send"
            data-patient-chat-target="form"
            data-audience="family"
            class="group/audience flex items-center gap-3 bg-white rounded-3xl pl-3 pr-2 py-2 border border-[#EFECE6] shadow-sm
                   group-data-[recording=true]/composer:hidden
                   data-[audience=team]:bg-[#FBF9F5] data-[audience=team]:border-[#B9B4AB] data-[audience=team]:border-dashed">
        <% if current_user.family_access? %>
          <%# Quick-actions toggle is family-only — opens the templates
              panel above. Clinicians get the visibility toggle instead. %>
          <button type="button" data-action="click->patient-chat#toggleQuickActions"
                  title="Quick actions"
                  class="w-9 h-9 rounded-full bg-[#FBF9F5] hover:bg-[#EFECE6] text-[#D97757] text-lg flex items-center justify-center transition">
            <i class="ri-add-line"></i>
          </button>
        <% end %>

        <%# Styled-placeholder pattern: invisible native placeholder + an
            absolutely-positioned overlay so we can bold the patient's first
            name in orange. Visibility is driven by Stimulus on input events,
            since peer-placeholder-shown isn't reliably scanned by Tailwind v4. %>
        <div class="relative flex-1">
          <input type="text" name="text" data-patient-chat-target="input"
                 autocomplete="off"
                 placeholder=" "
                 data-action="input->patient-chat#refreshPlaceholderOverlay"
                 class="w-full bg-transparent border-0 focus:outline-none text-[15px] placeholder-transparent py-2">
          <div data-patient-chat-target="placeholderOverlay"
               class="pointer-events-none absolute inset-0 flex items-center text-[15px] text-[#6B665F]">
            <%# Family-mode overlay — patient salutation in bold orange. %>
            <span class="group-data-[audience=team]/audience:hidden">
              <span>How is&nbsp;</span>
              <span class="font-bold text-[#D97757]"><%= patient_salutation(@patient) %></span>
              <span>&nbsp;doing?</span>
            </span>
            <%# Team-mode overlay — quiet, indicates the message is private. %>
            <span class="hidden group-data-[audience=team]/audience:inline italic">
              Note to the care team — family won't see this…
            </span>
          </div>
        </div>

        <button type="button" data-patient-chat-target="mic" data-action="click->patient-chat#toggleMic"
                disabled
                title="Tap to dictate (text)"
                class="w-9 h-9 rounded-full text-[#B9B4AB] text-lg flex items-center justify-center cursor-not-allowed transition">
          <i class="ri-mic-line"></i>
        </button>

        <%# Voice-note record button — captures actual audio (MediaRecorder),
            attaches to the Note, plays back inline in the bubble. Distinct
            from the mic above (which only transcribes to text). %>
        <button type="button"
                data-action="click->patient-chat#toggleRecord"
                data-patient-chat-target="recordButton"
                data-state="idle"
                title="Tap to record a voice note (audio)"
                class="w-9 h-9 rounded-full bg-[#FBF9F5] hover:bg-[#FFEDE2] text-[#C1403A] text-lg flex items-center justify-center transition">
          <i class="ri-voiceprint-line"></i>
        </button>
        <button type="submit"
                title="Send"
                class="inline-flex items-center gap-1.5 px-4 h-9 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium transition">
          <i class="ri-send-plane-fill"></i>
          <span>Send</span>
        </button>
      </form>

      <%# 'Living Wave' recording UI — replaces the input row while
          MediaRecorder is active. Cancel (trash) discards; Send (plane)
          stops + sends. Bars animate via CSS keyframes with staggered
          delays to mimic voice frequency without real audio analysis. %>
      <div class="hidden group-data-[recording=true]/composer:flex items-center gap-3 bg-white rounded-3xl pl-3 pr-2 py-2 border border-[#D97757] shadow-sm transition-all">
        <button type="button"
                data-action="click->patient-chat#cancelRecord"
                title="Cancel recording"
                class="w-9 h-9 rounded-full hover:bg-[#FFF3EC] text-[#6B665F] hover:text-[#C1403A] flex items-center justify-center transition">
          <i class="ri-delete-bin-line text-lg"></i>
        </button>

        <div class="flex items-center gap-[3px] h-8 flex-1 justify-center">
          <span class="w-1 bg-[#D97757] rounded-full h-3 animate-voice-wave" style="animation-delay:0s"></span>
          <span class="w-1 bg-[#D97757] rounded-full h-5 animate-voice-wave" style="animation-delay:-0.15s"></span>
          <span class="w-1 bg-[#D97757] rounded-full h-8 animate-voice-wave" style="animation-delay:-0.3s"></span>
          <span class="w-1 bg-[#D97757] rounded-full h-4 animate-voice-wave" style="animation-delay:-0.45s"></span>
          <span class="w-1 bg-[#D97757] rounded-full h-6 animate-voice-wave" style="animation-delay:-0.6s"></span>
          <span class="w-1 bg-[#D97757] rounded-full h-3 animate-voice-wave" style="animation-delay:-0.75s"></span>
          <span class="w-1 bg-[#D97757] rounded-full h-5 animate-voice-wave" style="animation-delay:-0.9s"></span>
          <span class="w-1 bg-[#D97757] rounded-full h-7 animate-voice-wave" style="animation-delay:-1.05s"></span>
        </div>

        <span data-patient-chat-target="recordTimer" class="font-mono text-[13px] text-[#D97757] font-bold tracking-wider min-w-[45px] text-right">0:00</span>

        <button type="button"
                data-action="click->patient-chat#toggleRecord"
                title="Stop recording &amp; send"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white shadow-sm active:scale-95 transition">
          <i class="ri-send-plane-fill text-[16px]"></i>
        </button>
      </div>

      </div>

      <div class="mt-2 text-[11px] text-[#6B665F] text-center">
        Messages go through HosAlivio. We triage and loop in your nurse or doctor instantly.
      </div>
    </div>
  </main>

  <!-- ─── Right Rail: At-a-Glance Accordion ─────────────────────── -->
  <aside data-patient-chat-mobile-target="tab" data-tab-name="details"
         class="hidden md:flex w-80 bg-white border-l border-[#EFECE6] flex-col overflow-hidden
                data-[mobile-active=true]:flex data-[mobile-active=true]:absolute data-[mobile-active=true]:inset-0 data-[mobile-active=true]:z-30 data-[mobile-active=true]:w-full">
    <div class="flex-1 overflow-y-auto divide-y divide-[#EFECE6]">
      <!-- Active Comfort Meds — open by default, priority section -->
      <details class="group" open>
        <%= acc_header("ri-capsule-line", "Active Comfort Meds", @active_orders.size.to_s) %>
        <div class="px-5 pb-4 pt-3">
          <% if @active_orders.empty? %>
            <div class="text-xs text-[#6B665F] italic">None</div>
          <% else %>
            <% headline_due = @headline_order && @order_schedules[@headline_order][:next_due_at] %>
            <div class="mb-3 rounded-lg bg-[#FBF9F5] p-2">
              <div class="text-[9px] uppercase tracking-widest text-[#6B665F] mb-1">Last <%= @timeline_window_hours %>h</div>
              <%= med_timeline_ribbon(logs: @timeline_logs, window_hours: @timeline_window_hours, headline_next_due: headline_due) %>
            </div>

            <ul class="space-y-2">
              <% @active_orders.each do |o| %>
                <% s = @order_schedules[o] %>
                <li class="text-[13px]">
                  <div class="flex items-baseline justify-between gap-2">
                    <div class="font-medium text-[#1D1C1A] truncate"><%= o.drug_name %> <%= o.dose %></div>
                    <span class="text-[10px] font-medium
                                 <%= {overdue: 'text-[#C1403A]', available: 'text-[#D97757]', upcoming: 'text-[#2F6F4E]', unknown: 'text-[#6B665F]'}[s[:status]] %>">
                      <%= s[:label] %>
                    </span>
                  </div>
                  <div class="text-[11px] text-[#6B665F] font-mono">
                    <%= o.route.upcase %> · <%= o.frequency %><%= " · PRN" if o.prn %>
                  </div>
                  <% if o.prn_indication.present? %>
                    <div class="text-[11px] text-[#6B665F] italic">for <%= o.prn_indication %></div>
                  <% end %>
                </li>
              <% end %>
            </ul>

            <% unless current_user.family_access? %>
              <button type="button"
                      class="mt-3 w-full text-[11px] px-3 py-1.5 rounded-full border border-dashed border-[#D9D5CD] text-[#6B665F] hover:bg-[#FBF9F5] hover:text-[#1D1C1A]">
                <i class="ri-add-line"></i> Add PRN
              </button>
            <% end %>
          <% end %>
        </div>
      </details>

      <% if @pre_admit_eval %>
        <% fam = current_user.family_access? %>
        <details class="group" <%= 'open' if @pre_admit_eval.status_final? || @pre_admit_eval.noe_overdue? %>>
          <%= acc_header("ri-file-shield-2-line", "Admission", @pre_admit_eval.status.to_s.tr("_", " ").upcase) %>
          <div class="px-5 pb-4 pt-2">
            <%
              status_color = case @pre_admit_eval.status.to_s
                             when "draft"      then "#6B665F"
                             when "final"      then "#2B4A7A"
                             when "certified"  then "#2F6F4E"
                             when "noe_filed"  then "#2F6F4E"
                             when "revoked"    then "#C1403A"
                             else                   "#6B665F"
                             end
            %>
            <div class="flex items-center gap-2 text-[12px] mb-2">
              <span class="w-2 h-2 rounded-full" style="background: <%= status_color %>;"></span>
              <span class="text-[#1D1C1A] font-medium"><%= @pre_admit_eval.status.to_s.tr("_", " ").capitalize %></span>
              <span class="text-[10px] text-[#6B665F] ml-auto font-mono"><%= @pre_admit_eval.evaluated_at&.strftime("%b %-d") %></span>
            </div>

            <div class="text-[11px] text-[#6B665F] space-y-1">
              <% if @pre_admit_eval.primary_icd10.present? %>
                <div>Diagnosis: <span class="font-mono text-[#1D1C1A]"><%= @pre_admit_eval.primary_icd10 %></span> <%= @pre_admit_eval.primary_icd10_description %></div>
              <% end %>
              <% if @pre_admit_eval.evaluator_name.present? %>
                <div>By: <%= @pre_admit_eval.evaluator_name %></div>
              <% end %>

              <% unless fam %>
                <% if @pre_admit_eval.noe_overdue? %>
                  <div class="mt-2 text-[11px] text-[#C1403A] font-bold">
                    <i class="ri-alarm-warning-fill"></i> NOE OVERDUE — file immediately
                  </div>
                <% elsif @pre_admit_eval.status_certified? && @pre_admit_eval.noe_deadline_at %>
                  <div class="mt-2 text-[11px] text-[#D97757]">
                    NOE due in <%= @pre_admit_eval.days_until_noe_deadline %>d
                    (<%= @pre_admit_eval.noe_deadline_at.strftime("%b %-d") %>)
                  </div>
                <% elsif @pre_admit_eval.status_final? %>
                  <div class="mt-2 text-[11px] text-[#2B4A7A]">Awaiting MD certification</div>
                <% elsif @pre_admit_eval.status_noe_filed? %>
                  <div class="mt-2 text-[11px] text-[#2F6F4E]"><i class="ri-check-line"></i> NOE filed <%= @pre_admit_eval.noe_filed_at&.strftime("%b %-d") %></div>
                <% end %>

                <% blockers = @pre_admit_eval.certification_blockers %>
                <% if blockers.any? %>
                  <div class="mt-2 text-[10px] text-[#C1403A]">Needs: <%= blockers.first(2).join("; ") %></div>
                <% end %>
              <% end %>
            </div>

            <% if fam && @pre_admit_eval.status_noe_filed? %>
              <div class="mt-2 text-[11px] text-[#2F6F4E]">
                <i class="ri-shield-check-line"></i> <%= @patient.first_name %> is officially on the hospice benefit. Medicare covers her care.
              </div>
            <% end %>
          </div>
        </details>
      <% end %>

      <!-- Care Snapshot (days / recert / BP / crises) — open by default -->
      <details class="group" open>
        <%= acc_header("ri-dashboard-3-line", "Care Snapshot") %>
        <div class="px-5 pb-4">
          <div class="grid grid-cols-2 gap-2">
            <div class="rounded-lg bg-[#FBF9F5] p-3">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Days in hospice</div>
              <div class="text-xl font-serif text-[#1D1C1A]"><%= @days_in_hospice || "—" %></div>
            </div>
            <div class="rounded-lg bg-[#FBF9F5] p-3">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Days to recert</div>
              <div class="text-xl font-serif <%= @days_to_recert && @days_to_recert <= 7 ? 'text-[#C1403A]' : 'text-[#1D1C1A]' %>">
                <%= @days_to_recert || "—" %>
              </div>
            </div>
            <%
              bp_fam_rail = current_user.family_access? && @patient.benefit_period.present?
              bp_rail_tooltip = bp_fam_rail ? benefit_period_explanation(@patient.benefit_period, @patient.first_name) : nil
            %>
            <div class="rounded-lg bg-[#FBF9F5] p-3 <%= 'cursor-help' if bp_fam_rail %>"
                 <% if bp_fam_rail %>
                   tabindex="0"
                   data-controller="tooltip"
                   data-tooltip-content-value="<%= bp_rail_tooltip %>"
                   data-action="mouseenter->tooltip#show mouseleave->tooltip#hide focus->tooltip#show blur->tooltip#hide click->tooltip#toggle"
                 <% end %>>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] <%= 'underline decoration-dotted decoration-[#6B665F] underline-offset-2' if bp_fam_rail %>">Benefit period</div>
              <div class="text-sm font-medium text-[#1D1C1A] mt-0.5"><%= benefit_period_label(@patient.benefit_period) %></div>
            </div>
            <div class="rounded-lg <%= @unresolved_crisis > 0 ? 'bg-[#FFF3EC] border border-[#D97757]' : 'bg-[#FBF9F5]' %> p-3">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Open crises</div>
              <div class="text-xl font-serif <%= @unresolved_crisis > 0 ? 'text-[#C1403A]' : 'text-[#1D1C1A]' %>">
                <%= @unresolved_crisis %>
              </div>
            </div>
          </div>

          <% next_rn_visit = @recent_visits.find { |v| v.discipline == "rn" && v.scheduled_at && v.scheduled_at > Time.current } %>
          <% if next_rn_visit %>
            <div class="mt-3 rounded-lg bg-[#E6F0EE] p-3 flex items-start gap-2">
              <i class="ri-calendar-check-line text-[#2F6F4E] mt-0.5"></i>
              <div class="text-[12px]">
                <div class="text-[10px] uppercase tracking-widest text-[#2F6F4E] font-bold">Next RN visit</div>
                <div class="text-[#1D1C1A]"><%= next_rn_visit.scheduled_at.strftime("%a %b %-d · %-l:%M %p") %></div>
                <% if next_rn_visit.user %>
                  <div class="text-[11px] text-[#6B665F]">with <%= next_rn_visit.user.full_name %></div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </details>

      <%# Quick Actions trimmed to two real items: Schedule visit (the
          calendar UI shows conflicts; chat can't), and Sign off (MD
          only, attestation that the agents legally cannot do for you).
          Everything else — refills, pages, chaplain requests — runs
          through the team-huddle chat: clinician types in plain
          English, HosAlivio dispatches the matching agent. %>
      <% unless current_user.family_access? %>
        <% viewer_roles = current_user.role_names %>
        <% pending_signoff = viewer_roles.include?("md") && @pre_admit_eval&.status_final? %>
        <details class="group" open>
          <%= acc_header("ri-flashlight-line", "Quick Actions") %>
          <div class="px-5 pb-4 space-y-2">
            <a href="<%= new_visit_path %>"
               class="flex items-center gap-2 w-full px-3 py-2 rounded-lg bg-[#FBF9F5] hover:bg-[#EFECE6] text-[13px] text-[#1D1C1A] transition">
              <i class="ri-calendar-line text-[#D97757]"></i> Schedule visit
            </a>

            <% if pending_signoff %>
              <%= link_to pre_admit_eval_path(@pre_admit_eval),
                    class: "flex items-center gap-2 w-full px-3 py-2 rounded-lg bg-[#E6F0EE] border border-[#2F6F4E] hover:bg-[#d6e8e2] text-[13px] text-[#1D1C1A] transition" do %>
                <i class="ri-quill-pen-line text-[#2F6F4E]"></i> Sign off pending pre-admit cert
              <% end %>
            <% end %>

            <p class="text-[11px] text-[#6B665F] leading-snug pt-1">
              For refills, chaplain pages, supply orders, anything routine: just type it in the team chat. HosAlivio dispatches the right agent.
            </p>
          </div>
        </details>
      <% end %>

      <!-- Latest vitals + trend sparklines -->
      <details class="group">
        <%= acc_header("ri-pulse-line", "Vitals", "n=#{@vitals_visits.size}") %>
        <div class="px-5 pb-4">
          <% if @latest_vitals_visit && (v = @latest_vitals_visit.vitals).present? %>
          <%
            rows = [
              { label: "TEMP",  current: v["temp"],  series: @vitals_series[:temp],   stroke: "#C1403A", normal: [97.0, 100.4] },
              { label: "BP",    current: v["bp"],    series: @vitals_series[:bp_sys], stroke: "#2B4A7A", normal: [90, 140] },
              { label: "HR",    current: v["pulse"], series: @vitals_series[:pulse],  stroke: "#2F6F4E", normal: [60, 100] },
              { label: "RR",    current: v["resp"],  series: @vitals_series[:resp],   stroke: "#7A4A8C", normal: [12, 22] },
              { label: "SpO2",  current: v["o2"],    series: @vitals_series[:o2],     stroke: "#2F6F4E", normal: [92, 100] }
            ]
          %>
          <div class="space-y-2">
            <% rows.each do |row| %>
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-baseline gap-2 flex-shrink-0">
                  <span class="text-[9px] text-[#6B665F] uppercase tracking-widest w-9"><%= row[:label] %></span>
                  <span class="text-sm font-mono text-[#1D1C1A]"><%= row[:current] || "—" %></span>
                </div>
                <div class="flex-1 flex justify-end">
                  <%= sparkline(row[:series], width: 100, height: 18, stroke: row[:stroke], normal_range: row[:normal]) %>
                </div>
              </div>
            <% end %>
          </div>
            <div class="mt-3 text-[10px] text-[#6B665F] pt-2 border-t border-[#EFECE6]">
              Last reading: <%= @latest_vitals_visit.discipline.upcase %> ·
              <%= @latest_vitals_visit.started_at&.strftime("%b %-d, %-l:%M %p") %>
              <% if @latest_vitals_visit.pain_score %> · pain <%= @latest_vitals_visit.pain_score %>/10<% end %>
            </div>
          <% else %>
            <div class="text-xs text-[#6B665F] italic">No vitals captured yet.</div>
          <% end %>
        </div>
      </details>

      <!-- Recent visits -->
      <details class="group">
        <%= acc_header("ri-calendar-check-line", "Recent Visits", @recent_visits.size.to_s) %>
        <div class="px-5 pb-4">
          <% if @recent_visits.empty? %>
            <div class="text-xs text-[#6B665F] italic">No visits yet.</div>
          <% else %>
          <ul class="space-y-2">
            <% @recent_visits.each do |v| %>
              <li class="text-[12px] flex items-start gap-2">
                <i class="<%=
                  { 'rn' => 'ri-nurse-line', 'md' => 'ri-stethoscope-line',
                    'sw' => 'ri-team-line', 'chaplain' => 'ri-hand-heart-line',
                    'aide' => 'ri-user-2-line', 'don' => 'ri-award-line' }
                  .fetch(v.discipline, 'ri-user-line') %> text-[#6B665F] pt-0.5"></i>
                <div class="flex-1">
                  <div class="text-[12px]">
                    <span class="font-medium text-[#1D1C1A]"><%= v.discipline.upcase %></span>
                    <span class="text-[10px] text-[#6B665F] ml-1">(<%= v.visit_type.tr("_", " ") %>)</span>
                  </div>
                  <div class="text-[10px] text-[#6B665F]"><%= v.started_at&.strftime("%b %-d · %-l:%M %p") || "scheduled" %></div>
                  <% if v.narrative.present? %>
                    <div class="text-[11px] text-[#3A3936] line-clamp-2 mt-0.5"><%= v.narrative %></div>
                  <% end %>
                </div>
              </li>
            <% end %>
            </ul>
          <% end %>
        </div>
      </details>

      <!-- DME at home -->
      <details class="group">
        <%= acc_header("ri-tools-line", "DME at Home", @active_dme.size.to_s) %>
        <div class="px-5 pb-4">
          <% if @active_dme.empty? %>
            <div class="text-xs text-[#6B665F] italic">None on order.</div>
          <% else %>
            <ul class="space-y-1">
              <% @active_dme.each do |d| %>
                <li class="flex items-center justify-between text-[12px]">
                  <span class="text-[#1D1C1A]"><%= d.equipment_type.tr("_", " ") %><%= " ×#{d.quantity}" if d.quantity > 1 %></span>
                  <span class="text-[10px] uppercase tracking-wider text-[#6B665F]"><%= d.status %></span>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </details>

      <!-- Pending pharmacy deliveries -->
      <% if @pending_deliveries.any? %>
        <details class="group">
          <%= acc_header("ri-truck-line", "Pharmacy Inbound", @pending_deliveries.size.to_s) %>
          <div class="px-5 pb-4">
            <ul class="space-y-1">
              <% @pending_deliveries.each do |p| %>
                <li class="flex items-center justify-between text-[12px]">
                  <span class="text-[#1D1C1A]"><%= p.kind.tr("_", " ") %></span>
                  <span class="text-[10px] uppercase tracking-wider text-[#D97757]"><%= p.status %></span>
                </li>
              <% end %>
            </ul>
          </div>
        </details>
      <% end %>
    </div>

    <!-- Footer: back to Mission Stage (clinicians only) -->
    <% unless current_user.family_access? %>
      <div class="border-t border-[#EFECE6] px-5 py-3">
        <a href="/dashboard" class="inline-flex items-center gap-1.5 text-xs text-[#6B665F] hover:text-[#1D1C1A]">
          <i class="ri-arrow-left-line"></i> Back to Mission Stage
        </a>
      </div>
    <% end %>
  </aside>

  <!-- Mobile bottom tab bar (visible only below md) -->
  <nav class="md:hidden fixed bottom-0 inset-x-0 bg-white border-t border-[#EFECE6] z-40 flex items-stretch">
    <%
      tabs = [
        { name: "team",    icon: "ri-team-line",           label: "Team" },
        { name: "chat",    icon: "ri-chat-3-line",         label: "Chat" },
        { name: "details", icon: "ri-file-list-3-line",    label: "Details" }
      ]
    %>
    <% tabs.each do |t| %>
      <button type="button"
              data-action="click->patient-chat-mobile#activate"
              data-tab-name="<%= t[:name] %>"
              data-patient-chat-mobile-target="button"
              data-mobile-active="<%= t[:name] == 'chat' ? 'true' : 'false' %>"
              class="flex-1 flex flex-col items-center justify-center py-2 text-[10px] text-[#6B665F] data-[mobile-active=true]:text-[#D97757] data-[mobile-active=true]:bg-[#FBF9F5] transition">
        <i class="<%= t[:icon] %> text-lg"></i>
        <span class="uppercase tracking-wider mt-0.5"><%= t[:label] %></span>
      </button>
    <% end %>
  </nav>
</div>
