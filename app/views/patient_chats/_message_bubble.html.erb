<%
  role = note.author_role
  is_family    = role == "family"
  is_system    = %w[admissions front_door_inbound system].include?(role)
  is_careteam  = !(is_family || is_system)
  is_ai        = note.ai_authored?

  alignment = is_family   ? ""                : (is_careteam ? "ml-auto" : "mx-auto")
  bubble_bg = is_family   ? "bg-[#FFF3EC]"    : (is_careteam ? "bg-[#E6F0EE]" : "bg-[#EFECE6]")
  text_color = "text-[#1D1C1A]"

  label_color = is_ai ? "#6B665F" : case role
                when "family"      then "#C1403A"
                when "rn"          then "#2F6F4E"
                when "md"          then "#2B4A7A"
                when "social_worker" then "#7A4A8C"
                when "chaplain"    then "#8C6A2F"
                when "pharmacy"    then "#5A2F7A"
                when "aide"        then "#3A6B6B"
                when "don"         then "#1D1C1A"
                when "dme"         then "#6B5A2F"
                when "insurance"   then "#4A4A6B"
                when "admissions", "front_door_inbound" then "#6B665F"
                else                    "#6B665F"
                end

  # Display the REAL human's name when a user authored the note. Fall back to
  # the model's display helper for AI-written notes ("HosAlivio Assist").
  speaker_name = note.display_author_name
  viewer_is_family = current_user&.family_access?

  # Warmer, personal subtitle for family viewers. Clinicians see the raw role.
  family_role_label = {
    "rn" => "Your RN", "md" => "Your doctor",
    "social_worker" => "Your social worker", "chaplain" => "Your chaplain",
    "aide" => "Your aide", "don" => "Your DON",
    "admissions" => "Your care coordinator", "pharmacy" => "Your pharmacist",
    "dme" => "Your equipment team", "insurance" => "Your benefits coordinator"
  }

  speaker_sub = if viewer_is_family && !is_ai
                  family_role_label[role] || note.display_author_subtitle
                elsif viewer_is_family && is_ai
                  "Automated reply on behalf of your care team"
                else
                  note.display_author_subtitle
                end

  # Rich hover tooltip for clinicians (and a simple one for family). All
  # times rendered in the patient's branch timezone so the title matches
  # the bubble timestamp (and matches what Cable will stream).
  ts_long = in_patient_zone(note.created_at, @patient, "%b %-d %-l:%M %p")
  bubble_title = if viewer_is_family
                   "Sent #{ts_long}"
                 elsif is_ai
                   "AI auto-draft on #{role.upcase} role · #{ts_long}"
                 elsif note.author_user
                   "#{note.author_user.full_name} via #{role.upcase} role · #{ts_long}"
                 else
                   "System-authored · role: #{role} · #{ts_long}"
                 end

  role_icon = is_ai ? "ri-robot-2-line" : {
    "family" => "ri-user-heart-line",
    "rn" => "ri-nurse-line",
    "md" => "ri-stethoscope-line",
    "social_worker" => "ri-team-line",
    "chaplain" => "ri-hand-heart-line",
    "pharmacy" => "ri-capsule-line",
    "aide" => "ri-user-2-line",
    "don" => "ri-award-line",
    "dme" => "ri-tools-line",
    "insurance" => "ri-bank-card-line",
    "admissions" => "ri-customer-service-2-line",
    "front_door_inbound" => "ri-customer-service-2-line",
    "system" => "ri-flashlight-line"
  }.fetch(role, "ri-user-line")
%>

<% if note.clinician_only? %>
  <%# Clinician-only audit log — collapsed by default. Pascal expands when
      he wants to audit the AI reasoning, otherwise it stays out of his way. %>
  <details class="group max-w-3xl">
    <summary class="cursor-pointer list-none flex items-center gap-2 py-1.5 px-3 text-[11px] text-[#6B665F] hover:bg-[#FBF9F5] rounded-md transition [&::-webkit-details-marker]:hidden">
      <i class="ri-arrow-right-s-line group-open:rotate-90 transition-transform"></i>
      <i class="ri-file-list-3-line text-[#B9B4AB]"></i>
      <span class="uppercase tracking-[0.18em] text-[9px] font-bold">Internal · <%= role.tr("_", " ") %> trace</span>
      <% if note.urgency_crisis? %>
        <span title="Contains a CRISIS-flagged trace" class="inline-flex items-center gap-1 text-[9px] font-bold text-[#C1403A] uppercase tracking-wider">
          <span class="w-1.5 h-1.5 rounded-full bg-[#C1403A] animate-pulse"></span>
          crisis
        </span>
      <% elsif note.urgency_urgent? %>
        <span class="inline-flex items-center gap-1 text-[9px] font-bold text-[#D97757] uppercase tracking-wider">
          <span class="w-1.5 h-1.5 rounded-full bg-[#D97757]"></span>
          urgent
        </span>
      <% end %>
      <span class="text-[10px] text-[#B9B4AB] font-mono ml-auto"><%= in_patient_zone(note.created_at, @patient) %></span>
    </summary>
    <div class="ml-6 mt-1 mb-2 py-2 px-3 bg-[#FBF9F5] border-l-2 border-[#D9D5CD] rounded-r-md">
      <div class="text-[12px] text-[#3A3936] leading-snug whitespace-pre-wrap break-words [overflow-wrap:anywhere] font-mono"><%= note.body %></div>
    </div>
  </details>
<% elsif is_system %>
  <%# System/Lucia notes ALWAYS render as the quiet triaged pill, even when
      urgency=crisis (those are audit breadcrumbs, not family-facing alarms). %>
<% end %>
<% if !note.clinician_only? && !is_system && note.urgency_crisis? %>
  <%# Full-width crisis highlight bar — only for family + care-team notes %>
  <div class="w-full rounded-2xl border-2 border-[#C1403A] bg-[#FFF3EC] overflow-hidden">
    <div class="bg-[#C1403A] text-white px-4 py-2 flex items-center gap-2">
      <i class="ri-alarm-warning-fill text-lg"></i>
      <span class="font-bold tracking-wider text-[13px]">URGENT · <%= speaker_name.upcase %></span>
      <span class="ml-auto text-[10px] opacity-80 font-mono"><%= in_patient_zone(note.created_at, @patient) %></span>
    </div>
    <div class="px-5 py-4">
      <p class="font-serif text-[16px] text-[#1D1C1A] leading-relaxed whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><%= explain_icd(note.body) %></p>
    </div>
  </div>
<% elsif !note.clinician_only? && is_system %>
  <%# System / Lucia triage: centered, subtle %>
  <div class="max-w-xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full <%= bubble_bg %> border border-[#EFECE6]">
      <% if is_ai %>
        <div class="w-7 h-7 rounded-full overflow-hidden flex-shrink-0 bg-white border border-[#EFECE6]">
          <%= image_tag "hosalivio_assistant.png", class: "w-full h-full object-cover object-top scale-125 origin-top", alt: "HosAlivio Assistant" %>
        </div>
      <% else %>
        <i class="<%= role_icon %> text-[14px]" style="color: <%= label_color %>;"></i>
      <% end %>
      <span class="text-[10px] font-bold uppercase tracking-widest" style="color: <%= label_color %>;"><%= is_ai ? "HosAlivio Assist" : "Triaged" %></span>
      <span class="text-[12px] text-[#3A3936] break-words [overflow-wrap:anywhere]"><%= explain_icd(note.body) %></span>
      <% if note.urgency_urgent? %>
        <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-[#D97757] text-white tracking-wider">URGENT</span>
      <% end %>
    </div>
    <div class="text-[10px] text-[#6B665F] mt-1 font-mono"><%= in_patient_zone(note.created_at, @patient) %></div>
  </div>
<% elsif !note.clinician_only? %>
  <div title="<%= bubble_title %>"
       class="max-w-xl min-w-0 <%= alignment %> <%= bubble_bg %> border border-[#EFECE6] rounded-3xl px-5 py-4 overflow-hidden <%= 'ring-1 ring-dashed ring-[#B9B4AB]' if is_ai %>">
    <div class="flex items-center justify-between mb-1 gap-2">
      <div class="min-w-0 flex items-center gap-2.5">
        <% if is_ai %>
          <div class="w-10 h-10 rounded-full overflow-hidden flex-shrink-0 bg-white border border-[#EFECE6]">
            <%= image_tag "hosalivio_assistant.png", class: "w-full h-full object-cover object-top scale-125 origin-top", alt: "HosAlivio Assistant" %>
          </div>
        <% elsif note.author_user&.has_avatar? %>
          <div class="w-10 h-10 rounded-full overflow-hidden flex-shrink-0">
            <%= image_tag note.author_user.avatar.variant(resize_to_fill: [120, 120]).processed, class: "w-full h-full object-cover" %>
          </div>
        <% end %>
        <div class="min-w-0">
          <div class="inline-flex items-center gap-1.5 text-[13px] font-medium" style="color: <%= label_color %>;">
            <% unless is_ai || note.author_user&.has_avatar? %><i class="<%= role_icon %> text-[14px]"></i><% end %>
            <span class="truncate"><%= speaker_name %></span>
          </div>
          <% if speaker_sub.present? %>
            <div class="text-[9px] uppercase tracking-[0.18em] text-[#6B665F] font-mono mt-0.5"><%= speaker_sub %></div>
          <% end %>
        </div>
      </div>
      <% if note.urgency_urgent? %>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-[#D97757] text-white tracking-wider flex-shrink-0">URGENT</span>
      <% end %>
    </div>
    <p class="font-serif text-[16px] <%= text_color %> leading-relaxed whitespace-pre-wrap break-words [overflow-wrap:anywhere] mt-1"><%= explain_icd(note.body) %></p>
    <div class="text-[10px] text-[#6B665F] mt-2 text-right font-mono">
      <%= in_patient_zone(note.created_at, @patient) %>
    </div>
  </div>
<% end %>
