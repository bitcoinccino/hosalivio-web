<%
  role = note.author_role
  is_family    = role == "family"
  is_system    = %w[admissions front_door_inbound system].include?(role)
  is_careteam  = !(is_family || is_system)
  is_ai        = note.ai_authored?

  alignment = is_family   ? ""                : (is_careteam ? "ml-auto" : "mx-auto")
  bubble_bg = is_family   ? "bg-[#FFF3EC]"    : (is_careteam ? "bg-[#E6F0EE]" : "bg-[#EFECE6]")
  text_color = "text-[#1D1C1A]"

  label_color = is_ai ? "#6B665F" : case role
                when "family"      then "#C1403A"
                when "rn"          then "#2F6F4E"
                when "md"          then "#2B4A7A"
                when "social_worker" then "#7A4A8C"
                when "chaplain"    then "#8C6A2F"
                when "pharmacy"    then "#5A2F7A"
                when "admissions", "front_door_inbound" then "#6B665F"
                else                    "#6B665F"
                end

  # Display the REAL human's name when a user authored the note. Fall back to
  # the model's display helper for AI-written notes ("HosAlivio Assist").
  speaker_name = note.display_author_name
  viewer_is_family = current_user&.family_access?

  # Warmer, personal subtitle for family viewers. Clinicians see the raw role.
  family_role_label = {
    "rn" => "Your RN", "md" => "Your doctor",
    "social_worker" => "Your social worker", "chaplain" => "Your chaplain",
    "aide" => "Your aide", "don" => "Your DON",
    "admissions" => "Your care coordinator", "pharmacy" => "Your pharmacist",
    "dme" => "Your equipment team", "insurance" => "Your benefits coordinator"
  }

  speaker_sub = if viewer_is_family && !is_ai
                  family_role_label[role] || note.display_author_subtitle
                elsif viewer_is_family && is_ai
                  "Automated reply on behalf of your care team"
                else
                  note.display_author_subtitle
                end

  # Rich hover tooltip for clinicians (and a simple one for family).
  bubble_title = if viewer_is_family
                   note.created_at.strftime("Sent %b %-d at %-l:%M %p")
                 elsif is_ai
                   "AI auto-draft on #{role.upcase} role · #{note.created_at.strftime('%b %-d %-l:%M %p')}"
                 elsif note.author_user
                   "#{note.author_user.full_name} via #{role.upcase} role · #{note.created_at.strftime('%b %-d %-l:%M %p')}"
                 else
                   "System-authored · role: #{role} · #{note.created_at.strftime('%b %-d %-l:%M %p')}"
                 end

  role_icon = is_ai ? "ri-robot-2-line" : {
    "family" => "ri-user-heart-line",
    "rn" => "ri-nurse-line",
    "md" => "ri-stethoscope-line",
    "social_worker" => "ri-team-line",
    "chaplain" => "ri-hand-heart-line",
    "pharmacy" => "ri-capsule-line",
    "admissions" => "ri-customer-service-2-line",
    "front_door_inbound" => "ri-customer-service-2-line",
    "system" => "ri-flashlight-line"
  }.fetch(role, "ri-user-line")
%>

<% if is_system %>
  <%# System/Lucia notes ALWAYS render as the quiet triaged pill, even when
      urgency=crisis (those are audit breadcrumbs, not family-facing alarms). %>
<% end %>
<% if !is_system && note.urgency_crisis? %>
  <%# Full-width crisis highlight bar — only for family + care-team notes %>
  <div class="w-full rounded-2xl border-2 border-[#C1403A] bg-[#FFF3EC] overflow-hidden">
    <div class="bg-[#C1403A] text-white px-4 py-2 flex items-center gap-2">
      <i class="ri-alarm-warning-fill text-lg"></i>
      <span class="font-bold tracking-wider text-[13px]">URGENT · <%= speaker_name.upcase %></span>
      <span class="ml-auto text-[10px] opacity-80 font-mono"><%= note.created_at.strftime("%-l:%M %p") %></span>
    </div>
    <div class="px-5 py-4">
      <p class="font-serif text-[16px] text-[#1D1C1A] leading-relaxed whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><%= explain_icd(note.body) %></p>
    </div>
  </div>
<% elsif is_system %>
  <%# System / Lucia triage: centered, subtle %>
  <div class="max-w-xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full <%= bubble_bg %>">
      <i class="<%= role_icon %> text-[14px]" style="color: <%= label_color %>;"></i>
      <span class="text-[10px] font-bold uppercase tracking-widest" style="color: <%= label_color %>;"><%= is_ai ? "HosAlivio Assist" : "Triaged" %></span>
      <span class="text-[12px] text-[#3A3936] break-words [overflow-wrap:anywhere]"><%= explain_icd(note.body) %></span>
      <% if note.urgency_urgent? %>
        <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-[#D97757] text-white tracking-wider">URGENT</span>
      <% end %>
    </div>
    <div class="text-[10px] text-[#6B665F] mt-1 font-mono"><%= note.created_at.strftime("%-l:%M %p") %></div>
  </div>
<% else %>
  <div title="<%= bubble_title %>"
       class="max-w-xl min-w-0 <%= alignment %> <%= bubble_bg %> rounded-3xl px-5 py-4 overflow-hidden <%= 'ring-1 ring-dashed ring-[#B9B4AB]' if is_ai %>">
    <div class="flex items-center justify-between mb-1 gap-2">
      <div class="min-w-0 flex items-center gap-2">
        <% if note.author_user&.has_avatar? %>
          <div class="w-6 h-6 rounded-full overflow-hidden flex-shrink-0">
            <%= image_tag note.author_user.avatar.variant(resize_to_fill: [48, 48]).processed, class: "w-full h-full object-cover" %>
          </div>
        <% end %>
        <div class="min-w-0">
          <div class="inline-flex items-center gap-1.5 text-[13px] font-medium" style="color: <%= label_color %>;">
            <% unless note.author_user&.has_avatar? %><i class="<%= role_icon %> text-[14px]"></i><% end %>
            <span class="truncate"><%= speaker_name %></span>
          </div>
          <% if speaker_sub.present? %>
            <div class="text-[9px] uppercase tracking-[0.18em] text-[#6B665F] font-mono mt-0.5"><%= speaker_sub %></div>
          <% end %>
        </div>
      </div>
      <% if note.urgency_urgent? %>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-[#D97757] text-white tracking-wider flex-shrink-0">URGENT</span>
      <% end %>
    </div>
    <p class="font-serif text-[16px] <%= text_color %> leading-relaxed whitespace-pre-wrap break-words [overflow-wrap:anywhere] mt-1"><%= explain_icd(note.body) %></p>
    <div class="text-[10px] text-[#6B665F] mt-2 text-right font-mono">
      <%= note.created_at.strftime("%-l:%M %p") %>
    </div>
  </div>
<% end %>
