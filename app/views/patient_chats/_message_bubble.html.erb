<%
  role = note.author_role
  is_family    = role == "family"
  is_system    = %w[admissions front_door_inbound system].include?(role)
  is_careteam  = !(is_family || is_system)
  is_ai        = note.ai_authored?

  alignment = is_family   ? ""                : (is_careteam ? "ml-auto" : "mx-auto")
  # Speaker-type color coding: HosAlivio = light orange, patient/family =
  # light purple, clinicians = light blue. AI takes precedence over its role
  # so a HosAlivio note always reads orange regardless of which role it spoke on.
  bubble_bg = if is_ai        then "bg-[#FFF3EC]"
              elsif is_family then "bg-[#F0EBFB]"
              elsif is_careteam then "bg-[#E9F1FB]"
              else                 "bg-[#EFECE6]"
              end
  text_color = "text-[#1D1C1A]"

  label_color = is_ai ? "#6B665F" : case role
                when "family"      then "#C1403A"
                when "rn"          then "#2F6F4E"
                when "md"          then "#2B4A7A"
                when "social_worker" then "#7A4A8C"
                when "chaplain"    then "#8C6A2F"
                when "pharmacy"    then "#5A2F7A"
                when "aide"        then "#3A6B6B"
                when "don"         then "#1D1C1A"
                when "dme"         then "#6B5A2F"
                when "insurance"   then "#4A4A6B"
                when "admissions", "front_door_inbound" then "#6B665F"
                else                    "#6B665F"
                end

  # Display the REAL human's name when a user authored the note. Fall back to
  # the model's display helper for AI-written notes ("HosAlivio").
  speaker_name = note.display_author_name
  viewer_is_family = current_user&.family_access?

  # Warmer, personal subtitle for family viewers. Clinicians see the raw role.
  family_role_label = {
    "rn" => "Your RN", "md" => "Your doctor",
    "social_worker" => "Your social worker", "chaplain" => "Your chaplain",
    "aide" => "Your aide", "don" => "Your DON",
    "admissions" => "Your care coordinator", "pharmacy" => "Your pharmacist",
    "dme" => "Your equipment team", "insurance" => "Your benefits coordinator"
  }

  speaker_sub = if viewer_is_family && !is_ai
                  family_role_label[role] || note.display_author_subtitle
                elsif viewer_is_family && is_ai
                  "Automated reply on behalf of your care team"
                else
                  note.display_author_subtitle
                end

  # Rich hover tooltip for clinicians (and a simple one for family). All
  # times rendered in the patient's branch timezone so the title matches
  # the bubble timestamp (and matches what Cable will stream).
  ts_long = in_patient_zone(note.created_at, @patient, "%b %-d %-l:%M %p")
  bubble_title = if viewer_is_family
                   "Sent #{ts_long}"
                 elsif is_ai
                   "AI auto-draft on #{role.upcase} role · #{ts_long}"
                 elsif note.author_user
                   "#{note.author_user.full_name} via #{role.upcase} role · #{ts_long}"
                 else
                   "System-authored · role: #{role} · #{ts_long}"
                 end

  role_icon = is_ai ? "ri-robot-2-line" : {
    "family" => "ri-user-heart-line",
    "rn" => "ri-nurse-line",
    "md" => "ri-stethoscope-line",
    "social_worker" => "ri-team-line",
    "chaplain" => "ri-hand-heart-line",
    "pharmacy" => "ri-capsule-line",
    "aide" => "ri-user-2-line",
    "don" => "ri-award-line",
    "dme" => "ri-tools-line",
    "insurance" => "ri-bank-card-line",
    "admissions" => "ri-customer-service-2-line",
    "front_door_inbound" => "ri-customer-service-2-line",
    "system" => "ri-flashlight-line"
  }.fetch(role, "ri-user-line")
%>

<% if note.clinician_only? && note.author_user_id.present? && note.action_payload.blank? %>
  <%# IDG huddle bubble — a real human posting privately to the care team.
      Family doesn't see this (server scope + JS guard). Visually distinct
      from the family-facing thread: dashed border, muted bg, "Team only" chip. %>
  <div class="max-w-2xl ml-auto bg-[#E9F1FB] border border-dashed border-[#A9C2E6] rounded-3xl px-5 py-4"
       title="Internal note · <%= note.author_user&.full_name %> · <%= in_patient_zone(note.created_at, @patient, "%b %-d %-l:%M %p") %>">
    <div class="flex items-center justify-between mb-1 gap-2">
      <div class="min-w-0 flex items-center gap-2.5">
        <span title="<%= speaker_name %>">
          <%= chat_avatar_tag(name: speaker_name, user: note.author_user, is_ai: is_ai, color: label_color, px: 40) %>
        </span>
        <div class="min-w-0">
          <div class="inline-flex items-center gap-1.5 text-[13px] font-medium" style="color: <%= label_color %>;">
            <span class="truncate"><%= speaker_name %></span>
          </div>
          <% if speaker_sub.present? %>
            <div class="text-[9px] uppercase tracking-[0.18em] text-[#6B665F] font-mono mt-0.5"><%= speaker_sub %></div>
          <% end %>
        </div>
      </div>
      <% if note.urgency_urgent? %>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-[#D97757] text-white tracking-wider flex-shrink-0">URGENT</span>
      <% end %>
    </div>
    <p class="font-serif text-[15px] text-[#3A3936] leading-relaxed whitespace-pre-wrap break-words [overflow-wrap:anywhere] mt-1"><%= note.body %></p>
    <div class="flex items-center justify-between mt-2 gap-2">
      <span class="inline-flex items-center gap-1 text-[9px] uppercase tracking-[0.18em] text-[#6B665F] bg-white border border-[#B9B4AB] rounded-full px-2 py-0.5"
            title="Hidden from the family — only the IDG sees this.">
        <i class="ri-team-line text-[10px]"></i> Team only
      </span>
      <div class="text-[10px] text-[#6B665F] font-mono"><%= in_patient_zone(note.created_at, @patient) %></div>
    </div>
  </div>
<% elsif note.clinician_only? && note.audit_kind == :hosalivio_offer %>
  <%# HosAlivio relay preview: a message drafted for a teammate, awaiting
      the clinician's Send/Cancel before it goes out. Dashed border reads as
      pending. Buttons are live only while this is the latest unanswered
      offer; once handled they collapse to a quiet "Handled" label. %>
  <% offer_pending = (ClinicianDispatcher.pending_relay_offer(note.patient)&.id == note.id) %>
  <div class="max-w-2xl" data-relay-offer data-relay-message="<%= note.offer_payload&.dig("message") %>">
    <div class="flex items-start gap-3 px-3 py-2 rounded-2xl bg-[#FBF9F5] border border-dashed border-[#D9B8A6]"
         title="HosAlivio drafted this message. It has not been sent yet.">
      <div class="w-7 h-7 rounded-full bg-white border border-[#EFECE6] overflow-hidden flex-shrink-0">
        <span class="w-full h-full flex items-center justify-center bg-[#D97757] text-white" title="HosAlivio"><i class="ri-mail-send-line text-[14px]"></i></span>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-[10px] uppercase tracking-[0.18em] text-[#6B665F] font-bold">HosAlivio · draft, not sent</div>
        <div data-relay-preview class="text-[13px] text-[#1D1C1A] mt-0.5 whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><%= note.offer_display_text %></div>
        <textarea data-relay-edit rows="3" maxlength="4000"
                  class="hidden w-full mt-1.5 text-[13px] rounded-lg border border-[#D9B8A6] bg-white px-2 py-1.5 text-[#1D1C1A] focus:outline-none focus:ring-1 focus:ring-[#D97757]"></textarea>
        <% if offer_pending %>
          <div class="mt-2 flex items-center gap-2" data-relay-actions>
            <button type="button" data-action="click->patient-chat#confirmRelay" data-decision="yes"
                    class="inline-flex items-center gap-1 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white px-3 py-1 text-[12px] font-medium">
              <i class="ri-send-plane-fill text-[12px]"></i> Send
            </button>
            <button type="button" data-action="click->patient-chat#editRelay" data-relay-edit-btn
                    class="inline-flex items-center gap-1 rounded-full bg-white border border-[#E4E0D8] hover:bg-[#F2EEE7] text-[#6B665F] px-3 py-1 text-[12px] font-medium">
              <i class="ri-pencil-line text-[12px]"></i> Edit
            </button>
            <button type="button" data-action="click->patient-chat#confirmRelay" data-decision="cancel"
                    class="inline-flex items-center gap-1 rounded-full bg-white border border-[#E4E0D8] hover:bg-[#F2EEE7] text-[#6B665F] px-3 py-1 text-[12px] font-medium">
              Cancel
            </button>
          </div>
        <% else %>
          <div class="mt-1.5 text-[11px] text-[#9A938A] italic">Handled</div>
        <% end %>
      </div>
      <div class="text-[10px] text-[#6B665F] font-mono flex-shrink-0"><%= in_patient_zone(note.created_at, @patient) %></div>
    </div>
  </div>
<% elsif note.clinician_only? && %i[hosalivio_ack hosalivio_answer].include?(note.audit_kind) %>
  <%# HosAlivio ack/answer pill: bot avatar + the message. Acks are dispatch
      confirmations ('Simone (Pharmacy) notified…'); answers are Q&A replies
      (reply-able, see the thread gate in show.html.erb). Same pill either way.
      Subtle, team-only, never family-visible. %>
  <% ack_text = note.body.to_s.sub(/\A\[HOSALIVIO_(?:ACK|ANSWER)\]\s*/, "") %>
  <div class="max-w-2xl">
    <div class="flex items-center gap-3 px-3 py-2 rounded-2xl bg-[#FBF9F5] border border-[#EFECE6]"
         title="HosAlivio dispatch confirmation">
      <div class="w-7 h-7 rounded-full bg-white border border-[#EFECE6] overflow-hidden flex-shrink-0">
        <span class="w-full h-full flex items-center justify-center bg-[#D97757] text-white" title="HosAlivio"><i class="ri-heart-pulse-line text-[14px]"></i></span>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-[10px] uppercase tracking-[0.18em] text-[#6B665F] font-bold">HosAlivio</div>
        <div class="text-[13px] text-[#1D1C1A] mt-0.5 whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><%= ack_text %></div>
      </div>
      <div class="text-[10px] text-[#6B665F] font-mono flex-shrink-0"><%= in_patient_zone(note.created_at, @patient) %></div>
    </div>
    <%= render "feedback_widget", note: note %>
  </div>
<% elsif note.clinician_only? && note.audit_kind == :guardrail %>
  <%# Guardrail block: an agent tried to take an action its cannot_do
      list forbids. We surface this as a small red pill so clinicians
      see WHY a dispatch they expected didn't happen, instead of having
      to tail the dev log. %>
  <% reason = note.body.to_s.sub(/\A\[GUARDRAIL_BLOCKED\]\s*/, "") %>
  <div class="max-w-3xl flex items-center gap-3 px-4 py-2.5 rounded-xl border border-[#C1403A] bg-[#FFF3EC]"
       title="HosAlivio guardrail blocked this action. Audit-logged.">
    <i class="ri-shield-cross-line text-[#C1403A] text-[18px] flex-shrink-0"></i>
    <div class="min-w-0 flex-1">
      <div class="text-[10px] uppercase tracking-[0.18em] text-[#C1403A] font-bold">
        Guardrail blocked
      </div>
      <div class="text-[13px] text-[#1D1C1A] mt-0.5"><%= reason %></div>
    </div>
    <div class="text-[10px] text-[#6B665F] font-mono flex-shrink-0"><%= in_patient_zone(note.created_at, @patient) %></div>
  </div>
<% elsif note.clinician_only? && (action = note.action_payload) %>
  <%# Action banner — green success bar, always visible. Pascal sees the
      result at a glance instead of reading rationale prose. %>
  <% role_label = role.tr("_", " ").upcase %>
  <% urgency_pulse = note.urgency_urgent? || note.urgency_crisis? %>
  <div class="max-w-3xl flex items-center gap-3 px-4 py-2.5 rounded-xl border border-[#7FB99A] bg-[#E6F0EA]"
       title="Action by <%= role_label %> · <%= in_patient_zone(note.created_at, @patient) %>">
    <i class="ri-checkbox-circle-fill text-[#2F6F4E] text-[18px] flex-shrink-0"></i>
    <div class="min-w-0 flex-1">
      <div class="text-[10px] uppercase tracking-[0.18em] text-[#2F6F4E] font-bold">
        <%= action[:label] %>
        <% if note.urgency_urgent? %>
          <span class="ml-1 text-[#D97757]">· Urgent</span>
        <% elsif note.urgency_crisis? %>
          <span class="ml-1 text-[#C1403A]">· Crisis</span>
        <% end %>
      </div>
      <% if action[:detail].present? %>
        <div class="text-[13px] text-[#1D1C1A] truncate mt-0.5"><%= action[:detail] %></div>
      <% end %>
    </div>
    <div class="text-[10px] text-[#6B665F] font-mono flex-shrink-0"><%= in_patient_zone(note.created_at, @patient) %></div>
  </div>
<% elsif note.clinician_only? %>
  <%# Clinician-only audit log — collapsed by default. Header label
      depends on note.audit_kind so chart entries read differently
      from rationale prose, and the admissions triage row gets its
      own framing. %>
  <%
    role_label = role.tr("_", " ").upcase
    audit_summary, audit_icon =
      case note.audit_kind
      when :triage    then ["HosAlivio · triage",                  "ri-radar-line"]
      when :chart     then ["#{role_label} chart entry",            "ri-file-text-line"]
      when :rationale then ["Why the #{role_label} agent acted",    "ri-lightbulb-line"]
      else                  ["Internal · #{role.tr('_', ' ')}",     "ri-file-list-3-line"]
      end
  %>
  <details class="group max-w-3xl">
    <summary class="cursor-pointer list-none flex items-center gap-2 py-1.5 px-3 text-[11px] text-[#6B665F] hover:bg-[#FBF9F5] rounded-md transition [&::-webkit-details-marker]:hidden">
      <i class="ri-arrow-right-s-line group-open:rotate-90 transition-transform"></i>
      <i class="<%= audit_icon %> text-[#B9B4AB]"></i>
      <span class="uppercase tracking-[0.18em] text-[9px] font-bold"><%= audit_summary %></span>
      <% if note.urgency_crisis? %>
        <span title="Contains a CRISIS-flagged trace" class="inline-flex items-center gap-1 text-[9px] font-bold text-[#C1403A] uppercase tracking-wider">
          <span class="w-1.5 h-1.5 rounded-full bg-[#C1403A] animate-pulse"></span>
          crisis
        </span>
      <% elsif note.urgency_urgent? %>
        <span class="inline-flex items-center gap-1 text-[9px] font-bold text-[#D97757] uppercase tracking-wider">
          <span class="w-1.5 h-1.5 rounded-full bg-[#D97757]"></span>
          urgent
        </span>
      <% end %>
      <span class="text-[10px] text-[#B9B4AB] font-mono ml-auto"><%= in_patient_zone(note.created_at, @patient) %></span>
    </summary>
    <div class="ml-6 mt-1 mb-2 py-2 px-3 bg-[#FBF9F5] border-l-2 border-[#D9D5CD] rounded-r-md">
      <div class="text-[12px] text-[#3A3936] leading-relaxed whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><%= render_audit_body(note.display_audit_body) %></div>
    </div>
  </details>
<% elsif is_system %>
  <%# System/HosAlivio notes ALWAYS render as the quiet triaged pill, even when
      urgency=crisis (those are audit breadcrumbs, not family-facing alarms). %>
<% end %>
<% if !note.clinician_only? && !is_system && note.urgency_crisis? %>
  <%# Full-width crisis highlight bar — only for family + care-team notes %>
  <div class="w-full rounded-2xl border-2 border-[#C1403A] bg-[#FFF3EC] overflow-hidden">
    <div class="bg-[#C1403A] text-white px-4 py-2 flex items-center gap-2">
      <i class="ri-alarm-warning-fill text-lg"></i>
      <span class="font-bold tracking-wider text-[13px]">URGENT · <%= speaker_name.upcase %></span>
      <span class="ml-auto text-[10px] opacity-80 font-mono"><%= in_patient_zone(note.created_at, @patient) %></span>
    </div>
    <div class="px-5 py-4">
      <% if note.body.present? %>
        <p class="font-serif text-[16px] text-[#1D1C1A] leading-relaxed whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><%= explain_icd(note.body, emphasize: is_ai) %></p>
      <% end %>
      <% if note.audio.attached? %>
        <%= audio_tag url_for(note.audio), controls: true, class: "w-full h-9 mt-2" %>
      <% end %>
    </div>
  </div>
<% elsif !note.clinician_only? && is_system && !is_ai %>
  <%# Non-AI triage breadcrumb: short, centered, subtle pill. A substantive
      HosAlivio family REPLY (is_ai) is a full message, not a pill — it falls
      through to the conversational bubble below, which wraps long text. %>
  <div class="max-w-xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full <%= bubble_bg %> border border-[#EFECE6]">
      <% if is_ai %>
        <div class="w-7 h-7 rounded-full overflow-hidden flex-shrink-0 bg-white border border-[#EFECE6]">
          <span class="w-full h-full flex items-center justify-center bg-[#D97757] text-white" title="HosAlivio"><i class="ri-heart-pulse-line text-[14px]"></i></span>
        </div>
      <% else %>
        <i class="<%= role_icon %> text-[14px]" style="color: <%= label_color %>;"></i>
      <% end %>
      <span class="text-[10px] font-bold uppercase tracking-widest" style="color: <%= label_color %>;"><%= is_ai ? "HosAlivio" : "Triaged" %></span>
      <span class="text-[12px] text-[#3A3936] break-words [overflow-wrap:anywhere]"><%= explain_icd(note.body, emphasize: is_ai) %></span>
      <% if note.urgency_urgent? %>
        <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-[#D97757] text-white tracking-wider">URGENT</span>
      <% end %>
    </div>
    <div class="text-[10px] text-[#6B665F] mt-1 font-mono"><%= in_patient_zone(note.created_at, @patient) %></div>
  </div>
<% elsif !note.clinician_only? %>
  <div title="<%= bubble_title %>"
       class="max-w-xl min-w-0 <%= alignment %> <%= bubble_bg %> border border-[#EFECE6] rounded-3xl px-5 py-4 overflow-hidden <%= 'ring-1 ring-dashed ring-[#B9B4AB]' if is_ai %>">
    <div class="flex items-center justify-between mb-1 gap-2">
      <div class="min-w-0 flex items-center gap-2.5">
        <span title="<%= is_ai ? 'HosAlivio' : speaker_name %>">
          <%= chat_avatar_tag(name: speaker_name, user: note.author_user, is_ai: is_ai, color: label_color, px: 40) %>
        </span>
        <div class="min-w-0">
          <div class="inline-flex items-center gap-1.5 text-[13px] font-medium" style="color: <%= label_color %>;">
            <span class="truncate"><%= speaker_name %></span>
          </div>
          <% if speaker_sub.present? %>
            <div class="text-[9px] uppercase tracking-[0.18em] text-[#6B665F] font-mono mt-0.5"><%= speaker_sub %></div>
          <% end %>
        </div>
      </div>
      <% if note.urgency_urgent? %>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-[#D97757] text-white tracking-wider flex-shrink-0">URGENT</span>
      <% end %>
    </div>
    <% if note.body.present? %>
      <p class="font-serif text-[16px] <%= text_color %> leading-relaxed whitespace-pre-wrap break-words [overflow-wrap:anywhere] mt-1"><%= explain_icd(note.body, emphasize: is_ai) %></p>
    <% end %>
    <% if note.audio.attached? %>
      <%= audio_tag url_for(note.audio), controls: true, class: "w-full h-9 mt-2" %>
    <% end %>
    <div class="flex items-center justify-between mt-2 gap-2">
      <% if is_ai && !viewer_is_family %>
        <span class="inline-flex items-center gap-1 text-[9px] uppercase tracking-[0.18em] text-[#6B665F] bg-[#FBF9F5] border border-[#EFECE6] rounded-full px-2 py-0.5"
              title="This message was sent to the family — they've already read it.">
          <i class="ri-send-plane-line text-[10px]"></i> Sent to family
        </span>
      <% else %>
        <span></span>
      <% end %>
      <div class="text-[10px] text-[#6B665F] font-mono">
        <%= in_patient_zone(note.created_at, @patient) %>
      </div>
    </div>
    <% if is_ai %>
      <%= render "feedback_widget", note: note %>
    <% end %>
  </div>
<% end %>
