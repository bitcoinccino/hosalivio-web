<% content_for :title, "Partner signup · Clinical & admin · HosAlivio" %>

<div class="min-h-screen bg-[#FBF9F5] px-4 sm:px-6 py-8 sm:py-12">
  <div class="max-w-2xl mx-auto">
    <%= render "wizard_header",
          step: 3,
          title: "Vendors, clinical team, and your admin login",
          subtitle: "Wires up the 12 HosAlivio agents to your vendors and creates your first login. The admin account you create here is what you'll use to sign in." %>

    <%= form_with url: complete_partner_path, method: :post, local: true, html: { class: "space-y-6 bg-white rounded-3xl border border-[#EFECE6] p-5 sm:p-8" } do |f| %>
      <% s3 = (@form && @form[:step3].presence) || {} %>

      <%# Vendors %>
      <div class="space-y-4">
        <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-medium">Clinical vendors</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-[11px] text-[#6B665F] mb-1">Pharmacy partner</label>
            <%= f.select :pharmacy_partner,
                  [["Optum", "optum"], ["Enclara", "enclara"], ["Local pharmacy", "local_pharmacy"]],
                  { include_blank: "— Select —", selected: s3[:pharmacy_partner] },
                  class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
            <p class="text-[10px] text-[#6B665F] mt-1">Wakes Simone (pharmacy agent).</p>
          </div>
          <div>
            <label class="block text-[11px] text-[#6B665F] mb-1">DME partner</label>
            <%= f.select :dme_partner,
                  [["StateServ", "stateserv"], ["Qualis", "qualis"], ["Local DME", "local_dme"]],
                  { include_blank: "— Select —", selected: s3[:dme_partner] },
                  class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
            <p class="text-[10px] text-[#6B665F] mt-1">Wakes Marcus (DME agent).</p>
          </div>
          <div>
            <label class="block text-[11px] text-[#6B665F] mb-1">EMR / system of record</label>
            <%= f.select :emr_system,
                  [["Homecare Homebase", "hchb"], ["Netsmart", "netsmart"], ["MatrixCare", "matrixcare"], ["WellSky", "wellsky"], ["Standalone (HosAlivio only)", "standalone"]],
                  { include_blank: "— Select —", selected: s3[:emr_system] },
                  class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
            <p class="text-[10px] text-[#6B665F] mt-1">Configures Wolfwide (billing agent).</p>
          </div>
          <div>
            <label class="block text-[11px] text-[#6B665F] mb-1">Medicare Admin. Contractor (MAC)</label>
            <%= f.select :mac_region,
                  [["Palmetto GBA", "palmetto_gba"], ["CGS", "cgs"], ["NGS", "ngs"], ["Noridian", "noridian"]],
                  { include_blank: "— Select —", selected: s3[:mac_region] },
                  class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
            <p class="text-[10px] text-[#6B665F] mt-1">Where Wolfwide files the electronic claims.</p>
          </div>
        </div>
      </div>

      <%# Leadership %>
      <div class="space-y-4 pt-4 border-t border-[#EFECE6]">
        <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-medium">Leadership team</div>
        <div>
          <label class="block text-[11px] text-[#6B665F] mb-1">Director of Nursing (DON)</label>
          <%= f.text_field :don_name, value: s3[:don_name],
                placeholder: "e.g. Diaphnie Casimir",
                class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
          <p class="text-[10px] text-[#6B665F] mt-1">Placeholder — invite them properly via the Team Members page later.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="sm:col-span-2">
            <label class="block text-[11px] text-[#6B665F] mb-1">Medical Director (MD) name</label>
            <%= f.text_field :md_name, value: s3[:md_name],
                  placeholder: "e.g. Dr. Esther Trotter",
                  class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
          </div>
          <div>
            <label class="block text-[11px] text-[#6B665F] mb-1">MD NPI</label>
            <%= f.text_field :md_npi, value: s3[:md_npi], pattern: "[0-9]{10}",
                  class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px] font-mono" %>
          </div>
        </div>
        <div>
          <label class="block text-[11px] text-[#6B665F] mb-1">MD email (for placeholder invitation)</label>
          <%= f.email_field :md_email, value: s3[:md_email],
                placeholder: "esther@mercyhospice.com",
                class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
          <p class="text-[10px] text-[#6B665F] mt-1">Optional. If supplied, we create a placeholder User so the Pre-Admit Eval has an evaluator to link.</p>
        </div>
      </div>

      <%# Admin login (what gets them into the product). %>
      <div class="space-y-4 pt-4 border-t border-[#EFECE6]">
        <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-medium">Your admin login</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-[11px] text-[#6B665F] mb-1">Email</label>
            <%= f.email_field :admin_email, value: s3[:admin_email], required: true,
                  class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
          </div>
          <div>
            <label class="block text-[11px] text-[#6B665F] mb-1">Password (min 8 chars)</label>
            <%= f.password_field :admin_password, required: true, minlength: 8,
                  class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px] font-mono" %>
          </div>
        </div>
      </div>

      <%# Demo seed toggle. %>
      <div class="pt-4 border-t border-[#EFECE6]">
        <label class="flex items-start gap-3 cursor-pointer">
          <%= f.check_box :seed_demo_patients, { checked: true, class: "mt-1 w-4 h-4 accent-[#D97757]" } %>
          <div>
            <div class="text-[13px] text-[#1D1C1A] font-medium">Seed demo patients (Maria, John, Liam)</div>
            <p class="text-[11px] text-[#6B665F] mt-0.5">Populates your dashboard with three realistic hospice cases so you can explore the agents immediately. You can delete them anytime.</p>
          </div>
        </label>
      </div>

      <div class="flex items-center justify-between pt-4 border-t border-[#EFECE6]">
        <%= link_to "Back", partner_step_2_path, class: "text-[13px] text-[#6B665F] hover:text-[#1D1C1A]" %>
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium transition">
          Create partner account <i class="ri-check-line"></i>
        </button>
      </div>
    <% end %>
  </div>
</div>
