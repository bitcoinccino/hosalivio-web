<%# One root message + its replies + reply affordances. Shared by the collapsed
    "earlier" group and the visible latest-day group in channels/thread.
    Locals: message, can_post, post_url %>
<% can_post = local_assigns.fetch(:can_post, false) %>
<% post_url = local_assigns.fetch(:post_url) %>
<div data-controller="thread">
  <%= render "channel_messages/message", message: message %>

  <%# Thread: replies + reply affordances, indented under the avatar. %>
  <% replies = message.replies.sort_by(&:created_at) %>
  <div class="ml-[46px]">
    <% if replies.any? %>
      <button type="button" data-action="thread#toggleReplies"
              class="inline-flex items-center gap-1 text-[11px] text-[#6B665F] hover:text-[#1D1C1A] font-medium">
        <i class="ri-corner-down-right-line"></i>
        <%= replies.size %> <%= "reply".pluralize(replies.size) %>
        <i class="ri-arrow-up-s-line transition-transform" data-thread-target="chevron"></i>
      </button>
    <% end %>

    <div id="channel-message-<%= message.id %>-replies" data-thread-target="replies"
         class="space-y-1 pl-3 border-l-2 border-[#EFECE6] mt-1">
      <% replies.each do |r| %>
        <%= render "channel_messages/message", message: r, reply: true %>
      <% end %>
    </div>

    <% if can_post %>
      <button type="button" data-action="thread#openReply"
              class="mt-1 inline-flex items-center gap-1 text-[11px] text-[#D97757] hover:underline font-medium">
        <i class="ri-reply-line"></i> Reply
      </button>
      <div data-thread-target="form" class="hidden mt-1">
        <%= form_with url: post_url, method: :post, data: { turbo: false } do %>
          <%= hidden_field_tag :parent_id, message.id %>
          <div class="flex items-center gap-2 bg-white rounded-2xl pl-3 pr-1.5 py-1 border border-[#EFECE6] shadow-sm">
            <input type="text" name="body" autocomplete="off"
                   placeholder="Reply to <%= message.user&.full_name.presence || "message" %>…"
                   class="flex-1 w-full bg-transparent border-0 focus:outline-none text-[13px] placeholder-[#6B665F] py-1">
            <button type="submit" title="Send reply"
                    class="flex-shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white transition">
              <i class="ri-send-plane-fill text-[13px]"></i>
            </button>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
