<%# A day-divider pill inside a channel thread (shared by the collapsed
    "earlier" group and the visible latest-day group). Local: date %>
<div class="flex items-center justify-center pt-2 pb-1">
  <div class="px-3 py-1 text-[10px] uppercase tracking-[0.18em] text-[#6B665F] bg-[#FBF9F5] border border-[#EFECE6] rounded-full font-medium"><%= relative_date_label(date) %></div>
</div>
