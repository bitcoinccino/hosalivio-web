<% content_for :title, "Team chat · ##{@channel&.slug}" %>
<div class="min-h-screen bg-[#FBF9F5]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6">
    <a href="<%= dashboard_path %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to dashboard
    </a>

    <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-4">
      <%# ── Channel list ─────────────────────────────────────── %>
      <aside class="rounded-2xl bg-white border border-[#EFECE6] p-3 h-fit">
        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold px-1 mb-2">Channels</div>
        <ul class="space-y-0.5">
          <% @channels.each do |c| %>
            <% active = (c.id == @channel&.id) %>
            <li>
              <%= link_to channel_path(c),
                    class: "flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-[13px] #{active ? 'bg-[#F0F4FA] text-[#2B4A7A] font-medium' : 'text-[#1D1C1A] hover:bg-[#FBF9F5]'}" do %>
                <span class="text-[#9A938A]">#</span><%= c.slug %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </aside>

      <%# ── Selected channel ─────────────────────────────────── %>
      <section class="rounded-2xl bg-white border border-[#EFECE6] flex flex-col overflow-hidden" style="height: 70vh;">
        <div class="px-5 py-3 border-b border-[#EFECE6]">
          <div class="text-[14px] font-serif text-[#1D1C1A]"># <%= @channel.name %></div>
          <% if @channel.description.present? %>
            <div class="text-[11px] text-[#6B665F] mt-0.5"><%= @channel.description %></div>
          <% end %>
        </div>

        <%# Live-append new messages for anyone viewing this channel. %>
        <%= turbo_stream_from [ @channel, :messages ] %>
        <div class="flex-1 overflow-y-auto px-1 py-3">
          <div id="channel-<%= @channel.id %>-messages" class="space-y-1">
            <% last_date = nil %>
            <% @messages.each do |m| %>
              <% d = m.created_at.to_date %>
              <% if d != last_date %>
                <div class="flex items-center justify-center pt-2 pb-1">
                  <div class="px-3 py-1 text-[10px] uppercase tracking-[0.18em] text-[#6B665F] bg-[#FBF9F5] border border-[#EFECE6] rounded-full font-medium"><%= relative_date_label(d) %></div>
                </div>
                <% last_date = d %>
              <% end %>

              <div data-controller="thread">
                <%= render "channel_messages/message", message: m %>

                <%# Thread: replies + reply affordances, indented under the avatar. %>
                <% replies = m.replies.sort_by(&:created_at) %>
                <div class="ml-[46px]">
                  <% if replies.any? %>
                    <button type="button" data-action="thread#toggleReplies"
                            class="inline-flex items-center gap-1 text-[11px] text-[#6B665F] hover:text-[#1D1C1A] font-medium">
                      <i class="ri-corner-down-right-line"></i>
                      <%= replies.size %> <%= "reply".pluralize(replies.size) %>
                      <i class="ri-arrow-up-s-line transition-transform" data-thread-target="chevron"></i>
                    </button>
                  <% end %>

                  <div id="channel-message-<%= m.id %>-replies" data-thread-target="replies"
                       class="space-y-1 pl-3 border-l-2 border-[#EFECE6] mt-1">
                    <% replies.each do |r| %>
                      <%= render "channel_messages/message", message: r, reply: true %>
                    <% end %>
                  </div>

                  <% if @can_post %>
                    <button type="button" data-action="thread#openReply"
                            class="mt-1 inline-flex items-center gap-1 text-[11px] text-[#D97757] hover:underline font-medium">
                      <i class="ri-reply-line"></i> Reply
                    </button>
                    <div data-thread-target="form" class="hidden mt-1">
                      <%= form_with url: channel_messages_path(@channel), method: :post, data: { turbo: false } do %>
                        <%= hidden_field_tag :parent_id, m.id %>
                        <div class="flex items-center gap-2 bg-white rounded-2xl pl-3 pr-1.5 py-1 border border-[#EFECE6] shadow-sm">
                          <input type="text" name="body" autocomplete="off"
                                 placeholder="Reply to <%= m.user&.full_name.presence || "message" %>…"
                                 class="flex-1 w-full bg-transparent border-0 focus:outline-none text-[13px] placeholder-[#6B665F] py-1">
                          <button type="submit" title="Send reply"
                                  class="flex-shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white transition">
                            <i class="ri-send-plane-fill text-[13px]"></i>
                          </button>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
          <% if @messages.empty? %>
            <p class="px-5 py-8 text-center text-[13px] text-[#6B665F]">No messages yet. Start the conversation.</p>
          <% end %>
        </div>

        <%# ── Composer / read-only notice ────────────────────── %>
        <div class="border-t border-[#EFECE6] p-3 bg-[#FBF9F5]">
          <% if @can_post %>
            <div data-controller="mention-autocomplete channel-recorder"
                 data-mention-autocomplete-items-value="<%= @mentionables.to_json %>"
                 data-channel-recorder-post-url-value="<%= channel_messages_path(@channel) %>">
              <div class="relative">
                <%# @-mention autocomplete dropdown (opens above the input). %>
                <div data-mention-autocomplete-target="menu"
                     class="hidden absolute bottom-full left-0 mb-2 w-72 max-h-64 overflow-y-auto rounded-2xl border border-[#EFECE6] bg-white shadow-lg py-1 z-50"></div>
                <%= form_with url: channel_messages_path(@channel), method: :post, data: { turbo: false } do %>
                  <div class="flex items-center gap-2 bg-white rounded-3xl pl-4 pr-2 py-2 border border-[#EFECE6] shadow-sm">
                    <input type="text" name="body" autocomplete="off"
                           data-mention-autocomplete-target="input" data-channel-recorder-target="input"
                           placeholder="Message #<%= @channel.slug %> — @ to tag a teammate…"
                           class="flex-1 w-full bg-transparent border-0 focus:outline-none text-[15px] placeholder-[#6B665F] py-2">
                    <button type="button" data-action="channel-recorder#toggleMic" data-channel-recorder-target="micButton"
                            title="Dictate (voice typing)"
                            class="flex-shrink-0 w-9 h-9 rounded-full bg-[#FBF9F5] hover:bg-[#EFECE6] text-[#D97757] flex items-center justify-center transition data-[on=true]:bg-[#D97757] data-[on=true]:text-white">
                      <i class="ri-mic-line text-lg"></i>
                    </button>
                    <button type="button" data-action="channel-recorder#toggleRecord" data-channel-recorder-target="recordButton"
                            title="Record a voice note"
                            class="flex-shrink-0 w-9 h-9 rounded-full bg-[#FBF9F5] hover:bg-[#EFECE6] text-[#D97757] flex items-center justify-center transition data-[on=true]:bg-[#C1403A] data-[on=true]:text-white">
                      <i class="ri-voiceprint-line text-lg"></i>
                    </button>
                    <button type="submit" title="Send"
                            class="flex-shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white shadow-sm active:scale-95 transition">
                      <i class="ri-send-plane-fill text-[16px]"></i>
                    </button>
                  </div>
                <% end %>
                <div data-channel-recorder-target="status" class="hidden mt-1.5 px-2 text-[11px] text-[#C1403A] flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-[#C1403A] animate-pulse"></span>
                  Recording… tap the voiceprint again to send, or
                  <button type="button" data-action="channel-recorder#cancel" class="underline hover:text-[#1D1C1A]">cancel</button>
                </div>
              </div>
            </div>
          <% else %>
            <p class="text-[12px] text-[#6B665F] px-1 py-1 flex items-center gap-1.5">
              <i class="ri-lock-line"></i> You can read #<%= @channel.slug %>, but only its team can post here.
            </p>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</div>
