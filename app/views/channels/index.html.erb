<% content_for :title, "Team chat · ##{@channel&.slug}" %>
<div class="min-h-screen bg-[#FBF9F5]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6">
    <a href="<%= dashboard_path %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to dashboard
    </a>

    <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-4">
      <%# ── Channel list ─────────────────────────────────────── %>
      <aside class="rounded-2xl bg-white border border-[#EFECE6] p-3 h-fit">
        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold px-1 mb-2">Channels</div>
        <ul class="space-y-0.5">
          <% @channels.each do |c| %>
            <% active = (c.id == @channel&.id) %>
            <li>
              <%= link_to channel_path(c),
                    class: "flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-[13px] #{active ? 'bg-[#F0F4FA] text-[#2B4A7A] font-medium' : 'text-[#1D1C1A] hover:bg-[#FBF9F5]'}" do %>
                <span class="text-[#9A938A]">#</span><%= c.slug %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </aside>

      <%# ── Selected channel ─────────────────────────────────── %>
      <section class="rounded-2xl bg-white border border-[#EFECE6] flex flex-col overflow-hidden" style="height: 70vh;">
        <div class="px-5 py-3 border-b border-[#EFECE6]">
          <div class="text-[14px] font-serif text-[#1D1C1A]"># <%= @channel.name %></div>
          <% if @channel.description.present? %>
            <div class="text-[11px] text-[#6B665F] mt-0.5"><%= @channel.description %></div>
          <% end %>
        </div>

        <%= render "channels/thread", channel: @channel, messages: @messages, can_post: @can_post, mentionables: @mentionables %>
      </section>
    </div>
  </div>
</div>
