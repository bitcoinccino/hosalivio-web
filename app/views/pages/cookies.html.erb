<% content_for :title, "Cookie Policy · HosAlivio" %>
<%
  sections = [
    [ "What are cookies?",
      [ "Cookies are small text files a website stores on your device. “Similar technologies” include local storage and session storage, which work in a comparable way. We use both and refer to them together as “cookies” in this policy." ] ],
    [ "How we use cookies",
      [ "We use cookies to:",
        [ "keep you signed in and secure your session;",
          "remember your preferences, such as whether a sidebar is collapsed;",
          "remember that you have acknowledged our cookie notice;",
          "understand how the Service is used so we can improve it, where analytics are enabled." ] ] ],
    [ "Types of cookies we use",
      [ [ "Strictly necessary — required for the Service to function, including authentication and security. The Service will not work properly without them.",
          "Functional — remember your choices and settings to improve your experience.",
          "Analytics / performance — help us understand usage and improve the Service; these are optional." ],
        "We do not use cookies for third-party advertising, and we do not sell information collected through cookies." ] ],
    [ "Third-party cookies",
      [ "Some features rely on trusted service providers (for example, infrastructure or analytics vendors) that may set their own cookies to operate. These providers act on our behalf under contract." ] ],
    [ "Managing cookies",
      [ "Most browsers let you view, block, or delete cookies through their settings, and you can clear local and session storage. Blocking strictly necessary cookies may prevent you from signing in or using parts of the Service. For choices about your health information, contact your hospice agency, which controls that data." ] ],
    [ "Changes to this policy",
      [ "We may update this policy from time to time. If we make material changes, we will update the “Last updated” date." ] ],
    [ "Contact",
      [ "Questions about our use of cookies? Contact HosAlivio at privacy@hosalivio.com." ] ]
  ]
%>
<div class="min-h-screen bg-[#FBF9F5]">
  <%= render "legal_header" %>

  <main class="px-6 lg:px-8 py-10">
    <div class="max-w-3xl mx-auto">
      <div class="mb-6">
        <div class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-[0.2em] text-[#D97757] font-bold mb-2">
          <i class="ri-cookie-line"></i> Legal
        </div>
        <h1 class="font-serif text-3xl md:text-4xl text-[#1D1C1A] leading-tight">Cookie Policy</h1>
        <p class="text-[12px] text-[#6B665F] mt-2">Last updated July 13, 2026</p>
      </div>

      <div class="bg-white rounded-2xl border border-[#EFECE6] p-6 md:p-8">
        <p class="text-[14px] text-[#3A3936] leading-relaxed mb-1">
          This Cookie Policy explains how HosAlivio uses cookies and similar technologies on our websites and platform (the “Service”). It should be read alongside our
          <%= link_to "Privacy Policy", privacy_path, class: "underline hover:text-[#1D1C1A]" %>.
        </p>

        <% sections.each_with_index do |(heading, blocks), i| %>
          <section class="mt-6">
            <h2 class="font-serif text-[19px] text-[#1D1C1A] mb-2"><%= "#{i + 1}. #{heading}" %></h2>
            <% blocks.each do |block| %>
              <% if block.is_a?(Array) %>
                <ul class="list-disc pl-5 text-[14px] text-[#3A3936] leading-relaxed mb-3 space-y-1">
                  <% block.each do |li| %><li><%= li %></li><% end %>
                </ul>
              <% else %>
                <p class="text-[14px] text-[#3A3936] leading-relaxed mb-3"><%= block %></p>
              <% end %>
            <% end %>
          </section>
        <% end %>

        <p class="text-[11px] text-[#6B665F] italic mt-8 pt-4 border-t border-[#EFECE6]">
          This document is provided as a starting point and does not constitute legal advice. Agencies should have their own counsel review it before relying on it.
        </p>
      </div>
    </div>
  </main>

  <%= render "site_footer" %>
</div>
