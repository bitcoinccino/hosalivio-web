              <% end %>
              <!-- Gradient scrim + label -->
              <div class="absolute bottom-0 inset-x-0 p-4 bg-gradient-to-t from-black/65 via-black/20 to-transparent text-white">
                <div class="text-[15px] font-medium leading-tight drop-shadow-sm"><%= agency.name %></div>
                <div class="text-[11px] opacity-90 mt-0.5 font-mono"><%= [agency.city, agency.state].compact.join(", ") %></div>
              </div>
              <!-- Hover overlay: specialties + contact hint -->
              <div class="absolute inset-0 bg-black/55 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition flex flex-col justify-between p-4 text-white">
                <div>
                  <div class="text-[15px] font-medium leading-tight"><%= agency.name %></div>
                  <div class="text-[11px] opacity-80 mt-0.5"><%= [agency.city, agency.state].compact.join(", ") %></div>
                  <div class="mt-3 flex flex-wrap gap-1">
                    <% agency.specialties.first(3).each do |s| %>
                      <span class="text-[10px] uppercase tracking-wider px-2 py-0.5 rounded bg-white/20 border border-white/30">
                        <%= Agency::SPECIALTY_CATALOG[s] || s.humanize %>
                      </span>
                    <% end %>
                  </div>
                  <% if agency.bio.present? %>
                    <p class="text-[12px] opacity-85 mt-3 line-clamp-4"><%= agency.bio %></p>
                  <% end %>
                </div>
                <div class="flex items-center justify-between text-[11px]">
                  <span class="opacity-80"><i class="ri-time-line"></i> ~<%= agency.response_sla_hours %>h</span>
                  <span class="inline-flex items-center gap-1 font-medium">
                    <i class="ri-phone-line"></i> Contact
                  </span>
                </div>
              </div>
            </article>
          <% end %>
        </div>
        </div>
      <% end %>
    </section>

    <!-- Quick-replies: relocated from inside the form to below the carousel -->
    <section class="px-4 md:px-10 pb-4 max-w-3xl mx-auto">
      <%= form_with(url: root_path, method: :get, local: true, html: { class: "" }) do %>
        <div class="text-[11px] uppercase tracking-widest text-[#6B665F] mb-3 text-center">Try a quick ask</div>
        <div class="flex flex-wrap gap-2 justify-center">
          <% [
               "Miami agency that serves Spanish-speaking families",
               "Pediatric hospice in Orlando",
               "Veterans care in North Florida",
               "Dementia specialists with Medicare",
               "LGBTQ+ affirming hospice"
             ].each do |q| %>
            <button type="submit" name="q" value="<%= q %>"
                    class="text-[12px] px-3 py-1.5 rounded-full bg-[#FBF9F5] border border-[#EFECE6] hover:border-[#D97757] hover:bg-[#FFF3EC] text-[#1D1C1A] transition">
              <%= q %>
            </button>
          <% end %>
        </div>
      <% end %>
    </section>

    <!-- HosAlivio's explanation bubble (after the cards + chips) -->
    <% if @match[:agencies].any? || @active_query.present? %>
      <section class="px-4 md:px-10 pb-10">
        <div class="max-w-3xl mx-auto flex items-start gap-3">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-white border border-[#EFECE6] overflow-hidden">
            <%= image_tag "hosalivio_assistant.png", class: "w-full h-full object-cover object-top scale-125 origin-top", alt: "HosAlivio" %>
          </div>
          <div class="bg-white rounded-2xl rounded-tl-md border border-[#EFECE6] px-4 py-2.5 text-[13px] text-[#1D1C1A]">
            <span class="font-bold">HosAlivio:</span> <%= @match[:explanation] %>
          </div>
        </div>
      </section>
    <% end %>

    <!-- Secondary FAQ prompts (still useful for orientation) -->
    <section class="px-4 md:px-10 pb-16 max-w-4xl mx-auto">
      <div class="text-center">
        <div class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-[0.2em] text-[#6B665F] font-bold mb-3">
          <i class="ri-question-answer-line"></i> Not sure what to ask yet?
        </div>
        <h2 class="font-serif text-2xl text-[#1D1C1A] mb-5">Start with a common question.</h2>
      </div>
      <div class="flex flex-wrap gap-2 max-w-3xl mx-auto justify-center">
        <% @starters.each do |s| %>
          <button type="button"
                  data-action="click->welcome#choosePrompt"
                  data-prompt-id="<%= s[:id] %>"
                  class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full bg-white border border-[#EFECE6] hover:border-[#D97757] hover:bg-[#FFF3EC] text-[13px] text-[#1D1C1A] transition">
            <i class="<%= s[:icon] %> text-[#D97757]"></i><%= s[:label] %>
          </button>
        <% end %>
      </div>

      <!-- Conversation thread (invisible until a chip is clicked) -->
      <div class="mt-6 space-y-5 max-w-3xl mx-auto" data-welcome-target="thread"></div>
    </section>
    <% end %>

    <footer class="px-4 md:px-10 py-5 text-center text-[11px] text-[#6B665F]">
      © <%= Date.current.year %> HosAlivio · <a href="#" class="hover:text-[#1D1C1A]">Privacy</a> · <a href="#" class="hover:text-[#1D1C1A]">HIPAA Notice</a>
    </footer>
  </main>

  <!-- ─── Modal: contact form ─────────────────────────────────────── -->
  <div data-welcome-target="capture"
       data-action="keydown.esc@window->welcome#closeCapture click->welcome#backdropClose"
       class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
    <div class="relative w-full max-w-lg bg-white rounded-2xl border border-[#EFECE6] shadow-xl p-6"
         data-welcome-target="captureDialog">
      <button type="button" data-action="click->welcome#closeCapture"
              class="absolute top-3 right-3 w-8 h-8 rounded-full text-[#6B665F] hover:bg-[#EFECE6] flex items-center justify-center">
        <i class="ri-close-line text-lg"></i>
      </button>

      <div class="text-[11px] uppercase tracking-[0.2em] text-[#D97757] font-bold mb-2">
        <i class="ri-map-pin-line"></i> Connect with a Local Care Coordinator
      </div>
      <div data-welcome-target="partnerBanner" class="hidden mb-3 px-3 py-2 rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[13px] text-[#1D1C1A]">
        <i class="ri-send-plane-2-line text-[#D97757]"></i>
        Sending your request to <span class="font-medium" data-welcome-target="partnerBannerName"></span>.
      </div>
      <div class="font-serif text-[16px] text-[#1D1C1A] mb-5">Share a few details to reach our team. A real coordinator, not an AI bot, will review your message and contact you, usually within the hour.</div>

      <%# Field styling is shared; keep it in one place so every input/select matches. %>
      <% field_class = "w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
      <form data-action="submit->welcome#submitCapture" class="space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <input type="text" name="first_name" placeholder="First name" required aria-label="First name" class="<%= field_class %>">
          <input type="text" name="last_name" placeholder="Last name" required aria-label="Last name" class="<%= field_class %>">
        </div>

        <select name="requester_role" aria-label="Your relationship to the patient" class="<%= field_class %> text-[#6B665F]">
          <option value="" selected>Your relationship to the patient (optional)</option>
          <% Inquiry::REQUESTER_ROLE_OPTIONS.each do |role| %>
            <option value="<%= role %>"><%= role %></option>
          <% end %>
        </select>

        <div class="grid grid-cols-2 gap-3">
          <input type="tel" name="caregiver_phone" placeholder="Caregiver phone number" required aria-label="Caregiver phone number"
                 inputmode="tel" class="<%= field_class %>">
          <input type="email" name="email" placeholder="Email address (optional)" aria-label="Email address" class="<%= field_class %>">
        </div>

        <div class="grid grid-cols-2 gap-3">
          <label class="block">
            <span class="block text-[11px] text-[#6B665F] mb-1">Patient date of birth (MM/DD/YYYY)</span>
            <input type="date" name="dob" aria-label="Patient date of birth" class="<%= field_class %>">
          </label>
          <label class="block">
            <span class="block text-[11px] text-[#6B665F] mb-1">Patient ZIP code</span>
            <input type="text" name="zip" placeholder="e.g. 33101" required inputmode="numeric" pattern="[0-9]{5}"
                   aria-label="Patient ZIP code" class="<%= field_class %>">
          </label>
        </div>

        <select name="diagnosis" aria-label="Primary diagnosis or primary concern" class="<%= field_class %> text-[#6B665F]">
          <option value="" selected>Primary diagnosis or primary concern (optional)</option>
          <% Inquiry::DIAGNOSIS_OPTIONS.each do |dx| %>
            <option value="<%= dx %>"><%= dx %></option>
          <% end %>
        </select>

        <div class="pt-3 border-t border-[#EFECE6] space-y-3">
          <div class="flex items-start gap-2 text-[11px] leading-relaxed text-[#6B665F]">
            <i class="ri-lock-2-line text-[#2F6F4E] mt-0.5"></i>
            <span><span class="font-bold text-[#2F6F4E]">Privacy guarantee:</span> This request is confidential, isolated from core medical records, and handled under strict HIPAA privacy safeguards.</span>
          </div>
          <div class="text-right">
            <button type="submit" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium transition">
              <i class="ri-send-plane-fill"></i> Request a Callback
            </button>
          </div>
        </div>
      </form>

      <div data-welcome-target="captureThanks" class="hidden">
        <div class="flex items-start gap-3 text-[#1D1C1A]">
          <i class="ri-check-double-line text-[#D97757] text-2xl"></i>
          <div>
            <div class="font-medium">Got it. A coordinator will reach out shortly. Keep your phone nearby.</div>
            <div class="text-[12px] text-[#3A3936] mt-1">If this is a medical emergency, call 911 now.</div>
          </div>
        </div>
        <div class="mt-5 text-right">
          <button type="button" data-action="click->welcome#closeCapture"
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#1D1C1A] hover:bg-[#3A3936] text-white text-sm font-medium transition">
            Close
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Floating chat bubble removed — the hero "Ask HosAlivio" pill
    is the canonical entry point and now does both Q&A + agency
    lookup. See the welcome-chat Stimulus controller wired into
    that hero form. %>
