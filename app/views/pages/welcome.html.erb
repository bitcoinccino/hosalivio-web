<% content_for :title, "HosAlivio · Find a hospice partner" %>

<div class="flex min-h-screen"
     data-controller="welcome mobile-filters sidebar"
     data-sidebar-storage-key-value="welcomeSidebar"
     data-welcome-prompts-value='<%= @prompts_js.to_json %>'>

  <!-- Mobile filter sheet backdrop (hidden by default) -->
  <div data-mobile-filters-target="backdrop"
       data-action="click->mobile-filters#close"
       class="hidden md:hidden fixed inset-0 z-40 bg-[#1D1C1A]/40 backdrop-blur-sm"></div>

  <!-- ─── Left Sidebar (returning) ─────────────────────────────── -->
  <aside data-mobile-filters-target="panel"
         data-sidebar-target="sidebar"
         data-collapsed="false"
         class="group/sb hidden md:flex w-72 data-[collapsed=true]:w-16 bg-[#EFECE6] border-r border-[#D9D5CD] flex-col justify-start p-6 data-[collapsed=true]:p-3 sticky top-0 h-screen transition-[width,padding] duration-200
                data-[open=true]:flex data-[open=true]:fixed data-[open=true]:inset-y-0 data-[open=true]:left-0 data-[open=true]:z-50 data-[open=true]:w-[88vw] data-[open=true]:max-w-[320px] data-[open=true]:overflow-y-auto">
    <div>
      <div class="flex items-center justify-between gap-2 group-data-[collapsed=true]/sb:flex-col group-data-[collapsed=true]/sb:gap-2">
        <%# Brand acts as the 'Home' button. Clicking it hides any
            currently-revealed section and brings the hero + search
            form back. %>
        <button type="button"
                data-action="click->welcome#showHome"
                title="Back to home"
                class="flex items-center gap-2 hover:opacity-80 transition">
          <div class="w-9 h-9 group-data-[collapsed=true]/sb:w-7 group-data-[collapsed=true]/sb:h-7 rounded-full bg-[#D97757] text-white flex items-center justify-center flex-shrink-0">
            <i class="ri-heart-pulse-line text-lg group-data-[collapsed=true]/sb:text-sm"></i>
          </div>
          <div class="group-data-[collapsed=true]/sb:hidden text-left">
            <h1 class="text-xs uppercase tracking-[0.2em] text-[#6B665F] font-bold">HosAlivio</h1>
            <div class="text-[10px] text-[#6B665F] italic -mt-0.5">Comfort Care on the Go</div>
          </div>
        </button>
        <%# Desktop sidebar collapse toggle: matches the in-app patient sidebar. %>
        <button type="button"
                data-action="click->sidebar#toggle"
                title="Toggle sidebar"
                class="hidden md:flex w-7 h-7 rounded-full hover:bg-[#D9D5CD] text-[#6B665F] hover:text-[#1D1C1A] items-center justify-center flex-shrink-0 transition">
          <i class="ri-side-bar-line text-[15px]"></i>
        </button>
        <%# Mobile-only close (the filter sheet panel). %>
        <button type="button" data-action="click->mobile-filters#close"
                class="md:hidden w-8 h-8 rounded-full hover:bg-[#D9D5CD] text-[#6B665F] flex items-center justify-center"
                title="Close filters">
          <i class="ri-close-line text-lg"></i>
        </button>
      </div>

      <%# Section nav: each row reveals the matching content section in
          the main column. Sections are hidden until a row is clicked.
          The nav carries data-active-section, which the per-row
          group-data-[active-section=…]/nav: variants use to paint the
          active row in HosAlivio terracotta. %>
      <nav data-welcome-target="nav"
           data-active-section="home"
           class="group/nav mt-6 space-y-1">
        <button type="button"
                data-action="click->welcome#showHome"
                title="Home"
                class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left text-[13px] text-[#1D1C1A] hover:bg-[#D9D5CD] transition
                       group-data-[active-section=home]/nav:bg-[#FFF3EC] group-data-[active-section=home]/nav:text-[#D97757]
                       group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <span class="w-7 h-7 rounded-full bg-white border border-[#D9D5CD] flex items-center justify-center flex-shrink-0 text-[#1D1C1A]
                       group-data-[active-section=home]/nav:text-[#D97757] group-data-[active-section=home]/nav:border-[#D97757]">
            <i class="ri-home-4-line"></i>
          </span>
          <span class="flex-1 group-data-[collapsed=true]/sb:hidden">Home</span>
        </button>

        <button type="button"
                data-action="click->welcome#showFamily"
                title="For families"
                class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left text-[13px] text-[#1D1C1A] hover:bg-[#D9D5CD] transition
                       group-data-[active-section=family]/nav:bg-[#FFF3EC] group-data-[active-section=family]/nav:text-[#D97757]
                       group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <span class="w-7 h-7 rounded-full bg-white border border-[#D9D5CD] flex items-center justify-center flex-shrink-0 text-[#1D1C1A]
                       group-data-[active-section=family]/nav:text-[#D97757] group-data-[active-section=family]/nav:border-[#D97757]">
            <i class="ri-user-heart-line"></i>
          </span>
          <span class="flex-1 group-data-[collapsed=true]/sb:hidden">For families</span>
        </button>

        <button type="button"
                data-action="click->welcome#showPartner"
                title="For partners"
                class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left text-[13px] text-[#1D1C1A] hover:bg-[#D9D5CD] transition
                       group-data-[active-section=partner]/nav:bg-[#FFF3EC] group-data-[active-section=partner]/nav:text-[#D97757]
                       group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <span class="w-7 h-7 rounded-full bg-white border border-[#D9D5CD] flex items-center justify-center flex-shrink-0 text-[#1D1C1A]
                       group-data-[active-section=partner]/nav:text-[#D97757] group-data-[active-section=partner]/nav:border-[#D97757]">
            <i class="ri-hospital-line"></i>
          </span>
          <span class="flex-1 group-data-[collapsed=true]/sb:hidden">For partners</span>
        </button>

        <button type="button"
                data-action="click->welcome#showFaq"
                title="FAQ"
                class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left text-[13px] text-[#1D1C1A] hover:bg-[#D9D5CD] transition
                       group-data-[active-section=faq]/nav:bg-[#FFF3EC] group-data-[active-section=faq]/nav:text-[#D97757]
                       group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <span class="w-7 h-7 rounded-full bg-white border border-[#D9D5CD] flex items-center justify-center flex-shrink-0 text-[#1D1C1A]
                       group-data-[active-section=faq]/nav:text-[#D97757] group-data-[active-section=faq]/nav:border-[#D97757]">
            <i class="ri-question-answer-line"></i>
          </span>
          <span class="flex-1 group-data-[collapsed=true]/sb:hidden">FAQ</span>
        </button>

        <%# Pricing page link — opens the full /pricing page in
            the same tab. Distinct from the showHome / showFamily
            buttons above because it's a separate route, not a
            section reveal on the welcome page. %>
        <%= link_to pricing_path,
              title: "Pricing",
              class: "w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left text-[13px] text-[#1D1C1A] hover:bg-[#D9D5CD] transition
                      group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0" do %>
          <span class="w-7 h-7 rounded-full bg-white border border-[#D9D5CD] flex items-center justify-center flex-shrink-0 text-[#1D1C1A]">
            <i class="ri-price-tag-3-line"></i>
          </span>
          <span class="flex-1 group-data-[collapsed=true]/sb:hidden">Pricing</span>
        <% end %>
      </nav>

      <div class="mt-6 rounded-lg bg-[#FBF9F5] border border-[#D9D5CD] p-3 group-data-[collapsed=true]/sb:hidden">
        <div class="inline-flex items-center gap-1.5 text-[10px] uppercase tracking-widest text-[#6B665F] mb-1 font-bold">
          <i class="ri-shield-check-line"></i> Private
        </div>
        <p class="text-[11px] text-[#6B665F] leading-snug">
          Nothing you type is saved to a patient chart unless you explicitly ask us to reach out.
        </p>
      </div>
    </div>

  </aside>

  <!-- ─── Main Stage: Directory + AI Guide ─────────────────────── -->
  <main class="flex-1 overflow-y-auto min-w-0 flex flex-col">
    <!-- Mobile-only top bar: hamburger + brand + Sign in -->
    <div class="md:hidden flex items-center justify-between px-4 pt-3 pb-2 border-b border-[#EFECE6]">
      <div class="flex items-center gap-2">
        <%# Hamburger — opens the left nav / directory panel on small screens. %>
        <button type="button" data-action="click->mobile-filters#open"
                aria-label="Open menu" title="Menu"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-[#D9D5CD] text-[#1D1C1A] hover:bg-[#EFECE6]">
          <i class="ri-menu-line text-lg"></i>
        </button>
        <%# Brand hidden on small screens — the hamburger opens the sidebar,
            which carries the HosAlivio brand, so repeating it here just
            crowds the bar. %>
        <div class="hidden sm:flex w-8 h-8 rounded-full bg-[#D97757] text-white items-center justify-center">
          <i class="ri-heart-pulse-line text-sm"></i>
        </div>
        <h1 class="hidden sm:block text-xs uppercase tracking-[0.2em] text-[#1D1C1A] font-bold">HosAlivio</h1>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to new_user_session_path,
              class: "inline-flex items-center gap-1 text-[12px] font-medium px-3 py-1.5 rounded-full bg-[#1D1C1A] text-[#FBF9F5]" do %>
          <i class="ri-login-box-line"></i> Sign in
        <% end %>
        <%= link_to new_partner_path,
              class: "inline-flex items-center gap-1 text-[12px] font-medium px-3 py-1.5 rounded-full bg-[#D97757] text-white" do %>
          <i class="ri-user-add-line"></i> Sign up
        <% end %>
      </div>
    </div>

    <!-- Top-right sign-in / sign-up bar (desktop only) -->
    <div class="hidden md:flex justify-end items-center gap-2 px-10 pt-4">
      <%= link_to new_user_session_path,
            class: "inline-flex items-center gap-1.5 text-[13px] font-medium px-3.5 py-1.5 rounded-full bg-[#1D1C1A] text-[#FBF9F5] hover:bg-[#3A3936] transition" do %>
        <i class="ri-login-box-line"></i> Sign in
      <% end %>
      <%= link_to new_partner_path,
            class: "inline-flex items-center gap-1.5 text-[13px] font-medium px-3.5 py-1.5 rounded-full bg-[#D97757] text-white hover:bg-[#c46a4b] transition" do %>
        <i class="ri-user-add-line"></i> Sign up
      <% end %>
    </div>

    <%# Hero + search form. Vertically centered in whatever vertical
        space is left between the top nav and the footer. Welcome
        controller hides this whole block (#hero) when a sidebar nav
        row is clicked, so only the chosen section is visible. The
        sidebar brand/logo brings it back. %>
    <div id="hero" class="flex-1 flex flex-col items-center justify-center w-full">

    <!-- Hero -->
    <section class="px-4 md:px-10 pt-4 pb-4 w-full">
      <div class="max-w-3xl mx-auto text-center">
        <div class="font-serif text-3xl md:text-4xl text-[#D97757] font-bold tracking-tight mb-4">
          HosAlivio
        </div>
        <%# Typewriter tagline — types itself out on first paint
            with a short pause between the two beats. Honors
            prefers-reduced-motion (just renders the final string). %>
        <h1 class="font-serif text-3xl md:text-4xl leading-tight text-[#1D1C1A] mb-3 min-h-[1.5em]"
            data-controller="typewriter"
            data-typewriter-phrases-value='["Care that hears you.","Relief that lasts.","Hospice Redefined.","Your voice guides our care."]'
            data-typewriter-speed-value="55"
            data-typewriter-erase-speed-value="32"
            data-typewriter-hold-value="1600"
            aria-label="Care that hears you. Relief that lasts. Hospice Redefined. Your voice guides our care."></h1>
        <p class="text-[15px] text-[#3A3936] mx-auto max-w-2xl leading-relaxed italic">
          Even when the rest of the world is asleep.
        </p>
      </div>
    </section>

    <!-- Ask HosAlivio chat — composer pill + inline transcript.
         Single entry point: Q&A goes through /public_chat, agency
         lookup through /public_chat/agencies. JS detects a 5-digit
         ZIP (or "in <City>") and fires both calls in parallel so
         partner agency cards show up alongside the friendly answer. -->
    <section class="px-4 md:px-10 pt-4 pb-6 w-full">
      <div class="max-w-3xl mx-auto"
           data-controller="welcome-chat"
           data-welcome-chat-url-value="<%= public_chat_path %>"
           data-welcome-chat-agencies-url-value="<%= public_chat_agencies_path %>"
           data-welcome-chat-feedback-url-value="<%= public_chat_feedback_path %>">

        <%# Transcript area — fills as turns happen. Empty by
            default so the composer leads the page; the assistant
            only speaks once the visitor sends their first message. %>
        <div data-welcome-chat-target="transcript"
             class="space-y-4 mb-4 max-h-[60vh] overflow-y-auto px-1"></div>

        <%# Composer pill — visually mirrors the patient-dashboard
            chat composer (rounded shape, avatar on the left, big
            terracotta send button on the right). %>
        <%# Composer with no explicit send button — submission rides
            on Enter (the form's submit handler stays the same).
            Avatar is the same orange heart-pulse mark used in the
            sidebar header + assistant chat bubbles. The hidden
            send target stays so the JS can still toggle disabled
            during in-flight requests. %>
        <form data-welcome-chat-target="form"
              data-action="submit->welcome-chat#ask"
              class="flex items-center gap-3 bg-white rounded-full border border-[#EFECE6] focus-within:border-[#D97757] transition-colors pl-3 pr-4 py-2">
          <input type="hidden" name="audience" value="family" data-welcome-chat-target="audience">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#D97757] text-white flex items-center justify-center">
            <i class="ri-heart-pulse-line text-lg"></i>
          </div>
          <input type="text" name="q"
                 data-welcome-chat-target="input"
                 autocomplete="off"
                 class="flex-1 bg-transparent border-0 focus:outline-none text-[15px] placeholder-[#6B665F] py-2"
                 placeholder="Ask anything about hospice">
          <button type="submit" data-welcome-chat-target="send" class="hidden" aria-hidden="true"></button>
        </form>

        <%# Starter prompts — plain stacked text that fills the composer and
            asks on click. Kept visually as text (not chips), but each is a
            button so tapping one starts the conversation. Hidden after the
            first turn so they don't keep occupying space. %>
        <div data-welcome-chat-target="quickStart"
             class="flex flex-col items-start gap-1.5 mt-4 text-[#6B665F] text-[14px] italic">
          <button type="button"
                  data-action="click->welcome-chat#pick"
                  data-welcome-chat-question-param="What does hospice cost?"
                  class="inline-flex items-center gap-1.5 text-left hover:text-[#D97757] transition-colors">
            <i class="ri-money-dollar-circle-line text-[15px] not-italic"></i>
            <span>What does hospice cost?</span>
          </button>
          <button type="button"
                  data-action="click->welcome-chat#pick"
                  data-welcome-chat-question-param="Can care happen at home?"
                  class="inline-flex items-center gap-1.5 text-left hover:text-[#D97757] transition-colors">
            <i class="ri-home-heart-line text-[15px] not-italic"></i>
            <span>Can care happen at home?</span>
          </button>
          <button type="button"
                  data-action="click->welcome-chat#pick"
                  data-welcome-chat-question-param="How do we get started?"
                  class="inline-flex items-center gap-1.5 text-left hover:text-[#D97757] transition-colors">
            <i class="ri-route-line text-[15px] not-italic"></i>
            <span>How do we get started?</span>
          </button>
        </div>
      </div>
    </section>

    </div><%# end vertical-center wrapper %>

    <%# === Removed below the form: partner carousel, freeform Q&A, AI explanation =====
        Replaced with hospice-focused benefit sections + a Family/Partner FAQ toggle.
        The Medicare Hospice Benefit (6-month terminal prognosis) is the only legal
        path the platform supports. =================================================== %>

    <!-- Benefits: slide toggle between patients and partners -->
    <%# Hidden by default; sidebar nav (welcome#showFamily / showPartner)
        un-hides this and sets data-audience to the right panel. %>
    <section id="benefits"
             class="hidden group/aud px-4 md:px-10 pt-2 pb-12 max-w-5xl mx-auto scroll-mt-8"
             data-controller="faq-toggle"
             data-audience="family">

      <%# Slide toggle: animated background pill slides between the two
          options as data-audience flips. Track is fixed-width (300px)
          so the indicator math is exact. %>
      <div class="flex justify-center mb-6">
        <div class="relative inline-flex w-[300px] rounded-full bg-[#FBF9F5] border border-[#EFECE6] p-1 text-[13px]">
          <span aria-hidden="true"
                class="absolute top-1 bottom-1 left-1 w-[calc(50%-0.25rem)] rounded-full bg-[#1D1C1A] shadow-sm transition-transform duration-300 ease-out
                       group-data-[audience=partner]/aud:translate-x-full"></span>
          <button type="button"
                  data-action="click->faq-toggle#show"
                  data-audience="family"
                  class="relative z-10 flex-1 px-4 py-2 rounded-full font-medium transition-colors
                         group-data-[audience=family]/aud:text-white
                         group-data-[audience=partner]/aud:text-[#6B665F]
                         group-data-[audience=partner]/aud:hover:text-[#1D1C1A]">
            <i class="ri-user-heart-line mr-1"></i> For families
          </button>
          <button type="button"
                  data-action="click->faq-toggle#show"
                  data-audience="partner"
                  class="relative z-10 flex-1 px-4 py-2 rounded-full font-medium transition-colors
                         group-data-[audience=partner]/aud:text-white
                         group-data-[audience=family]/aud:text-[#6B665F]
                         group-data-[audience=family]/aud:hover:text-[#1D1C1A]">
            <i class="ri-hospital-line mr-1"></i> For partners
          </button>
        </div>
      </div>

      <%# Family panel: shown when audience=family, hidden when partner. %>
      <div class="group-data-[audience=partner]/aud:hidden">
        <div class="text-center mb-8">
          <h2 class="font-serif text-[28px] md:text-[32px] text-[#1D1C1A] leading-tight">Hospice care that actually picks up at 2 a.m.</h2>
          <p class="text-[14px] text-[#6B665F] mt-3 max-w-2xl mx-auto leading-relaxed">
            When the morphine isn't working or you just need someone to hear what's happening,
            HosAlivio puts your nurse, doctor, chaplain, and aide one message away by voice or text.
            Covered by the Medicare Hospice Benefit. No out-of-pocket cost.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <%
            family_benefits = [
              { icon: "ri-mic-line",                title: "Don't describe it. Let us hear it.",
                body: "Hold the phone near Mom and tap record. Your nurse hears the exact rasp, the cough, the silence between breaths, instead of you struggling to find the words." },
              { icon: "ri-customer-service-2-line", title: "The right human, right now.",
                body: "Smart routing, human response. HosAlivio instantly pages the exact clinician you need, Pascal (RN), Dr. Esther, or Chaplain Geoginio, and you see exactly who picked up and when." },
              { icon: "ri-shield-check-line",       title: "100% covered. Zero out-of-pocket.",
                body: "When a physician confirms eligibility, the Medicare hospice benefit covers care, medications, and equipment. You focus on family; we handle the paperwork." },
              { icon: "ri-home-heart-line",         title: "Home is where the heart stays.",
                body: "We bring the care to your bedside, so you stay exactly where you belong: in your bed, in your room, surrounded by your people." }
            ]
          %>
          <% family_benefits.each do |b| %>
            <div class="rounded-2xl bg-white border border-[#EFECE6] p-5 hover:shadow-sm transition">
              <div class="w-10 h-10 rounded-full bg-[#FFF3EC] text-[#D97757] flex items-center justify-center mb-3">
                <i class="<%= b[:icon] %> text-lg"></i>
              </div>
              <div class="font-serif text-[16px] text-[#1D1C1A] mb-1"><%= b[:title] %></div>
              <p class="text-[13px] text-[#3A3936] leading-relaxed"><%= b[:body] %></p>
            </div>
          <% end %>
        </div>
      </div>

      <%# Partner panel: shown when audience=partner. %>
      <div class="hidden group-data-[audience=partner]/aud:block">
        <div class="text-center mb-8">
          <h2 class="font-serif text-[28px] md:text-[32px] text-[#1D1C1A] leading-tight">Run your agency at scale, not at its breaking point.</h2>
          <p class="text-[14px] text-[#6B665F] mt-3 max-w-2xl mx-auto leading-relaxed">
            HosAlivio is the intelligent front door for your hospice. We triage family
            messages, automate CMS-compliant charting, and protect your revenue, so your
            nurses can get back to being nurses.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <%
            partner_benefits = [
              { icon: "ri-customer-service-2-line", title: "Triage that actually saves your on-call.",
                body: "Stop paging your RNs for non-clinical noise. HosAlivio answers family chats in seconds, classifies urgency, and only interrupts your on-call team when a human touch is required.",
                result: "A 40% reduction in unnecessary after-hours pings." },
              { icon: "ri-file-shield-2-line",      title: "Survey-ready charting, drafted in real-time.",
                body: "Our AI transforms visit narratives and pre-admit evaluations into structured, CMS-compliant JSON and text. It captures the clinical decline required for reimbursement, minimizing ADR (Additional Documentation Request) risks.",
                result: "Audit-proof documentation that's finished before the clinician leaves the driveway." },
              { icon: "ri-time-line",               title: "Defend your NOE (Notice of Election) window.",
                body: "The 5-day clock is ruthless. HosAlivio tracks the timeline from the moment the MD certifies, alerting your billing team and preparing the files to ensure you never miss a reimbursement day.",
                result: "No more \"untimely filing\" penalties." },
              { icon: "ri-stack-line",              title: "Integrated or standalone: your choice.",
                body: "We don't replace your EMR; we make it smarter. HosAlivio hooks directly into Homecare Homebase, Netsmart, MatrixCare, and WellSky via secure API, or runs as a high performance standalone for growing teams.",
                result: nil }
            ]
          %>
          <% partner_benefits.each do |b| %>
            <div class="rounded-2xl bg-white border border-[#EFECE6] p-5 hover:shadow-sm transition flex flex-col">
              <div class="w-10 h-10 rounded-full bg-[#FBF9F5] border border-[#EFECE6] text-[#2F6F4E] flex items-center justify-center mb-3">
                <i class="<%= b[:icon] %> text-lg"></i>
              </div>
              <div class="font-serif text-[16px] text-[#1D1C1A] mb-1"><%= b[:title] %></div>
              <p class="text-[13px] text-[#3A3936] leading-relaxed flex-1"><%= b[:body] %></p>
              <% if b[:result] %>
                <div class="mt-3 pt-3 border-t border-[#EFECE6] inline-flex items-start gap-1.5 text-[12px] text-[#2F6F4E] font-medium">
                  <i class="ri-arrow-right-circle-line mt-0.5 flex-shrink-0"></i>
                  <span><strong class="uppercase tracking-widest text-[10px] mr-1">Result:</strong><%= b[:result] %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
        <%# ── ROI block ─ static "what a typical 10-nurse agency
            saves" panel + an interactive slider calculator that
            updates the totals + headline live. Numbers calibrated
            so the default state (10 nurses · 25% turnover) matches
            the static example above. %>
        <div class="mt-12 max-w-4xl mx-auto">
          <div class="text-center mb-6">
            <div class="inline-flex items-center gap-1.5 text-[10px] uppercase tracking-[0.2em] text-[#2F6F4E] font-bold mb-2">
