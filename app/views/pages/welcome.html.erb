<% content_for :title, "HosAlivio · Find a hospice partner" %>

<div class="flex min-h-screen"
     data-controller="welcome mobile-filters sidebar"
     data-sidebar-storage-key-value="welcomeSidebar"
     data-welcome-prompts-value='<%= @prompts_js.to_json %>'>

  <!-- Mobile filter sheet backdrop (hidden by default) -->
  <div data-mobile-filters-target="backdrop"
       data-action="click->mobile-filters#close"
       class="hidden md:hidden fixed inset-0 z-40 bg-[#1D1C1A]/40 backdrop-blur-sm"></div>

  <!-- ─── Left Sidebar (returning) ─────────────────────────────── -->
  <aside data-mobile-filters-target="panel"
         data-sidebar-target="sidebar"
         data-collapsed="false"
         class="group/sb hidden md:flex w-72 data-[collapsed=true]:w-16 bg-[#EFECE6] border-r border-[#D9D5CD] flex-col justify-start p-6 data-[collapsed=true]:p-3 sticky top-0 h-screen transition-[width,padding] duration-200
                data-[open=true]:flex data-[open=true]:fixed data-[open=true]:inset-y-0 data-[open=true]:left-0 data-[open=true]:z-50 data-[open=true]:w-[88vw] data-[open=true]:max-w-[320px] data-[open=true]:overflow-y-auto">
    <div>
      <div class="flex items-center justify-between gap-2 group-data-[collapsed=true]/sb:flex-col group-data-[collapsed=true]/sb:gap-2">
        <%# Brand acts as the 'Home' button. Clicking it hides any
            currently-revealed section and brings the hero + search
            form back. %>
        <button type="button"
                data-action="click->welcome#showHome"
                title="Back to home"
                class="flex items-center gap-2 hover:opacity-80 transition">
          <div class="w-9 h-9 group-data-[collapsed=true]/sb:w-7 group-data-[collapsed=true]/sb:h-7 rounded-full bg-[#D97757] text-white flex items-center justify-center flex-shrink-0">
            <i class="ri-heart-pulse-line text-lg group-data-[collapsed=true]/sb:text-sm"></i>
          </div>
          <div class="group-data-[collapsed=true]/sb:hidden text-left">
            <h1 class="text-xs uppercase tracking-[0.2em] text-[#6B665F] font-bold">HosAlivio</h1>
            <div class="text-[10px] text-[#6B665F] italic -mt-0.5">Comfort Care on the Go</div>
          </div>
        </button>
        <%# Desktop sidebar collapse toggle: matches the in-app patient sidebar. %>
        <button type="button"
                data-action="click->sidebar#toggle"
                title="Toggle sidebar"
                class="hidden md:flex w-7 h-7 rounded-full hover:bg-[#D9D5CD] text-[#6B665F] hover:text-[#1D1C1A] items-center justify-center flex-shrink-0 transition">
          <i class="ri-side-bar-line text-[15px]"></i>
        </button>
        <%# Mobile-only close (the filter sheet panel). %>
        <button type="button" data-action="click->mobile-filters#close"
                class="md:hidden w-8 h-8 rounded-full hover:bg-[#D9D5CD] text-[#6B665F] flex items-center justify-center"
                title="Close filters">
          <i class="ri-close-line text-lg"></i>
        </button>
      </div>

      <p class="mt-6 pb-5 border-b border-[#D9D5CD] text-[13px] text-[#3A3936] leading-relaxed group-data-[collapsed=true]/sb:hidden">
        Gentle, expert hospice care. Covered by Medicare. Always at home.
      </p>

      <%# Section nav: each row reveals the matching content section in
          the main column. Sections are hidden until a row is clicked.
          The nav carries data-active-section, which the per-row
          group-data-[active-section=…]/nav: variants use to paint the
          active row in HosAlivio terracotta. %>
      <nav data-welcome-target="nav"
           data-active-section="home"
           class="group/nav mt-6 space-y-1">
        <button type="button"
                data-action="click->welcome#showHome"
                title="Home"
                class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left text-[13px] text-[#1D1C1A] hover:bg-[#D9D5CD] transition
                       group-data-[active-section=home]/nav:bg-[#FFF3EC] group-data-[active-section=home]/nav:text-[#D97757]
                       group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <span class="w-7 h-7 rounded-full bg-white border border-[#D9D5CD] flex items-center justify-center flex-shrink-0 text-[#1D1C1A]
                       group-data-[active-section=home]/nav:text-[#D97757] group-data-[active-section=home]/nav:border-[#D97757]">
            <i class="ri-home-4-line"></i>
          </span>
          <span class="flex-1 group-data-[collapsed=true]/sb:hidden">Home</span>
        </button>

        <button type="button"
                data-action="click->welcome#showFamily"
                title="For families"
                class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left text-[13px] text-[#1D1C1A] hover:bg-[#D9D5CD] transition
                       group-data-[active-section=family]/nav:bg-[#FFF3EC] group-data-[active-section=family]/nav:text-[#D97757]
                       group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <span class="w-7 h-7 rounded-full bg-white border border-[#D9D5CD] flex items-center justify-center flex-shrink-0 text-[#D97757]
                       group-data-[active-section=family]/nav:border-[#D97757]">
            <i class="ri-user-heart-line"></i>
          </span>
          <span class="flex-1 group-data-[collapsed=true]/sb:hidden">For families</span>
        </button>

        <button type="button"
                data-action="click->welcome#showPartner"
                title="For partners"
                class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left text-[13px] text-[#1D1C1A] hover:bg-[#D9D5CD] transition
                       group-data-[active-section=partner]/nav:bg-[#FFF3EC] group-data-[active-section=partner]/nav:text-[#D97757]
                       group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <span class="w-7 h-7 rounded-full bg-white border border-[#D9D5CD] flex items-center justify-center flex-shrink-0 text-[#2F6F4E]
                       group-data-[active-section=partner]/nav:text-[#D97757] group-data-[active-section=partner]/nav:border-[#D97757]">
            <i class="ri-hospital-line"></i>
          </span>
          <span class="flex-1 group-data-[collapsed=true]/sb:hidden">For partners</span>
        </button>

        <button type="button"
                data-action="click->welcome#showFaq"
                title="FAQ"
                class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-left text-[13px] text-[#1D1C1A] hover:bg-[#D9D5CD] transition
                       group-data-[active-section=faq]/nav:bg-[#FFF3EC] group-data-[active-section=faq]/nav:text-[#D97757]
                       group-data-[collapsed=true]/sb:justify-center group-data-[collapsed=true]/sb:px-0">
          <span class="w-7 h-7 rounded-full bg-white border border-[#D9D5CD] flex items-center justify-center flex-shrink-0 text-[#6B665F]
                       group-data-[active-section=faq]/nav:text-[#D97757] group-data-[active-section=faq]/nav:border-[#D97757]">
            <i class="ri-question-answer-line"></i>
          </span>
          <span class="flex-1 group-data-[collapsed=true]/sb:hidden">FAQ</span>
        </button>
      </nav>

      <div class="mt-6 rounded-lg bg-[#FBF9F5] border border-[#D9D5CD] p-3 group-data-[collapsed=true]/sb:hidden">
        <div class="inline-flex items-center gap-1.5 text-[10px] uppercase tracking-widest text-[#6B665F] mb-1 font-bold">
          <i class="ri-shield-check-line"></i> Private
        </div>
        <p class="text-[11px] text-[#6B665F] leading-snug">
          Nothing you type is saved to a patient chart unless you explicitly ask us to reach out.
        </p>
      </div>
    </div>

  </aside>

  <!-- ─── Main Stage: Directory + AI Guide ─────────────────────── -->
  <main class="flex-1 overflow-y-auto min-w-0 flex flex-col">
    <!-- Mobile-only top bar: brand + Filter trigger + Sign in -->
    <div class="md:hidden flex items-center justify-between px-4 pt-3 pb-2 border-b border-[#EFECE6]">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-full bg-[#D97757] text-white flex items-center justify-center">
          <i class="ri-heart-pulse-line text-sm"></i>
        </div>
        <h1 class="text-xs uppercase tracking-[0.2em] text-[#1D1C1A] font-bold">HosAlivio</h1>
      </div>
      <div class="flex items-center gap-2">
        <button type="button" data-action="click->mobile-filters#open"
                class="inline-flex items-center gap-1 text-[12px] px-3 py-1.5 rounded-full border border-[#D9D5CD] text-[#1D1C1A] hover:bg-[#EFECE6]">
          <i class="ri-filter-3-line"></i> Filter
        </button>
        <%= link_to new_user_session_path,
              class: "inline-flex items-center gap-1 text-[12px] font-medium px-3 py-1.5 rounded-full bg-[#1D1C1A] text-[#FBF9F5]" do %>
          <i class="ri-login-box-line"></i> Sign in
        <% end %>
        <%= link_to new_partner_path,
              class: "inline-flex items-center gap-1 text-[12px] font-medium px-3 py-1.5 rounded-full bg-[#D97757] text-white" do %>
          <i class="ri-user-add-line"></i> Sign up
        <% end %>
      </div>
    </div>

    <!-- Top-right sign-in / sign-up bar (desktop only) -->
    <div class="hidden md:flex justify-end items-center gap-2 px-10 pt-4">
      <%= link_to new_user_session_path,
            class: "inline-flex items-center gap-1.5 text-[13px] font-medium px-3.5 py-1.5 rounded-full bg-[#1D1C1A] text-[#FBF9F5] hover:bg-[#3A3936] transition" do %>
        <i class="ri-login-box-line"></i> Sign in
      <% end %>
      <%= link_to new_partner_path,
            class: "inline-flex items-center gap-1.5 text-[13px] font-medium px-3.5 py-1.5 rounded-full bg-[#D97757] text-white hover:bg-[#c46a4b] transition" do %>
        <i class="ri-user-add-line"></i> Sign up
      <% end %>
    </div>

    <%# Hero + search form. Vertically centered in whatever vertical
        space is left between the top nav and the footer. Welcome
        controller hides this whole block (#hero) when a sidebar nav
        row is clicked, so only the chosen section is visible. The
        sidebar brand/logo brings it back. %>
    <div id="hero" class="flex-1 flex flex-col items-center justify-center w-full">

    <!-- Hero -->
    <section class="px-4 md:px-10 pt-4 pb-4 w-full">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-[0.2em] text-[#D97757] font-bold mb-3">
          <i class="ri-sparkling-2-line"></i> Care That Listens · HosAlivio
        </div>
        <h1 class="font-serif text-3xl md:text-4xl leading-tight text-[#1D1C1A] mb-2">
          Hospice care that picks up the phone.
        </h1>
        <p class="text-[15px] text-[#3A3936] mx-auto max-w-2xl leading-relaxed">
          Tell HosAlivio what you need, in plain English. We match you with a vetted Medicare hospice partner near you, then your nurse, doctor, and chaplain are one message away.
        </p>
      </div>
    </section>

    <!-- HosAlivio Co-Pilot search -->
    <section class="px-4 md:px-10 pt-4 pb-6 w-full">
      <%= form_with(url: root_path, method: :get, local: true, html: { class: "max-w-3xl mx-auto" }) do %>
        <% Array(params[:specialty]).each { |v| %>
          <%= hidden_field_tag "specialty[]", v %>
        <% } %>
        <% Array(params[:insurance]).each { |v| %>
          <%= hidden_field_tag "insurance[]", v %>
        <% } %>
        <% Array(params[:language]).each { |v| %>
          <%= hidden_field_tag "language[]", v %>
        <% } %>
        <% if params[:zip].present? %>
          <%= hidden_field_tag :zip, params[:zip] %>
        <% end %>

        <div class="flex items-center gap-3 bg-white rounded-full border border-[#EFECE6] shadow-sm pl-3 pr-2 py-2">
          <div class="flex-shrink-0 w-10 h-10 rounded-full overflow-hidden bg-white border border-[#EFECE6]">
            <%= image_tag "hosalivio_assistant.png", class: "w-full h-full object-cover object-top scale-125 origin-top", alt: "HosAlivio" %>
          </div>
          <input type="text" name="q" value="<%= @active_query %>"
                 class="flex-1 bg-transparent border-0 focus:outline-none text-[15px] placeholder-[#6B665F] py-2"
                 placeholder="e.g. Miami agency with dementia care that accepts Medicare">
          <button type="submit" class="inline-flex items-center gap-1.5 px-4 h-9 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium transition">
            <i class="ri-search-line"></i> Ask HosAlivio
          </button>
        </div>

      <% end %>
    </section>

    </div><%# end vertical-center wrapper %>

    <%# === Removed below the form: partner carousel, freeform Q&A, AI explanation =====
        Replaced with hospice-focused benefit sections + a Family/Partner FAQ toggle.
        The Medicare Hospice Benefit (6-month terminal prognosis) is the only legal
        path the platform supports. =================================================== %>

    <!-- Benefits: slide toggle between patients and partners -->
    <%# Hidden by default; sidebar nav (welcome#showFamily / showPartner)
        un-hides this and sets data-audience to the right panel. %>
    <section id="benefits"
             class="hidden group/aud px-4 md:px-10 pt-2 pb-12 max-w-5xl mx-auto scroll-mt-8"
             data-controller="faq-toggle"
             data-audience="family">

      <%# Slide toggle: animated background pill slides between the two
          options as data-audience flips. Track is fixed-width (300px)
          so the indicator math is exact. %>
      <div class="flex justify-center mb-6">
        <div class="relative inline-flex w-[300px] rounded-full bg-[#FBF9F5] border border-[#EFECE6] p-1 text-[13px]">
          <span aria-hidden="true"
                class="absolute top-1 bottom-1 left-1 w-[calc(50%-0.25rem)] rounded-full bg-[#1D1C1A] shadow-sm transition-transform duration-300 ease-out
                       group-data-[audience=partner]/aud:translate-x-full"></span>
          <button type="button"
                  data-action="click->faq-toggle#show"
                  data-audience="family"
                  class="relative z-10 flex-1 px-4 py-2 rounded-full font-medium transition-colors
                         group-data-[audience=family]/aud:text-white
                         group-data-[audience=partner]/aud:text-[#6B665F]
                         group-data-[audience=partner]/aud:hover:text-[#1D1C1A]">
            <i class="ri-user-heart-line mr-1"></i> For families
          </button>
          <button type="button"
                  data-action="click->faq-toggle#show"
                  data-audience="partner"
                  class="relative z-10 flex-1 px-4 py-2 rounded-full font-medium transition-colors
                         group-data-[audience=partner]/aud:text-white
                         group-data-[audience=family]/aud:text-[#6B665F]
                         group-data-[audience=family]/aud:hover:text-[#1D1C1A]">
            <i class="ri-hospital-line mr-1"></i> For partners
          </button>
        </div>
      </div>

      <%# Family panel: shown when audience=family, hidden when partner. %>
      <div class="group-data-[audience=partner]/aud:hidden">
        <div class="text-center mb-8">
          <h2 class="font-serif text-[28px] md:text-[32px] text-[#1D1C1A] leading-tight">Hospice care that actually picks up at 2 a.m.</h2>
          <p class="text-[14px] text-[#6B665F] mt-3 max-w-2xl mx-auto leading-relaxed">
            When the morphine isn't working or you just need someone to hear what's happening,
            HosAlivio puts your nurse, doctor, chaplain, and aide one message away by voice or text.
            Covered by the Medicare Hospice Benefit. No out-of-pocket cost.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <%
            family_benefits = [
              { icon: "ri-mic-line",          title: "Voice notes for breath sounds",
                body: "Hold the phone near Mom. Your nurse hears the exact rasp instead of you trying to describe it." },
              { icon: "ri-customer-service-2-line", title: "Real humans, named on every reply",
                body: "Pascal, RN. Dr. Esther. Geoginio, chaplain. You see who picked up your message and when." },
              { icon: "ri-shield-check-line", title: "Medicare-covered, no bill",
                body: "If a doctor says six months or less, the Medicare Hospice Benefit covers care, meds, and equipment." },
              { icon: "ri-home-heart-line",   title: "At home, with your people",
                body: "Hospice keeps you in your bed, in your room, surrounded by who you want there." }
            ]
          %>
          <% family_benefits.each do |b| %>
            <div class="rounded-2xl bg-white border border-[#EFECE6] p-5 hover:shadow-sm transition">
              <div class="w-10 h-10 rounded-full bg-[#FFF3EC] text-[#D97757] flex items-center justify-center mb-3">
                <i class="<%= b[:icon] %> text-lg"></i>
              </div>
              <div class="font-serif text-[16px] text-[#1D1C1A] mb-1"><%= b[:title] %></div>
              <p class="text-[13px] text-[#3A3936] leading-relaxed"><%= b[:body] %></p>
            </div>
          <% end %>
        </div>
      </div>

      <%# Partner panel: shown when audience=partner. %>
      <div class="hidden group-data-[audience=partner]/aud:block">
        <div class="text-center mb-8">
          <h2 class="font-serif text-[28px] md:text-[32px] text-[#1D1C1A] leading-tight">Run your agency without burning out your nurses.</h2>
          <p class="text-[14px] text-[#6B665F] mt-3 max-w-2xl mx-auto leading-relaxed">
            HosAlivio handles the front door so your clinicians focus on the bedside.
            AI triages every family message, routes to the right human, drafts CMS-compliant
            documentation, and keeps the Notice of Election clock from running out.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <%
            partner_benefits = [
              { icon: "ri-customer-service-2-line", title: "AI front-door triage 24/7",
                body: "HosAlivio answers family chats in under a minute, classifies urgency, and only pages your on-call when it actually has to." },
              { icon: "ri-file-shield-2-line",      title: "Audit-proof charting on autopilot",
                body: "Visit narratives, pre-admit eval JSON, and recert justifications generated in CMS-compliant phrasing. Survey-ready." },
              { icon: "ri-time-line",               title: "Notice of Election deadlines, defended",
                body: "5-day NOE clock auto-tracked the moment the MD certifies. Insurance agent files before the window closes." },
              { icon: "ri-stack-line",              title: "Plays nice with your stack",
                body: "Hooks into Homecare Homebase, Netsmart, MatrixCare, and WellSky. Or runs standalone if you want." }
            ]
          %>
          <% partner_benefits.each do |b| %>
            <div class="rounded-2xl bg-white border border-[#EFECE6] p-5 hover:shadow-sm transition">
              <div class="w-10 h-10 rounded-full bg-[#FBF9F5] border border-[#EFECE6] text-[#2F6F4E] flex items-center justify-center mb-3">
                <i class="<%= b[:icon] %> text-lg"></i>
              </div>
              <div class="font-serif text-[16px] text-[#1D1C1A] mb-1"><%= b[:title] %></div>
              <p class="text-[13px] text-[#3A3936] leading-relaxed"><%= b[:body] %></p>
            </div>
          <% end %>
        </div>
        <div class="text-center mt-8">
          <%= link_to new_partner_path,
                class: "inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium transition" do %>
            <i class="ri-user-add-line"></i> Sign up your agency
          <% end %>
        </div>
      </div>
    </section>

    <!-- FAQ: toggle between Family/Patient and Hospice Partner -->
    <%# Hidden by default; sidebar nav (welcome#showFaq) un-hides.
        Outer section spans full main width; an inner wrapper handles
        the max-width so the toggle pill below can center-flex
        properly without inline-margin-auto getting in its way. %>
    <section id="faq"
             class="hidden px-4 md:px-10 py-12 scroll-mt-8 group/faq"
             data-controller="faq-toggle"
             data-audience="family">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <div class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-[0.2em] text-[#6B665F] font-bold mb-3">
            <i class="ri-question-answer-line"></i> Frequently asked
          </div>
          <h2 class="font-serif text-[26px] text-[#1D1C1A] leading-tight">Common questions, plain answers.</h2>
        </div>

        <%# Two-tab switcher: outer flex wrapper centers the inline pill
            (mx-auto on inline-flex doesn't behave). Animated background
            indicator slides between the two tabs as data-audience flips. %>
        <div class="flex justify-center mb-6">
          <div class="relative inline-flex w-[340px] max-w-full rounded-full bg-[#FBF9F5] border border-[#EFECE6] p-1 text-[13px]">
            <span aria-hidden="true"
                  class="absolute top-1 bottom-1 left-1 w-[calc(50%-0.25rem)] rounded-full bg-[#1D1C1A] shadow-sm transition-transform duration-300 ease-out
                         group-data-[audience=partner]/faq:translate-x-full"></span>
            <button type="button"
                    data-action="click->faq-toggle#show"
                    data-audience="family"
                    class="relative z-10 flex-1 px-4 py-1.5 rounded-full transition-colors
                           group-data-[audience=family]/faq:text-white
                           group-data-[audience=partner]/faq:text-[#6B665F]
                           group-data-[audience=partner]/faq:hover:text-[#1D1C1A]">
              Patients
            </button>
            <button type="button"
                    data-action="click->faq-toggle#show"
                    data-audience="partner"
                    class="relative z-10 flex-1 px-4 py-1.5 rounded-full transition-colors
                           group-data-[audience=partner]/faq:text-white
                           group-data-[audience=family]/faq:text-[#6B665F]
                           group-data-[audience=family]/faq:hover:text-[#1D1C1A]">
              Partners
            </button>
          </div>
        </div>

      <%# Family/patient FAQ: visible when data-audience="family" %>
      <div class="space-y-2 group-data-[audience=partner]/faq:hidden">
        <%
          family_faq = [
            ["What is hospice care?",
             "Hospice is comfort-focused care for someone with a terminal illness when curative treatment is no longer the goal. The team (nurse, doctor, social worker, chaplain, aide) comes to your home and manages pain, breathing, and the family experience together."],
            ["Who pays for hospice?",
             "Medicare's Hospice Benefit covers it 100%: the nurse, the doctor, the medications related to the terminal diagnosis, oxygen, hospital beds, and chaplain visits. There's no copay or deductible. Medicaid and most private insurers cover it the same way."],
            ["Do I have to give up my regular doctor?",
             "No. Your primary doctor can stay involved. You also get a hospice physician (HosAlivio's Dr. Esther in our demo) who oversees the comfort plan. The two coordinate."],
            ["Can I change my mind?",
             "Yes. You can revoke hospice and go back to curative treatment any day, for any reason. Hospice isn't a one-way door."],
            ["How fast can someone start?",
             "If a doctor signs off on a six-month prognosis today, an admissions visit is usually the same day or next day. Crisis symptoms (pain, breathing) get a phone-call response within minutes once you're enrolled."],
            ["Is HosAlivio my hospice?",
             "No. HosAlivio is the platform your hospice agency uses to run their care. You'll pick a real local agency (or be referred to one); HosAlivio is what makes their nurse, doctor, and chaplain feel one tap away."]
          ]
        %>
        <% family_faq.each do |q, a| %>
          <details class="group rounded-xl bg-white border border-[#EFECE6] hover:border-[#D9D5CD] transition overflow-hidden">
            <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-4 [&::-webkit-details-marker]:hidden">
              <span class="font-serif text-[15px] text-[#1D1C1A]"><%= q %></span>
              <i class="ri-add-line text-[#6B665F] group-open:rotate-45 transition-transform flex-shrink-0"></i>
            </summary>
            <div class="px-5 pb-4 text-[13px] text-[#3A3936] leading-relaxed border-t border-[#EFECE6] pt-3"><%= a %></div>
          </details>
        <% end %>
      </div>

      <%# Partner FAQ: visible when data-audience="partner" %>
      <div class="space-y-2 hidden group-data-[audience=partner]/faq:block">
        <%
          partner_faq = [
            ["Is the AI replacing our admissions coordinator?",
             "No. HosAlivio is the front-door triage layer; it acknowledges every family message in seconds, classifies urgency, and pages the right human. Your coordinator stops drowning in 2 a.m. pages and gets to focus on the cases that actually need a human."],
            ["How does HosAlivio handle PHI / HIPAA?",
             "Patient data is encrypted at rest with Active Record Encryption (chart fields, notes, addresses), audit-logged via PaperTrail on every write, and scoped per-agency via ActsAsTenant. We sign a BAA before any agency goes live."],
            ["Does it integrate with our EMR?",
             "Yes. Homecare Homebase, Netsmart, MatrixCare, and WellSky are first-class. You can also run HosAlivio standalone if you'd rather not bridge a System of Record."],
            ["What about the Notice of Election deadline?",
             "The 5-day NOE clock starts the moment the MD certifies. HosAlivio's insurance agent watches it, flags overdue at 4 days, and auto-files when authorized. No more late submissions costing you the benefit period."],
            ["What does it cost the agency?",
             "Tiered by patient census. The starter tier covers small agencies free during pilot; VHAS Pro adds compliance automation and multi-branch oversight. Pricing is on the partner contract."],
            ["What if the AI gets a clinical question wrong?",
             "It doesn't give clinical advice; it routes. Every triage decision is logged, every prose draft is gated through a documentation discipline block, and any actual order requires the MD agent (which only proposes inside protocol)."],
            ["How long is implementation?",
             "Self-serve signup is the wizard you just saw: 3 minutes from Sign up to a populated dashboard. Full integration with an existing EMR + BAA + clinical team onboarding usually 1-2 weeks."]
          ]
        %>
        <% partner_faq.each do |q, a| %>
          <details class="group rounded-xl bg-white border border-[#EFECE6] hover:border-[#D9D5CD] transition overflow-hidden">
            <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-4 [&::-webkit-details-marker]:hidden">
              <span class="font-serif text-[15px] text-[#1D1C1A]"><%= q %></span>
              <i class="ri-add-line text-[#6B665F] group-open:rotate-45 transition-transform flex-shrink-0"></i>
            </summary>
            <div class="px-5 pb-4 text-[13px] text-[#3A3936] leading-relaxed border-t border-[#EFECE6] pt-3"><%= a %></div>
          </details>
        <% end %>
      </div>
      </div><%# end max-w-3xl wrapper %>
    </section>

    <%# === Original carousel + Q&A code below intentionally removed.
        Kept the modal at the very bottom so the contact-callback flow
        still works when triggered from the partner-signup page. =========== %>
    <% if false %>
    <section class="pb-6 max-w-3xl mx-auto" data-controller="carousel">
      <% if @match[:agencies].empty? %>
        <div class="max-w-2xl text-center py-16 mx-auto px-4 md:px-10">
          <div class="w-12 h-12 rounded-full bg-[#EFECE6] flex items-center justify-center mx-auto mb-4">
            <i class="ri-inbox-2-line text-xl text-[#6B665F]"></i>
          </div>
          <div class="font-serif text-lg text-[#1D1C1A]">No partners match those filters.</div>
          <div class="text-[13px] text-[#6B665F] mt-2">Try fewer filters, a broader zip, or let HosAlivio handle it via the bar above.</div>
        </div>
      <% else %>
        <!-- Header: Explore partners (left) + What's new (slides in more) -->
        <div class="flex items-baseline justify-between px-4 md:px-10 mb-4">
          <h2 class="font-serif text-[20px] text-[#1D1C1A]">Explore partners</h2>
          <button type="button" data-action="click->carousel#showMore"
                  class="inline-flex items-center gap-1 text-[13px] text-[#6B665F] hover:text-[#1D1C1A] underline-offset-2 hover:underline">
            What's new <i class="ri-arrow-right-s-line"></i>
          </button>
        </div>

        <!-- Track with floating left/right arrows -->
        <div class="relative">
          <button type="button" data-action="click->carousel#prev" aria-label="Previous"
                  class="absolute left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full border border-[#EFECE6] bg-white/95 backdrop-blur hover:bg-white text-[#1D1C1A] shadow-md flex items-center justify-center transition">
            <i class="ri-arrow-left-s-line text-xl"></i>
          </button>
          <button type="button" data-action="click->carousel#next" aria-label="Next"
                  class="absolute right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full border border-[#EFECE6] bg-white/95 backdrop-blur hover:bg-white text-[#1D1C1A] shadow-md flex items-center justify-center transition">
            <i class="ri-arrow-right-s-line text-xl"></i>
          </button>

          <div data-carousel-target="track"
               class="flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth px-6 pb-4 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
          <% @match[:agencies].each do |agency| %>
            <article
              data-action="click->welcome#contactPartner"
              data-agency-id="<%= agency.id %>"
              data-agency-name="<%= agency.name %>"
              class="group relative snap-start flex-shrink-0 w-56 h-72 rounded-2xl overflow-hidden cursor-pointer transition shadow-sm hover:shadow-lg">
              <!-- Hero fill -->
              <div class="absolute inset-0" style="background: linear-gradient(135deg, <%= agency.hero_color %> 0%, <%= agency.hero_color %>cc 60%, <%= agency.hero_color %>90 100%);"></div>
              <!-- Big emoji / visual anchor -->
              <div class="absolute inset-0 flex items-center justify-center opacity-90 text-[90px] select-none">
                <span><%= agency.emoji %></span>
              </div>
              <!-- Top-right status chip -->
              <% if agency.accepting_referrals %>
                <div class="absolute top-3 right-3">
                  <span class="inline-flex items-center gap-1 text-[10px] uppercase tracking-wider text-white bg-black/25 backdrop-blur rounded-full px-2 py-0.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>Accepting
                  </span>
                </div>
              <% end %>
              <!-- Gradient scrim + label -->
              <div class="absolute bottom-0 inset-x-0 p-4 bg-gradient-to-t from-black/65 via-black/20 to-transparent text-white">
                <div class="text-[15px] font-medium leading-tight drop-shadow-sm"><%= agency.name %></div>
                <div class="text-[11px] opacity-90 mt-0.5 font-mono"><%= [agency.city, agency.state].compact.join(", ") %></div>
              </div>
              <!-- Hover overlay: specialties + contact hint -->
              <div class="absolute inset-0 bg-black/55 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition flex flex-col justify-between p-4 text-white">
                <div>
                  <div class="text-[15px] font-medium leading-tight"><%= agency.name %></div>
                  <div class="text-[11px] opacity-80 mt-0.5"><%= [agency.city, agency.state].compact.join(", ") %></div>
                  <div class="mt-3 flex flex-wrap gap-1">
                    <% agency.specialties.first(3).each do |s| %>
                      <span class="text-[10px] uppercase tracking-wider px-2 py-0.5 rounded bg-white/20 border border-white/30">
                        <%= Agency::SPECIALTY_CATALOG[s] || s.humanize %>
                      </span>
                    <% end %>
                  </div>
                  <% if agency.bio.present? %>
                    <p class="text-[12px] opacity-85 mt-3 line-clamp-4"><%= agency.bio %></p>
                  <% end %>
                </div>
                <div class="flex items-center justify-between text-[11px]">
                  <span class="opacity-80"><i class="ri-time-line"></i> ~<%= agency.response_sla_hours %>h</span>
                  <span class="inline-flex items-center gap-1 font-medium">
                    <i class="ri-phone-line"></i> Contact
                  </span>
                </div>
              </div>
            </article>
          <% end %>
        </div>
        </div>
      <% end %>
    </section>

    <!-- Quick-replies: relocated from inside the form to below the carousel -->
    <section class="px-4 md:px-10 pb-4 max-w-3xl mx-auto">
      <%= form_with(url: root_path, method: :get, local: true, html: { class: "" }) do %>
        <div class="text-[11px] uppercase tracking-widest text-[#6B665F] mb-3 text-center">Try a quick ask</div>
        <div class="flex flex-wrap gap-2 justify-center">
          <% [
               "Miami agency that serves Spanish-speaking families",
               "Pediatric hospice in Orlando",
               "Veterans care in North Florida",
               "Dementia specialists with Medicare",
               "LGBTQ+ affirming hospice"
             ].each do |q| %>
            <button type="submit" name="q" value="<%= q %>"
                    class="text-[12px] px-3 py-1.5 rounded-full bg-[#FBF9F5] border border-[#EFECE6] hover:border-[#D97757] hover:bg-[#FFF3EC] text-[#1D1C1A] transition">
              <%= q %>
            </button>
          <% end %>
        </div>
      <% end %>
    </section>

    <!-- HosAlivio's explanation bubble (after the cards + chips) -->
    <% if @match[:agencies].any? || @active_query.present? %>
      <section class="px-4 md:px-10 pb-10">
        <div class="max-w-3xl mx-auto flex items-start gap-3">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-white border border-[#EFECE6] overflow-hidden">
            <%= image_tag "hosalivio_assistant.png", class: "w-full h-full object-cover object-top scale-125 origin-top", alt: "HosAlivio" %>
          </div>
          <div class="bg-white rounded-2xl rounded-tl-md border border-[#EFECE6] px-4 py-2.5 text-[13px] text-[#1D1C1A]">
            <span class="font-bold">HosAlivio:</span> <%= @match[:explanation] %>
          </div>
        </div>
      </section>
    <% end %>

    <!-- Secondary FAQ prompts (still useful for orientation) -->
    <section class="px-4 md:px-10 pb-16 max-w-4xl mx-auto">
      <div class="text-center">
        <div class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-[0.2em] text-[#6B665F] font-bold mb-3">
          <i class="ri-question-answer-line"></i> Not sure what to ask yet?
        </div>
        <h2 class="font-serif text-2xl text-[#1D1C1A] mb-5">Start with a common question.</h2>
      </div>
      <div class="flex flex-wrap gap-2 max-w-3xl mx-auto justify-center">
        <% @starters.each do |s| %>
          <button type="button"
                  data-action="click->welcome#choosePrompt"
                  data-prompt-id="<%= s[:id] %>"
                  class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full bg-white border border-[#EFECE6] hover:border-[#D97757] hover:bg-[#FFF3EC] text-[13px] text-[#1D1C1A] transition">
            <i class="<%= s[:icon] %> text-[#D97757]"></i><%= s[:label] %>
          </button>
        <% end %>
      </div>

      <!-- Conversation thread (invisible until a chip is clicked) -->
      <div class="mt-6 space-y-5 max-w-3xl mx-auto" data-welcome-target="thread"></div>
    </section>
    <% end %>

    <footer class="px-4 md:px-10 py-5 text-center text-[11px] text-[#6B665F]">
      © <%= Date.current.year %> HosAlivio · <a href="#" class="hover:text-[#1D1C1A]">Privacy</a> · <a href="#" class="hover:text-[#1D1C1A]">HIPAA Notice</a>
    </footer>
  </main>

  <!-- ─── Modal: contact form ─────────────────────────────────────── -->
  <div data-welcome-target="capture"
       data-action="keydown.esc@window->welcome#closeCapture click->welcome#backdropClose"
       class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
    <div class="relative w-full max-w-lg bg-white rounded-2xl border border-[#EFECE6] shadow-xl p-6"
         data-welcome-target="captureDialog">
      <button type="button" data-action="click->welcome#closeCapture"
              class="absolute top-3 right-3 w-8 h-8 rounded-full text-[#6B665F] hover:bg-[#EFECE6] flex items-center justify-center">
        <i class="ri-close-line text-lg"></i>
      </button>

      <div class="text-[11px] uppercase tracking-[0.2em] text-[#D97757] font-bold mb-2">
        <i class="ri-map-pin-line"></i> Reach a local coordinator
      </div>
      <div data-welcome-target="partnerBanner" class="hidden mb-3 px-3 py-2 rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[13px] text-[#1D1C1A]">
        <i class="ri-send-plane-2-line text-[#D97757]"></i>
        Sending your request to <span class="font-medium" data-welcome-target="partnerBannerName"></span>.
      </div>
      <div class="font-serif text-[16px] text-[#1D1C1A] mb-5">Leave a zip code and a way to reach you. A coordinator will call, usually within the hour.</div>

      <form data-action="submit->welcome#submitCapture" class="space-y-3">
        <input type="text" name="zip" placeholder="ZIP code" required inputmode="numeric" pattern="[0-9]{5}"
               class="w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
        <input type="text" name="name" placeholder="First name" required
               class="w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
        <input type="text" name="contact" placeholder="Phone or email" required
               class="w-full px-3 py-2.5 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
        <div class="flex items-center justify-between gap-3 pt-3 border-t border-[#EFECE6] text-[11px] text-[#6B665F]">
          <span><i class="ri-shield-check-line"></i> Not stored in any medical record.</span>
          <button type="submit" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium transition">
            <i class="ri-send-plane-fill"></i> Request a callback
          </button>
        </div>
      </form>

      <div data-welcome-target="captureThanks" class="hidden">
        <div class="flex items-start gap-3 text-[#1D1C1A]">
          <i class="ri-check-double-line text-[#D97757] text-2xl"></i>
          <div>
            <div class="font-medium">Thank you. A coordinator will reach out shortly.</div>
            <div class="text-[12px] text-[#3A3936] mt-1">For medical emergencies, always call 911.</div>
          </div>
        </div>
        <div class="mt-5 text-right">
          <button type="button" data-action="click->welcome#closeCapture"
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#1D1C1A] hover:bg-[#3A3936] text-white text-sm font-medium transition">
            Close
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
