<% content_for :title, "Calendar · HosAlivio" %>

<%
  discipline_color = {
    "rn" => "#2F6F4E", "md" => "#2B4A7A", "sw" => "#7A4A8C",
    "chaplain" => "#8C6A2F", "aide" => "#AD7340", "don" => "#8B5A2B"
  }
  # Scheduling is a manager action. Performing clinicians (RN/MD) view their
  # own schedule read-only — so the "+ Add" / click-to-book affordances and
  # the empty-cell copy both branch on this.
  can_schedule = (current_user.role_names & %w[admin don admissions ceo]).any?
%>

<div class="min-h-screen" data-controller="calendar">
  <!-- Top bar -->
  <header class="sticky top-0 z-20 bg-[#FBF9F5]/90 backdrop-blur border-b border-[#EFECE6]">
    <%
      # A week can straddle two months (or years) — spell that out so the
      # RN always knows which month/year she's looking at.
      month_label =
        if @week_start.month == @week_end.month
          @week_start.strftime("%B %Y")
        elsif @week_start.year == @week_end.year
          "#{@week_start.strftime('%B')} – #{@week_end.strftime('%B %Y')}"
        else
          "#{@week_start.strftime('%b %Y')} – #{@week_end.strftime('%b %Y')}"
        end
      week_range =
        if @week_start.month == @week_end.month
          "#{@week_start.strftime('%b %-d')}–#{@week_end.strftime('%-d')}, #{@week_end.year}"
        else
          "#{@week_start.strftime('%b %-d')} – #{@week_end.strftime('%b %-d, %Y')}"
        end
    %>
    <div class="max-w-[1400px] mx-auto px-4 md:px-6 min-h-14 py-2 flex items-center justify-between gap-3">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/dashboard" class="text-[12px] text-[#6B665F] hover:text-[#1D1C1A] inline-flex items-center gap-1 flex-shrink-0">
          <i class="ri-arrow-left-line"></i><span class="hidden sm:inline"> Dashboard</span>
        </a>
        <div class="min-w-0">
          <h1 class="font-serif text-[17px] md:text-[20px] text-[#1D1C1A] leading-tight truncate"><%= month_label %></h1>
          <span class="text-[10px] md:text-[11px] text-[#6B665F] font-mono block truncate">
            <%= @agency&.name %> · <%= week_range %>
          </span>
        </div>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        <%# Week nav lives in the top bar on desktop; on mobile it moves to the
            sticky bottom bar so this row isn't cramped. %>
        <div class="hidden md:flex items-center gap-2">
          <a href="<%= calendar_path(date: (@week_start - 7.days).iso8601) %>"
             class="w-8 h-8 rounded-full border border-[#EFECE6] bg-white hover:bg-[#FBF9F5] text-[#1D1C1A] flex items-center justify-center">
            <i class="ri-arrow-left-s-line"></i>
          </a>
          <a href="<%= calendar_path %>"
             class="text-[12px] px-3 py-1.5 rounded-full border border-[#EFECE6] bg-white hover:bg-[#FBF9F5] text-[#1D1C1A]">
            Today
          </a>
          <a href="<%= calendar_path(date: (@week_start + 7.days).iso8601) %>"
             class="w-8 h-8 rounded-full border border-[#EFECE6] bg-white hover:bg-[#FBF9F5] text-[#1D1C1A] flex items-center justify-center">
            <i class="ri-arrow-right-s-line"></i>
          </a>
        </div>
        <%# Scheduling is an admin/admissions action — performing clinicians
            (RN/MD/etc.) see their own schedule but don't book visits here.
            Desktop-only: booking is a back-office task, not a phone one. %>
        <% if can_schedule %>
          <a href="<%= new_visit_path %>"
             class="hidden md:inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white font-medium">
            <i class="ri-add-line"></i> New visit
          </a>
        <% end %>
        <span class="hidden md:block w-px h-6 bg-[#EFECE6] mx-1"></span>
        <%= render "shared/user_menu" %>
      </div>
    </div>
  </header>


  <main class="max-w-[1400px] mx-auto px-4 md:px-6 py-6 pb-24 md:pb-6">
    <%# Desktop: the dense week grid. Hidden on phones — they get the
        vertical agenda below instead (a 7-column grid can't be usable
        on a narrow screen). %>
    <div class="hidden md:block overflow-x-auto -mx-4 md:mx-0 px-4 md:px-0">
    <% if @clinicians.empty? %>
      <div class="text-center py-20 text-[#6B665F]">
        <div class="w-12 h-12 rounded-full bg-[#EFECE6] flex items-center justify-center mx-auto mb-3">
          <i class="ri-calendar-line text-xl"></i>
        </div>
        <div class="font-serif text-lg text-[#1D1C1A]">No clinicians assigned to this agency yet.</div>
        <div class="text-[13px] mt-1">Diaphnie (DON) assigns the team; once she does, their rows will appear here.</div>
      </div>
    <% else %>
      <!-- Grid header: day columns -->
      <div class="grid rounded-t-2xl bg-white border border-[#EFECE6] border-b-0" style="grid-template-columns: 180px repeat(7, 1fr);">
        <div class="px-3 py-2 text-[10px] uppercase tracking-widest text-[#6B665F]">Clinician</div>
        <% @days.each do |d| %>
          <div class="px-2 py-2 text-center border-l border-[#EFECE6]
                      <%= 'bg-[#FBF9F5]' if d == Date.current %>">
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F]"><%= d.strftime("%a") %></div>
            <div class="text-[15px] font-serif <%= 'text-[#D97757] font-bold' if d == Date.current %>"><%= d.day %></div>
          </div>
        <% end %>
      </div>

      <!-- Clinician rows -->
      <% @clinicians.each do |user| %>
        <div class="grid bg-white border border-t-0 border-[#EFECE6] last:rounded-b-2xl" style="grid-template-columns: 180px repeat(7, 1fr);">
          <!-- Row header: clinician name -->
          <div class="px-3 py-3 border-r border-[#EFECE6] flex items-center gap-2">
            <%
              role = (user.role_names & %w[rn md don sw chaplain aide social_worker]).first || "rn"
              role_color = discipline_color[role == "social_worker" ? "sw" : role] || "#6B665F"
            %>
            <% if user.has_avatar? %>
              <%= image_tag url_for(user.avatar), class: "w-7 h-7 rounded-full object-cover flex-shrink-0 border border-[#EFECE6]" %>
            <% else %>
              <div class="w-7 h-7 rounded-full text-white text-[11px] font-medium flex items-center justify-center flex-shrink-0"
                   style="background: <%= role_color %>;">
                <%= user.full_name.to_s.split.map(&:first).first(2).join.upcase %>
              </div>
            <% end %>
            <div class="min-w-0">
              <div class="text-[13px] text-[#1D1C1A] truncate"><%= user.full_name %></div>
              <div class="text-[10px] text-[#6B665F] uppercase tracking-wider"><%= role == "social_worker" ? "sw" : role %></div>
            </div>
          </div>

          <!-- Day cells -->
          <% @days.each do |day| %>
            <% cell_visits = @cells[[user.id, day]] %>
            <div class="border-l border-[#EFECE6] min-h-[96px] p-1.5 transition relative <%= 'cursor-pointer hover:bg-[#FBF9F5]' if can_schedule %> <%= 'bg-[#FBF9F5]/40' if day == Date.current %>"
                 <% if can_schedule %>
                   data-action="click->calendar#newVisitForCell"
                   data-user-id="<%= user.id %>"
                   data-scheduled-at="<%= day.beginning_of_day.change(hour: 9).iso8601 %>"
                   data-discipline="<%= user.role_names.first %>"
                 <% end %>>
              <% if cell_visits.size > 1 %>
                <div class="text-[9px] font-bold uppercase tracking-wider text-[#6B665F] px-1 pb-1"><%= cell_visits.size %> visits</div>
              <% end %>
              <div class="<%= 'max-h-[200px] overflow-y-auto pr-0.5' if cell_visits.size > 2 %>">
              <% cell_visits.each do |v| %>
                <%
                  d_key = v.discipline.to_s == "social_worker" ? "sw" : v.discipline.to_s
                  color = discipline_color[d_key] || "#6B665F"
                %>
                <a href="<%= visit_path(v) %>"
                   data-turbo-frame="visit-modal"
                   class="block mb-1 px-2 py-1 rounded-lg text-[11px] leading-tight text-white shadow-sm hover:shadow hover:brightness-110 transition"
                   style="background: <%= color %>;">
                  <div class="flex items-center justify-between gap-1">
                    <span class="font-mono"><%= v.anchor_start&.strftime("%-l:%M%P") %></span>
                    <span class="opacity-80" title="<%= v.agent_authored ? 'Scheduled by AI agent' : 'Scheduled by a human' %>">
                      <%= v.agent_authored ? "🤖" : "👤" %>
                    </span>
                  </div>
                  <div class="truncate mt-0.5">
                    <%= v.patient&.full_name || "—" %>
                  </div>
                  <div class="text-[9px] opacity-80 font-mono mt-0.5 truncate">
                    <%= v.patient&.mrn %>
                    <% if v.patient&.zip.present? %>
                      · <%= v.patient.zip.to_s[0, 3] %>xx
                    <% end %>
                  </div>
                  <% if v.visit_type.to_s != "routine" || v.service_location.to_s != "home" %>
                    <div class="text-[9px] uppercase tracking-wider opacity-80 mt-0.5">
                      <% if v.visit_type.to_s != "routine" %><%= v.visit_type %><% end %>
                      <% if v.service_location.to_s != "home" %>
                        <span title="Not at patient's home">· <%= v.service_location.to_s.tr("_", " ") %></span>
                      <% end %>
                    </div>
                  <% end %>
                </a>
              <% end %>
              </div>
              <% if cell_visits.empty? %>
                <% if can_schedule %>
                  <%# Manager: hover an empty cell to book a visit on that day. %>
                  <div class="text-[10px] text-[#D9D5CD] hover:text-[#6B665F] opacity-0 hover:opacity-100 transition text-center pt-2">
                    + Add
                  </div>
                <% else %>
                  <%# Performing clinician: read-only, so make a clear day plain. %>
                  <div class="text-[10px] text-[#C9C5BD] text-center pt-3 select-none">
                    <i class="ri-checkbox-blank-circle-line"></i><br>No visits
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

    </div>

      <!-- Legend -->
      <div class="mt-6 flex items-center gap-4 text-[11px] text-[#6B665F] flex-wrap">
        <span class="uppercase tracking-widest">Legend:</span>
        <% [["RN","#2F6F4E"], ["MD","#2B4A7A"], ["SW","#7A4A8C"], ["Chaplain","#8C6A2F"], ["Aide","#AD7340"], ["DON","#8B5A2B"]].each do |label, color| %>
          <span class="inline-flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded" style="background: <%= color %>;"></span>
            <%= label %>
          </span>
        <% end %>
        <span class="ml-auto">🤖 AI-scheduled &nbsp;·&nbsp; 👤 Human-scheduled</span>
      </div>
    <% end %>

    <%# ── Mobile agenda (below md) ─────────────────────────────────
        A vertical, tappable day-by-day list — readable on a phone with
        no horizontal scroll. One section per day; visits across all
        visible clinicians, sorted by time. Tapping a visit opens the
        same visit-modal Turbo Frame the grid uses. %>
    <div class="md:hidden space-y-4">
      <% if @clinicians.empty? %>
        <div class="text-center py-16 text-[#6B665F]">
          <div class="w-12 h-12 rounded-full bg-[#EFECE6] flex items-center justify-center mx-auto mb-3">
            <i class="ri-calendar-line text-xl"></i>
          </div>
          <div class="font-serif text-lg text-[#1D1C1A]">No clinicians assigned yet.</div>
        </div>
      <% else %>
        <% @days.each do |day| %>
          <% day_visits = @clinicians.flat_map { |u| @cells[[u.id, day]] }.sort_by { |v| v.anchor_start || Time.current } %>
          <% is_today = (day == Date.current) %>
          <section class="rounded-2xl bg-white border <%= is_today ? 'border-[#D97757]' : 'border-[#EFECE6]' %> overflow-hidden">
            <div class="px-4 py-2.5 border-b border-[#EFECE6] flex items-center justify-between <%= is_today ? 'bg-[#FFF3EC]' : 'bg-[#FBF9F5]' %>">
              <div class="flex items-center gap-2 min-w-0">
                <span class="text-[14px] font-serif font-bold text-[#1D1C1A]"><%= day.strftime("%A") %></span>
                <span class="text-[11px] text-[#6B665F] font-mono"><%= day.strftime("%b %-d") %></span>
                <% if is_today %>
                  <span class="text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded-full bg-[#D97757] text-white">Today</span>
                <% end %>
              </div>
              <span class="text-[10px] text-[#6B665F] flex-shrink-0"><%= day_visits.size %> <%= day_visits.size == 1 ? "visit" : "visits" %></span>
            </div>
            <% if day_visits.empty? %>
              <div class="px-4 py-4 text-center text-[12px] text-[#C9C5BD]">No visits</div>
            <% else %>
              <ul class="divide-y divide-[#EFECE6]">
                <% day_visits.each do |v| %>
                  <%
                    d_key = v.discipline.to_s == "social_worker" ? "sw" : v.discipline.to_s
                    color = discipline_color[d_key] || "#6B665F"
                  %>
                  <li>
                    <a href="<%= visit_path(v) %>" data-turbo-frame="visit-modal"
                       class="flex items-stretch gap-3 px-4 py-3 active:bg-[#FBF9F5] transition">
                      <span class="w-1 rounded-full flex-shrink-0" style="background: <%= color %>;"></span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between gap-2">
                          <span class="text-[14px] font-medium text-[#1D1C1A] truncate"><%= v.patient&.full_name || "—" %></span>
                          <span class="text-[12px] font-mono text-[#6B665F] flex-shrink-0"><%= v.anchor_start&.strftime("%-l:%M %p") %></span>
                        </div>
                        <div class="text-[11px] text-[#6B665F] truncate mt-0.5">
                          <% if @clinicians.size > 1 %><%= v.user&.full_name %> · <% end %>
                          <%= v.visit_type.to_s.tr("_", " ") %>
                          <% if v.service_location.to_s != "home" %> · <%= v.service_location.to_s.tr("_", " ") %><% end %>
                          <% if v.patient&.mrn.present? %> · <span class="font-mono"><%= v.patient.mrn %></span><% end %>
                        </div>
                      </div>
                      <i class="ri-arrow-right-s-line text-[#C9C5BD] self-center flex-shrink-0"></i>
                    </a>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </section>
        <% end %>
      <% end %>
    </div>
  </main>

  <%# Mobile week navigation — moved out of the cramped top bar to a
      thumb-friendly sticky footer (desktop keeps the arrows up top). %>
  <nav class="md:hidden fixed bottom-0 inset-x-0 z-30 bg-white/95 backdrop-blur border-t border-[#EFECE6] flex items-stretch">
    <a href="<%= calendar_path(date: (@week_start - 7.days).iso8601) %>"
       class="flex-1 flex flex-col items-center justify-center py-2.5 text-[10px] uppercase tracking-wider text-[#6B665F] active:bg-[#FBF9F5]">
      <i class="ri-arrow-left-s-line text-lg"></i> Prev
    </a>
    <a href="<%= calendar_path %>"
       class="flex-1 flex flex-col items-center justify-center py-2.5 text-[10px] uppercase tracking-wider font-bold text-[#D97757] active:bg-[#FBF9F5] border-x border-[#EFECE6]">
      <i class="ri-focus-3-line text-lg"></i> Today
    </a>
    <a href="<%= calendar_path(date: (@week_start + 7.days).iso8601) %>"
       class="flex-1 flex flex-col items-center justify-center py-2.5 text-[10px] uppercase tracking-wider text-[#6B665F] active:bg-[#FBF9F5]">
      <i class="ri-arrow-right-s-line text-lg"></i> Next
    </a>
  </nav>

  <%# Visit cards open in here (Turbo Frame modal). %>
  <%= turbo_frame_tag "visit-modal" %>
</div>
