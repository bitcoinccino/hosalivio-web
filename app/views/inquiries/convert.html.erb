<% content_for :title, "Convert inquiry · HosAlivio" %>

<div class="min-h-screen bg-[#FBF9F5] py-10 px-4">
  <div class="max-w-2xl mx-auto">

    <a href="<%= inquiry_path(@inquiry) %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to inquiry
    </a>

    <div class="rounded-2xl bg-white border border-[#EFECE6] shadow-sm p-8">
      <div class="text-[11px] uppercase tracking-[0.2em] text-[#D97757] font-bold mb-2">
        <i class="ri-user-add-line"></i> Convert to admission
      </div>
      <h1 class="font-serif text-2xl text-[#1D1C1A] mb-2">
        Take <%= @inquiry.first_name.presence || "this inquiry" %> into your census.
      </h1>
      <p class="text-[13px] text-[#3A3936] mb-6">
        A new <span class="font-mono">Patient</span> row will be created with status <strong>referred</strong>. The family's original question will be attached as the first chart note so the admission nurse has context before the visit.
      </p>

      <!-- Inquiry summary — everything the family / referrer gave us, so you can
           review the full picture before committing to a patient record. -->
      <div class="mb-6">
        <%= render "summary", inquiry: @inquiry %>
      </div>

      <% if flash[:alert] %>
        <div class="mb-4 px-3 py-2 rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[#C1403A] text-sm">
          <i class="ri-error-warning-line mr-1"></i><%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with(url: convert_to_patient_inquiry_path(@inquiry), method: :post, local: true, html: { class: "space-y-4" }) do %>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1">First name</label>
            <input type="text" name="first_name" value="<%= @inquiry.first_name %>" required
                   class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
          </div>
          <div>
            <label class="block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1">Last name <span class="text-[#C1403A]">*</span></label>
            <input type="text" name="last_name" value="<%= @inquiry.last_name %>" required autofocus
                   class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
          </div>
          <div>
            <label class="block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1">Date of birth <span class="text-[#C1403A]">*</span></label>
            <input type="date" name="dob" value="<%= @inquiry.dob %>" required
                   class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
          </div>
          <div>
            <label class="block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1">Gender</label>
            <select name="gender"
                    class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
              <option value="">(choose)</option>
              <option value="F">F</option>
              <option value="M">M</option>
              <option value="X">Non-binary / other</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1">Primary diagnosis <span class="text-[#C1403A]">*</span></label>
          <input type="text" name="primary_diagnosis" required
                 placeholder="e.g. End-stage CHF (ICD-10 I50.84)"
                 class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
        </div>

        <div>
          <label class="block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1">Initial code status</label>
          <select name="code_status"
                  class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
            <option value="full_code">Full Code (default; revisit at GOC conversation)</option>
            <option value="dnr">DNR</option>
            <option value="dni">DNI</option>
            <option value="dnr_dni">DNR/DNI</option>
            <option value="comfort_only">Comfort-only</option>
          </select>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1">Primary caregiver</label>
            <input type="text" name="caregiver_name"
                   placeholder="e.g. Carlos Alvarez (son)"
                   class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
          </div>
          <div>
            <label class="block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1">Caregiver phone</label>
            <input type="text" name="caregiver_phone" value="<%= @inquiry.caregiver_phone %>"
                   class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
          </div>
        </div>

        <div class="pt-4 border-t border-[#EFECE6] flex items-center justify-between gap-3">
          <a href="<%= inquiry_path(@inquiry) %>" class="text-[13px] text-[#6B665F] hover:text-[#1D1C1A]">Cancel</a>
          <button type="submit" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium transition">
            <i class="ri-user-add-line"></i> Create patient &amp; convert
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
