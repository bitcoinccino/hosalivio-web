<% content_for :title, "Inquiry · #{@inquiry.first_name.presence || "Referral"}" %>
<%
  status_pill = {
    "new_lead"  => [ "#D97757", "#FFF3EC", "New lead" ],
    "claimed"   => [ "#2B4A7A", "#F0F4FA", "Claimed" ],
    "contacted" => [ "#2F6F4E", "#E6F0EE", "Contacted" ],
    "converted" => [ "#2F6F4E", "#E6F0EE", "Converted" ],
    "dismissed" => [ "#6B665F", "#EFECE6", "Dismissed" ]
  }
  st_fg, st_bg, st_label = status_pill[@inquiry.status.to_s] || [ "#6B665F", "#EFECE6", @inquiry.status.to_s ]
  is_open = @inquiry.status_new_lead? || @inquiry.status_claimed? || @inquiry.status_contacted?

  # Timeline stamps to show, in order, when present.
  stamps = [
    [ "Received",  @inquiry.created_at ],
    [ "Claimed",   @inquiry.claimed_at ],
    [ "Contacted", @inquiry.contacted_at ],
    [ "Converted", @inquiry.converted_at ]
  ].select { |_, t| t.present? }
%>
<div class="min-h-screen bg-[#FBF9F5] py-10 px-4">
  <div class="max-w-2xl mx-auto">

    <a href="<%= inquiries_path %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to Referrals
    </a>

    <div class="rounded-2xl bg-white border border-[#EFECE6] shadow-sm p-8">
      <div class="flex items-start justify-between gap-3 mb-5">
        <div class="min-w-0">
          <div class="text-[11px] uppercase tracking-[0.2em] text-[#D97757] font-bold mb-1">
            <i class="ri-inbox-line"></i> Referral inquiry
          </div>
          <h1 class="font-serif text-2xl text-[#1D1C1A] truncate">
            <%= [ @inquiry.first_name, @inquiry.last_name ].map(&:presence).compact.join(" ").presence || "Anonymous inquiry" %>
          </h1>
          <div class="text-[12px] text-[#6B665F] mt-0.5 flex items-center gap-1.5 flex-wrap">
            <% if @inquiry.payer_label %>
              <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded bg-[#F0F4FA] text-[#2B4A7A]"><%= @inquiry.payer_label %></span>
            <% end %>
            <span><% if @inquiry.city_state.present? %><%= @inquiry.city_state %> · <% end %>received <%= time_ago_in_words(@inquiry.created_at) %> ago</span>
          </div>
        </div>

        <div class="flex items-center gap-2 flex-shrink-0">
          <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-3 py-1 rounded-full whitespace-nowrap" style="color: <%= st_fg %>; background: <%= st_bg %>;">
            <span class="w-1.5 h-1.5 rounded-full" style="background: <%= st_fg %>;"></span><%= st_label %>
          </span>

          <%# Actions menu — "..." toggle, upper right. %>
          <div class="relative" data-controller="menu">
            <button type="button" data-action="menu#toggle" aria-label="Actions"
                    class="w-9 h-9 rounded-full bg-white border border-[#D9D5CD] text-[#1D1C1A] hover:bg-[#FBF9F5] hover:border-[#D97757] inline-flex items-center justify-center transition">
              <i class="ri-more-fill text-lg"></i>
            </button>
            <div data-menu-target="panel" class="hidden absolute right-0 mt-2 w-56 z-30 rounded-2xl bg-white border border-[#EFECE6] shadow-xl overflow-hidden py-1">
              <% if is_open %>
                <% if @inquiry.status_new_lead? %>
                  <%= button_to claim_inquiry_path(@inquiry),
                        form: { class: "block" }, data: { action: "menu#close" },
                        class: "w-full text-left flex items-center gap-2.5 px-4 py-2.5 text-[13px] text-[#D97757] font-medium hover:bg-[#FFF3EC]" do %>
                    <i class="ri-hand-heart-line"></i> Claim this lead
                  <% end %>
                <% else %>
                  <%= link_to convert_inquiry_path(@inquiry),
                        data: { action: "menu#close" },
                        class: "w-full text-left flex items-center gap-2.5 px-4 py-2.5 text-[13px] text-[#D97757] font-medium hover:bg-[#FFF3EC]" do %>
                    <i class="ri-user-add-line"></i> Convert to patient
                  <% end %>
                <% end %>

                <% if @inquiry.status_claimed? %>
                  <%= button_to mark_contacted_inquiry_path(@inquiry),
                        form: { class: "block" }, data: { action: "menu#close" },
                        class: "w-full text-left flex items-center gap-2.5 px-4 py-2.5 text-[13px] text-[#1D1C1A] hover:bg-[#FBF9F5]" do %>
                    <i class="ri-phone-line text-[#6B665F]"></i> Mark contacted
                  <% end %>
                <% end %>

                <div class="my-1 border-t border-[#EFECE6]"></div>
                <%= button_to dismiss_inquiry_path(@inquiry),
                      form: { class: "block", data: { turbo_confirm: "Dismiss this inquiry? It will drop off the inbox." } },
                      data: { action: "menu#close" },
                      class: "w-full text-left flex items-center gap-2.5 px-4 py-2.5 text-[13px] text-[#C1403A] hover:bg-[#FFF3EC]" do %>
                  <i class="ri-close-line"></i> Dismiss inquiry
                <% end %>
              <% elsif @inquiry.status_converted? && @inquiry.converted_patient.present? %>
                <%= link_to patient_path(@inquiry.converted_patient),
                      data: { action: "menu#close" },
                      class: "w-full text-left flex items-center gap-2.5 px-4 py-2.5 text-[13px] text-[#1D1C1A] hover:bg-[#FBF9F5]" do %>
                  <i class="ri-user-heart-line text-[#2F6F4E]"></i> Open patient record
                <% end %>
              <% else %>
                <div class="px-4 py-2.5 text-[13px] text-[#A8A299]">No actions available</div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <%# Full captured record. %>
      <%= render "summary", inquiry: @inquiry %>

      <% if stamps.size > 1 %>
        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-[11px] text-[#6B665F]">
          <% stamps.each do |label, t| %>
            <span><span class="uppercase tracking-widest text-[10px]"><%= label %></span> <%= t.strftime("%b %-d, %-l:%M %p") %></span>
          <% end %>
        </div>
      <% end %>

      <%# Terminal-state note (converted / dismissed) — actions live in the "..." menu. %>
      <% if @inquiry.status_converted? %>
        <div class="mt-6 pt-5 border-t border-[#EFECE6] flex items-center justify-between gap-3 flex-wrap">
          <div class="text-[13px] text-[#3A3936]">
            <i class="ri-check-line text-[#2F6F4E]"></i> Converted to a patient record.
          </div>
          <% if @inquiry.converted_patient.present? %>
            <%= link_to "Open patient", patient_path(@inquiry.converted_patient),
                  class: "text-[13px] text-[#2B4A7A] hover:underline font-medium" %>
          <% end %>
        </div>
      <% elsif @inquiry.status_dismissed? %>
        <div class="mt-6 pt-5 border-t border-[#EFECE6] text-[13px] text-[#6B665F]">
          <i class="ri-close-line"></i> This inquiry was dismissed. It no longer appears in the inbox.
        </div>
      <% end %>
    </div>
  </div>
</div>
