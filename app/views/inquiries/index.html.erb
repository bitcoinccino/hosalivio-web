<% content_for :title, "Referrals · Inquiries" %>
<%
  # Status pill: colour + human label per inquiry state shown in the inbox.
  status_pill = {
    "new_lead"    => [ "#D97757", "New lead" ],
    "claimed"     => [ "#2B4A7A", "Claimed" ],
    "contacted"   => [ "#2F6F4E", "Contacted" ],
    "considering" => [ "#8C6A2F", "Considering" ]
  }
  # Payer chip: fg + bg per coverage type (Medicare/Medicaid stand out).
  payer_pill = {
    "medicare" => [ "#2B4A7A", "#F0F4FA" ],
    "medicaid" => [ "#2F6F4E", "#E6F0EE" ],
    "private"  => [ "#8A4B2F", "#FFF7F2" ],
    "va"       => [ "#1D1C1A", "#EFECE6" ],
    "selfpay"  => [ "#6B665F", "#EFECE6" ]
  }
%>
<div class="max-w-5xl mx-auto px-4 md:px-8 py-6">
  <div class="flex items-start justify-between gap-3 mb-5 flex-wrap">
    <div>
      <a href="<%= dashboard_path %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-2">
        <i class="ri-arrow-left-line"></i> Dashboard
      </a>
      <h1 class="font-serif text-[24px] text-[#1D1C1A]">Referrals &amp; inquiries</h1>
      <div class="text-[12px] text-[#6B665F]"><%= @agency&.name %> · <%= @open_total %> open</div>
    </div>
    <% if @followups_due.to_i > 0 %>
      <%= link_to inquiries_path(status: "considering"),
            class: "inline-flex items-center gap-1.5 text-[12px] font-medium px-3 py-1.5 rounded-full bg-[#FFF3EC] text-[#B4552F] border border-[#F1C7AE] hover:bg-[#FCE7DA] transition" do %>
        <i class="ri-time-line"></i> <%= @followups_due %> follow-up<%= "s" if @followups_due != 1 %> due
      <% end %>
    <% end %>
  </div>

  <%# Status filter chips (link-based, preserve nothing else — this list has no search yet). %>
  <div class="flex items-center gap-1.5 flex-wrap mb-4">
    <%= link_to "All", inquiries_path,
          class: "text-[11px] px-2.5 py-1 rounded-full border transition #{@status.blank? ? 'bg-[#1D1C1A] text-white border-[#1D1C1A]' : 'border-[#EFECE6] text-[#6B665F] hover:bg-[#FBF9F5]'}" %>
    <% %w[new_lead claimed contacted considering].each do |st| %>
      <% color, label = status_pill[st] %>
      <%= link_to inquiries_path(status: st),
            class: "inline-flex items-center gap-1 text-[11px] px-2.5 py-1 rounded-full border transition #{@status == st ? 'bg-[#1D1C1A] text-white border-[#1D1C1A]' : 'border-[#EFECE6] text-[#6B665F] hover:bg-[#FBF9F5]'}" do %>
        <span class="w-1.5 h-1.5 rounded-full" style="background: <%= color %>;"></span><%= label %>
        <span class="font-mono opacity-70"><%= @status_counts[st] || 0 %></span>
      <% end %>
    <% end %>
  </div>

  <section class="rounded-2xl border border-[#EFECE6] bg-white overflow-hidden">
    <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between">
      <h2 class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold">
        <i class="ri-inbox-unarchive-line text-[#D97757]"></i> Inbox (<%= @inquiries.size %>)
      </h2>
      <span class="text-[10px] text-[#6B665F]">name · diagnosis · location</span>
    </div>

    <% if @inquiries.empty? %>
      <p class="px-5 py-10 text-center text-[13px] text-[#6B665F]">
        <%= @status.present? ? "No #{status_pill[@status]&.last&.downcase} inquiries right now." : "No open inquiries. New leads land here the moment they come in." %>
      </p>
    <% else %>
      <ul class="divide-y divide-[#EFECE6]">
        <% @inquiries.each do |inq| %>
          <% st_color, _st_label = status_pill[inq.status.to_s] || [ "#6B665F", inq.status.to_s ] %>
          <% initials = [ inq.first_name, inq.last_name ].map { |n| n.to_s.strip.first }.compact.join.upcase.presence %>
          <% full_name = [ inq.first_name, inq.last_name ].map(&:presence).compact.join(" ").presence || "Anonymous" %>
          <%# A whole row links to the detail page, where you decide what to do. %>
          <li>
            <%= link_to inquiry_path(inq), class: "flex items-center gap-3 px-5 py-3 hover:bg-[#FBF9F5] transition" do %>
              <div class="relative w-10 h-10 rounded-full bg-[#EFECE6] text-[#1D1C1A] text-[12px] font-bold flex items-center justify-center flex-shrink-0">
                <%= initials || "?" %>
                <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-white" style="background: <%= st_color %>;" title="<%= inq.status.to_s.tr("_", " ") %>"></span>
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 min-w-0">
                  <span class="text-[14px] text-[#1D1C1A] truncate font-medium"><%= full_name %></span>
                  <% if inq.payer_label %>
                    <% pfg, pbg = payer_pill[inq.payer] || [ "#6B665F", "#EFECE6" ] %>
                    <span class="flex-shrink-0 text-[10px] font-semibold px-1.5 py-0.5 rounded" style="color: <%= pfg %>; background: <%= pbg %>;"><%= inq.payer_label %></span>
                  <% end %>
                </div>
                <div class="text-[12px] text-[#6B665F] truncate">
                  <%= inq.diagnosis.presence || "Diagnosis not stated" %>
                </div>
                <div class="text-[11px] text-[#6B665F] truncate">
                  <span class="font-mono"><%= inq.zip.presence || "ZIP —" %></span>
                  <% if inq.city_state.present? %> · <%= inq.city_state %><% end %>
                  <% if inq.status_considering? && inq.follow_up_at.present? %>
                    · <span class="<%= inq.follow_up_due? ? "text-[#B4552F] font-medium" : "text-[#8C6A2F]" %>">
                        <i class="ri-time-line"></i> follow up <%= inq.follow_up_at.to_date.strftime("%b %-d") %>
                      </span>
                  <% end %>
                </div>
              </div>
              <span class="inline-flex items-center gap-1 text-[11px] px-3 py-1.5 rounded-full border border-[#EFECE6] text-[#3A3936] flex-shrink-0">
                View <i class="ri-arrow-right-line"></i>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </section>
</div>
