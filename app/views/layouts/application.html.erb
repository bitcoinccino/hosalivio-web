<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hosalivio Web" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hosalivio Web">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Tailwind-compiled CSS (built by tailwindcss:watch/build) %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%# Remix Icon — https://remixicon.com %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css">

    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#FBF9F5] text-[#1D1C1A] antialiased"
        data-viewer-family="<%= current_user&.family_access? ? 'true' : 'false' %>">
    <%= yield %>
  </body>
</html>
