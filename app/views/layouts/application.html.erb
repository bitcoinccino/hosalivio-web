<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hosalivio Web" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hosalivio Web">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Tailwind-compiled CSS (built by tailwindcss:watch/build) %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%# Remix Icon — https://remixicon.com %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css">

    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#FBF9F5] text-[#1D1C1A] antialiased"
        data-viewer-family="<%= current_user&.family_access? ? 'true' : 'false' %>"
        data-viewer-first-name="<%= viewer_mention_name %>"
        data-viewer-user-id="<%= current_user&.id %>"
        data-hosalivio-bot-src="<%= asset_path('hosalivio_assistant.png') %>">
    <%# Global flash / toast messages — auto-wired to flash_controller.js (dismiss). %>
    <% if flash.any? %>
      <div class="fixed top-4 right-4 z-50 flex flex-col gap-2 w-[min(92vw,360px)]">
        <% flash.each do |type, message| %>
          <% next if message.blank? %>
          <%
            tone = case type.to_s
                   when "notice", "success" then "border-[#2F6F4E] bg-[#EAF2EE] text-[#235c3e]"
                   when "alert", "error"     then "border-[#C1403A] bg-[#FFF3EC] text-[#9A2F2A]"
                   else                            "border-[#EFECE6] bg-white text-[#1D1C1A]"
                   end
            icon = case type.to_s
                   when "notice", "success" then "ri-checkbox-circle-line"
                   when "alert", "error"     then "ri-error-warning-line"
                   else                            "ri-information-line"
                   end
          %>
          <div data-controller="flash"
               class="flex items-start gap-2 rounded-xl border <%= tone %> px-3 py-2.5 shadow-sm text-[13px]">
            <i class="<%= icon %> mt-0.5"></i>
            <span class="flex-1"><%= message %></span>
            <button type="button" data-action="flash#dismiss" class="opacity-60 hover:opacity-100" aria-label="Dismiss">
              <i class="ri-close-line"></i>
            </button>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Live in-app notifications. Every page subscribes to the signed-in
        user's own signed stream; Notification#broadcast_realtime appends a
        toast the moment a mention / reply / assignment / flag is created,
        on whatever page they happen to be on. %>
    <% if user_signed_in? %>
      <%= turbo_stream_from "notifications:user:#{current_user.id}" %>
      <div id="notification-toasts" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 w-[min(92vw,360px)]"></div>
    <% end %>

    <%= yield %>

    <%# Cookie notice — shown to visitors (signed-in users have already passed
        through the public site); avoids overlapping the app's fixed bottom UI. %>
    <% unless user_signed_in? %>
      <%= render "shared/cookie_banner" %>
    <% end %>
  </body>
</html>
