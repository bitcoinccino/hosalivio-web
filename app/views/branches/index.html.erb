<% content_for :title, "Branches · HosAlivio" %>
<div class="min-h-screen bg-[#FBF9F5] py-10 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/dashboard" class="text-[12px] text-[#6B665F] hover:text-[#1D1C1A] inline-flex items-center gap-1 mb-2">
          <i class="ri-arrow-left-line"></i> Dashboard
        </a>
        <h1 class="font-serif text-2xl text-[#1D1C1A]">Branches</h1>
        <div class="text-[12px] text-[#6B665F] mt-0.5">
          <%= current_user.agency&.name %> · <%= @branches.count %> location<%= @branches.count == 1 ? "" : "s" %>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to new_branch_path,
              class: "inline-flex items-center gap-1.5 text-[13px] px-4 py-2 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white font-medium" do %>
          <i class="ri-map-pin-add-line"></i> New branch
        <% end %>
        <span class="w-px h-6 bg-[#EFECE6] mx-1"></span>
        <%= render "shared/user_menu" %>
      </div>
    </div>

    <% if flash[:notice] %>
      <div class="mb-4 px-4 py-3 rounded-lg bg-[#EEF5EC] border border-[#9BBF93] text-[#2F6F4E] text-[13px]"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="mb-4 px-4 py-3 rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[#C1403A] text-[13px]"><%= flash[:alert] %></div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%
        type_pill_color = {
          "office" => "#3A6B7A", "ipu" => "#8C2F5A",
          "satellite" => "#6B7A3A", "storage_hub" => "#7A6B5A"
        }
      %>
      <% @branches.each do |b| %>
        <div class="rounded-2xl bg-white border border-[#EFECE6] p-5 <%= 'opacity-60' unless b.active %>">
          <div class="flex items-start justify-between">
            <div>
              <div class="flex items-center gap-2">
                <span class="inline-block px-2 py-0.5 rounded-full text-[10px] uppercase tracking-wider text-white"
                      style="background: <%= type_pill_color[b.branch_type] || '#6B665F' %>;">
                  <%= b.branch_type.to_s.tr("_", " ") %>
                </span>
                <% if b.active %>
                  <span class="text-[11px] text-[#2F6F4E]">● Active</span>
                <% else %>
                  <span class="text-[11px] text-[#C1403A]">● Inactive</span>
                <% end %>
              </div>
              <h2 class="font-serif text-lg text-[#1D1C1A] mt-1"><%= b.name %></h2>
              <div class="text-[12px] text-[#6B665F]">
                <%= [b.city, b.state, b.zip].compact_blank.join(", ").presence || "Location not set" %>
                <span class="ml-1 text-[10px] font-mono">· <%= b.timezone %></span>
              </div>
            </div>
          </div>

          <% if b.npi.present? || b.ccn.present? %>
            <div class="mt-3 text-[10px] font-mono text-[#6B665F] flex flex-wrap gap-x-3">
              <% if b.npi.present? %><span>NPI <span class="text-[#1D1C1A]"><%= b.npi %></span></span><% end %>
              <% if b.ccn.present? %><span>CCN <span class="text-[#1D1C1A]"><%= b.ccn %></span></span><% end %>
              <% if b.state_license_number.present? %><span>LIC <span class="text-[#1D1C1A]"><%= b.state_license_number %></span></span><% end %>
            </div>
          <% end %>

          <div class="mt-3 text-[11px] text-[#6B665F]">
            <i class="ri-route-line"></i> <%= b.service_area_summary %>
          </div>

          <div class="grid grid-cols-3 gap-3 mt-4 pt-3 border-t border-[#EFECE6] text-[12px]">
            <div>
              <div class="text-[9px] uppercase tracking-widest text-[#6B665F]">Staff</div>
              <div class="font-mono text-[#1D1C1A]"><%= b.staff_count %></div>
            </div>
            <div>
              <div class="text-[9px] uppercase tracking-widest text-[#6B665F]">Patients</div>
              <div class="font-mono text-[#1D1C1A]"><%= b.patient_count %></div>
            </div>
            <div>
              <div class="text-[9px] uppercase tracking-widest text-[#6B665F]">Phone</div>
              <div class="font-mono text-[#1D1C1A] truncate"><%= b.phone.presence || "—" %></div>
            </div>
          </div>

          <% leadership = [
               ["Admin", b.manager],
               ["MD",    b.medical_director],
               ["DON",   b.director_of_nursing],
               ["Sup",   b.clinical_supervisor]
             ].select { |_, u| u } %>
          <% if leadership.any? %>
            <div class="mt-3 pt-3 border-t border-[#EFECE6] text-[11px] text-[#6B665F] space-y-0.5">
              <% leadership.each do |label, user| %>
                <div><span class="font-mono text-[9px] uppercase tracking-wider mr-1"><%= label %></span><%= user.full_name %></div>
              <% end %>
            </div>
          <% end %>

          <div class="mt-4 flex items-center justify-end gap-2">
            <%= link_to "Edit", edit_branch_path(b), class: "text-[12px] px-3 py-1 rounded-full border border-[#D9D5CD] text-[#1D1C1A] hover:bg-[#FBF9F5]" %>
            <% if b.users.empty? && b.patients.empty? %>
              <%= button_to "Delete", branch_path(b), method: :delete,
                    data: { turbo_confirm: "Delete branch '#{b.name}'?" },
                    class: "text-[12px] px-3 py-1 rounded-full border border-[#D9D5CD] text-[#C1403A] hover:bg-[#FFF3EC]" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
