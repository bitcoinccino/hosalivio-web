<%
  # Pool of clinicians at this agency — never family users. Scoped per
  # leadership slot below so each dropdown only shows the appropriate
  # role (MD director gets MDs, DON gets DONs, etc.).
  clinical_pool = User
                    .where(agency: current_user.agency, active: true)
                    .where(family_access: [false, nil])
                    .includes(:roles)
                    .order(:full_name)

  options_for_role = ->(role_names) {
    pool = clinical_pool.select { |u| (u.role_names & Array(role_names)).any? }
    pool.map { |u| [u.full_name, u.id] }
  }
  any_clinician_options = clinical_pool.map { |u| [u.full_name, u.id] }

  manager_options    = options_for_role.call(%w[admin don admissions])
  md_options         = options_for_role.call(%w[md])
  don_options        = options_for_role.call(%w[don])
  supervisor_options = options_for_role.call(%w[don rn])

  type_options = [
    ["Standard office (admin)", "office"],
    ["Inpatient Unit (freestanding IPU)", "ipu"],
    ["Satellite site", "satellite"],
    ["Storage hub / DME warehouse", "storage_hub"]
  ]
  input_cls = "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]"
  label_cls = "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1"

  # Collapsible section (accordion) styles.
  det_cls  = "group rounded-xl border border-[#EFECE6] bg-white overflow-hidden"
  summ_cls = "flex items-center justify-between px-4 py-3 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden hover:bg-[#FBF9F5]"
  sumttl   = "flex items-center gap-2 text-[12px] uppercase tracking-[0.15em] text-[#6B665F] font-bold"
  chev     = "ri-arrow-down-s-line text-lg text-[#6B665F] group-open:rotate-180 transition-transform"
  body_cls = "px-4 pb-4 pt-1 space-y-3"
%>
<%= form_with(model: @branch, local: true, html: { class: "space-y-4" }) do |f| %>
  <% if flash[:alert].present? %>
    <div class="px-3 py-2 rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[#C1403A] text-sm">
      <i class="ri-error-warning-line mr-1"></i><%= flash[:alert] %>
    </div>
  <% end %>

  <!-- 1. Identity -->
  <details class="<%= det_cls %>" open>
    <summary class="<%= summ_cls %>">
      <span class="<%= sumttl %>"><i class="ri-building-2-line"></i> Identity</span>
      <i class="<%= chev %>"></i>
    </summary>
    <div class="<%= body_cls %>">
      <div class="grid grid-cols-3 gap-3">
        <div class="col-span-2">
          <%= f.label :name, "Branch name", class: label_cls %>
          <%= f.text_field :name, required: true, placeholder: "e.g. Orlando", class: input_cls %>
        </div>
        <div>
          <%= f.label :branch_type, "Type", class: label_cls %>
          <%= f.select :branch_type, type_options, {}, class: input_cls %>
        </div>
      </div>
      <div>
        <%= f.label :address_line1, "Street (line 1)", class: label_cls %>
        <%= f.text_field :address_line1, placeholder: "123 Main St", class: input_cls %>
      </div>
      <div>
        <%= f.label :address_line2, "Street (line 2, optional)", class: label_cls %>
        <%= f.text_field :address_line2, placeholder: "Suite 200", class: input_cls %>
      </div>
      <div class="grid grid-cols-4 gap-3">
        <div class="col-span-2">
          <%= f.label :city, class: label_cls %>
          <%= f.text_field :city, class: input_cls %>
        </div>
        <div>
          <%= f.label :state, class: label_cls %>
          <%= f.text_field :state, maxlength: 2, placeholder: "FL", class: "#{input_cls} uppercase" %>
        </div>
        <div>
          <%= f.label :zip, class: label_cls %>
          <%= f.text_field :zip, class: input_cls %>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <%= f.label :phone, "Main phone", class: label_cls %>
          <%= f.telephone_field :phone, class: input_cls %>
        </div>
        <div>
          <%= f.label :after_hours_phone, "After-hours triage line", class: label_cls %>
          <%= f.telephone_field :after_hours_phone, class: input_cls %>
        </div>
      </div>
    </div>
  </details>

  <!-- 2. Regulatory -->
  <details class="<%= det_cls %>">
    <summary class="<%= summ_cls %>">
      <span class="<%= sumttl %>"><i class="ri-shield-check-line"></i> Regulatory &amp; Compliance</span>
      <i class="<%= chev %>"></i>
    </summary>
    <div class="<%= body_cls %>">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <%= f.label :npi, "NPI (10 digits)", class: label_cls %>
          <%= f.text_field :npi, maxlength: 10, placeholder: "1234567890", class: "#{input_cls} font-mono" %>
        </div>
        <div>
          <%= f.label :ccn, "Medicare CCN", class: label_cls %>
          <%= f.text_field :ccn, maxlength: 10, placeholder: "103001", class: "#{input_cls} font-mono" %>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <%= f.label :ein, "Tax ID / EIN", class: label_cls %>
          <%= f.text_field :ein, placeholder: "XX-XXXXXXX", class: "#{input_cls} font-mono" %>
        </div>
        <div>
          <%= f.label :state_license_number, "State license #", class: label_cls %>
          <%= f.text_field :state_license_number, class: "#{input_cls} font-mono" %>
        </div>
      </div>
    </div>
  </details>

  <!-- 3. Operational & Routing -->
  <details class="<%= det_cls %>">
    <summary class="<%= summ_cls %>">
      <span class="<%= sumttl %>"><i class="ri-route-line"></i> Operational &amp; Routing</span>
      <i class="<%= chev %>"></i>
    </summary>
    <div class="<%= body_cls %>">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <%= f.label :timezone, class: label_cls %>
          <%= f.select :timezone,
                ActiveSupport::TimeZone.us_zones.map { |z| [z.name, z.name] },
                { selected: @branch.timezone.presence || "America/New_York" },
                class: input_cls %>
        </div>
        <div>
          <%= f.label :triage_email, "Triage / alerts inbox", class: label_cls %>
          <%= f.email_field :triage_email, placeholder: "orlando.triage@mercy.com", class: input_cls %>
        </div>
      </div>
      <div>
        <%= f.label :service_area_zips, "Service-area ZIP codes", class: label_cls %>
        <%= render "tag_field",
              values:      Array(@branch.service_area_zips),
              name:        "branch[service_area_zips][]",
              placeholder: "Type a ZIP and press Enter…",
              pattern:     '^\d{3}(\d{2})?$' %>
        <div class="text-[10px] text-[#6B665F] mt-1">Add 5-digit ZIPs or 3-digit prefixes (e.g. 328). Admissions AI routes inquiries to the branch whose ZIPs match.</div>
      </div>
      <div>
        <%= f.label :service_area_counties, "Service-area counties", class: label_cls %>
        <%= render "tag_field",
              values:          Array(@branch.service_area_counties),
              name:            "branch[service_area_counties][]",
              placeholder:     "Type a county and press Enter…",
              space_separated: false %>
        <div class="text-[10px] text-[#6B665F] mt-1">Add one county per tag. Used alongside ZIPs to route inquiries to this branch.</div>
      </div>
    </div>
  </details>

  <!-- 4. Leadership -->
  <details class="<%= det_cls %>">
    <summary class="<%= summ_cls %>">
      <span class="<%= sumttl %>"><i class="ri-user-star-line"></i> Leadership</span>
      <i class="<%= chev %>"></i>
    </summary>
    <div class="<%= body_cls %>">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <%= f.label :manager_id, "Administrator / branch manager", class: label_cls %>
          <%= f.select :manager_id, manager_options, { include_blank: "— none —" }, class: input_cls %>
        </div>
        <div>
          <%= f.label :medical_director_id, "Medical Director (MD)", class: label_cls %>
          <%= f.select :medical_director_id, md_options, { include_blank: "— none —" }, class: input_cls %>
        </div>
        <div>
          <%= f.label :director_of_nursing_id, "Director of Nursing (DON)", class: label_cls %>
          <%= f.select :director_of_nursing_id, don_options, { include_blank: "— none —" }, class: input_cls %>
        </div>
        <div>
          <%= f.label :clinical_supervisor_id, "Clinical supervisor", class: label_cls %>
          <%= f.select :clinical_supervisor_id, supervisor_options, { include_blank: "— none —" }, class: input_cls %>
        </div>
      </div>
    </div>
  </details>

  <!-- Actions -->
  <div class="pt-4 border-t border-[#EFECE6] flex items-center justify-between gap-3 flex-wrap">
    <%# Active — a switch with a short explanation. %>
    <label class="inline-flex items-center gap-3 cursor-pointer">
      <span class="relative inline-flex items-center">
        <%= f.check_box :active, class: "peer sr-only" %>
        <span class="w-10 h-6 rounded-full bg-[#D9D5CD] peer-checked:bg-[#2F6F4E] peer-focus-visible:ring-2 peer-focus-visible:ring-[#D97757] transition"></span>
        <span class="absolute left-0.5 top-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform peer-checked:translate-x-4"></span>
      </span>
      <span>
        <span class="block text-[13px] font-medium text-[#1D1C1A]">Active branch</span>
        <span class="block text-[11px] text-[#6B665F]">Inactive branches are hidden from routing and new admissions.</span>
      </span>
    </label>

    <div class="flex items-center gap-2">
      <%= link_to branches_path,
            class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-[#D9D5CD] text-[#6B665F] hover:bg-[#EFECE6] hover:text-[#1D1C1A] text-sm font-medium transition" do %>
        <i class="ri-close-line"></i> Cancel
      <% end %>
      <%= f.submit (@branch.persisted? ? "Save changes" : "Create branch"),
            class: "inline-flex items-center gap-1.5 px-5 py-2 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium cursor-pointer" %>
    </div>
  </div>
<% end %>
