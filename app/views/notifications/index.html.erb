<% content_for :title, "Notifications · HosAlivio" %>

<div class="min-h-screen bg-[#FBF9F5] py-10 px-4">
  <div class="max-w-2xl mx-auto">
    <a href="<%= dashboard_path %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to dashboard
    </a>

    <div class="flex items-center justify-between mb-5">
      <h1 class="font-serif text-2xl text-[#1D1C1A]">Your notifications</h1>
      <% if @notifications.any? { |n| n.read_at.nil? } %>
        <%= button_to mark_all_read_notifications_path, class: "text-[12px] text-[#6B665F] hover:text-[#1D1C1A] underline-offset-2 hover:underline" do %>
          Mark all read
        <% end %>
      <% end %>
    </div>

    <%# Live target: Notification#broadcast_realtime prepends new rows here and
        removes the empty state below. The layout already subscribes this page
        to the user's notifications stream. %>
    <div id="notifications-list" class="space-y-2">
      <%= render @notifications %>
    </div>

    <% if @notifications.empty? %>
      <div id="notif-empty-state" class="text-center py-20 text-[#6B665F]">
        <div class="w-12 h-12 rounded-full bg-[#EFECE6] flex items-center justify-center mx-auto mb-3">
          <i class="ri-notification-off-line text-xl"></i>
        </div>
        <div class="font-serif text-lg text-[#1D1C1A]">Quiet for now.</div>
        <div class="text-[13px] mt-1">Reminders for tomorrow's visits arrive in the afternoon.</div>
      </div>
    <% end %>
  </div>
</div>
