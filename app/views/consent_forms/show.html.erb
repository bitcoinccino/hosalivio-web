<%
  c   = @consent
  sig = c.signatures.recent_first.first
%>
<% content_for :title, "#{c.kind_label} · #{@patient.full_name}" %>
<style>
  @media print {
    @page { margin: 0.6in; size: letter; }
    body { background: white !important; color: black !important; }
    .no-print, .no-print * { display: none !important; }
  }
</style>
<div class="min-h-screen bg-[#FBF9F5] py-8 px-6">
  <div class="max-w-3xl mx-auto">
    <div class="flex items-center justify-between gap-3 mb-4 no-print">
      <a href="<%= patient_consents_path(@patient) %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A]">
        <i class="ri-arrow-left-line"></i> Back to consents
      </a>
      <button type="button" onclick="window.print()"
              class="inline-flex items-center gap-1 text-[12px] px-3 py-1.5 rounded-full border border-[#EFECE6] bg-white hover:bg-[#FBF9F5] text-[#6B665F]">
        <i class="ri-printer-line"></i> Print / Download PDF
      </button>
    </div>

    <div class="rounded-2xl bg-white border border-[#EFECE6] p-6 shadow-sm">
      <div class="flex items-start justify-between gap-3 flex-wrap mb-1">
        <div>
          <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold">Signed consent</div>
          <h1 class="font-serif text-2xl text-[#1D1C1A] leading-tight"><%= c.kind_label %></h1>
        </div>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] uppercase tracking-widest font-bold text-[#2F6F4E] bg-[#E6F0EE] border border-[#2F6F4E]">
          <i class="ri-shield-check-line"></i> Signed
        </span>
      </div>
      <div class="text-[12px] text-[#6B665F] mt-1 mb-5">
        For <%= @patient.full_name %> · MRN <%= @patient.mrn %> ·
        <%= c.signed_at.strftime("%a %b %-d, %Y · %-l:%M %p") %>
      </div>

      <%# What was signed — same body the signer agreed to. %>
      <% if c.form_content.present? %>
        <section class="rounded-xl bg-[#FBF9F5] border border-[#EFECE6] p-4 mb-5">
          <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-1">Attestation</div>
          <p class="text-[14px] text-[#1D1C1A] leading-relaxed whitespace-pre-wrap"><%= c.form_content %></p>
        </section>
      <% end %>

      <%# Signer block — patient or representative + relationship %>
      <section class="rounded-xl border border-[#EFECE6] p-4 mb-5">
        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-2">Signer</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-[12px]">
          <div>
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Name</div>
            <div class="text-[#1D1C1A] font-medium"><%= c.signer_name %></div>
          </div>
          <div>
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Role</div>
            <div class="text-[#1D1C1A]">
              <% if c.signed_by_patient? %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] uppercase tracking-widest font-bold text-[#2F6F4E] bg-[#E6F0EE] border border-[#2F6F4E]">
                  <i class="ri-user-3-line"></i> Patient (self)
                </span>
              <% else %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] uppercase tracking-widest font-bold text-[#D97757] bg-[#FFF3EC] border border-[#D97757]">
                  <i class="ri-team-line"></i> Representative
                </span>
                <% rel = c.signer_relationship.presence || c.signer_role.tr("_", " ").titleize %>
                <span class="text-[12px] text-[#1D1C1A] ml-1"><%= rel %></span>
              <% end %>
            </div>
          </div>
          <% unless c.signed_by_patient? %>
            <div class="sm:col-span-2">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Authority to sign</div>
              <div class="text-[#1D1C1A]"><%= c.signer_authority.presence || "—" %></div>
            </div>
          <% end %>
          <div>
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Witnessed by</div>
            <div class="text-[#1D1C1A] font-medium"><%= c.witnessed_by.full_name %></div>
          </div>
          <div>
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Signed at</div>
            <div class="text-[#1D1C1A] font-mono text-[12px]"><%= c.signed_at.strftime("%Y-%m-%d %H:%M %Z") %></div>
          </div>
        </div>
      </section>

      <%# Signature image — drawn fresh on the witnessing tablet. %>
      <section class="mb-5">
        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-2">Signature</div>
        <% if c.signature_image.attached? %>
          <div class="bg-white rounded-xl border border-[#EFECE6] p-4 inline-block">
            <%= image_tag c.signature_image, class: "h-28 max-w-[500px] object-contain" %>
          </div>
        <% else %>
          <div class="text-[12px] text-[#6B665F] italic">No signature image stored.</div>
        <% end %>
      </section>

      <%# Audit row — IP / user-agent / verification method / hash %>
      <% if sig %>
        <section class="rounded-xl bg-[#FBF9F5] border border-[#EFECE6] p-4">
          <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-1">Audit</div>
          <div class="text-[11px] text-[#6B665F] leading-relaxed">
            <%= sig.short_audit_line %>
            <% if sig.user_agent.present? %>
              <br><span class="text-[#1D1C1A] font-mono text-[10px]"><%= sig.user_agent.truncate(80) %></span>
            <% end %>
          </div>
          <% if sig.document_hash.present? %>
            <div class="mt-2 pt-2 border-t border-[#EFECE6]">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-0.5 inline-flex items-center gap-1">
                <i class="ri-fingerprint-line"></i> Security hash (SHA-256)
              </div>
              <div class="font-mono text-[10px] text-[#1D1C1A] break-all leading-tight"
                   title="Hash of the signed payload at signing time. Any change to the underlying record after this would produce a different hash.">
                <%= sig.document_hash %>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>
    </div>
  </div>
</div>
