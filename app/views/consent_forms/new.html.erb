<%
  kind  = (@consent.kind.presence || "hospice_election")
  label = ConsentForm::KIND_LABELS[kind] || kind.titleize

  # Single source of truth on the model (also snapshotted server-side into
  # form_content at create). Agency name is filled in — bold + uppercase —
  # so the document names who the care is from / whose notice it is.
  body      = ConsentForm.attestation_html_for(kind, agency: @patient.agency)
  rationale = ConsentForm.rationale_html_for(kind, agency: @patient.agency)
%>
<% content_for :title, "New consent · #{@patient.full_name}" %>
<div class="min-h-screen bg-[#FBF9F5] py-8 px-6">
  <div class="max-w-3xl mx-auto">
    <a href="<%= patient_consents_path(@patient) %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to consents
    </a>

    <%= form_with model: @consent, url: patient_consents_path(@patient), local: true,
          data: {
            controller: "consent-sign",
            consent_sign_patient_name_value: @patient.full_name,
            action: "submit->consent-sign#submit"
          },
          class: "space-y-5" do |f| %>

      <%# Header — patient + consent kind %>
      <section class="rounded-2xl bg-white border border-[#EFECE6] p-5">
        <% if @guided %>
          <div class="mb-2 inline-flex items-center gap-1.5 text-[10px] uppercase tracking-widest text-[#D97757] font-bold">
            <i class="ri-list-check-2"></i> Required admission consent · you can stop and finish later
          </div>
        <% end %>
        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-1">Consent</div>
        <h1 class="font-serif text-2xl text-[#1D1C1A] leading-tight"><%= label %></h1>
        <div class="text-[12px] text-[#6B665F] mt-1">
          For <strong class="text-[#1D1C1A] font-medium"><%= @patient.full_name %></strong>
          · MRN <%= @patient.mrn %>
          · witnessed by <%= @witness&.full_name || "your care team" %>
        </div>
        <%= f.hidden_field :kind, value: kind %>
        <% if @guided %><input type="hidden" name="flow" value="required"><% end %>
      </section>

      <%# Why this form is required — collapsible; expand to read the rationale. %>
      <% if rationale.present? %>
        <details class="group rounded-2xl bg-[#F0F4FA] border border-[#D7E0EE]">
          <summary class="list-none cursor-pointer flex items-center justify-between gap-2 p-5 [&::-webkit-details-marker]:hidden">
            <span class="flex items-center gap-1.5 text-[10px] uppercase tracking-widest text-[#2B4A7A] font-bold">
              <i class="ri-information-line"></i> Why this is required
            </span>
            <i class="ri-arrow-down-s-line text-[#2B4A7A] group-open:rotate-180 transition-transform"></i>
          </summary>
          <p class="px-5 pb-5 text-[13px] text-[#2B4A7A] leading-relaxed"><%= rationale %></p>
        </details>
      <% end %>

      <%# The text the signer is agreeing to — collapsible, open by default. %>
      <details open class="group rounded-2xl bg-white border border-[#EFECE6]">
        <summary class="list-none cursor-pointer flex items-center justify-between gap-2 p-5 [&::-webkit-details-marker]:hidden">
          <span class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold">What's being signed</span>
          <i class="ri-arrow-down-s-line text-[#6B665F] group-open:rotate-180 transition-transform"></i>
        </summary>
        <p class="px-5 pb-5 text-[14px] text-[#1D1C1A] leading-relaxed whitespace-pre-wrap"><%= body %></p>
      </details>

      <%# Who is signing — patient / known family member / other %>
      <section class="rounded-2xl bg-white border border-[#EFECE6] p-5">
        <div class="text-[10px] uppercase tracking-widest text-[#4A4A45] font-bold mb-3">Who is signing?</div>

        <div class="inline-flex p-1 bg-[#FBF9F5] rounded-full border border-[#EFECE6] gap-1 mb-4">
          <button type="button" data-consent-sign-target="patientBtn"
                  data-action="click->consent-sign#signerPatient"
                  class="px-4 py-1.5 rounded-full text-[12px] font-medium bg-white text-[#1D1C1A] shadow-sm">
            The patient
          </button>
          <button type="button" data-consent-sign-target="someoneBtn"
                  data-action="click->consent-sign#signerSomeone"
                  class="px-4 py-1.5 rounded-full text-[12px] font-medium text-[#6B665F]">
            Someone else
          </button>
        </div>

        <%= f.hidden_field :signer_role, value: "patient", data: { consent_sign_target: "roleField" } %>

        <%# "Someone else" mode: pick the family member FIRST — it fills in the
            name below. Shown above the name field. %>
        <% if @family_users.any? %>
          <div data-consent-sign-target="familyBlock" class="hidden mb-3">
            <label class="block text-[11px] uppercase tracking-widest text-[#4A4A45] font-bold mb-1">Which family member?</label>
            <select data-consent-sign-target="familySelect" data-action="change->consent-sign#familyChanged"
                    class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
              <option value="">Select…</option>
              <% @family_users.each do |fu| %>
                <option value="fam-<%= fu.id %>"
                        data-name="<%= fu.full_name %>"
                        data-role="<%= ConsentForm.role_for_relationship(fu.relationship) %>"
                        data-rel="<%= fu.relationship %>">
                  <%= fu.full_name %><%= " · #{fu.relationship}" if fu.relationship.present? %>
                </option>
              <% end %>
              <option value="other">Someone else (not listed)</option>
            </select>
          </div>
        <% end %>

        <%# Signer name — auto-filled + read-only for the patient and known
            family; editable only in "other". %>
        <div class="mb-3">
          <label class="block text-[11px] uppercase tracking-widest text-[#4A4A45] font-bold mb-1">Signer name</label>
          <%= f.text_field :signer_name, value: @patient.full_name, readonly: true, required: true,
                placeholder: "Type the signer's full name",
                data: { consent_sign_target: "nameField", action: "input->consent-sign#nameTyped" },
                class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px] font-serif uppercase tracking-wider" %>
        </div>

        <div data-consent-sign-target="patientNote" class="text-[11px] text-[#6B665F] italic">
          The patient is signing in person, witnessed by <%= @witness&.full_name || current_user.full_name %>.
        </div>

        <%# Representative details — shown below the name in "Someone else" mode. %>
        <div data-consent-sign-target="repDetails" class="hidden space-y-3 pt-3 border-t border-[#EFECE6]">
          <%# Manual relationship fields — hidden until "other" (or shown
              immediately when no family is on file). %>
          <div data-consent-sign-target="otherFields" class="<%= "hidden" if @family_users.any? %> grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <label class="block text-[11px] uppercase tracking-widest text-[#4A4A45] font-bold mb-1">Relationship to patient</label>
              <select data-consent-sign-target="roleSelect" data-action="change->consent-sign#roleSelectChanged"
                      class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]">
                <%= options_for_select(ConsentForm::REPRESENTATIVE_ROLE_OPTIONS) %>
              </select>
            </div>
            <div>
              <label class="block text-[11px] uppercase tracking-widest text-[#4A4A45] font-bold mb-1">Relationship label (optional)</label>
              <%= f.text_field :signer_relationship, placeholder: "e.g. eldest son",
                    data: { consent_sign_target: "relInput" },
                    class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
            </div>
          </div>

          <%# Authority to sign — a selectable list of standing bases. %>
          <div>
            <label class="block text-[11px] uppercase tracking-widest text-[#4A4A45] font-bold mb-1">Authority to sign on the patient's behalf</label>
            <%= f.select :signer_authority, ConsentForm::AUTHORITY_OPTIONS,
                  { include_blank: "Select…" },
                  class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
            <div class="text-[10px] text-[#6B665F] mt-1">CMS expects a documented reason when a representative signs instead of the patient.</div>
          </div>
        </div>
      </section>

      <%# Signature canvas %>
      <section class="rounded-2xl bg-white border border-[#EFECE6] p-5">
        <div class="text-[10px] uppercase tracking-widest text-[#4A4A45] font-bold mb-2">Signature</div>
        <div class="rounded-xl border-2 border-dashed border-[#D9D5CD] bg-[#FBF9F5] overflow-hidden mb-3" style="touch-action: none;">
          <canvas data-consent-sign-target="canvas"
                  class="w-full h-[200px] block bg-white"></canvas>
        </div>
        <%# Printed name beneath the signature — mirrors the signer name live. %>
        <div class="flex items-baseline gap-2 mb-3 px-1">
          <span class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold flex-shrink-0">Printed name</span>
          <span data-consent-sign-target="printedName"
                class="flex-1 border-b border-[#D9D5CD] text-[14px] text-[#1D1C1A] font-serif uppercase tracking-wider pb-0.5">&nbsp;</span>
        </div>
        <div class="flex items-center justify-between gap-3 flex-wrap">
          <div class="text-[11px] text-[#6B665F]">
            Hand the tablet to the signer. They draw above; we'll smooth the strokes.
          </div>
          <button type="button"
                  data-action="click->consent-sign#clearPad"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[12px] text-[#6B665F] hover:bg-[#FBF9F5] border border-[#D9D5CD]">
            <i class="ri-eraser-line"></i> Clear
          </button>
        </div>
        <%= f.hidden_field :signature_data_url, data: { consent_sign_target: "dataField" } %>
      </section>

      <%# Errors %>
      <% if @consent.errors.any? %>
        <div class="rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[#C1403A] text-[12px] px-4 py-3">
          <%= @consent.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <p class="text-[11px] text-[#6B665F] text-center">
        By signing, the signer agrees to HosAlivio's
        <%= link_to "Terms of Service", terms_path, target: "_blank", rel: "noopener", class: "underline hover:text-[#1D1C1A]" %> and
        <%= link_to "Privacy Policy", privacy_path, target: "_blank", rel: "noopener", class: "underline hover:text-[#1D1C1A]" %>.
      </p>

      <div class="flex items-center justify-between gap-3">
        <%= link_to "Cancel", patient_consents_path(@patient),
              class: "text-[13px] text-[#6B665F] hover:text-[#1D1C1A]" %>
        <button type="submit"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white text-sm font-semibold shadow-sm">
          <i class="ri-quill-pen-line"></i> Capture signature
        </button>
      </div>
    <% end %>
  </div>
</div>
