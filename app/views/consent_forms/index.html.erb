<% content_for :title, "Consents · #{@patient.full_name}" %>
<div class="min-h-screen bg-[#FBF9F5] py-8 px-6">
  <div class="max-w-3xl mx-auto">
    <a href="<%= patient_path(@patient) %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to <%= @patient.full_name %>
    </a>

    <div class="flex items-center justify-between gap-3 flex-wrap mb-5">
      <div>
        <h1 class="font-serif text-2xl text-[#1D1C1A]">Consent forms</h1>
        <div class="text-[12px] text-[#6B665F] mt-1"><%= @patient.full_name %> · <%= @patient.mrn %></div>
      </div>
    </div>

    <%
      fam         = current_user.family_access?
      signed      = @consents.map(&:kind).uniq
      first_out   = @outstanding_required.first
      other_kinds = ConsentForm::KINDS - ConsentForm::REQUIRED_KINDS   # clinician-only (DNR)
    %>

    <%# Required-for-admission checklist + guided "sign each form" launcher. %>
    <div class="rounded-2xl bg-white border border-[#EFECE6] p-4 mb-5">
      <div class="flex items-center justify-between gap-3 mb-3">
        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold">Required for admission</div>
        <% if first_out %>
          <%= link_to new_patient_consent_path(@patient, kind: first_out, flow: "required"),
                class: "inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white font-medium" do %>
            <i class="ri-list-check-2"></i> Start required consents
          <% end %>
        <% else %>
          <span class="inline-flex items-center gap-1 text-[11px] text-[#2F6F4E] font-medium"><i class="ri-checkbox-circle-line"></i> All signed</span>
        <% end %>
      </div>
      <div class="space-y-2">
        <% ConsentForm::REQUIRED_KINDS.each do |k| %>
          <% done = signed.include?(k) %>
          <div class="flex items-start gap-2 text-[13px]">
            <i class="mt-0.5 <%= done ? "ri-checkbox-circle-fill text-[#2F6F4E]" : "ri-checkbox-blank-circle-line text-[#B9B4AB]" %>"></i>
            <div class="min-w-0 flex-1">
              <div class="<%= done ? "text-[#6B665F]" : "text-[#1D1C1A]" %>"><%= ConsentForm::KIND_LABELS[k] %></div>
              <% r = ConsentForm.rationale_html_for(k, agency: @patient.agency) %>
              <% if r.present? %><div class="text-[11px] text-[#6B665F] mt-0.5 leading-snug"><%= r %></div><% end %>
            </div>
            <% unless done %>
              <%= link_to "Sign", new_patient_consent_path(@patient, kind: k),
                    class: "flex-shrink-0 text-[12px] px-3 py-1 rounded-full bg-[#FFF3EC] hover:bg-[#FCE9DD] border border-[#D97757] text-[#D97757] font-medium" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Other consents (e.g. DNR) — clinician-captured only. %>
    <% unless fam %>
      <div class="rounded-2xl bg-white border border-[#EFECE6] p-4 mb-5">
        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-3">Other consents</div>
        <div class="space-y-2">
          <% other_kinds.each do |k| %>
            <% r = ConsentForm.rationale_html_for(k, agency: @patient.agency) %>
            <div class="flex items-start justify-between gap-3 rounded-xl border border-[#EFECE6] p-3">
              <div class="min-w-0">
                <div class="text-[13px] font-medium text-[#1D1C1A]"><%= ConsentForm::KIND_LABELS[k] %></div>
                <% if r.present? %><div class="text-[11px] text-[#6B665F] mt-0.5 leading-snug"><%= r %></div><% end %>
              </div>
              <%= link_to new_patient_consent_path(@patient, kind: k),
                    class: "flex-shrink-0 inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full bg-[#FFF3EC] hover:bg-[#FCE9DD] border border-[#D97757] text-[#D97757] font-medium" do %>
                <i class="ri-quill-pen-line"></i> Sign
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Existing consents, newest first. Each row links to a
        detail view that renders the signed form + audit trail. %>
    <% if @consents.any? %>
      <ul class="space-y-2">
        <% @consents.each do |c| %>
          <li class="rounded-2xl bg-white border border-[#EFECE6] p-4 flex items-start justify-between gap-3 hover:border-[#D97757] transition">
            <div class="flex-1 min-w-0">
              <div class="text-[13px] font-medium text-[#1D1C1A]"><%= c.kind_label %></div>
              <div class="text-[11px] text-[#6B665F] mt-0.5">
                Signed by <strong class="text-[#1D1C1A]"><%= c.signer_label %></strong>
                · witnessed by <%= c.witnessed_by.full_name %>
                · <%= c.signed_at.strftime("%b %-d, %Y · %-l:%M %p") %>
              </div>
            </div>
            <%= link_to "Open", patient_consent_path(@patient, c),
                  class: "text-[12px] px-3 py-1 rounded-full border border-[#D9D5CD] hover:bg-[#FBF9F5] text-[#1D1C1A] font-medium whitespace-nowrap" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="rounded-2xl bg-white border border-dashed border-[#EFECE6] p-8 text-center text-[12px] text-[#6B665F] italic">
        No consents captured yet. Pick a form above to start.
      </div>
    <% end %>
  </div>
</div>
