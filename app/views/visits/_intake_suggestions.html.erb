<%# Intake fields the admission narrative surfaced, staged for RN review.
    Renders nothing unless there are staged suggestions. Blanks-only — the
    extractor never offers a field the patient already has. %>
<% suggestions = visit.suggested_intake %>
<% if suggestions.present? %>
  <%
    labels = {
      "marital_status"           => "Marital status",
      "living_arrangements"      => "Living arrangements",
      "attending_physician_name" => "Attending physician",
      "veteran_status"           => "Veteran status",
      "caregiver_relationship"   => "Caregiver relationship",
      "code_status"              => "Code status",
    }
    code_labels = { "full_code" => "Full code", "dnr" => "DNR", "dni" => "DNI", "dnr_dni" => "DNR / DNI", "comfort_only" => "Comfort only" }
    display = ->(k, v) { k == "code_status" ? (code_labels[v] || v) : v }
  %>
  <div class="rounded-2xl border border-[#2B4A7A] bg-[#F0F4FA] p-4">
    <div class="flex items-start gap-3">
      <i class="ri-sparkling-2-line text-[#2B4A7A] text-lg mt-0.5 flex-shrink-0"></i>
      <div class="flex-1 min-w-0">
        <div class="text-[11px] uppercase tracking-widest text-[#2B4A7A] font-bold">Intake details from this visit</div>
        <div class="text-[12px] text-[#1D1C1A] mt-1">
          HosAlivio heard these while you documented. Check the ones to add to
          <strong><%= visit.patient&.full_name %></strong>'s intake — only blank fields are offered, nothing is overwritten.
        </div>

        <%= form_with url: apply_intake_suggestions_visit_path(visit), method: :post, data: { turbo: false }, class: "mt-3 space-y-2" do %>
          <% suggestions.each do |key, value| %>
            <label class="flex items-center gap-2.5 rounded-lg border border-[#D9E1EE] bg-white px-3 py-2 cursor-pointer">
              <input type="checkbox" name="fields[]" value="<%= key %>" checked
                     class="rounded border-[#B9C7DB] text-[#2B4A7A] focus:ring-[#2B4A7A]">
              <span class="text-[10px] uppercase tracking-widest text-[#6B665F] font-medium w-36 flex-shrink-0"><%= labels[key] || key.humanize %></span>
              <span class="text-[13px] text-[#1D1C1A] font-medium truncate"><%= display.call(key, value) %></span>
            </label>
          <% end %>
          <button type="submit"
                  class="mt-1 inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#2B4A7A] hover:bg-[#22406b] text-white text-[13px] font-medium cursor-pointer">
            <i class="ri-check-line"></i> Add checked to intake
          </button>
        <% end %>

        <%# Separate form — nesting forms is invalid HTML. %>
        <div class="mt-2">
          <%= button_to "Dismiss all", dismiss_intake_suggestions_visit_path(visit), method: :post,
                form: { data: { turbo: false } },
                class: "text-[12px] text-[#6B665F] hover:text-[#1D1C1A] underline" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
