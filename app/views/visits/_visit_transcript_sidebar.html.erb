<%# Transcript sidebar (right column on the visit edit page).
    The narrative_link Stimulus controller renders the raw text
    into per-speaker turn-blocks (Pascal terracotta, Maria sage),
    bolds medical terms, supports highlight-to-jump from the note
    panes, and powers the search / speaker / keyword filter
    controls right above this card. Locals: `visit`. %>
<%
  raw  = visit.narrative_raw.to_s
  poly = visit.narrative.to_s
  text = raw.presence || poly.presence
%>
<aside class="rounded-2xl bg-white border border-[#EFECE6] overflow-hidden lg:sticky lg:top-20 lg:self-start w-full">
  <div class="px-4 py-3 border-b border-[#EFECE6]">
    <h3 class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold">
      <i class="ri-mic-line"></i> Recording transcript
    </h3>
    <div class="text-[11px] text-[#6B665F] mt-0.5">
      <% if raw.present? %>
        Raw transcript with speaker tags
      <% elsif poly.present? %>
        Polished narrative (no raw transcript saved)
      <% else %>
        No transcript yet
      <% end %>
    </div>
    <% if text.present? %>
      <div class="mt-2 inline-flex items-center gap-1.5 px-2 py-1 rounded-full bg-[#FFF3EC] border border-[#D97757] text-[#D97757] text-[10px] font-bold uppercase tracking-widest">
        <i class="ri-magic-line"></i>
        <span>Highlight a phrase in the note to jump here</span>
      </div>
      <div data-narrative-link-target="status" class="text-[10px] mt-1 min-h-[14px] text-[#6B665F]"></div>
    <% end %>
  </div>

  <% if text.present? %>
    <%# Search + filter chips. The controller hides non-matching
        turn-blocks rather than rebuilding the DOM so highlights
        and speaker tints stay intact across filter switches. %>
    <div class="px-4 py-2 border-b border-[#EFECE6] bg-[#FBF9F5] space-y-2">
      <div class="relative">
        <i class="ri-search-line absolute left-2 top-1/2 -translate-y-1/2 text-[#6B665F] text-[12px]"></i>
        <input type="text"
               data-narrative-link-target="search"
               data-action="input->narrative-link#search"
               placeholder="Search transcript…"
               class="w-full pl-7 pr-2 py-1.5 rounded-full border border-[#D9D5CD] bg-white text-[12px] focus:border-[#D97757] focus:outline-none">
      </div>
      <div class="flex items-center justify-between gap-2 flex-wrap">
        <div class="inline-flex p-0.5 bg-white rounded-full border border-[#EFECE6] gap-0.5 text-[10px] uppercase tracking-widest font-bold">
          <% [["all","All"], ["patient","Patient"], ["clinician","Clinician"], ["keywords","Keywords"]].each_with_index do |(key, label), i| %>
            <button type="button"
                    data-narrative-link-target="filter"
                    data-action="click->narrative-link#setFilter"
                    data-narrative-link-filter-param="<%= key %>"
                    class="px-2.5 py-1 rounded-full transition <%= i == 0 ? 'bg-white text-[#1D1C1A] shadow-sm' : 'text-[#6B665F]' %>">
              <%= label %>
            </button>
          <% end %>
        </div>
        <div data-narrative-link-target="count" class="text-[10px] text-[#6B665F]"></div>
      </div>
    </div>
  <% end %>

  <div class="px-3 py-3 max-h-[calc(100vh-380px)] overflow-y-auto">
    <% if text.present? %>
      <%# Stimulus reads the raw transcript out of data-transcript-text
          (so we don't have to round-trip through textContent, which
          can mangle whitespace) and renders turn-blocks into this
          container. The empty initial textContent + the raw text
          on the data attr keeps SSR happy without flashing the
          unstyled bracketed transcript. %>
      <div data-narrative-link-target="transcript"
           data-transcript-text="<%= text %>"
           class="font-serif italic text-[12px] text-[#3A3936] leading-relaxed whitespace-pre-wrap"><%= text %></div>
    <% else %>
      <div class="text-[12px] text-[#6B665F] italic text-center py-6">
        No transcript yet.
        <% if visit.started_at.nil? %>
          <br>Start the visit on the recording page.
        <% end %>
      </div>
    <% end %>
  </div>

  <% if raw.present? && poly.present? && raw != poly %>
    <div class="px-4 py-2 text-[10px] text-[#6B665F] border-t border-[#EFECE6] bg-[#FBF9F5]">
      <i class="ri-information-line"></i>
      The middle column shows the version polished by HosAlivio.
    </div>
  <% end %>
</aside>
