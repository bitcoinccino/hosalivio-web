<% content_for :title, "Recording visit · #{@visit.patient.full_name}" %>
<%
  patient_first = patient_salutation(@visit.patient)

  # Patient.preferred_language stores 2-letter ISO codes (default "en").
  # Web Speech API wants BCP-47 ("en-US", "es-ES", ...). Keep the map
  # here so the controller can map back-and-forth without round-tripping.
  language_options = [
    { code: "en", bcp47: "en-US", label: "English"        },
    { code: "es", bcp47: "es-ES", label: "Spanish"        },
    { code: "ht", bcp47: "ht-HT", label: "Haitian Creole" },
    { code: "pt", bcp47: "pt-BR", label: "Portuguese"     }
  ]
  patient_lang_code = @visit.patient.preferred_language.presence_in(Patient::SUPPORTED_LANGUAGES) || "en"
  current_lang      = language_options.find { |l| l[:code] == patient_lang_code } || language_options.first
%>

<%# Full-screen voice-first recording stage. Stimulus controller
    runs Web Speech API for transcription + MediaRecorder for audio +
    AnalyserNode for the live waveform. On Stop it ships transcript +
    audio to /visits/:id (PATCH) and redirects to the edit page. %>
<div class="min-h-screen bg-[#1D1C1A] text-white flex flex-col"
     data-controller="voice-visit"
     data-voice-visit-update-url-value="<%= visit_path(@visit) %>"
     data-voice-visit-edit-url-value="<%= edit_visit_path(@visit) %>"
     data-voice-visit-discard-url-value="<%= discard_visit_path(@visit) %>"
     data-voice-visit-csrf-value="<%= form_authenticity_token %>"
     data-voice-visit-lang-value="<%= current_lang[:bcp47] %>"
     data-voice-visit-lang-code-value="<%= current_lang[:code] %>"
     data-voice-visit-needs-type-picker-value="<%= @needs_type_picker ? 'true' : 'false' %>"
     data-voice-visit-suggested-type-value="<%= @suggested_type %>"
     data-voice-visit-patient-id-value="<%= @visit.patient_id %>"
     <%# Speaker roster — first diarized voice → RN (current_user),
         second → patient, third+ → family in roster order. The
         AsrDeepgramClient claims slots in order as new speaker
         indices appear. JSON-encoded; controller decodes via the
         Stimulus Array value type. %>
     <%
       speaker_roster = []
       speaker_roster << current_user.full_name.to_s.split.first if current_user&.full_name.present?
       speaker_roster << @visit.patient.first_name if @visit.patient&.first_name.present?
       fam = User.where(patient_id: @visit.patient_id, family_access: true).order(:full_name).limit(2)
       fam.each { |f| speaker_roster << f.full_name.to_s.split.first if f.full_name.present? }
     %>
     data-voice-visit-speaker-roster-value="<%= speaker_roster.compact.uniq.to_json %>">

  <%# Top bar: patient name + cancel link %>
  <header class="flex items-center justify-between px-6 py-5">
    <div>
      <div class="text-[10px] uppercase tracking-[0.2em] text-white/60 font-bold">Recording visit</div>
      <div class="font-serif text-[20px] mt-0.5"><%= patient_first %></div>
    </div>
    <%# Cancel POSTs to /visits/:id/discard which destroys the visit
        if it's empty (no narrative, no audio). Plain anchor with
        Turbo's data-turbo-method so we don't introduce a wrapping
        <form> that breaks the header's flex layout. %>
    <%= link_to discard_visit_path(@visit),
          data: { turbo_method: :post,
                  turbo_confirm: "Cancel this recording? Empty visits will be discarded.",
                  action: "click->voice-visit#cancel" },
          class: "text-[12px] text-white/60 hover:text-white inline-flex items-center gap-1.5" do %>
      <i class="ri-close-line text-lg"></i> Cancel
    <% end %>
  </header>

  <%# Consent gate — shown first, hidden once the RN taps 'I have
      consent'. Reminds the RN to ask the patient + family before
      any audio is captured, and explains the purpose in plain
      English so the conversation goes smoothly. %>
  <div data-voice-visit-target="consentPanel"
       class="flex-1 flex items-center justify-center px-6">
    <div class="max-w-md text-center">
      <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center mx-auto mb-4">
        <i class="ri-shield-check-line text-[#D97757] text-[28px]"></i>
      </div>
      <h2 class="font-serif text-[24px] leading-tight">Get consent before you start.</h2>
      <p class="text-[13px] text-white/70 mt-3 leading-relaxed">
        Ask <%= patient_first %> (and any family present) if it's okay to record this visit. Briefly explain why:
      </p>
      <ul class="text-[13px] text-white/80 mt-3 space-y-2 text-left">
        <li class="flex gap-2">
          <i class="ri-check-line text-[#D97757] mt-0.5"></i>
          <span>I'm recording so the care team has your exact words and breath sounds, not my paraphrase.</span>
        </li>
        <li class="flex gap-2">
          <i class="ri-check-line text-[#D97757] mt-0.5"></i>
          <span>The recording stays in your hospice chart. Only your care team can listen to it.</span>
        </li>
        <li class="flex gap-2">
          <i class="ri-check-line text-[#D97757] mt-0.5"></i>
          <span>You can ask me to stop or delete it any time, no questions asked.</span>
        </li>
      </ul>
      <button type="button"
              data-action="click->voice-visit#acknowledgeConsent"
              class="mt-6 inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium transition active:scale-95">
        <i class="ri-check-double-line"></i> I have consent
      </button>
      <div class="text-[11px] text-white/40 mt-3">
        If they decline, tap Cancel up top — nothing is saved.
      </div>
    </div>
  </div>

  <%# Visit-type picker — shown between consent and the recording stage
      ONLY when the RN started the visit ad-hoc (one-button quick action)
      and the type wasn't pre-set on the schedule. Pre-scheduled visits
      skip this panel and go straight to the mic. The Suggested badge
      defaults to Admission for first-timers, Routine otherwise. %>
  <div data-voice-visit-target="typePickerPanel"
       class="hidden flex-1 flex-col items-center justify-center px-6">
    <div class="max-w-md w-full text-center">
      <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center mx-auto mb-4">
        <i class="ri-stethoscope-line text-[#D97757] text-[28px]"></i>
      </div>
      <h2 class="font-serif text-[24px] leading-tight">What kind of visit is this?</h2>
      <p class="text-[13px] text-white/60 mt-2">Pick once. We use this to route the chart correctly.</p>

      <div class="mt-6 space-y-3 text-left">
        <% [
          { type: "admission", label: "Admission visit",  sub: "Start of Care · evaluates eligibility for hospice", icon: "ri-user-heart-line" },
          { type: "routine",   label: "Routine visit",    sub: "Ongoing care · symptoms, vitals, interventions",   icon: "ri-play-circle-line" }
        ].each do |opt| %>
          <button type="button"
                  data-action="click->voice-visit#pickType"
                  data-visit-type="<%= opt[:type] %>"
                  class="w-full flex items-start gap-3 px-4 py-3 rounded-2xl bg-white/5 hover:bg-white/10 border border-white/10 hover:border-[#D97757]/60 transition text-left">
            <span class="w-9 h-9 rounded-full bg-[#D97757]/20 text-[#D97757] flex items-center justify-center flex-shrink-0">
              <i class="<%= opt[:icon] %> text-[18px]"></i>
            </span>
            <span class="min-w-0 flex-1">
              <span class="flex items-center gap-2">
                <span class="text-[14px] font-medium text-white"><%= opt[:label] %></span>
                <% if @suggested_type == opt[:type] %>
                  <span class="text-[8px] uppercase tracking-widest text-[#2F6F4E] bg-[#2F6F4E]/15 border border-[#2F6F4E]/40 rounded-full px-1.5 py-0.5 font-bold">Suggested</span>
                <% end %>
              </span>
              <span class="block text-[11px] text-white/60 mt-0.5"><%= opt[:sub] %></span>
            </span>
            <i class="ri-arrow-right-line text-white/40 flex-shrink-0 mt-2.5"></i>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# Interviewee picker — who is the RN interviewing: the patient, the
      family, or both. Shown after consent (and the type picker, if any),
      before the mic. Stored on the visit so the chart records the source. %>
  <div data-voice-visit-target="interviewPanel"
       class="hidden flex-1 flex-col items-center justify-center px-6">
    <div class="max-w-md w-full text-center">
      <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center mx-auto mb-4">
        <i class="ri-group-line text-[#D97757] text-[28px]"></i>
      </div>
      <h2 class="font-serif text-[24px] leading-tight">Who are you interviewing?</h2>
      <p class="text-[13px] text-white/60 mt-2">We label the transcript and chart with the source.</p>

      <%
        pt            = @visit.patient
        pt_initials   = pt.full_name.to_s.split.map(&:first).first(2).join.upcase
        fam           = @interview_family
        photo_classes = "w-9 h-9 rounded-full object-cover flex-shrink-0 border border-white/20"
      %>
      <div class="mt-6 space-y-3 text-left">
        <% [
          { who: "patient", label: "The patient",        sub: "#{patient_first} is the primary source",                 icon: "ri-user-3-line" },
          { who: "family",  label: "The family",         sub: "A family member or caregiver is speaking for the patient", icon: "ri-parent-line" },
          { who: "both",    label: "Patient and family", sub: "Both are present and contributing",                       icon: "ri-group-line" }
        ].each do |opt| %>
          <button type="button"
                  data-action="click->voice-visit#pickInterviewee"
                  data-interviewee="<%= opt[:who] %>"
                  class="w-full flex items-start gap-3 px-4 py-3 rounded-2xl bg-white/5 hover:bg-white/10 border border-white/10 hover:border-[#D97757]/60 transition text-left">
            <%# Put a real face on each option: the patient's photo, a family
                member's avatar, or both overlapped. Fall back to initials /
                a role icon when no image is on file. %>
            <% if opt[:who] == "patient" && pt.has_photo? %>
              <%= image_tag url_for(pt.photo), class: photo_classes, alt: pt.full_name %>
            <% elsif opt[:who] == "family" && fam&.has_avatar? %>
              <%= image_tag url_for(fam.avatar), class: photo_classes, alt: fam.full_name %>
            <% elsif opt[:who] == "both" && (pt.has_photo? || fam&.has_avatar?) %>
              <span class="flex-shrink-0 flex items-center w-12 h-9">
                <% if pt.has_photo? %>
                  <%= image_tag url_for(pt.photo), class: "w-9 h-9 rounded-full object-cover border-2 border-[#1D1C1A] relative z-10", alt: pt.full_name %>
                <% else %>
                  <span class="w-9 h-9 rounded-full bg-[#D97757]/20 text-[#D97757] text-[11px] font-bold flex items-center justify-center border-2 border-[#1D1C1A] relative z-10"><%= pt_initials %></span>
                <% end %>
                <% if fam&.has_avatar? %>
                  <%= image_tag url_for(fam.avatar), class: "w-9 h-9 rounded-full object-cover border-2 border-[#1D1C1A] -ml-4", alt: fam.full_name %>
                <% else %>
                  <span class="w-9 h-9 rounded-full bg-white/10 text-[#D97757] flex items-center justify-center border-2 border-[#1D1C1A] -ml-4"><i class="ri-parent-line text-[16px]"></i></span>
                <% end %>
              </span>
            <% elsif opt[:who] == "patient" %>
              <span class="w-9 h-9 rounded-full bg-[#D97757]/20 text-[#D97757] text-[12px] font-bold flex items-center justify-center flex-shrink-0"><%= pt_initials %></span>
            <% else %>
              <span class="w-9 h-9 rounded-full bg-[#D97757]/20 text-[#D97757] flex items-center justify-center flex-shrink-0">
                <i class="<%= opt[:icon] %> text-[18px]"></i>
              </span>
            <% end %>
            <span class="min-w-0 flex-1">
              <span class="text-[14px] font-medium text-white"><%= opt[:label] %></span>
              <span class="block text-[11px] text-white/60 mt-0.5"><%= opt[:sub] %></span>
            </span>
            <i class="ri-arrow-right-line text-white/40 flex-shrink-0 mt-2.5"></i>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# Main stage: timer + canvas waveform + mic + transcript.
      Hidden until the RN acknowledges consent (see panel above).
      Tightened gaps and shorter canvas so the whole stack fits one
      viewport height with the mic button always above the fold. %>
  <main data-voice-visit-target="stage"
        class="hidden flex-1 flex-col items-center justify-center px-6 gap-5 pb-6">
    <%# Transient toast for ASR-mode changes (e.g., Deepgram dropped
        mid-session, fell back to Web Speech). JS shows + auto-hides
        after a few seconds. Hidden by default. %>
    <div data-voice-visit-target="asrToast"
         class="hidden mx-auto max-w-md rounded-full bg-[#1D1C1A] border border-[#D97757]/40 px-4 py-2 text-[12px] text-white/90 items-center gap-2 transition-opacity duration-300">
      <i class="ri-alert-line text-[#D97757]"></i>
      <span data-voice-visit-target="asrToastText">Switched to backup transcription.</span>
    </div>

    <div class="text-center">
      <div data-voice-visit-target="timer"
           class="font-mono text-[48px] md:text-[64px] tracking-[0.05em] text-[#D97757] tabular-nums leading-none">0:00</div>
      <div data-voice-visit-target="status"
           class="text-[12px] uppercase tracking-[0.18em] text-white/50 font-bold mt-2">Press the mic to begin</div>
    </div>

    <%# Canvas-driven AnalyserNode waveform. Width is responsive,
        height fixed; the controller sizes the bitmap to the CSS box. %>
    <div class="w-full max-w-[640px] h-[120px] md:h-[160px]">
      <canvas data-voice-visit-target="canvas"
              class="w-full h-full"></canvas>
    </div>

    <%# Primary controls — mic in the center, optional Pause / Stop
        as smaller satellites. Pulled UP into the main stage (out of
        the footer) so it's always visible above the fold. %>
    <div class="flex items-center justify-center gap-6">
      <button type="button"
              data-action="click->voice-visit#togglePause"
              data-voice-visit-target="pauseButton"
              title="Pause / resume"
              class="hidden w-14 h-14 rounded-full bg-white/10 hover:bg-white/20 text-white text-[20px] flex items-center justify-center transition">
        <i class="ri-pause-line"></i>
      </button>

      <button type="button"
              data-action="click->voice-visit#toggle"
              data-voice-visit-target="recordButton"
              data-state="idle"
              title="Tap to start recording"
              class="w-20 h-20 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white shadow-2xl flex items-center justify-center transition active:scale-95">
        <i data-voice-visit-target="recordIcon" class="ri-mic-fill text-[32px]"></i>
      </button>

      <button type="button"
              data-action="click->voice-visit#stop"
              data-voice-visit-target="stopButton"
              title="Stop and review"
              class="hidden w-14 h-14 rounded-full bg-white text-[#1D1C1A] hover:bg-white/90 shadow-md flex items-center justify-center transition">
        <i class="ri-check-line text-[24px]"></i>
      </button>
    </div>

    <%# Speaker-tag buttons + language pill. Tapping a speaker pill
        inserts a [Patient:] or [RN:] line break into the live
        transcript. The language pill opens a tiny popover that swaps
        the SpeechRecognition lang on the fly and (optionally) writes
        the choice back to Patient#preferred_language as the new
        default for future visits. Web Speech doesn't diarize and is
        language-specific, so both labels and language are manual v1. %>
    <%# Recognizer status badge — set by JS once the ASR session is
        resolved. Green dot + "Deepgram + diarize" when streaming is
        live; amber dot + "Web Speech (manual labels)" when the
        fallback is in use. Hidden until the recording starts. %>
    <div data-voice-visit-target="asrBadge"
         class="hidden items-center gap-1.5 text-[10px] uppercase tracking-[0.18em] text-white/60 font-bold mx-auto">
      <span data-voice-visit-target="asrDot" class="w-1.5 h-1.5 rounded-full bg-[#2F6F4E]"></span>
      <span data-voice-visit-target="asrMode">Deepgram + diarize</span>
    </div>

    <div class="flex items-center justify-center gap-3 flex-wrap">
      <%# Speaker-tag pills — visible only when manual diarization is
          needed (Web Speech path or Deepgram fell back mid-session).
          Hidden by default; voice_visit_controller#_paintAsrMode
          flips visibility based on the live ASR backend. %>
      <div data-voice-visit-target="speakerPills" class="hidden items-center gap-3">
        <button type="button"
                data-action="click->voice-visit#tagSpeaker"
                data-speaker="Patient"
                class="px-4 py-1.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/15 text-[12px] text-white/90 inline-flex items-center gap-1.5 transition active:scale-95">
          <i class="ri-user-voice-line text-[#D97757]"></i> Patient said…
        </button>
        <button type="button"
                data-action="click->voice-visit#tagSpeaker"
                data-speaker="RN"
                class="px-4 py-1.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/15 text-[12px] text-white/90 inline-flex items-center gap-1.5 transition active:scale-95">
          <i class="ri-stethoscope-line text-[#D97757]"></i> RN said…
        </button>
      </div>

      <%# Solo dictation toggle — when on, the live transcript renders
          without speaker tags (single continuous narrative). RN flips
          this on for "driving home, narrating alone" cases. %>
      <button type="button"
              data-action="click->voice-visit#toggleSolo"
              data-voice-visit-target="soloButton"
              title="Solo dictation (no speaker tags)"
              class="px-4 py-1.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/15 text-[12px] text-white/90 inline-flex items-center gap-1.5 transition active:scale-95">
        <i class="ri-user-voice-line text-[#D97757]"></i> Solo
      </button>

      <div class="relative">
        <button type="button"
                data-action="click->voice-visit#toggleLangMenu"
                data-voice-visit-target="langButton"
                class="px-4 py-1.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/15 text-[12px] text-white/90 inline-flex items-center gap-1.5 transition active:scale-95">
          <span data-voice-visit-target="langFlag" class="flex items-center"><%= language_flag(current_lang[:code]) %></span>
          <span data-voice-visit-target="langLabel"><%= current_lang[:label] %></span>
          <i class="ri-arrow-down-s-line text-white/60"></i>
        </button>
        <div data-voice-visit-target="langMenu"
             class="hidden absolute right-0 bottom-full mb-2 w-60 rounded-xl bg-[#2A2825] border border-white/10 shadow-xl overflow-hidden z-40">
          <div class="px-3 py-2 border-b border-white/10 text-[10px] uppercase tracking-[0.18em] text-white/50 font-bold">
            Transcription language
          </div>
          <% language_options.each do |opt| %>
            <button type="button"
                    data-action="click->voice-visit#selectLang"
                    data-code="<%= opt[:code] %>"
                    data-bcp47="<%= opt[:bcp47] %>"
                    data-label="<%= opt[:label] %>"
                    class="w-full flex items-center gap-2.5 px-3 py-2 text-left text-[13px] text-white/90 hover:bg-white/10 transition">
              <%# The visible SVG flag here doubles as the source the JS
                  copies into the pill on selection — see selectLang. We
                  used to also stash it in a data-flag-html attribute,
                  but the SVG's inner quotes broke out of that attribute
                  and dumped raw markup into the menu UI. %>
              <%= language_flag(opt[:code]) %>
              <span class="flex-1"><%= opt[:label] %></span>
              <% if opt[:code] == current_lang[:code] %>
                <i class="ri-check-line text-[#D97757]"></i>
              <% end %>
            </button>
          <% end %>
          <label class="flex items-center gap-2 px-3 py-2 border-t border-white/10 text-[12px] text-white/80 hover:bg-white/5 cursor-pointer">
            <input type="checkbox"
                   data-voice-visit-target="syncLangCheckbox"
                   class="accent-[#D97757]">
            <span>Set as patient default</span>
          </label>
        </div>
      </div>
    </div>

    <%# Live transcript preview (scrolls). Pure feedback; the official
        narrative gets saved on Stop. %>
    <div data-voice-visit-target="transcript"
         class="w-full max-w-[640px] min-h-[60px] max-h-[120px] overflow-y-auto rounded-2xl bg-white/5 border border-white/10 p-3 text-[13px] text-white/90 leading-relaxed font-serif italic whitespace-pre-wrap">
      <%# Filled by the controller as the recognizer delivers interim
          + final results. Copy stays mode-agnostic because the
          speaker-tag pills only appear in Web Speech fallback —
          Deepgram auto-tags via diarization. %>
      <span class="text-white/40 not-italic">Recording the full visit. Your words and the patient's words will appear here as you speak.</span>
    </div>

    <div class="text-[11px] text-white/40 text-center">
      Auto-saves to the chart on Stop. Vitals are extracted on the next screen.
    </div>
  </main>
</div>
