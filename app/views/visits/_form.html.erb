<%= form_with(model: @visit, local: true, html: { class: "space-y-4", multipart: true }) do |f| %>
  <% if flash[:alert].present? %>
    <div class="px-3 py-2 rounded-lg bg-[#FFF3EC] border border-[#D97757] text-[#C1403A] text-sm">
      <i class="ri-error-warning-line mr-1"></i><%= flash[:alert] %>
    </div>
  <% end %>

  <div>
    <%= f.label :patient_id, "Patient", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
    <%= f.select :patient_id,
          @patients.map { |p| ["#{p.mrn} · #{p.full_name}", p.id] },
          { include_blank: "Select patient..." },
          class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :user_id, "Clinician", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
      <%= f.select :user_id,
            @clinicians.map { |u|
              role = (u.role_names & %w[rn md don sw chaplain aide social_worker]).first
              branch_tag = u.branch&.name.presence ? " · #{u.branch.name}" : ""
              ["#{u.full_name} (#{role})#{branch_tag}", u.id]
            },
            {},
            class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
    </div>
    <div>
      <%= f.label :discipline, class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
      <%= f.select :discipline,
            Visit.disciplines.keys.map { |d| [d.upcase, d] },
            {},
            class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :scheduled_at, "Scheduled start", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
      <%= f.datetime_local_field :scheduled_at,
            value: @visit.scheduled_at&.strftime("%Y-%m-%dT%H:%M"),
            class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
    </div>
    <div>
      <%= f.label :ended_at, "Expected end (optional)", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
      <%= f.datetime_local_field :ended_at,
            value: @visit.ended_at&.strftime("%Y-%m-%dT%H:%M"),
            class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :visit_type, class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
      <%= f.select :visit_type,
            Visit.visit_types.keys.map { |vt| [vt.tr('_', ' ').titleize, vt] },
            {},
            class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
    </div>
    <div>
      <%
        location_labels = {
          "home" => "Home (Q5001)", "ipu" => "Hospice IPU (Q5006)",
          "hospital_gip" => "Hospital / GIP (Q5005)", "snf" => "SNF (Q5004)",
          "alf" => "ALF (Q5002)", "nursing_facility" => "Nursing facility (Q5003)",
          "psychiatric_facility" => "Psych facility (Q5008)",
          "group_home" => "Group home (Q5009)",
          "temporary_lodging" => "Temp lodging (Q5009)",
          "other" => "Other (Q5009)"
        }
      %>
      <%= f.label :service_location, "Place of service", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
      <%= f.select :service_location,
            Visit.service_locations.keys.map { |k| [location_labels[k] || k, k] },
            {},
            class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
    </div>
  </div>

  <div>
    <%= f.label :facility_name, "Facility name (only if not at home)", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
    <%= f.text_field :facility_name,
          placeholder: "e.g. Memorial Regional Hospital, room 412",
          class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
  </div>

  <% mic = mic_controller_name(current_user.agency) %>
  <div data-controller="<%= mic %> vitals-extractor" data-<%= mic %>-lang-value="en-US" class="space-y-3">
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :narrative, "Narrative (optional, can fill at the bedside)", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium" %>
        <div class="flex items-center gap-2">
          <span data-<%= mic %>-target="status" class="text-[11px] text-[#6B665F]"></span>
          <button type="button"
                  data-action="click-><%= mic %>#toggle"
                  data-<%= mic %>-target="button"
                  class="inline-flex items-center gap-1 text-[11px] px-3 py-1.5 rounded-full bg-[#FBF9F5] text-[#D97757] hover:bg-[#EFECE6] border border-[#EFECE6] transition"
                  title="Tap to dictate">
            <i class="ri-mic-line"></i> Dictate
          </button>
        </div>
      </div>
      <%= f.text_area :narrative, rows: 4,
            data: { "#{mic}_target": "output", vitals_extractor_target: "narrative" },
            placeholder: "Type, or tap Dictate to speak. e.g. \"BP 128/76, pulse 88, pain 4/10. Patient resting comfortably after morphine dose.\"",
            class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
    </div>

    <%# Clinical audio recorder — separate from Dictate. Captures the
        bedside (breath sounds, family voice, exact phrasing) as an
        ActiveStorage attachment on the Visit. Played back from the
        chart. Uses MediaRecorder + a hidden file input so the blob
        ships with the normal form submit. %>
    <div data-controller="audio-recorder" class="rounded-xl border border-dashed border-[#D9D5CD] bg-white p-3">
      <div class="flex items-center justify-between gap-3">
        <div class="min-w-0">
          <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-medium">Bedside audio (optional)</div>
          <div class="text-[11px] text-[#6B665F] mt-0.5">Records breath sounds, family voice, exact phrasing — saved with this visit.</div>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <span data-audio-recorder-target="timer" class="text-[11px] font-mono text-[#6B665F] min-w-[3ch] text-right"></span>
          <button type="button"
                  data-action="click->audio-recorder#togglePause"
                  data-audio-recorder-target="pauseButton"
                  class="hidden w-9 h-9 rounded-full bg-[#FBF9F5] hover:bg-[#EFECE6] text-[#3A3936] flex items-center justify-center transition"
                  title="Pause / resume">
            <i class="ri-pause-line"></i>
          </button>
          <button type="button"
                  data-action="click->audio-recorder#toggle"
                  data-audio-recorder-target="recordButton"
                  data-state="idle"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#FBF9F5] text-[#C1403A] hover:bg-[#FFEDE2] border border-[#EFECE6] transition text-[12px] font-medium"
                  title="Record bedside audio">
            <i class="ri-record-circle-line"></i>
            <span>Record</span>
          </button>
        </div>
      </div>

      <%# File input is hidden — the recorder's MediaRecorder Blob is
          stuffed into .files via DataTransfer on stop, so the form
          submit ships the audio as visit[audio_note]. %>
      <%= f.file_field :audio_note, accept: "audio/*", class: "hidden", data: { "audio-recorder-target": "fileInput" } %>

      <div data-audio-recorder-target="preview" hidden class="mt-3 flex items-center gap-2">
        <audio data-audio-recorder-target="player" controls class="flex-1 h-9"></audio>
        <button type="button"
                data-action="click->audio-recorder#discard"
                class="text-[11px] text-[#6B665F] hover:text-[#C1403A] underline"
                title="Discard this recording">
          Remove
        </button>
      </div>

      <% if @visit.persisted? && @visit.audio_note.attached? %>
        <div class="mt-3 flex items-center gap-2">
          <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Saved audio:</div>
          <%= audio_tag url_for(@visit.audio_note), controls: true, class: "flex-1 h-9" %>
        </div>
      <% end %>
    </div>

    <!-- Vitals: freely editable, auto-fillable from the narrative above -->
    <div class="rounded-xl border border-[#EFECE6] bg-[#FBF9F5] p-3">
      <div class="flex items-center justify-between mb-2">
        <div>
          <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-medium">Vitals at visit</div>
          <span data-vitals-extractor-target="summary" class="text-[10px] text-[#6B665F]"></span>
        </div>
        <button type="button"
                data-action="click->vitals-extractor#extract"
                class="inline-flex items-center gap-1 text-[11px] px-3 py-1.5 rounded-full bg-white text-[#1D1C1A] hover:bg-[#EFECE6] border border-[#D9D5CD] transition"
                title="Parse BP, temp, HR, RR, SpO2, and pain score out of the narrative">
          <i class="ri-magic-line"></i> Auto-fill from narrative
        </button>
      </div>
      <% vitals_source = (@visit.vitals.presence || {}) %>
      <div class="grid grid-cols-3 md:grid-cols-6 gap-2">
        <div class="col-span-2">
          <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">BP</label>
          <input type="text" name="visit[vitals][bp]" value="<%= vitals_source["bp"] %>"
                 placeholder="128/76"
                 data-vitals-extractor-target="bp"
                 class="mt-0.5 w-full px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono">
        </div>
        <div>
          <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">Temp</label>
          <input type="text" name="visit[vitals][temp]" value="<%= vitals_source["temp"] %>"
                 placeholder="98.6"
                 data-vitals-extractor-target="temp"
                 class="mt-0.5 w-full px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono">
        </div>
        <div>
          <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">Pulse</label>
          <input type="text" name="visit[vitals][pulse]" value="<%= vitals_source["pulse"] %>"
                 placeholder="88"
                 data-vitals-extractor-target="pulse"
                 class="mt-0.5 w-full px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono">
        </div>
        <div>
          <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">RR</label>
          <input type="text" name="visit[vitals][resp]" value="<%= vitals_source["resp"] %>"
                 placeholder="16"
                 data-vitals-extractor-target="resp"
                 class="mt-0.5 w-full px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono">
        </div>
        <div>
          <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">SpO2</label>
          <input type="text" name="visit[vitals][o2]" value="<%= vitals_source["o2"] %>"
                 placeholder="95"
                 data-vitals-extractor-target="o2"
                 class="mt-0.5 w-full px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono">
        </div>
      </div>
      <div class="mt-2">
        <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">Pain score (0–10)</label>
        <%= f.number_field :pain_score, min: 0, max: 10, step: 1,
              data: { vitals_extractor_target: "painScore" },
              class: "mt-0.5 w-20 px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono" %>
      </div>
    </div>
  </div>

  <div class="pt-3 border-t border-[#EFECE6] flex items-center justify-between text-[11px] text-[#6B665F]">
    <span>
      <i class="ri-shield-check-line"></i>
      Overlap + 30-min windshield buffer enforced by the database.
    </span>
    <div class="flex items-center gap-2">
      <%= link_to "Cancel", calendar_path, class: "text-[13px] text-[#6B665F] hover:text-[#1D1C1A]" %>
      <%= f.submit (@visit.persisted? ? "Save changes" : "Schedule visit"),
            class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium cursor-pointer" %>
    </div>
  </div>
<% end %>
