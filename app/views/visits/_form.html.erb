<%
  form_data = {
    controller: "visit-form",
    visit_form_scheduling_value: @visit.new_record?,
    action: "submit->visit-form#validate"
  }
  form_data[:turbo_frame] = "_top" if local_assigns[:modal]
%>
<%= form_with(model: @visit, local: true, html: { id: "visit-edit-form", class: "space-y-4", multipart: true, data: form_data }) do |f| %>
  <%# When the visit is in :recording state (Pascal already tapped
      Start), Pascal doesn't need to look at patient/clinician/scheduled
      times again, those are already locked in. Collapse all the
      scheduling metadata into a small expandable so the narrative +
      dictate + record block can rise to the top of the page. %>
  <% in_progress = @visit.persisted? && @visit.currently_in_progress? %>
  <%# Completed = visit is finished. The narrative + audio + visit
      metadata (patient, clinician, scheduled times, type, location)
      are all part of the medical record and must not be edited
      inline. Corrections go through a late-entry note. Vitals stay
      editable because they're often corrected after the fact (RN
      misreads a glucose strip, fixes pulse from 88 to 98) without
      requiring a chart amendment. %>
  <% completed = @visit.persisted? && @visit.completed_visit? %>
  <% scheduling_new_visit = @visit.new_record? %>
  <%# Visit metadata (patient, clinician, scheduled time, type,
      location) is set by the role that scheduled the visit
      (admissions, admin, DON). Performing clinicians (RN, MD, SW,
      chaplain, aide) get a read-only view because changing the
      assignment from the bedside is a workflow violation; they
      ping admissions if anything's wrong. %>
  <% can_edit_metadata = (current_user.role_names & %w[admin don admissions]).any? %>
  <% role_label = @visit.discipline.to_s.presence&.upcase || "VISIT" %>
  <% calendar_return_path = calendar_path(date: (@visit.scheduled_at || Time.current).to_date.iso8601) %>

  <% metadata_block = capture do %>
    <%
      # During recording / draft review (in_progress) the billing-identity
      # fields are locked: patient, clinician, visit role, scheduled start, and
      # visit type. Changing them mid-encounter risks linking PHI to the wrong
      # chart, breaking the EVV time marker, or rejecting on EMR sync. Only the
      # end time and the location stay editable (clinical judgment / EVV moves).
      lock_id  = in_progress
      lock_cls = " disabled:bg-[#EFECE6] disabled:text-[#8A8379] disabled:cursor-not-allowed disabled:border-[#EFECE6]"
    %>
    <% if lock_id %>
      <div class="mb-3 px-3 py-2 rounded-lg bg-[#FFF9F4] border border-[#F1D9C9] text-[11px] text-[#9A5A3A] flex items-start gap-1.5">
        <i class="ri-lock-2-line mt-0.5"></i>
        <span>Patient, clinician, role, start time, and visit type are locked during the visit. You can still adjust the <strong>end time</strong> and <strong>location</strong>.</span>
      </div>
    <% end %>
    <div class="<%= scheduling_new_visit ? 'rounded-2xl border border-[#D97757] bg-[#FFF9F4] p-4' : '' %>">
      <div class="flex items-center justify-between gap-3 mb-1">
        <%= f.label :patient_id, "Patient", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium" %>
        <% if scheduling_new_visit %>
          <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-[#D97757] text-white uppercase tracking-wider">Required</span>
        <% end %>
      </div>
      <%= f.select :patient_id,
            @patients.map { |p| ["#{p.mrn} · #{p.full_name}", p.id] },
            { include_blank: "Select patient..." },
            required: scheduling_new_visit,
            autofocus: scheduling_new_visit,
            disabled: lock_id,
            data: { visit_form_target: "patient", action: "change->visit-form#patientChanged" },
            class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]#{lock_cls}" %>
      <% if scheduling_new_visit %>
        <p class="mt-1 text-[11px] text-[#6B665F]">Select who this visit is for. The calendar already filled in the clinician and time.</p>
        <p class="hidden mt-1 text-[11px] text-[#C1403A]" data-visit-form-target="patientError"></p>
      <% end %>
    </div>

    <div class="grid grid-cols-2 gap-3 mt-3">
      <div>
        <%= f.label :user_id, "Clinician", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
        <%= f.select :user_id,
              @clinicians.map { |u|
                role = (u.role_names & %w[rn md don sw chaplain aide social_worker]).first
                branch_tag = u.branch&.name.presence ? " · #{u.branch.name}" : ""
                ["#{u.full_name} (#{role})#{branch_tag}", u.id]
              },
              {},
              disabled: lock_id,
              class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]#{lock_cls}" %>
      </div>
      <div>
        <%= f.label :discipline, "Visit role", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
        <%= f.select :discipline,
              Visit.disciplines.keys.map { |d| [d.upcase, d] },
              {},
              disabled: lock_id,
              class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]#{lock_cls}" %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3 mt-3">
      <div>
        <%= f.label :scheduled_at, "Scheduled start", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
        <%= f.datetime_local_field :scheduled_at,
              value: @visit.scheduled_at&.strftime("%Y-%m-%dT%H:%M"),
              disabled: lock_id,
              class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]#{lock_cls}" %>
      </div>
      <div>
        <%= f.label :ended_at, "Ends around (optional)", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
        <%= f.datetime_local_field :ended_at,
              value: @visit.ended_at&.strftime("%Y-%m-%dT%H:%M"),
              class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3 mt-3">
      <div>
        <%= f.label :visit_type, class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
        <%# Order matches the four categories the RN actually picks
            from (initial / routine / follow-up / inquiry); the rest
            sit below in the same select for billing parity. %>
        <% visit_type_order = %w[admission routine follow_up inquiry recert face_to_face discharge death] %>
        <%= f.select :visit_type,
              visit_type_order.map { |vt| [Visit::VISIT_TYPE_LABELS[vt] || vt.titleize, vt] },
              {},
              disabled: lock_id,
              class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]#{lock_cls}" %>
      </div>
      <div>
        <%
          location_labels = {
            "home" => "Home (Q5001)", "ipu" => "Hospice IPU (Q5006)",
            "hospital_gip" => "Hospital / GIP (Q5005)", "snf" => "SNF (Q5004)",
            "alf" => "ALF (Q5002)", "nursing_facility" => "Nursing facility (Q5003)",
            "psychiatric_facility" => "Psych facility (Q5008)",
            "group_home" => "Group home (Q5009)",
            "temporary_lodging" => "Temp lodging (Q5009)",
            "other" => "Other (Q5009)"
          }
        %>
        <%= f.label :service_location, "Visit location", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
        <%= f.select :service_location,
              Visit.service_locations.keys.map { |k| [location_labels[k] || k, k] },
              {},
              data: { visit_form_target: "serviceLocation", action: "change->visit-form#syncFacility" },
              class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
      </div>
    </div>

    <div class="mt-3" data-visit-form-target="facilityGroup">
      <%= f.label :facility_name, "Facility / room", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
      <%= f.text_field :facility_name,
            placeholder: "e.g. Memorial Regional Hospital, room 412",
            data: { visit_form_target: "facilityName" },
            class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px]" %>
      <p class="mt-1 text-[11px] text-[#6B665F]">Used only when the visit is not at the patient's home.</p>
    </div>
  <% end %>

  <%# Read-only metadata (completed visits only). Renders the same
      fields as `metadata_block` but as static dl/dt/dd pairs so the
      record can't be amended after the chart entry is signed. %>
  <% metadata_readonly_block = capture do %>
    <%
      location_labels_ro = {
        "home" => "Home (Q5001)", "ipu" => "Hospice IPU (Q5006)",
        "hospital_gip" => "Hospital / GIP (Q5005)", "snf" => "SNF (Q5004)",
        "alf" => "ALF (Q5002)", "nursing_facility" => "Nursing facility (Q5003)",
        "psychiatric_facility" => "Psych facility (Q5008)",
        "group_home" => "Group home (Q5009)",
        "temporary_lodging" => "Temp lodging (Q5009)",
        "other" => "Other (Q5009)"
      }
      ro_rows = [
        ["Patient",         @visit.patient ? "#{@visit.patient.mrn} · #{@visit.patient.full_name}" : "—"],
        ["Clinician",       @visit.user ? "#{@visit.user.full_name} (#{(@visit.user.role_names & %w[rn md don sw chaplain aide social_worker admissions]).first || '—'})" : "—"],
        ["Discipline",      @visit.discipline.to_s.upcase],
        ["Visit type",      @visit.visit_type_label],
        ["Place of service", location_labels_ro[@visit.service_location.to_s] || @visit.service_location.to_s.titleize],
        ["Facility",        @visit.facility_name.presence || "—"],
        ["Scheduled start", @visit.scheduled_at&.strftime("%a %b %-d, %Y · %-l:%M %p") || "—"],
        ["Started",         @visit.started_at&.strftime("%a %b %-d, %Y · %-l:%M %p") || "—"],
        ["Ended",           @visit.ended_at&.strftime("%a %b %-d, %Y · %-l:%M %p") || "—"]
      ]

      # Patient-level fields the RN wants in the same locked panel
      # (caregiver, language, home) without bouncing to the patient
      # chat. Pulled inline so they don't ride in a separate widget.
      patient_ro_rows = []
      if (p = @visit.patient)
        cg = [p.caregiver_name, p.caregiver_phone].compact_blank.join(" · ")
        patient_ro_rows << ["Caregiver", cg] if cg.present?
        if p.preferred_language.present?
          lang_map = { "en" => "English", "es" => "Spanish", "ht" => "Haitian Creole", "pt" => "Portuguese", "other" => "Other" }
          patient_ro_rows << ["Preferred language", lang_map[p.preferred_language] || p.preferred_language.titleize]
        end
        home = [p.city, p.state].compact_blank.join(", ")
        patient_ro_rows << ["Home", home] if home.present?
        if p.code_status.present?
          cs_label = case p.code_status
                     when "full_code"    then "Full Code"
                     when "dnr"          then "DNR"
                     when "dni"          then "DNI"
                     when "dnr_dni"      then "DNR / DNI"
                     when "comfort_only" then "Comfort Only"
                     else p.code_status.to_s.titleize
                     end
          patient_ro_rows << ["Code status", cs_label]
        end
      end
    %>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-[12px]">
      <% ro_rows.each do |label, value| %>
        <div>
          <dt class="text-[10px] uppercase tracking-widest text-[#6B665F]"><%= label %></dt>
          <dd class="text-[#1D1C1A]"><%= value %></dd>
        </div>
      <% end %>
    </dl>
    <% if patient_ro_rows.any? %>
      <div class="mt-3 pt-3 border-t border-[#EFECE6]">
        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-2">Patient · home environment</div>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-[12px]">
          <% patient_ro_rows.each do |label, value| %>
            <div>
              <dt class="text-[10px] uppercase tracking-widest text-[#6B665F]"><%= label %></dt>
              <dd class="text-[#1D1C1A]"><%= value %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% end %>
    <div class="mt-3 text-[11px] text-[#6B665F] inline-flex items-start gap-1.5">
      <i class="ri-lock-2-line mt-0.5"></i>
      <span>Visit metadata is locked once the chart entry is finished. Corrections require a late-entry note.</span>
    </div>
  <% end %>

  <%# Metadata visibility rules:
      :recording  — collapsed in a <details> below (RN already knows
                    who/where, only needs it to fix a typo mid-visit)
      :completed  — same: collapsed below; nothing's being scheduled,
                    the chart entry is the focus
      :ready / :scheduled — prominent at top: this is the scheduling
                            screen, those fields are the point %>
  <% collapse_metadata = in_progress || completed %>
  <% if collapse_metadata %>
    <%# rendered as a <details> below, after the narrative block %>
  <% else %>
    <%= can_edit_metadata ? metadata_block : metadata_readonly_block %>
  <% end %>

  <%# Edit page is text-only. All recording (mic + audio capture)
      happens at /visits/:id/record — the dedicated recording page.
      The Dictate button + bedside MediaRecorder block were removed;
      the RN edits the saved chart entry here, doesn't re-record. %>
  <% unless scheduling_new_visit %>
    <div data-controller="vitals-extractor"
         data-vitals-extractor-auto-extract-value="<%= local_assigns[:just_recorded] ? 'true' : 'false' %>"
         class="space-y-3">
      <% if completed %>
        <%# Narrative display lives in the Team tab above; the form
            only carries the value through so vitals corrections submit
            without blanking the locked narrative. The hidden mirror
            lets the vitals extractor still scan it. %>
        <%= f.hidden_field :narrative %>
        <div class="hidden" data-vitals-extractor-target="narrative"><%= @visit.narrative %></div>
      <% else %>
        <div>
          <%= f.label :narrative, "Narrative", class: "block text-[11px] uppercase tracking-widest text-[#6B665F] font-medium mb-1" %>
          <%= f.text_area :narrative, rows: 6,
                data: { vitals_extractor_target: "narrative" },
                placeholder: "Edit the recorded narrative here. To capture new audio, use Record on the patient chart instead.",
                class: "w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#D97757] focus:outline-none text-[14px] font-serif leading-relaxed" %>
        </div>
      <% end %>

    <%# Bedside audio playback lives in the footer audio bar on the
        edit page; no inline player here to avoid duplication. %>

    <%# Vitals — only on routine/care visits where the nurse
        actually takes vital signs at the bedside. Initial
        (admission) and follow-up visits don't capture vitals
        through this form (admission gets them from the eval; FU
        visits aren't vitals-driven). The pain_score field rides
        with vitals so it's hidden too on non-routine visits. %>
      <% if @visit.visit_category == :routine %>
      <%# Collapsible vitals — captured but not always front-and-
          center, so default to closed. Auto-opens when a freshly-
          recorded visit lands here (?just_recorded=1) so the RN
          sees the auto-extracted vitals without an extra click. %>
      <% vitals_source = (@visit.vitals.presence || {}) %>
      <% any_vitals = vitals_source.values.any? { |v| v.to_s.strip.present? } || @visit.pain_score.to_i.positive? %>
      <details class="rounded-xl border border-[#EFECE6] bg-[#FBF9F5] group" <%= "open" if local_assigns[:just_recorded] || any_vitals %>>
        <summary class="cursor-pointer list-none flex items-center justify-between p-3 [&::-webkit-details-marker]:hidden">
          <div class="inline-flex items-center gap-2">
            <i class="ri-pulse-line text-[#D97757]"></i>
            <div>
              <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-medium">Vitals at visit</div>
              <span data-vitals-extractor-target="summary" class="text-[10px] text-[#6B665F]"></span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <% if any_vitals %>
              <span class="text-[10px] uppercase tracking-widest font-bold text-[#2F6F4E] bg-[#E6F0EE] border border-[#2F6F4E] rounded-full px-2 py-0.5">Captured</span>
            <% else %>
              <span class="text-[10px] uppercase tracking-widest text-[#6B665F]">None yet</span>
            <% end %>
            <i class="ri-arrow-down-s-line text-[#6B665F] group-open:rotate-180 transition-transform"></i>
          </div>
        </summary>
        <div class="px-3 pb-3">
          <% unless completed %>
            <div class="flex justify-end mb-2">
              <button type="button"
                      data-action="click->vitals-extractor#extract"
                      class="inline-flex items-center gap-1 text-[11px] px-3 py-1.5 rounded-full bg-white text-[#1D1C1A] hover:bg-[#EFECE6] border border-[#D9D5CD] transition"
                      title="Parse BP, temp, HR, RR, SpO2, and pain score out of the narrative">
                <i class="ri-magic-line"></i> Auto-fill from narrative
              </button>
            </div>
          <% end %>
        <div class="grid grid-cols-3 md:grid-cols-6 gap-2">
          <div class="col-span-2">
            <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">BP</label>
            <input type="text" name="visit[vitals][bp]" value="<%= vitals_source["bp"] %>"
                   placeholder="128/76"
                   data-vitals-extractor-target="bp"
                   class="mt-0.5 w-full px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono">
          </div>
          <div>
            <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">Temp</label>
            <input type="text" name="visit[vitals][temp]" value="<%= vitals_source["temp"] %>"
                   placeholder="98.6"
                   data-vitals-extractor-target="temp"
                   class="mt-0.5 w-full px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono">
          </div>
          <div>
            <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">Pulse</label>
            <input type="text" name="visit[vitals][pulse]" value="<%= vitals_source["pulse"] %>"
                   placeholder="88"
                   data-vitals-extractor-target="pulse"
                   class="mt-0.5 w-full px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono">
          </div>
          <div>
            <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">RR</label>
            <input type="text" name="visit[vitals][resp]" value="<%= vitals_source["resp"] %>"
                   placeholder="16"
                   data-vitals-extractor-target="resp"
                   class="mt-0.5 w-full px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono">
          </div>
          <div>
            <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">SpO2</label>
            <input type="text" name="visit[vitals][o2]" value="<%= vitals_source["o2"] %>"
                   placeholder="95"
                   data-vitals-extractor-target="o2"
                   class="mt-0.5 w-full px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono">
          </div>
        </div>
        <div class="mt-2">
          <label class="block text-[9px] uppercase tracking-widest text-[#6B665F]">Pain score (0–10)</label>
          <%= f.number_field :pain_score, min: 0, max: 10, step: 1,
                data: { vitals_extractor_target: "painScore" },
                class: "mt-0.5 w-20 px-2 py-1 rounded border border-[#D9D5CD] bg-white text-[13px] font-mono" %>
        </div>
        </div>
      </details>
      <% end %>
    </div>
  <% end %>

  <% if collapse_metadata %>
    <%# Quiet, collapsible Visit details panel.
        Editability rules:
          completed visits             → read-only (chart entry locked)
          performing clinician (RN/MD) → read-only (admin-set assignment)
          admin / DON / admissions     → editable (they own the schedule) %>
    <% metadata_locked = completed || !can_edit_metadata %>
    <details class="rounded-xl border border-[#EFECE6] bg-[#FBF9F5]">
      <summary class="cursor-pointer list-none flex items-center justify-between px-4 py-3 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] [&::-webkit-details-marker]:hidden">
        <span class="inline-flex items-center gap-1.5">
          <% if metadata_locked %>
            <i class="ri-lock-2-line"></i>
            <%= completed ? "Visit details (locked)" : "Visit details (set by admissions)" %>
          <% else %>
            <i class="ri-list-settings-line"></i>
            Visit details (patient, clinician, type, location)
          <% end %>
        </span>
        <i class="ri-arrow-down-s-line group-open:rotate-180 transition-transform"></i>
      </summary>
      <div class="px-4 pb-4">
        <% if metadata_locked %>
          <%= metadata_readonly_block %>
          <% unless completed %>
            <div class="mt-3 text-[11px] text-[#6B665F] inline-flex items-start gap-1.5">
              <i class="ri-information-line mt-0.5"></i>
              <span>Need to change the assignment? Ping admissions or DON; they own the schedule.</span>
            </div>
          <% end %>
        <% else %>
          <%= metadata_block %>
        <% end %>
      </div>
    </details>
  <% end %>

  <%# State-aware button row.
      :scheduled / :ready  (admin or DON pre-visit)  → Cancel + Save/Schedule, buffer notice shown
      :recording           (RN in the middle of it)  → small Save draft link only; the green Finish lives outside this form (edit.html.erb)
      :completed           (chart entry signed)      → just Save vitals corrections (only field still editable)
  %>
  <% if completed %>
    <div class="pt-3 border-t border-[#EFECE6] flex items-center justify-end">
      <%= f.submit "Save vitals corrections",
            class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium cursor-pointer" %>
    </div>
  <% elsif in_progress %>
    <%# Two submit buttons, same form. submit_action=draft just
        saves; submit_action=finish saves AND triggers the
        finish flow (stamp ended_at, polish, extractor, route to
        MD). Server reads params[:submit_action] in #update.
        Discard draft is a separate DELETE link — out of the form
        so it doesn't accidentally submit save+discard. %>
    <%# Discard + Save draft moved to the three-dot menu on the patient header
        (edit.html.erb). The green Complete-visit CTA stays here as the primary. %>
    <div class="pt-3 border-t border-[#EFECE6] flex flex-col gap-3">
      <button type="submit" name="submit_action" value="finish"
              data-turbo-confirm="Finish this visit for <%= @visit.patient&.full_name %>? This saves your edits, stamps end time, and lands you on the chart for review."
              class="w-full inline-flex items-center justify-center gap-2 px-4 py-3 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white text-sm font-semibold shadow-sm">
        <i class="ri-check-double-line text-lg"></i> Complete visit
      </button>
      <div class="text-[11px] text-[#6B665F] text-center">
        <% if @visit.visit_type_admission? %>
          Saves your edits, stamps the end time, updates the eval, then returns here for RN review before MD routing.
        <% else %>
          Saves your edits and stamps the end time.
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="pt-3 border-t border-[#EFECE6] flex items-center justify-between text-[11px] text-[#6B665F]">
      <span>
        <i class="ri-shield-check-line"></i>
        Overlap + 30-min windshield buffer enforced by the database.
      </span>
      <div class="flex items-center gap-3">
        <%= link_to "Cancel", calendar_return_path,
              class: "text-[13px] px-4 py-2 rounded-full border border-[#D9D5CD] text-[#6B665F] hover:bg-[#F1EEE8] hover:text-[#1D1C1A] transition" %>
        <%= f.submit (@visit.persisted? ? "Save changes" : "Add to #{role_label} calendar"),
              class: "inline-flex items-center gap-1.5 px-5 py-2 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-sm font-medium cursor-pointer" %>
      </div>
    </div>
  <% end %>
<% end %>
