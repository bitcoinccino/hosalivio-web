<%
  # 'Clear & dictate' button on the visit show page links here with
  # ?focus=narrative. We wipe the AI-pending placeholder in-memory so
  # the form renders an empty narrative ready for Pascal to dictate
  # into. The actual save still goes through the normal update path.
  if params[:focus] == "narrative" && @visit.narrative.to_s.start_with?("Narrative pending")
    @visit.narrative = ""
  end

  # ?just_recorded=1 — landed here from the full-screen recording
  # screen. The narrative is fresh; auto-extract vitals into the
  # form on page load so the RN sees them pre-filled before Finish.
  just_recorded = params[:just_recorded] == "1"
%>
<% if just_recorded %>
  <div class="max-w-7xl mx-auto px-4 pt-4">
    <div class="rounded-2xl bg-[#E6F0EE] border border-[#2F6F4E] p-3 text-[12px] text-[#1D1C1A]">
      <i class="ri-check-line text-[#2F6F4E]"></i>
      Recording saved. Review the narrative + vitals below, then tap <strong>Finish visit</strong>.
    </div>
  </div>
<% end %>
<%

  # Visit lifecycle states drive the entire page language:
  #   scheduled    — start time in the future, not yet begun
  #   ready        — scheduled time is now or passed, not yet begun
  #   recording    — started_at set, ended_at nil (actively documenting)
  #   completed    — both timestamps set (editing a past visit)
  now      = Time.current
  state = if @visit.ended_at
            :completed
          elsif @visit.started_at
            :recording
          elsif @visit.scheduled_at && @visit.scheduled_at <= now
            :ready
          else
            :scheduled
          end

  is_admission = @visit.visit_type.to_s == "admission"
  linked_eval  = @visit.pre_admit_eval

  page_title, header_label, header_icon, header_color = case state
    when :completed
      if is_admission && linked_eval
        ["Pre-eval note · HosAlivio",    "Edit pre-eval note",      "ri-clipboard-line",       "#2B4A7A"]
      else
        ["Edit visit · HosAlivio",       "Edit completed visit",    "ri-edit-2-line",          "#6B665F"]
      end
    when :recording
      ["Visit in progress · HosAlivio",  "Visit in progress",       "ri-time-line",            "#C1403A"]
    when :ready
      ["Start visit · HosAlivio",        "Start visit",             "ri-calendar-check-line",  "#D97757"]
    else
      ["Edit visit · HosAlivio",         "Edit scheduled visit",    "ri-calendar-event-line",  "#D97757"]
    end

  # "Scheduled by" line: prefer the actual human who created the
  # visit (admin / admissions / on-call RN). Fall back to the assigned
  # clinician for legacy visits with no created_by stamp. AI-scheduled
  # visits show the persona instead.
  scheduler = @visit.created_by_user || (@visit.agent_authored ? nil : @visit.user)
  scheduler_role = scheduler ? (scheduler.role_names & %w[admin don admissions rn md sw social_worker chaplain aide]).first : nil
%>
<% content_for :title, page_title %>
<div class="min-h-screen bg-[#FBF9F5] py-10 px-4">
  <div class="max-w-7xl mx-auto">
    <a href="<%= dashboard_path %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to My Day
    </a>

    <%# Three-column workspace: visit history (left) | structured
        chart entry (middle) | recording transcript + audio (right).
        Sidebars are collapsible (chevron in their header, persisted
        per user via localStorage). Grid uses auto sizing for the
        sidebars so when they collapse to ~48px the middle column
        gets the reclaimed space automatically. Stacks single-column
        under xl breakpoint so phones / narrow laptops still get a
        readable layout. %>
    <div class="grid grid-cols-1 xl:grid-cols-[auto_minmax(0,1fr)_auto] gap-4">

      <%# ── Left: visit history ───────────────────────── %>
      <%= render "visit_history_sidebar", current_visit: @visit %>

      <%# ── Middle: structured chart entry + edit form ── %>
      <div class="rounded-2xl bg-white border border-[#EFECE6] shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
          <div class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-[0.2em] font-bold" style="color: <%= header_color %>;">
            <i class="<%= header_icon %>"></i> <%= header_label %>
          </div>
          <% if state == :recording %>
            <div class="inline-flex items-center gap-1.5 text-[11px] text-[#C1403A]">
              <span class="w-2 h-2 rounded-full bg-[#C1403A] animate-pulse"></span>
              Started <%= @visit.started_at.strftime("%-l:%M %p") %>
            </div>
          <% end %>
        </div>
        <h1 class="font-serif text-xl text-[#1D1C1A] mb-1">
          <%= @visit.patient&.full_name %>
        </h1>
        <div class="text-[11px] text-[#6B665F] mb-5">
          <% if @visit.agent_authored %>
            🤖 Scheduled by HosAlivio
          <% elsif scheduler %>
            👤 Scheduled by <%= scheduler_role&.tr("_", " ")&.titleize&.then { |r| "#{r} " } %><strong class="text-[#1D1C1A] font-medium">@<%= scheduler.full_name.split.first %></strong>
          <% else %>
            👤 Scheduled by a human
          <% end %>
        </div>

        <%# Admission visit with a linked eval renders the structured
            chart entry as a document (matching the openclaw EMR-style
            pre-admit_note.txt shape). The detailed editable form
            lives on /pre_admit_evals/:id/edit. %>
        <% if is_admission && linked_eval %>
          <%= render "eval_document", eval_rec: linked_eval, visit: @visit %>
        <% end %>

        <%= render "form", just_recorded: just_recorded %>
      </div>

      <%# ── Right: recording transcript + audio ────────── %>
      <%= render "visit_transcript_sidebar", visit: @visit %>

    </div>
  </div>
</div>
