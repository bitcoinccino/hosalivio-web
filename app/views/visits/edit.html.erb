<%
  # 'Clear & dictate' button on the visit show page links here with
  # ?focus=narrative. We wipe the AI-pending placeholder in-memory so
  # the form renders an empty narrative ready for Pascal to dictate
  # into. The actual save still goes through the normal update path.
  if params[:focus] == "narrative" && @visit.narrative.to_s.start_with?("Narrative pending")
    @visit.narrative = ""
  end

  # ?just_recorded=1 — landed here from the full-screen recording
  # screen. The narrative is fresh; auto-extract vitals into the
  # form on page load so the RN sees them pre-filled before Finish.
  just_recorded = params[:just_recorded] == "1"
%>
<% if just_recorded %>
  <div class="max-w-3xl mx-auto px-4 pt-4">
    <div class="rounded-2xl bg-[#E6F0EE] border border-[#2F6F4E] p-3 text-[12px] text-[#1D1C1A]">
      <i class="ri-check-line text-[#2F6F4E]"></i>
      Recording saved. Review the narrative + vitals below, then tap <strong>Finish visit</strong>.
    </div>
  </div>
<% end %>
<%

  # Visit lifecycle states drive the entire page language:
  #   scheduled    — start time in the future, not yet begun
  #   ready        — scheduled time is now or passed, not yet begun
  #   recording    — started_at set, ended_at nil (actively documenting)
  #   completed    — both timestamps set (editing a past visit)
  now      = Time.current
  state = if @visit.ended_at
            :completed
          elsif @visit.started_at
            :recording
          elsif @visit.scheduled_at && @visit.scheduled_at <= now
            :ready
          else
            :scheduled
          end

  is_admission = @visit.visit_type.to_s == "admission"
  linked_eval  = @visit.pre_admit_eval

  page_title, header_label, header_icon, header_color = case state
    when :completed
      if is_admission && linked_eval
        ["Pre-eval note · HosAlivio",    "Edit pre-eval note",      "ri-clipboard-line",       "#2B4A7A"]
      else
        ["Edit visit · HosAlivio",       "Edit completed visit",    "ri-edit-2-line",          "#6B665F"]
      end
    when :recording
      ["Visit in progress · HosAlivio",  "Visit in progress",       "ri-time-line",            "#C1403A"]
    when :ready
      ["Start visit · HosAlivio",        "Start visit",             "ri-calendar-check-line",  "#D97757"]
    else
      ["Edit visit · HosAlivio",         "Edit scheduled visit",    "ri-calendar-event-line",  "#D97757"]
    end

  # "Scheduled by" line: prefer the actual human who created the
  # visit (admin / admissions / on-call RN). Fall back to the assigned
  # clinician for legacy visits with no created_by stamp. AI-scheduled
  # visits show the persona instead.
  scheduler = @visit.created_by_user || (@visit.agent_authored ? nil : @visit.user)
  scheduler_role = scheduler ? (scheduler.role_names & %w[admin don admissions rn md sw social_worker chaplain aide]).first : nil
%>
<% content_for :title, page_title %>
<div class="min-h-screen bg-[#FBF9F5] py-10 px-4">
  <div class="max-w-3xl mx-auto">
    <a href="<%= current_user.role_names.include?("don") ? dashboard_path : dashboard_path %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to My Day
    </a>
    <div class="rounded-2xl bg-white border border-[#EFECE6] shadow-sm p-6">
      <div class="flex items-center justify-between mb-2">
        <div class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-[0.2em] font-bold" style="color: <%= header_color %>;">
          <i class="<%= header_icon %>"></i> <%= header_label %>
        </div>
        <% if state == :recording %>
          <div class="inline-flex items-center gap-1.5 text-[11px] text-[#C1403A]">
            <span class="w-2 h-2 rounded-full bg-[#C1403A] animate-pulse"></span>
            Started <%= @visit.started_at.strftime("%-l:%M %p") %>
          </div>
        <% end %>
      </div>
      <h1 class="font-serif text-xl text-[#1D1C1A] mb-1">
        <%= @visit.patient&.full_name %>
      </h1>
      <div class="text-[11px] text-[#6B665F] mb-5">
        <% if @visit.agent_authored %>
          🤖 Scheduled by HosAlivio
        <% elsif scheduler %>
          👤 Scheduled by <%= scheduler_role&.tr("_", " ")&.titleize&.then { |r| "#{r} " } %><strong class="text-[#1D1C1A] font-medium">@<%= scheduler.full_name.split.first %></strong>
        <% else %>
          👤 Scheduled by a human
        <% end %>
      </div>

      <% if is_admission && linked_eval %>
        <%
          dx_section = linked_eval.diagnosis_section
          primary_dx = dx_section["primary_terminal_diagnosis"].is_a?(Hash) ? dx_section["primary_terminal_diagnosis"] : {}
          secondary_dx = Array(dx_section["secondary_diagnoses"])
          lcd_criteria = Array(dx_section["lcd_criteria_met"])
          pps_obj      = linked_eval.pps_object
          pps_hash     = pps_obj.is_a?(Hash) ? pps_obj : {}
          blockers     = linked_eval.certification_blockers
          status_color = case linked_eval.status.to_s
                         when "certified" then "#2F6F4E"
                         when "final"     then "#2B4A7A"
                         else                   "#6B665F"
                         end
        %>
        <div class="mb-5 rounded-2xl border border-[#2B4A7A] bg-[#F0F4FA] p-4"
             data-controller="json-toggle">
          <div class="flex items-start gap-3">
            <i class="ri-clipboard-line text-[#2B4A7A] text-lg mt-0.5"></i>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2 flex-wrap">
                <div class="text-[11px] uppercase tracking-widest text-[#2B4A7A] font-bold">Pre-admit assessment</div>
                <div class="flex items-center gap-2">
                  <%# Segmented toggle between the human-friendly summary
                      and the raw JSON dump. Both are pre-rendered; the
                      json-toggle controller just hides one or the other. %>
                  <div class="inline-flex items-center rounded-full bg-white/60 border border-[#2B4A7A]/20 p-0.5 text-[11px]">
                    <button type="button"
                            data-action="click->json-toggle#showHuman"
                            data-json-toggle-target="humanButton"
                            class="px-2.5 py-1 rounded-full bg-white text-[#1D1C1A] shadow-sm font-medium">
                      Human friendly
                    </button>
                    <button type="button"
                            data-action="click->json-toggle#showJson"
                            data-json-toggle-target="jsonButton"
                            class="px-2.5 py-1 rounded-full text-[#6B665F] font-medium">
                      JSON
                    </button>
                  </div>
                  <span class="inline-flex items-center gap-1 text-[10px] uppercase tracking-widest font-bold rounded-full px-2 py-0.5"
                        style="color: <%= status_color %>; background: <%= status_color %>1a; border: 1px solid <%= status_color %>40;">
                    <%= linked_eval.status.to_s.tr("_", " ") %>
                  </span>
                </div>
              </div>

              <%# Compact human-readable preview of the JSON eval. Key
                  fields only — full sections live on the eval show
                  page (button below). Renders nothing for empty
                  fields so a fresh draft doesn't show a wall of dashes. %>
              <div data-json-toggle-target="human">
              <dl class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-[12px]">
                <% if primary_dx["description"].present? || primary_dx["icd10"].present? %>
                  <div class="sm:col-span-2">
                    <dt class="text-[10px] uppercase tracking-widest text-[#6B665F]">Terminal diagnosis</dt>
                    <dd class="text-[#1D1C1A]">
                      <%= primary_dx["description"] %>
                      <% if primary_dx["icd10"].present? %>
                        <span class="font-mono text-[11px] text-[#6B665F] ml-1">(<%= primary_dx["icd10"] %>)</span>
                      <% end %>
                    </dd>
                  </div>
                <% end %>

                <% if secondary_dx.any? %>
                  <div class="sm:col-span-2">
                    <dt class="text-[10px] uppercase tracking-widest text-[#6B665F]">Secondary diagnoses</dt>
                    <dd class="text-[#1D1C1A]">
                      <% secondary_dx.each do |sd| %>
                        <% case sd
                           when Hash %>
                          <span class="inline-block mr-2"><%= sd["description"] || sd["icd10"] %></span>
                        <% else %>
                          <span class="inline-block mr-2"><%= sd %></span>
                        <% end %>
                      <% end %>
                    </dd>
                  </div>
                <% end %>

                <% if pps_hash["score"].present? || pps_hash["source"].present? %>
                  <div>
                    <dt class="text-[10px] uppercase tracking-widest text-[#6B665F]">PPS</dt>
                    <dd class="text-[#1D1C1A]">
                      <span class="font-mono"><%= pps_hash["score"] || "—" %><%= "%" if pps_hash["score"].present? %></span>
                      <% if pps_hash["source"].present? %>
                        <span class="text-[10px] text-[#6B665F] ml-1">· <%= pps_hash["source"] %></span>
                      <% end %>
                    </dd>
                    <% if pps_hash["justification"].present? %>
                      <dd class="text-[11px] text-[#6B665F] italic mt-0.5"><%= pps_hash["justification"] %></dd>
                    <% end %>
                  </div>
                <% end %>

                <% if lcd_criteria.any? %>
                  <div>
                    <dt class="text-[10px] uppercase tracking-widest text-[#6B665F]">LCD criteria met</dt>
                    <dd class="text-[#1D1C1A]"><%= lcd_criteria.size %> noted</dd>
                  </div>
                <% end %>

                <% if blockers.any? %>
                  <div class="sm:col-span-2">
                    <dt class="text-[10px] uppercase tracking-widest text-[#C1403A]">Certification blockers</dt>
                    <dd class="text-[#C1403A] text-[12px]">
                      <ul class="list-disc list-inside">
                        <% blockers.each do |b| %><li><%= b %></li><% end %>
                      </ul>
                    </dd>
                  </div>
                <% end %>
              </dl>

              <% if primary_dx.empty? && secondary_dx.empty? && pps_hash["score"].blank? && lcd_criteria.empty? %>
                <div class="mt-2 text-[12px] text-[#6B665F] italic">
                  No structured fields extracted yet. Dictate the assessment below, then tap <strong>Sync to Eval</strong>.
                </div>
              <% end %>
              </div><%# /human %>

              <%# JSON view — raw dump, pretty-printed. Hidden until the
                  RN flips the toggle. Useful for developers + curious
                  RNs who want to see exactly what the AI extracted. %>
              <div data-json-toggle-target="json" class="hidden mt-3">
                <pre class="text-[11px] leading-snug font-mono bg-white border border-[#2B4A7A]/20 rounded-lg p-3 overflow-x-auto max-h-80 overflow-y-auto text-[#1D1C1A]"><%= JSON.pretty_generate(linked_eval.raw_json) %></pre>
              </div>

              <div class="mt-3 flex items-center gap-2 flex-wrap">
                <% if state != :completed %>
                  <%= button_to sync_to_eval_visit_path(@visit), method: :post,
                        class: "inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full bg-[#2B4A7A] hover:bg-[#223d66] text-white font-medium" do %>
                    <i class="ri-magic-line"></i> Sync to Eval
                  <% end %>
                <% end %>
                <%= link_to pre_admit_eval_path(linked_eval),
                      class: "inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full border border-[#2B4A7A] text-[#2B4A7A] hover:bg-white font-medium" do %>
                  <i class="ri-external-link-line"></i> View full assessment
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <%= render "form", just_recorded: just_recorded %>

      <% if state == :recording %>
        <div class="mt-5 pt-5 border-t border-[#EFECE6]">
          <%= button_to finish_visit_path(@visit), method: :post,
                data: { turbo_confirm: "Finish this visit for #{@visit.patient&.full_name}?" },
                class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white text-sm font-medium" do %>
            <i class="ri-check-double-line"></i> Finish visit
          <% end %>
          <span class="text-[11px] text-[#6B665F] ml-2">Stamps the end time and returns to My Day.</span>
        </div>
      <% end %>
    </div>
  </div>
</div>
