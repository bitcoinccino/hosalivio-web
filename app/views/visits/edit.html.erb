<%
  # 'Clear & dictate' button on the visit show page links here with
  # ?focus=narrative. We wipe the AI-pending placeholder in-memory so
  # the form renders an empty narrative ready for Pascal to dictate
  # into. The actual save still goes through the normal update path.
  if params[:focus] == "narrative" && @visit.narrative.to_s.start_with?("Narrative pending")
    @visit.narrative = ""
  end

  # ?just_recorded=1 — landed here from the full-screen recording
  # screen. The narrative is fresh; auto-extract vitals into the
  # form on page load so the RN sees them pre-filled before Finish.
  just_recorded = params[:just_recorded] == "1"

  now      = Time.current
  state = if @visit.ended_at
            :completed
          elsif @visit.started_at
            :recording
          elsif @visit.scheduled_at && @visit.scheduled_at <= now
            :ready
          else
            :scheduled
          end

  is_admission = @visit.visit_type.to_s == "admission"
  linked_eval  = @visit.pre_admit_eval

  routed_to_md = is_admission && linked_eval &&
                 Notification.exists?(kind: "pre_admit_review_ready", linked: linked_eval)

  page_title, header_label, header_icon, header_color = case state
    when :completed
      if is_admission && linked_eval && routed_to_md
        ["Pre-eval note · HosAlivio",    "Pre-eval note (routed)",   "ri-send-plane-line",     "#2F6F4E"]
      elsif is_admission && linked_eval
        ["General chart · HosAlivio",    "General chart",            "ri-edit-2-line",         "#D97757"]
      else
        ["Edit visit · HosAlivio",       "Edit completed visit",     "ri-edit-2-line",         "#6B665F"]
      end
    when :recording
      ["Visit in progress · HosAlivio",  "Visit in progress",        "ri-time-line",           "#C1403A"]
    when :ready
      ["Start visit · HosAlivio",        "Start visit",              "ri-calendar-check-line", "#D97757"]
    else
      ["Edit visit · HosAlivio",         "Edit scheduled visit",     "ri-calendar-event-line", "#D97757"]
    end

  scheduler = @visit.created_by_user || (@visit.agent_authored ? nil : @visit.user)
  scheduler_role = scheduler ? (scheduler.role_names & %w[admin don admissions rn md sw social_worker chaplain aide]).first : nil

  patient = @visit.patient
  patient_initials = patient ? [patient.first_name, patient.last_name].compact.map { |n| n[0] }.join.upcase : ""

  status_color = case patient&.status
    when "active"     then "#2F6F4E"
    when "admitted"   then "#D97757"
    when "referred"   then "#6B665F"
    when "revoked"    then "#C1403A"
    when "discharged" then "#6B665F"
    when "deceased"   then "#1D1C1A"
    else                   "#6B665F"
    end

  rn_role = (current_user.role_names & %w[rn md don sw chaplain aide social_worker admissions admin]).first
%>
<% content_for :title, page_title %>

<div class="min-h-screen bg-[#FBF9F5]" data-controller="narrative-link">

  <%# ── Top navbar ──────────────────────────────────────
      Back arrow returns to the patient main dashboard.
      Right side shows the signed-in clinician's avatar
      + name + role so Pascal always sees who he is on the
      chart he's about to sign. %>
  <header class="bg-white border-b border-[#EFECE6] px-6 lg:px-8 py-3 sticky top-0 z-20">
    <div class="flex items-center justify-between gap-4">
      <a href="<%= patient ? patient_path(patient) : dashboard_path %>"
         class="inline-flex items-center gap-2 text-[13px] text-[#1D1C1A] hover:text-[#D97757] font-medium">
        <i class="ri-arrow-left-line text-lg"></i>
        <span>Back<% if patient %> to <%= patient.full_name %><% end %></span>
      </a>

      <div class="inline-flex items-center gap-1 text-[11px] uppercase tracking-[0.2em] font-bold" style="color: <%= header_color %>;">
        <i class="<%= header_icon %>"></i> <%= header_label %>
      </div>

      <div class="inline-flex items-center gap-3">
        <div class="text-right hidden sm:block">
          <div class="text-[13px] text-[#1D1C1A] font-medium leading-tight"><%= current_user.full_name %></div>
          <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">
            <% if rn_role %><%= rn_role.tr("_", " ") %><% end %>
            <% if current_user.respond_to?(:branch) && current_user.branch %> · <%= current_user.branch.name %><% end %>
          </div>
        </div>
        <% if current_user.has_avatar? %>
          <%= image_tag current_user.avatar,
                class: "w-10 h-10 rounded-full object-cover border border-[#EFECE6]" %>
        <% else %>
          <div class="w-10 h-10 rounded-full bg-[#FBF9F5] border border-[#EFECE6] flex items-center justify-center text-[12px] font-bold text-[#D97757]">
            <%= current_user.initials %>
          </div>
        <% end %>
      </div>
    </div>
  </header>

  <% if just_recorded %>
    <div class="px-6 lg:px-8 pt-4">
      <div class="rounded-2xl bg-[#E6F0EE] border border-[#2F6F4E] p-3 text-[12px] text-[#1D1C1A]">
        <i class="ri-check-line text-[#2F6F4E]"></i>
        Recording saved. Review the narrative + vitals below, then tap <strong>Finish visit</strong>.
      </div>
    </div>
  <% end %>

  <%# ── Main row: full sidebar (left) + middle + transcript (right) ── %>
  <%# Bottom padding leaves room for the fixed audio footer so the
      last form button isn't hidden under it. %>
  <div class="px-6 lg:px-8 py-6 pb-24">
    <div class="grid grid-cols-1 lg:grid-cols-[320px_minmax(0,1fr)_380px] 2xl:grid-cols-[360px_minmax(0,1fr)_420px] gap-4">

      <%= render "visit_history_sidebar", current_visit: @visit %>

      <div class="rounded-2xl bg-white border border-[#EFECE6] shadow-sm p-6 relative">

        <%# Visit actions — three-dot menu at the far right of the header.
            Holds the secondary actions (Save draft submits the form below via
            the form= attribute; Discard deletes the draft). %>
        <% unless @visit.completed_visit? %>
          <div class="absolute top-3 right-3 z-20" data-controller="menu">
            <button type="button" data-action="menu#toggle"
                    class="w-8 h-8 rounded-full hover:bg-[#FBF9F5] flex items-center justify-center text-[#6B665F]"
                    aria-label="Visit actions">
              <i class="ri-more-2-fill text-[18px]"></i>
            </button>
            <div data-menu-target="panel"
                 class="hidden absolute right-0 mt-1 w-44 rounded-xl bg-white border border-[#EFECE6] shadow-lg py-1 text-[13px] text-left">
              <% if @visit.currently_in_progress? %>
                <button type="submit" form="visit-edit-form" name="submit_action" value="draft"
                        data-action="menu#close"
                        class="w-full text-left px-4 py-2 hover:bg-[#FBF9F5] inline-flex items-center gap-2 text-[#1D1C1A]">
                  <i class="ri-save-line text-[#6B665F]"></i> Save draft
                </button>
              <% end %>
              <%= link_to visit_path(@visit, from: "edit"),
                    data: { turbo_method: :delete,
                            turbo_confirm: "Discard this draft? The audio + transcript will be deleted permanently.",
                            action: "menu#close" },
                    class: "w-full px-4 py-2 hover:bg-[#FFF3EC] text-[#C1403A] inline-flex items-center gap-2" do %>
                <i class="ri-delete-bin-line"></i> Discard
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Patient hero — avatar, name, then a single row of uniform
            pill chips (age · status · MRN). Drops the schedule
            attribution line; schedulers live in the locked Visit
            details panel below. %>
        <div class="text-center pb-6 border-b border-[#EFECE6]">
          <div class="mx-auto w-20 h-20 rounded-full bg-gradient-to-br from-[#FFF3EC] to-[#FBF9F5] border border-[#EFECE6] flex items-center justify-center text-[20px] font-bold text-[#D97757] mb-3 shadow-sm">
            <%= patient_initials.presence || "?" %>
          </div>
          <h1 class="font-serif text-[26px] leading-tight text-[#1D1C1A] tracking-tight">
            <%= patient&.full_name || "—" %>
          </h1>
          <div class="mt-3 inline-flex items-center gap-1.5 flex-wrap justify-center">
            <% if patient&.age_years %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-medium bg-[#FBF9F5] border border-[#EFECE6] text-[#1D1C1A]">
                <i class="ri-user-3-line text-[#6B665F]"></i> <%= patient.age_years %> yrs
              </span>
            <% end %>
            <% if patient&.status %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-bold uppercase tracking-widest"
                    style="color: <%= status_color %>; background-color: <%= status_color %>14; border: 1px solid <%= status_color %>55;">
                <span class="w-1.5 h-1.5 rounded-full" style="background-color: <%= status_color %>;"></span>
                <%= patient.status.to_s.titleize %>
              </span>
            <% end %>
            <% if patient %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-mono bg-white border border-[#EFECE6] text-[#6B665F]">
                <i class="ri-hashtag text-[#D9D5CD]"></i><%= patient.mrn %>
              </span>
            <% end %>
          </div>
        </div>

        <%# Stage banner is computed up here but rendered at the
            bottom of the middle column (below the form) so it
            doesn't push the chart content + flags down. The
            variables stay in scope for the bottom render. %>
        <%
          stage_label, stage_sub, stage_bg, stage_fg, stage_border, stage_icon =
            if state == :completed && is_admission && linked_eval && routed_to_md
              ["Routed to MD",            "Awaiting physician certification",                  "#E6F0EE", "#2F6F4E", "#2F6F4E", "ri-send-plane-line"]
            elsif state == :completed && is_admission && linked_eval
              ["General chart · review",  "Polished narrative + extracted eval ready for RN review", "#FFF3EC", "#D97757", "#D97757", "ri-edit-2-line"]
            elsif state == :completed && @visit.signed_off_by_rn?
              ["Signed & locked",         "Chart entry signed by clinician — corrections need a late-entry note.", "#E6F0EE", "#2F6F4E", "#2F6F4E", "ri-shield-check-line"]
            elsif state == :completed
              ["Completed · awaiting sign-off", "Visit ended. Sign the note below to lock the chart entry.", "#FFF3EC", "#D97757", "#D97757", "ri-time-line"]
            elsif state == :recording
              ["Visit in progress",       "Recording started · finish to lock the chart",       "#FFE9E0", "#C1403A", "#C1403A", "ri-time-line"]
            elsif state == :ready
              ["Ready to start",          "Scheduled time has arrived",                         "#FFF3EC", "#D97757", "#D97757", "ri-calendar-check-line"]
            else
              ["Scheduled",               "Visit not yet started",                              "#FBF9F5", "#6B665F", "#EFECE6", "ri-calendar-event-line"]
            end
        %>

        <%# ── Clinical flags ─ at-a-glance chips for what's actually
            wrong with this patient. Pulled from the eval (when an
            admission visit has one) plus visit-level vitals so they
            update live with the chart. %>
        <%
          flags = []
          if linked_eval
            pae   = linked_eval.diagnosis_section || {}
            pdx   = pae["primary_terminal_diagnosis"].is_a?(Hash) ? pae["primary_terminal_diagnosis"] : {}
            sx    = linked_eval.other_symptoms || {}
            pain  = sx["pain"].is_a?(Hash)    ? sx["pain"]    : {}
            dysp  = sx["dyspnea"].is_a?(Hash) ? sx["dyspnea"] : {}
            nut   = linked_eval.nutritional_decline || {}
            fd    = linked_eval.functional_decline || {}

            flags << { kind: "dx",       label: pdx["description"], sub: pdx["icd10"], tone: "primary" } if pdx["description"].present?
            Array(pae["related_conditions"]).each do |c|
              flags << { kind: "related", label: c, tone: "warn" }
            end
            if dysp["severity"].present?
              flags << { kind: "dyspnea", label: "Dyspnea: #{dysp["severity"]}", tone: "alert" }
            end
            if nut["weight_loss_lbs"].present? || nut["weight_loss_pct"].present?
              chunks = []
              chunks << "#{nut["weight_loss_lbs"]} lb" if nut["weight_loss_lbs"].present?
              chunks << "#{nut["weight_loss_pct"]}%"   if nut["weight_loss_pct"].present?
              flags << { kind: "weight", label: "Weight loss: #{chunks.join(' / ')}", tone: "warn" }
            end
            flags << { kind: "fall",      label: "Fall risk: #{fd["fall_history"]}", tone: "warn"  } if fd["fall_history"].to_s.match?(/yes|history|recent|fall/i)
            flags << { kind: "wounds",    label: "Wounds: #{sx["wounds"]}",          tone: "alert" } if sx["wounds"].to_s.present? && sx["wounds"].to_s.downcase != "none"
            flags << { kind: "delirium",  label: "Delirium",                          tone: "alert" } if sx["delirium"].to_s.present? && sx["delirium"].to_s.downcase != "none"
            flags << { kind: "infection", label: "Infection: #{sx["infections"]}",   tone: "alert" } if sx["infections"].to_s.present? && sx["infections"].to_s.downcase != "none"
          end

          # Visit-level pain score (vitals are always editable, even on completed visits)
          if @visit.pain_score.to_i > 0
            score = @visit.pain_score.to_i
            tone  = score >= 7 ? "alert" : (score >= 4 ? "warn" : "info")
            flags << { kind: "pain", label: "Pain #{score}/10", tone: tone }
          end

          # Code status: a hospice flag the team has to know on every visit
          if patient&.code_status.present?
            cs_label = case patient.code_status
                       when "full_code"    then "Full Code"
                       when "dnr"          then "DNR"
                       when "dni"          then "DNI"
                       when "dnr_dni"      then "DNR / DNI"
                       when "comfort_only" then "Comfort Only"
                       else patient.code_status.to_s.titleize
                       end
            cs_tone = patient.code_status == "full_code" ? "info" : "alert"
            flags << { kind: "code_status", label: cs_label, tone: cs_tone }
          end
        %>
        <% if flags.any? %>
          <div class="mt-4">
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-2 inline-flex items-center gap-1">
              <i class="ri-alarm-warning-line"></i> Clinical flags
            </div>
            <div class="flex flex-wrap gap-1.5">
              <% flags.each do |f| %>
                <%
                  fg, bg, border = case f[:tone]
                    when "alert"   then ["#C1403A", "#FFE9E0", "#C1403A"]
                    when "warn"    then ["#D97757", "#FFF3EC", "#D97757"]
                    when "primary" then ["#2B4A7A", "#E8EEF7", "#2B4A7A"]
                    else                ["#1D1C1A", "#FBF9F5", "#D9D5CD"]
                    end
                %>
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-medium"
                      style="color: <%= fg %>; background-color: <%= bg %>; border: 1px solid <%= border %>;">
                  <%= f[:label] %>
                  <% if f[:sub].present? %>
                    <span class="font-mono text-[10px] opacity-70">· <%= f[:sub] %></span>
                  <% end %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Caregiver / language / home / code-status now live in the
            "Patient · home environment" section of the locked Visit
            details panel below — no separate widget so we don't show
            the same data twice. %>

        <%# Open MD revision request — when the on-call MD reviewed
            the routed eval and asked the RN to revise something,
            we surface their comment here so the RN sees exactly
            what to fix before re-routing. Resolves automatically
            when route_to_md fires again. %>
        <% if linked_eval %>
          <% open_request = linked_eval.revision_requests.open.recent_first.first %>
          <% if open_request %>
            <div class="mt-5 rounded-2xl border border-[#D97757] bg-[#FFF3EC] p-4 flex items-start gap-3">
              <i class="ri-arrow-go-back-line text-[#D97757] text-lg mt-0.5 flex-shrink-0"></i>
              <div class="flex-1 min-w-0">
                <div class="text-[11px] uppercase tracking-widest text-[#D97757] font-bold">
                  MD requested changes
                </div>
                <div class="text-[12px] text-[#1D1C1A] mt-1 leading-relaxed">
                  <strong><%= open_request.requester.full_name %></strong>
                  on <%= open_request.created_at.strftime("%b %-d · %-l:%M %p") %>:
                </div>
                <blockquote class="mt-2 text-[13px] text-[#1D1C1A] italic border-l-2 border-[#D97757] pl-3 whitespace-pre-wrap">
                  <%= open_request.comment %>
                </blockquote>
                <div class="text-[11px] text-[#6B665F] mt-2">
                  Edit the eval (Medicaid tab) or the narrative (Team tab), then sign &amp; route to MD again.
                </div>
              </div>
            </div>
          <% end %>
        <% end %>

        <%# Non-admission visit sign-off — when the visit is already
            signed, the confirmation card is purely informational so
            it renders below the form (next to the stage banner) so
            the chart content stays at the top. The active sign
            panel still surfaces above the form so the RN sees the
            action they need to take. %>
        <% rn_visit_sig = (state == :completed && !is_admission) ? @visit.signatures.where(verification_method: "rn_visit_signoff").order(:signed_at).last : nil %>
        <% if state == :completed && !is_admission && rn_visit_sig.nil? %>
          <div class="mt-5">
            <%= render "shared/signature_panel",
                  submit_path:   sign_note_visit_path(@visit),
                  submit_method: :post,
                  submit_label:  "Sign visit note",
                  headline:      "Sign · visit note",
                  intent_text:   "I, the signing clinician, attest that this visit note is accurate and complete to the best of my knowledge.",
                  confirm:       "Sign and lock this visit note for #{@visit.patient&.full_name}? Future corrections require a late-entry note.",
                  tone:          :certify %>
          </div>
        <% end %>

        <%# Route-to-MD banner (admission visits with linked eval). %>
        <% if is_admission && linked_eval && state == :completed %>
          <% routed_at = Notification.where(kind: "pre_admit_review_ready", linked: linked_eval).order(:created_at).first&.created_at %>
          <% if routed_at %>
            <div class="mt-5 rounded-2xl border border-[#2F6F4E] bg-[#E6F0EE] p-4 flex items-start gap-3">
              <i class="ri-send-plane-line text-[#2F6F4E] text-lg mt-0.5"></i>
              <div class="flex-1">
                <div class="text-[11px] uppercase tracking-widest text-[#2F6F4E] font-bold">Routed to MD</div>
                <div class="text-[12px] text-[#1D1C1A] mt-1">
                  Sent to the MD certification queue on <%= routed_at.strftime("%b %-d, %-l:%M %p") %>.
                  Dr. on call sees it in their Handoffs Waiting card.
                </div>
              </div>
            </div>
          <% else %>
            <div class="mt-5 space-y-3">
              <div class="rounded-2xl border border-[#D97757] bg-[#FFF3EC] p-4 flex items-start gap-3">
                <i class="ri-edit-2-line text-[#D97757] text-lg mt-0.5 flex-shrink-0"></i>
                <div class="flex-1 min-w-0">
                  <div class="text-[11px] uppercase tracking-widest text-[#D97757] font-bold">General chart · awaiting RN review</div>
                  <div class="text-[12px] text-[#1D1C1A] mt-1">
                    Polished narrative + extracted eval below. Review for accuracy. When ready, sign and route to MD for certification.
                  </div>
                </div>
              </div>

              <%= render "shared/signature_panel",
                    submit_path:   route_to_md_visit_path(@visit),
                    submit_method: :post,
                    submit_label:  "Route to MD for certification",
                    headline:      "Sign · route to MD",
                    intent_text:   "I certify that I have reviewed this pre-admit evaluation and authorize routing it to the on-call MD for certification.",
                    confirm:       "Apply your signature and route this eval to the on-call MD?",
                    tone:          :route %>
            </div>
          <% end %>
        <% end %>

        <%# ── Note format tabs: Medicaid (structured eval doc),
            Team (conversational IDT narrative), JSON (raw payload).
            All three panes render even when content is missing —
            empty panes show a placeholder so the toggle is always
            visible and the RN can audit what's in the chart. %>
        <%
          has_team_narrative = @visit.narrative.present?
          json_payload =
            if linked_eval
              JSON.pretty_generate(linked_eval.raw_json || {})
            else
              JSON.pretty_generate({
                visit: @visit.attributes.except("encrypted_password", "created_at", "updated_at"),
                narrative: @visit.narrative,
                narrative_raw: @visit.narrative_raw,
                vitals: @visit.vitals
              }.compact)
            end
          initial_tab = linked_eval ? "medicaid" : (has_team_narrative ? "team" : "json")
        %>
        <% export_filename = "visit-#{@visit.patient&.mrn}-#{(@visit.scheduled_at || @visit.created_at)&.to_date}" %>
        <div data-controller="note-tabs note-export"
             data-note-tabs-initial="<%= initial_tab %>"
             data-note-export-text-value="<%= @visit.narrative %>"
             data-note-export-json-value="<%= json_payload %>"
             data-note-export-filename-value="<%= export_filename %>"
             class="mt-6">
          <div class="flex items-center justify-between mb-3 gap-2 flex-wrap">
            <div class="flex items-center gap-2.5">
              <div class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold">
                <i class="ri-file-text-line"></i> Note
              </div>
              <%# Export ("sync") — copy the note text, download .txt / .json. %>
              <div class="inline-flex items-center gap-1 text-[#6B665F]">
                <button type="button" data-action="note-export#copyText" title="Copy the note text"
                        class="inline-flex items-center gap-1 text-[11px] px-2 py-1 rounded-full hover:bg-[#FBF9F5] hover:text-[#1D1C1A] border border-transparent hover:border-[#EFECE6] transition">
                  <i class="ri-file-copy-line"></i> Copy
                </button>
                <button type="button" data-action="note-export#downloadTxt" title="Download the note as a text file"
                        class="inline-flex items-center gap-1 text-[11px] px-2 py-1 rounded-full hover:bg-[#FBF9F5] hover:text-[#1D1C1A] border border-transparent hover:border-[#EFECE6] transition">
                  <i class="ri-download-line"></i> .txt
                </button>
                <button type="button" data-action="note-export#downloadJson" title="Download the structured eval as JSON">
                  <span class="inline-flex items-center gap-1 text-[11px] px-2 py-1 rounded-full hover:bg-[#FBF9F5] hover:text-[#1D1C1A] border border-transparent hover:border-[#EFECE6] transition">
                    <i class="ri-braces-line"></i> .json
                  </span>
                </button>
              </div>
            </div>
            <div class="inline-flex p-1 bg-[#FBF9F5] rounded-full border border-[#EFECE6] gap-1 flex-wrap">
              <button type="button"
                      data-note-tabs-target="button"
                      data-action="click->note-tabs#show"
                      data-note-tabs-pane-param="medicaid"
                      class="px-4 py-1.5 rounded-full text-[12px] font-medium transition">
                Medicaid
              </button>
              <button type="button"
                      data-note-tabs-target="button"
                      data-action="click->note-tabs#show"
                      data-note-tabs-pane-param="icd"
                      class="px-4 py-1.5 rounded-full text-[12px] font-medium transition">
                ICD Codes
              </button>
              <button type="button"
                      data-note-tabs-target="button"
                      data-action="click->note-tabs#show"
                      data-note-tabs-pane-param="team"
                      class="px-4 py-1.5 rounded-full text-[12px] font-medium transition">
                Team
              </button>
              <button type="button"
                      data-note-tabs-target="button"
                      data-action="click->note-tabs#show"
                      data-note-tabs-pane-param="json"
                      class="px-4 py-1.5 rounded-full text-[12px] font-medium transition">
                JSON
              </button>
            </div>
          </div>

          <div data-note-tabs-target="pane" data-note-tabs-pane="medicaid" data-narrative-link-target="source" class="hidden">
            <% if linked_eval %>
              <%= render "eval_document", eval_rec: linked_eval, visit: @visit %>
            <% else %>
              <div class="rounded-2xl bg-white border border-dashed border-[#EFECE6] p-6 text-center text-[12px] text-[#6B665F] italic space-y-2">
                <% if @visit.needs_pre_eval? %>
                  <div>
                    Initial visit · pre-eval not generated yet.
                    Finish the recording and the extractor will populate this view.
                  </div>
                <% else %>
                  <div>
                    Medicaid pre-eval is only generated on
                    <strong>Initial (new admission)</strong> visits.
                    This is a <strong><%= @visit.visit_type_label %></strong>
                    visit, so only the <strong>Team</strong> note applies.
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>

          <div data-note-tabs-target="pane" data-note-tabs-pane="icd" data-narrative-link-target="source" class="hidden">
            <%
              dx_section  = linked_eval&.diagnosis_section || {}
              primary_dx  = dx_section["primary_terminal_diagnosis"].is_a?(Hash) ? dx_section["primary_terminal_diagnosis"] : {}
              secondary   = Array(dx_section["secondary_diagnoses"])
              related     = Array(dx_section["related_conditions"])
              unrelated   = Array(dx_section["unrelated_conditions"])
              lcd_section = linked_eval&.medicare_lcd || {}
              lcd_met     = Array(dx_section["lcd_criteria_met"])
              icd_avail   = primary_dx["icd10"].present? || secondary.any? || related.any?
            %>
            <div class="rounded-2xl bg-white border border-[#EFECE6] p-6">
              <div class="text-[10px] uppercase tracking-[0.2em] text-[#1D1C1A] font-bold mb-4 border-b border-[#EFECE6] pb-2 inline-flex items-center gap-1">
                <i class="ri-hospital-line"></i> ICD-10 Coding
              </div>

              <% if icd_avail %>
                <%# Primary terminal Dx ─ the one that drives hospice
                    eligibility. Code, description, friendly definition
                    from the explanation table, plus any sentences in
                    the narrative that support it. %>
                <%
                  primary_code = primary_dx["icd10"].presence
                  primary_desc = primary_dx["description"].presence
                  primary_def  = primary_code ? icd_definition(primary_code, primary_desc) : nil
                  primary_evi  = primary_code ? icd_evidence(primary_code, primary_desc, @visit.narrative) : []
                %>
                <div class="mb-5">
                  <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-1">Primary terminal diagnosis</div>
                  <div class="rounded-xl border border-[#D97757] bg-[#FFF3EC] p-3">
                    <div class="flex items-baseline gap-3 flex-wrap">
                      <span class="font-mono text-[16px] font-bold text-[#1D1C1A]"><%= primary_code || "—" %></span>
                      <span class="text-[13px] text-[#1D1C1A]"><%= primary_desc || "—" %></span>
                    </div>
                    <% if primary_def.present? %>
                      <div class="mt-2 pt-2 border-t border-[#D97757]/30 text-[12px] text-[#1D1C1A] leading-relaxed">
                        <span class="text-[10px] uppercase tracking-widest text-[#D97757] font-bold mr-1">Definition</span>
                        <%= primary_def %>
                      </div>
                    <% end %>
                    <% if primary_evi.any? %>
                      <div class="mt-2 pt-2 border-t border-[#D97757]/30">
                        <div class="text-[10px] uppercase tracking-widest text-[#D97757] font-bold mb-1">
                          <i class="ri-double-quotes-l"></i> Note evidence
                        </div>
                        <% primary_evi.each do |s| %>
                          <div class="text-[12px] italic text-[#3A3936] leading-relaxed border-l-2 border-[#D97757] pl-2 mt-1">
                            <%= s %>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                  <% if lcd_section["lcd_type"].present? %>
                    <div class="text-[11px] text-[#6B665F] mt-1.5">
                      <i class="ri-shield-check-line"></i>
                      LCD: <span class="text-[#1D1C1A] font-medium"><%= lcd_section["lcd_type"] %></span>
                    </div>
                  <% end %>
                </div>

                <%# Secondary diagnoses ─ each row gets its own definition
                    + evidence block so the MD can audit every code. %>
                <% if secondary.any? %>
                  <div class="mb-5">
                    <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-2">Secondary diagnoses</div>
                    <ul class="space-y-3">
                      <% secondary.each do |sd| %>
                        <%
                          sec_code = sd.is_a?(Hash) ? sd["icd10"].presence : sd.to_s.presence
                          sec_desc = sd.is_a?(Hash) ? sd["description"].presence : nil
                          sec_def  = sec_code ? icd_definition(sec_code, sec_desc) : nil
                          sec_evi  = sec_code ? icd_evidence(sec_code, sec_desc, @visit.narrative) : []
                        %>
                        <li class="rounded-xl border border-[#EFECE6] bg-[#FBF9F5] p-3">
                          <div class="flex items-baseline gap-3 flex-wrap">
                            <span class="font-mono text-[13px] font-bold text-[#1D1C1A] min-w-[80px]"><%= sec_code || "—" %></span>
                            <span class="text-[13px] text-[#1D1C1A]"><%= sec_desc || sec_def || "—" %></span>
                          </div>
                          <% if sec_def.present? && sec_def != sec_desc %>
                            <div class="mt-1.5 text-[12px] text-[#3A3936] leading-relaxed">
                              <span class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mr-1">Definition</span>
                              <%= sec_def %>
                            </div>
                          <% end %>
                          <% if sec_evi.any? %>
                            <div class="mt-1.5">
                              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-1">
                                <i class="ri-double-quotes-l"></i> Note evidence
                              </div>
                              <% sec_evi.each do |s| %>
                                <div class="text-[12px] italic text-[#3A3936] leading-relaxed border-l-2 border-[#D9D5CD] pl-2 mt-1">
                                  <%= s %>
                                </div>
                              <% end %>
                            </div>
                          <% end %>
                        </li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>

                <%# Related vs unrelated ─ Medicare needs both buckets;
                    related conditions are covered under the hospice
                    benefit, unrelated billed separately. %>
                <% if related.any? || unrelated.any? %>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
                    <% if related.any? %>
                      <div>
                        <div class="text-[10px] uppercase tracking-widest text-[#2F6F4E] font-bold mb-1">Related conditions</div>
                        <ul class="text-[12px] text-[#1D1C1A] space-y-0.5">
                          <% related.each do |c| %>
                            <li class="flex gap-2"><span class="text-[#2F6F4E]">●</span> <span><%= c %></span></li>
                          <% end %>
                        </ul>
                      </div>
                    <% end %>
                    <% if unrelated.any? %>
                      <div>
                        <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-1">Unrelated conditions</div>
                        <ul class="text-[12px] text-[#1D1C1A] space-y-0.5">
                          <% unrelated.each do |c| %>
                            <li class="flex gap-2"><span class="text-[#6B665F]">○</span> <span><%= c %></span></li>
                          <% end %>
                        </ul>
                      </div>
                    <% end %>
                  </div>
                <% end %>

                <%# LCD criteria the eval claims are met ─ each bullet
                    has to map to clinical evidence in the chart for
                    the MD's certification to hold up. %>
                <% if lcd_met.any? %>
                  <div>
                    <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-1">LCD criteria met</div>
                    <ul class="text-[12px] text-[#1D1C1A] space-y-1">
                      <% lcd_met.each do |c| %>
                        <li class="flex gap-2"><i class="ri-check-line text-[#2F6F4E] mt-0.5"></i><span><%= c %></span></li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>
              <% else %>
                <div class="text-center text-[12px] text-[#6B665F] italic py-6">
                  No ICD codes captured yet. They populate from the
                  pre-admit eval once the extractor has run.
                </div>
              <% end %>
            </div>
          </div>

          <div data-note-tabs-target="pane" data-note-tabs-pane="team" data-narrative-link-target="source" class="hidden">
            <%# AI care-team handoff summary (1-3 lines): status, key findings,
                what's next. Generated on finish; regenerate after editing. %>
            <div class="rounded-2xl bg-[#FBF9F5] border border-[#EFECE6] p-4 mb-4">
              <div class="flex items-center justify-between mb-2 gap-2 flex-wrap">
                <div class="text-[10px] uppercase tracking-[0.2em] text-[#6B665F] font-bold inline-flex items-center gap-1.5">
                  <i class="ri-sparkling-2-line text-[#D97757]"></i> Care-team summary
                </div>
                <%= button_to regenerate_summary_visit_path(@visit),
                      method: :post,
                      class: "inline-flex items-center gap-1 text-[11px] px-2.5 py-1 rounded-full border border-[#EFECE6] text-[#6B665F] hover:text-[#1D1C1A] hover:bg-white transition" do %>
                  <i class="ri-refresh-line"></i> <%= @visit.team_summary.present? ? "Regenerate" : "Generate" %>
                <% end %>
              </div>
              <% if @visit.team_summary.present? %>
                <p class="text-[13px] text-[#1D1C1A] leading-relaxed whitespace-pre-line"><%= @visit.team_summary %></p>
              <% else %>
                <p class="text-[12px] text-[#6B665F] italic">No summary yet, it's generated when you finish the visit, or tap Generate.</p>
              <% end %>
            </div>

            <% if has_team_narrative %>
              <%
                team_locked     = @visit.chart_locked? ? true : false
                team_paragraphs = @visit.narrative.to_s.split(/\n{2,}/).map(&:strip).reject(&:blank?)
              %>
              <div class="rounded-2xl bg-white border border-[#EFECE6] p-6"
                   data-controller="inline-edit"
                   data-inline-edit-url-value="<%= visit_path(@visit) %>"
                   data-inline-edit-field-value="narrative"
                   data-inline-edit-locked-value="<%= team_locked ? 'true' : 'false' %>">
                <div class="flex items-center justify-between mb-3 border-b border-[#EFECE6] pb-2 gap-2 flex-wrap">
                  <div class="text-[10px] uppercase tracking-[0.2em] text-[#1D1C1A] font-bold">
                    Team Narrative (IDT Admission Note)
                  </div>
                  <div class="flex items-center gap-2">
                    <% if team_locked %>
                      <span class="text-[10px] text-[#2F6F4E] italic inline-flex items-center gap-1">
                        <i class="ri-shield-check-line"></i>
                        MD-signed · late-entry note for corrections
                      </span>
                    <% else %>
                      <span class="text-[10px] text-[#6B665F] italic inline-flex items-center gap-1">
                        <i class="ri-cursor-line"></i> Click any sentence to edit
                      </span>
                    <% end %>
                    <span data-inline-edit-target="status" class="text-[10px] min-h-[14px]"></span>
                  </div>
                </div>
                <div class="font-serif text-[14px] text-[#1D1C1A] leading-relaxed">
                  <% team_paragraphs.each do |para| %>
                    <%
                      sentences  = para.split(/(?<=[.!?])\s+/).map(&:strip).reject(&:blank?)
                      span_class = team_locked ? "px-0.5" : "cursor-text hover:bg-[#FFF3EC] hover:rounded px-0.5 transition"
                    %>
                    <p class="mb-3" data-paragraph="true">
                      <% sentences.each_with_index do |s, i| %>
                        <span data-inline-edit-target="sentence"
                              data-action="click->inline-edit#edit"
                              data-original="<%= s %>"
                              title="<%= team_locked ? "MD-signed — late-entry note for corrections" : "Click to edit" %>"
                              class="<%= span_class %>"><%= s %></span><%= " " unless i == sentences.size - 1 %>
                      <% end %>
                    </p>
                  <% end %>
                </div>
              </div>
            <% else %>
              <div class="rounded-2xl bg-white border border-dashed border-[#EFECE6] p-6 text-center text-[12px] text-[#6B665F] italic">
                No team narrative yet. Capture a recording on the
                visit's record page; the polish step will write it here.
              </div>
            <% end %>
          </div>

          <div data-note-tabs-target="pane" data-note-tabs-pane="json" class="hidden">
            <div class="rounded-2xl bg-[#1D1C1A] text-[#EFECE6] p-4 overflow-auto max-h-[60vh]">
              <pre class="font-mono text-[11px] leading-relaxed whitespace-pre"><%= json_payload %></pre>
            </div>
          </div>
        </div>

        <%# Editable form (vitals + metadata + buttons). %>
        <div class="mt-6">
          <%= render "form", just_recorded: just_recorded %>
        </div>

        <%# ── Stage banner (footer position) ─ visit lifecycle
            sits at the bottom so the chart + flags don't get
            pushed below the fold. Same data, just lower in the
            visual hierarchy. %>
        <div class="mt-6 rounded-2xl p-4 flex items-start gap-3"
             style="background-color: <%= stage_bg %>; border: 1px solid <%= stage_border %>;">
          <i class="<%= stage_icon %> text-lg mt-0.5" style="color: <%= stage_fg %>;"></i>
          <div class="flex-1 min-w-0">
            <div class="text-[10px] uppercase tracking-[0.2em] font-bold" style="color: <%= stage_fg %>;">
              Stage · <%= stage_label %>
            </div>
            <div class="text-[12px] text-[#1D1C1A] mt-0.5"><%= stage_sub %></div>
          </div>
        </div>

        <%# ── Signature & audit (collapsible) ─ when the visit
            note is already RN-signed, show a tight summary line
            with a chevron; expanding reveals the full signature
            image + audit fingerprint. Default-closed because once
            it's signed, the confirmation is purely historical. %>
        <% if rn_visit_sig %>
          <details class="mt-3 rounded-2xl border border-[#2F6F4E] bg-[#E6F0EE] group">
            <summary class="cursor-pointer list-none flex items-center justify-between p-4 [&::-webkit-details-marker]:hidden">
              <div class="inline-flex items-center gap-2 min-w-0">
                <i class="ri-shield-check-line text-[#2F6F4E] text-lg flex-shrink-0"></i>
                <div class="min-w-0">
                  <div class="text-[10px] uppercase tracking-widest text-[#2F6F4E] font-bold">Visit note signed</div>
                  <div class="text-[12px] text-[#1D1C1A] truncate">
                    <strong><%= rn_visit_sig.signed_name %></strong> · <%= rn_visit_sig.signed_at.strftime("%b %-d, %Y · %-l:%M %p") %>
                  </div>
                </div>
              </div>
              <i class="ri-arrow-down-s-line text-[#2F6F4E] group-open:rotate-180 transition-transform flex-shrink-0"></i>
            </summary>
            <div class="px-4 pb-4 border-t border-[#2F6F4E]/30">
              <% if rn_visit_sig.signature_blob_id && (blob = ActiveStorage::Blob.find_by(id: rn_visit_sig.signature_blob_id)) %>
                <div class="mt-3 bg-white rounded-lg border border-[#EFECE6] p-3 inline-block">
                  <%= image_tag blob, class: "h-24 max-w-[480px] object-contain" %>
                </div>
              <% end %>
              <div class="text-[11px] text-[#6B665F] mt-2 leading-relaxed">
                <%= rn_visit_sig.short_audit_line %>
              </div>
              <% if rn_visit_sig.document_hash.present? %>
                <div class="mt-2 pt-2 border-t border-[#2F6F4E]/20">
                  <div class="text-[10px] uppercase tracking-widest text-[#6B665F] font-bold mb-0.5 inline-flex items-center gap-1">
                    <i class="ri-fingerprint-line"></i> Security hash (SHA-256)
                  </div>
                  <div class="font-mono text-[10px] text-[#1D1C1A] break-all leading-tight"
                       title="Hash of the signed payload at signing time. Any change to the underlying record after this would produce a different hash.">
                    <%= rn_visit_sig.document_hash %>
                  </div>
                </div>
              <% end %>
            </div>
          </details>
        <% end %>

      </div>

      <%= render "visit_transcript_sidebar", visit: @visit %>

    </div>

  </div>

  <%# ── Fixed audio footer: pinned to the bottom of the viewport
      so the player stays in reach while the RN scrolls through
      the note + transcript. %>
  <div class="fixed bottom-0 left-0 right-0 z-30 px-6 lg:px-8 pb-3 pt-2 bg-gradient-to-t from-[#FBF9F5] via-[#FBF9F5] to-transparent pointer-events-none">
    <div class="pointer-events-auto shadow-[0_-4px_12px_rgba(29,28,26,0.06)] rounded-2xl">
      <%= render "visit_transcript_footer", visit: @visit %>
    </div>
  </div>
</div>
