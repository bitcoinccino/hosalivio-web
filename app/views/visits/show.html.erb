<% content_for :title, "Visit · HosAlivio" %>
<%
  discipline_color = {
    "rn" => "#2F6F4E", "md" => "#2B4A7A", "sw" => "#7A4A8C",
    "chaplain" => "#8C6A2F", "aide" => "#AD7340", "don" => "#8B5A2B"
  }
  d_key = @visit.discipline.to_s == "social_worker" ? "sw" : @visit.discipline.to_s
  color = discipline_color[d_key] || "#6B665F"
  modal_request = request.headers["Turbo-Frame"].to_s == "visit-modal" || params[:modal].present?
  patient = @visit.patient
  clinician = @visit.user
  scheduler = @visit.created_by_user
  scheduler_label =
    if @visit.agent_authored?
      "HosAlivio"
    elsif scheduler&.role_names&.include?("admin")
      "Admin"
    elsif scheduler
      scheduler.full_name
    else
      "Staff"
    end
  status_label =
    if @visit.completed_visit?
      "Completed"
    elsif @visit.currently_in_progress?
      "In progress"
    elsif @visit.stale_in_progress?
      "Needs review"
    else
      "Scheduled"
    end
%>

<% visit_card = capture do %>
  <% unless modal_request %>
    <a href="<%= calendar_path(date: @visit.scheduled_at&.to_date) %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A] mb-4">
      <i class="ri-arrow-left-line"></i> Back to calendar
    </a>
  <% end %>
  <div class="<%= modal_request ? '' : 'rounded-2xl bg-white border border-[#EFECE6] shadow-sm overflow-hidden' %>">
      <div class="h-2" style="background: <%= color %>;"></div>
      <div class="p-5 md:p-6">
        <div class="flex flex-col gap-4">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider text-white"
                      style="background: <%= color %>;">
                  <i class="ri-stethoscope-line"></i>
                  <%= @visit.discipline.to_s.upcase %>
                </span>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-[#FBF9F5] border border-[#EFECE6] text-[10px] font-bold uppercase tracking-wider text-[#3A3936]">
                  <%= @visit.visit_type.to_s.tr("_", " ") %>
                </span>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-[#E6F0EE] border border-[#C8DDD6] text-[10px] font-bold uppercase tracking-wider text-[#2F6F4E]">
                  <%= status_label %>
                </span>
              </div>
              <h1 class="font-serif text-2xl text-[#1D1C1A] leading-tight flex items-center gap-2.5">
                <span class="w-10 h-10 rounded-full border border-[#EFECE6] bg-white overflow-hidden flex-shrink-0 inline-flex items-center justify-center">
                  <% if patient&.has_photo? %>
                    <%= image_tag url_for(patient.photo), class: "w-full h-full object-cover" %>
                  <% else %>
                    <span class="text-[13px] font-bold text-[#6B665F]"><%= "#{patient&.first_name.to_s[0]}#{patient&.last_name.to_s[0]}".upcase.presence || "PT" %></span>
                  <% end %>
                </span>
                <span class="truncate"><%= patient&.full_name || "Patient not set" %></span>
              </h1>
              <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-[12px] text-[#6B665F]">
                <% if patient&.mrn.present? %>
                  <span class="inline-flex items-center gap-1 font-mono">
                    <i class="ri-hashtag"></i> <%= patient.mrn %>
                  </span>
                <% end %>
                <% if clinician %>
                  <span class="inline-flex items-center gap-1">
                    <i class="ri-user-heart-line"></i> <%= clinician.full_name %>
                  </span>
                <% end %>
              </div>
            </div>
            <div class="text-right flex-shrink-0">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Time</div>
              <div class="text-sm font-mono text-[#1D1C1A]"><%= @visit.scheduled_at&.strftime("%a %b %-d") || "—" %></div>
              <div class="text-sm font-mono text-[#1D1C1A]"><%= @visit.scheduled_at&.strftime("%-l:%M %p") || "—" %></div>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
            <div class="rounded-xl border border-[#EFECE6] bg-[#FBF9F5] p-3">
              <div class="text-[9px] uppercase tracking-widest text-[#6B665F]">Assigned to</div>
              <div class="mt-1 text-[13px] text-[#1D1C1A] truncate"><%= clinician&.full_name || "Unassigned" %></div>
            </div>
            <div class="rounded-xl border border-[#EFECE6] bg-[#FBF9F5] p-3">
              <div class="text-[9px] uppercase tracking-widest text-[#6B665F]">Scheduled by</div>
              <div class="mt-1 text-[13px] text-[#1D1C1A]"><%= scheduler_label %></div>
            </div>
            <div class="rounded-xl border border-[#EFECE6] bg-[#FBF9F5] p-3">
              <div class="text-[9px] uppercase tracking-widest text-[#6B665F]">Ends around</div>
              <div class="mt-1 text-[13px] font-mono text-[#1D1C1A]"><%= @visit.ended_at&.strftime("%-l:%M %p") || "Not set" %></div>
            </div>
          </div>
        </div>

        <%
          # Clinical detail (medical snapshot + start) is for the assigned
          # clinician + managers + the reviewing MD only.
          is_assigned   = @visit.user_id == current_user.id
          is_mgr        = (current_user.role_names & %w[admin don admissions ceo]).any?
          can_see_clin  = is_assigned || is_mgr || current_user.role_names.include?("md")
          can_start     = !@visit.completed_visit? && (is_assigned || is_mgr)
        %>

        <%# Start the visit straight from the card. %>
        <% if can_start %>
          <div class="mt-4 flex flex-wrap items-center gap-2">
            <%= link_to record_visit_path(@visit), data: { turbo_frame: "_top" },
                  class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white text-[13px] font-semibold" do %>
              <i class="ri-mic-line"></i> Start visit (record)
            <% end %>
            <%= link_to edit_visit_path(@visit), data: { turbo_frame: "_top" },
                  class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-full border border-[#D9D5CD] text-[#1D1C1A] text-[13px] hover:bg-[#FBF9F5]" do %>
              <i class="ri-folder-chart-line"></i> Open workspace
            <% end %>
          </div>
        <% end %>

        <%# Pre-visit medical snapshot — what the RN needs before walking in. %>
        <% if can_see_clin && patient %>
          <%
            cs        = patient.code_status
            dx        = patient.primary_diagnosis.presence
            allergies = Array(patient.try(:allergies)).reject(&:blank?)
            med_count = patient.medication_orders.where(status: :active).count
          %>
          <div class="mt-4 rounded-2xl border border-[#EFECE6] bg-[#FBF9F5] p-4">
            <div class="text-[11px] uppercase tracking-[0.16em] text-[#6B665F] font-bold mb-2 inline-flex items-center gap-1.5">
              <i class="ri-heart-pulse-line text-[#C1403A]"></i> Medical status
            </div>
            <% if cs.present? || dx || allergies.any? || med_count > 0 %>
              <div class="flex flex-wrap gap-1.5 text-[11px]">
                <% if cs.present? %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full <%= (patient.dnr? || patient.dnr_dni?) ? 'bg-[#C1403A] text-white' : 'bg-white border border-[#EFECE6] text-[#3A3936]' %> font-bold uppercase tracking-wider"><%= cs.to_s.tr("_", "/").upcase %></span>
                <% end %>
                <% if dx %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-[#F0F4FA] border border-[#C8D6E8] text-[#2B4A7A]"><i class="ri-stethoscope-line"></i><%= dx %></span>
                <% end %>
                <% if allergies.any? %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-[#FFF3EC] border border-[#D97757] text-[#C1403A]"><i class="ri-alert-line"></i> Allergies: <%= allergies.join(", ") %></span>
                <% end %>
                <% if med_count > 0 %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-white border border-[#EFECE6] text-[#3A3936]"><i class="ri-capsule-line"></i> <%= med_count %> active med<%= 's' unless med_count == 1 %></span>
                <% end %>
              </div>
            <% else %>
              <div class="text-[12px] text-[#6B665F]">No clinical status on file yet.</div>
            <% end %>
          </div>
        <% end %>

        <% if @visit.started_at || @visit.ended_at %>
          <div class="grid grid-cols-2 gap-3 pb-4 mb-4 border-b border-[#EFECE6] text-[12px]">
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Started</div>
              <div class="font-mono text-[#1D1C1A]"><%= @visit.started_at&.strftime("%-l:%M %p") || "—" %></div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Ended</div>
              <div class="font-mono text-[#1D1C1A]"><%= @visit.ended_at&.strftime("%-l:%M %p") || "—" %></div>
            </div>
          </div>
        <% end %>

        <%
          location_q = {
            "home" => "Q5001", "ipu" => "Q5006", "hospital_gip" => "Q5005",
            "snf" => "Q5004", "alf" => "Q5002", "nursing_facility" => "Q5003",
            "psychiatric_facility" => "Q5008", "group_home" => "Q5009",
            "temporary_lodging" => "Q5009", "other" => "Q5009"
          }
          loc_key = @visit.service_location.to_s
          loc_label = loc_key.tr("_", " ")
        %>
        <div class="my-5 rounded-2xl border border-[#EFECE6] bg-white shadow-sm overflow-hidden">
          <div class="px-4 py-3 border-b border-[#EFECE6] bg-[#FBF9F5] flex items-center justify-between gap-3">
            <div class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.16em] text-[#6B665F] font-bold">
              <i class="ri-map-pin-2-line text-[#D97757]"></i> Contact & location
            </div>
            <div class="text-[9px] text-[#C1403A] uppercase tracking-wider">Private patient info · access recorded</div>
          </div>

          <div class="p-4">
            <div class="inline-flex items-center gap-1.5 mb-3 px-2.5 py-1 rounded-full bg-[#FBF9F5] border border-[#EFECE6] text-[10px] font-mono text-[#3A3936]">
              <i class="ri-home-heart-line text-[#D97757]"></i>
              <%= loc_label.titleize %>
              <span class="text-[#6B665F]">· <%= location_q[loc_key] %></span>
            </div>

            <% if @visit.uses_patient_home_address? %>
              <% if patient&.address_line1.present? %>
                <div class="text-[14px] text-[#1D1C1A] leading-snug">
                  <%= patient.address_line1 %><% if patient.address_line2.present? %>, <%= patient.address_line2 %><% end %><br>
                  <%= [patient.city, patient.state].compact_blank.join(", ") %> <%= patient.zip %>
                </div>
              <% else %>
                <div class="text-[13px] text-[#6B665F]">No home address recorded.</div>
              <% end %>
            <% else %>
              <div class="text-[14px] text-[#1D1C1A] leading-snug">
                <%= @visit.facility_name.presence || "Facility name not recorded" %>
              </div>
              <div class="text-[11px] text-[#6B665F] mt-1">
                Patient home on file: <%= [patient&.city, patient&.state].compact_blank.join(", ").presence || "—" %>
              </div>
            <% end %>

            <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-2">
              <div class="rounded-xl bg-[#FBF9F5] border border-[#EFECE6] p-3">
                <div class="text-[9px] uppercase tracking-widest text-[#6B665F]">Patient phone</div>
                <% if patient&.phone.present? %>
                  <a href="tel:<%= patient.phone %>" class="mt-1 inline-flex items-center gap-1 text-[13px] font-mono text-[#1D1C1A] hover:underline">
                    <i class="ri-phone-line text-[#D97757]"></i> <%= patient.phone %>
                  </a>
                <% else %>
                  <div class="mt-1 text-[13px] text-[#6B665F]">Not recorded</div>
                <% end %>
              </div>
              <div class="rounded-xl bg-[#FBF9F5] border border-[#EFECE6] p-3">
                <div class="text-[9px] uppercase tracking-widest text-[#6B665F]">Caregiver</div>
                <% if patient&.caregiver_name.present? %>
                  <% cg_user = patient.family_users.detect(&:has_avatar?) %>
                  <div class="mt-1 flex items-center gap-2">
                    <span class="w-8 h-8 rounded-full border border-[#EFECE6] bg-white overflow-hidden flex-shrink-0 inline-flex items-center justify-center">
                      <% if cg_user&.has_avatar? %>
                        <%= image_tag url_for(cg_user.avatar), class: "w-full h-full object-cover" %>
                      <% else %>
                        <span class="text-[11px] font-bold text-[#6B665F]"><%= patient.caregiver_name.to_s.split.map { |w| w[0] }.first(2).join.upcase.presence || "CG" %></span>
                      <% end %>
                    </span>
                    <div class="min-w-0">
                      <div class="text-[13px] text-[#1D1C1A] truncate"><%= patient.caregiver_name %></div>
                      <% if patient.caregiver_relationship.present? %>
                        <div class="text-[10px] uppercase tracking-wider text-[#6B665F]"><%= patient.caregiver_relationship %></div>
                      <% end %>
                    </div>
                  </div>
                  <% if patient.caregiver_phone.present? %>
                    <a href="tel:<%= patient.caregiver_phone %>" class="mt-1 inline-block text-[12px] font-mono text-[#6B665F] hover:underline"><%= patient.caregiver_phone %></a>
                  <% end %>
                <% else %>
                  <div class="mt-1 text-[13px] text-[#6B665F]">Not recorded</div>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <% if !modal_request && @visit.narrative.present? %>
          <%
            placeholder_narrative = @visit.narrative.to_s.start_with?("Narrative pending")
          %>
          <div class="mb-4">
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-1 flex items-center gap-2">
              <span>Narrative</span>
              <% if placeholder_narrative %>
                <span class="text-[9px] uppercase tracking-[0.18em] font-bold text-[#D97757] bg-[#FFF3EC] border border-[#D97757] rounded-full px-2 py-0.5">
                  <i class="ri-mic-line"></i> Awaiting RN
                </span>
              <% end %>
            </div>
            <% if placeholder_narrative %>
              <%# Muted, italic — the placeholder is a prompt, not a note. %>
              <p class="text-[13px] text-[#6B665F] italic leading-relaxed whitespace-pre-wrap"><%= @visit.narrative %></p>
              <% if @visit.user_id == current_user.id || (current_user.role_names & %w[admin don admissions]).any? %>
                <%= link_to edit_visit_path(@visit, focus: "narrative"),
                      class: "mt-2 inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white transition" do %>
                  <i class="ri-mic-line"></i> Clear &amp; dictate
                <% end %>
              <% end %>
            <% else %>
              <p class="text-[13px] text-[#3A3936] leading-relaxed whitespace-pre-wrap"><%= @visit.narrative %></p>
            <% end %>
          </div>
        <% end %>

        <% unless modal_request %>
          <% conversation_turns = visit_transcript_turns(@visit) %>
          <% if conversation_turns.any? %>
            <%= render "visits/visit_conversation", turns: conversation_turns %>
          <% end %>
        <% end %>

        <% if !modal_request && @visit.audio_note.attached? %>
          <div class="mb-4">
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-1 flex items-center gap-1">
              <i class="ri-mic-line"></i> Bedside audio
            </div>
            <%= render "visits/audio_player", src: url_for(@visit.audio_note), audio_class: "flex-1 min-w-[220px] h-9" %>
          </div>
        <% end %>

        <% if !modal_request && (@visit.pain_score.present? || @visit.vitals.present?) %>
          <div class="grid grid-cols-5 gap-2 pb-4 mb-4 border-b border-[#EFECE6] text-center">
            <% [["Pain", @visit.pain_score ? "#{@visit.pain_score}/10" : nil],
                ["Temp", @visit.vitals["temp"]], ["BP", @visit.vitals["bp"]],
                ["HR", @visit.vitals["pulse"]], ["SpO2", @visit.vitals["o2"]]].each do |label, val| %>
              <div>
                <div class="text-[9px] uppercase tracking-widest text-[#6B665F]"><%= label %></div>
                <div class="text-sm font-mono text-[#1D1C1A]"><%= val || "—" %></div>
              </div>
            <% end %>
          </div>
        <% end %>

        <div class="pt-1 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <%= link_to patient_path(patient),
                data: { turbo_frame: "_top" },
                class: "inline-flex items-center justify-center gap-1.5 px-4 py-2 rounded-full bg-[#D97757] hover:bg-[#c46a4b] text-white text-[13px] font-medium" do %>
            <i class="ri-folder-chart-line"></i> Chart
          <% end %>
          <div class="flex flex-wrap items-center gap-2">
            <% if @visit.completed_visit? %>
              <%= link_to edit_visit_path(@visit),
                    data: { turbo_frame: "_top" },
                    class: "inline-flex items-center gap-1 text-[12px] px-3 py-1.5 rounded-full border border-[#D9D5CD] text-[#1D1C1A] hover:bg-[#FBF9F5]",
                    title: "Completed visits are locked except vitals corrections and late-entry workflows." do %>
                <i class="ri-lock-2-line"></i> Corrections
              <% end %>
            <% elsif (current_user.role_names & %w[admin don admissions ceo]).any? %>
              <%# Reschedule + remove are scheduling actions — admin/admissions
                  only. The assigned RN records the visit (start_now) and
                  discards their own draft from the recording workspace. %>
              <%= link_to edit_visit_path(@visit),
                    data: { turbo_frame: "_top" },
                    class: "inline-flex items-center gap-1 text-[12px] px-3 py-1.5 rounded-full border border-[#D9D5CD] text-[#1D1C1A] hover:bg-[#FBF9F5]" do %>
                <i class="ri-edit-2-line"></i> Edit / reschedule
              <% end %>
              <%= button_to visit_path(@visit), method: :delete,
                    data: { turbo_confirm: "Remove this scheduled visit? It will no longer appear on the calendar." },
                    form: { data: { turbo_frame: "_top" } },
                    class: "inline-flex items-center gap-1 text-[12px] px-3 py-1.5 rounded-full bg-[#C1403A] text-white hover:bg-[#a5342f]" do %>
                <i class="ri-delete-bin-line"></i> Remove
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
  </div>
<% end %>

<% if modal_request %>
  <%= turbo_frame_tag "visit-modal" do %>
    <div class="fixed inset-0 z-50 bg-[#1D1C1A]/45 backdrop-blur-sm flex items-start justify-center overflow-y-auto px-4 py-6 md:py-10"
         data-controller="modal"
         data-action="click->modal#closeFromBackdrop">
      <div class="w-full max-w-xl rounded-2xl bg-white border border-[#EFECE6] shadow-2xl overflow-hidden">
        <div class="flex items-center justify-between px-5 py-3 border-b border-[#EFECE6] bg-[#FBF9F5]">
          <div class="text-[11px] uppercase tracking-[0.2em] text-[#6B665F] font-bold">Visit details</div>
          <button type="button"
                  data-action="click->modal#close"
                  class="w-8 h-8 rounded-full inline-flex items-center justify-center text-[#6B665F] hover:text-[#1D1C1A] hover:bg-white"
                  aria-label="Close visit details modal">
            <i class="ri-close-line text-lg"></i>
          </button>
        </div>
        <%= visit_card %>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="min-h-screen bg-[#FBF9F5] py-10 px-4">
    <div class="max-w-xl mx-auto">
      <%= visit_card %>
    </div>
  </div>
<% end %>
