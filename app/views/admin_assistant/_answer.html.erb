<%# HosAlivio's answer body (no avatar — the bubble supplies it). Three states:
      @items  → a deterministic oversight report (title + lead + list)
      @answer → a free-form, agency-grounded reply
      else    → the command nudge %>
<% if @items %>
  <%# Single natural lead (topic folded in) — no separate title label. %>
  <p class="text-[13px] text-[#1D1C1A] <%= 'mb-2' if @items.any? %>"><%= @lead %></p>
  <% if @items.any? %>
    <ul class="space-y-1.5">
      <% @items.each do |it| %>
        <li class="text-[13px] flex items-start gap-2 <%= it.urgent ? "text-[#C1403A] font-medium" : "text-[#1D1C1A]" %>">
          <i class="<%= it.urgent ? "ri-alarm-warning-fill text-[#C1403A]" : "ri-checkbox-blank-circle-fill text-[6px] text-[#B9B3A9] mt-1.5" %>"></i>
          <span class="flex-1"><%= it.text %></span>
          <% if it.patient_id %>
            <%= link_to "Open", patient_path(it.patient_id), class: "text-[11px] text-[#2B4A7A] hover:underline whitespace-nowrap flex-shrink-0" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
<% elsif @answer.present? %>
  <div class="text-[13px] text-[#1D1C1A] whitespace-pre-wrap leading-snug"><%= @answer %></div>
<% else %>
  <p class="text-[13px] text-[#6B665F]">I don't have that one as a ready report yet — try one of these:</p>
<% end %>

<%# Tappable follow-up prompts — keep the conversation going with one tap.
    Each re-enters #ask via the same optimistic path as the composer's
    quick-asks (button_to → POST /assistant/ask → turbo-stream append). %>
<% if @followups.present? %>
  <div class="mt-3 flex flex-wrap gap-1.5">
    <% @followups.each do |q| %>
      <%= button_to admin_assistant_ask_path, params: { q: q }, method: :post,
            form: { class: "contents" },
            class: "inline-flex items-center gap-1 text-[12px] px-2.5 py-1 rounded-full border border-[#EFECE6] bg-white text-[#6B665F] hover:text-[#D97757] hover:border-[#D97757] transition" do %>
        <i class="ri-corner-down-right-line text-[13px]"></i>
        <%= q.humanize %>
      <% end %>
    <% end %>
  </div>
<% end %>
