<%# The question bubble + a typing indicator are added optimistically client-
    side on submit. Here we drop the typing indicator and append HosAlivio's
    answer bubble. %>
<%= turbo_stream.remove "assistant-typing" %>
<%= turbo_stream.append "assistant-thread" do %>
  <div class="flex items-start gap-2">
    <span class="w-8 h-8 rounded-full bg-[#D97757] text-white flex items-center justify-center flex-shrink-0"><i class="ri-heart-pulse-line text-sm"></i></span>
    <div class="max-w-[85%] rounded-2xl rounded-bl-sm border bg-[#FBF9F5] border-[#EFECE6] text-[#1D1C1A] px-4 py-2.5 shadow-sm"><%= render "answer" %></div>
  </div>
<% end %>
