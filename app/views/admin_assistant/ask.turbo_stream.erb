<%# The question bubble + a typing indicator are added optimistically client-
    side on submit. Here we drop the typing indicator and append HosAlivio's
    answer bubble. %>
<%= turbo_stream.remove "assistant-typing" %>
<%= turbo_stream.append "assistant-thread" do %>
  <div class="flex items-start gap-2">
    <span class="w-7 h-7 rounded-full bg-[#FFF3EC] text-[#D97757] flex items-center justify-center flex-shrink-0"><i class="ri-sparkling-2-line text-[14px]"></i></span>
    <div class="max-w-[85%] rounded-2xl rounded-tl-sm bg-[#FFF3EC] px-3.5 py-2.5"><%= render "answer" %></div>
  </div>
<% end %>
