<%= turbo_frame_tag "assistant-answer" do %>
  <div class="mt-3 rounded-xl border border-[#EFECE6] bg-[#FBF9F5] p-3">
    <% if @known %>
      <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-2"><%= @title %></div>
      <% if @items.empty? %>
        <p class="text-[13px] text-[#2F6F4E]">Nothing to show — you're all caught up.</p>
      <% else %>
        <ul class="space-y-1.5">
          <% @items.each do |it| %>
            <li class="text-[13px] flex items-start gap-2 <%= it.urgent ? "text-[#C1403A] font-medium" : "text-[#1D1C1A]" %>">
              <i class="<%= it.urgent ? "ri-alarm-warning-fill text-[#C1403A]" : "ri-checkbox-blank-circle-fill text-[6px] text-[#B9B3A9] mt-1.5" %>"></i>
              <span class="flex-1"><%= it.text %></span>
              <% if it.patient_id %>
                <%= link_to "Open", patient_path(it.patient_id), class: "text-[11px] text-[#2B4A7A] hover:underline whitespace-nowrap flex-shrink-0" %>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
    <% else %>
      <p class="text-[13px] text-[#6B665F]">I didn't catch that. Try: <strong>today's priorities</strong>, <strong>patients needing attention</strong>, <strong>compliance status</strong>, <strong>new referrals</strong>, or <strong>daily report</strong>.</p>
    <% end %>
  </div>
<% end %>
