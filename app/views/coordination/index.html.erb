<% content_for :title, "Coordination queue" %>

<div class="max-w-6xl mx-auto px-4 md:px-8 py-6">
  <div class="flex items-start justify-between gap-3 mb-6 flex-wrap">
    <div>
      <div class="text-[11px] uppercase tracking-[0.2em] text-[#6B665F] font-bold">Admissions</div>
      <h1 class="font-serif text-[24px] text-[#1D1C1A]">Coordination queue</h1>
      <div class="text-[12px] text-[#6B665F]"><%= @agency&.name %> · inbound leads and new registrations, side by side</div>
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      <% if @noe_overdue.positive? %>
        <%= link_to admissions_queue_path,
              class: "inline-flex items-center gap-1.5 text-[11px] px-3 py-1.5 rounded-full bg-[#C1403A] text-white font-bold uppercase tracking-widest" do %>
          <i class="ri-alarm-warning-fill"></i> <%= @noe_overdue %> NOE overdue
        <% end %>
      <% end %>
      <%= link_to admissions_queue_path,
            class: "text-[11px] px-3 py-1.5 rounded-full border border-[#2B4A7A] text-[#2B4A7A] hover:bg-[#F0F4FA] inline-flex items-center gap-1.5 font-medium" do %>
        <i class="ri-folder-history-line"></i> Admissions queue
      <% end %>
      <%= link_to new_patient_path,
            class: "text-[11px] px-3 py-1.5 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white inline-flex items-center gap-1.5 font-medium" do %>
        <i class="ri-user-add-line"></i> Register patient
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 items-start">

    <%# ── Inbound leads ─────────────────────────────────────── %>
    <section class="rounded-2xl border border-[#EFECE6] bg-white overflow-hidden">
      <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between">
        <h2 class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold"><i class="ri-inbox-line text-[#D97757]"></i> Inbound leads (<%= @leads.size %>)</h2>
        <span class="text-[10px] text-[#6B665F]">waiting to convert</span>
      </div>
      <% if @leads.empty? %>
        <p class="px-5 py-8 text-center text-[13px] text-[#6B665F]">No open leads. The pipeline is clear.</p>
      <% else %>
        <% lead_pill = { "new_lead" => [ "#FFF3EC", "#C1403A", "New" ], "claimed" => [ "#F0F4FA", "#2B4A7A", "Claimed" ], "contacted" => [ "#E6F0EE", "#2F6F4E", "Contacted" ] } %>
        <ul class="divide-y divide-[#EFECE6]">
          <% @leads.each do |lead| %>
            <% bg, fg, lbl = lead_pill[lead.status.to_s] || [ "#EFECE6", "#6B665F", lead.status.to_s ] %>
            <li>
              <%= link_to convert_inquiry_path(lead), class: "block px-5 py-3 hover:bg-[#FBF9F5] transition" do %>
                <div class="flex items-center justify-between gap-2">
                  <div class="text-[13px] font-medium text-[#1D1C1A] truncate"><%= lead.display_label %></div>
                  <span class="text-[9px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full whitespace-nowrap" style="background: <%= bg %>; color: <%= fg %>;"><%= lbl %></span>
                </div>
                <% if lead.preferred_window_label %>
                  <div class="text-[11px] text-[#D97757] font-medium mt-0.5">
                    <i class="ri-calendar-event-line"></i> Prefers a call <%= lead.preferred_window_label %>
                  </div>
                <% end %>
                <div class="text-[11px] text-[#6B665F] mt-0.5 truncate">
                  <%= lead.source_prompt.to_s.tr("_", " ") %><%
                    %><%= " · #{lead.requester_role}" if lead.requester_role.present? %><%
                    %><%= " · via #{lead.referring_provider}" if lead.referring_provider.present? %>
                  · <%= time_ago_in_words(lead.created_at) %> ago
                  <% if lead.claimed_by %> · <span class="text-[#2B4A7A]">claimed by <%= lead.claimed_by.full_name.to_s.split.first %></span><% end %>
                </div>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </section>

    <%# ── New registrations ─────────────────────────────────── %>
    <section class="rounded-2xl border border-[#EFECE6] bg-white overflow-hidden">
      <div class="px-5 py-3 border-b border-[#EFECE6] flex items-center justify-between">
        <h2 class="text-[11px] uppercase tracking-widest text-[#1D1C1A] font-bold"><i class="ri-user-received-line text-[#2F6F4E]"></i> New registrations (<%= @new_patients.size %>)</h2>
        <span class="text-[10px] text-[#6B665F]">verify + schedule</span>
      </div>
      <% if @new_patients.empty? %>
        <p class="px-5 py-8 text-center text-[13px] text-[#6B665F]">No patients awaiting admission setup.</p>
      <% else %>
        <% pay_color = { "active" => "#2F6F4E", "pending" => "#D97757", "none" => "#6B665F" } %>
        <ul class="divide-y divide-[#EFECE6]">
          <% @new_patients.each do |p| %>
            <li class="px-5 py-3">
              <div class="flex items-center justify-between gap-2">
                <%= link_to p.full_name, patient_path(p), class: "text-[13px] font-medium text-[#1D1C1A] truncate hover:underline" %>
                <span class="text-[10px] text-[#6B665F] font-mono whitespace-nowrap"><%= p.mrn %></span>
              </div>
              <div class="text-[11px] text-[#6B665F] mt-0.5 truncate">
                registered <%= time_ago_in_words(p.created_at) %> ago
                · <%= p.assigned_rn ? "RN #{p.assigned_rn.full_name.to_s.split.first}" : "no RN yet" %>
              </div>
              <%# Insurance verification chips (from the intake blob) %>
              <div class="flex items-center gap-1.5 mt-1.5 flex-wrap">
                <% [ [ "medicare", "Medicare" ], [ "medicaid", "Medicaid" ], [ "commercial", "Commercial" ] ].each do |key, lbl| %>
                  <% st = p.intake["insurance_#{key}_status"].to_s.presence || "unverified" %>
                  <% col = pay_color[st] || "#C1403A" %>
                  <span class="text-[10px] px-2 py-0.5 rounded-full border" style="color: <%= col %>; border-color: <%= col %>44;"><%= lbl %>: <%= st %></span>
                <% end %>
              </div>
              <div class="flex items-center gap-3 mt-2 text-[11px] font-medium">
                <%= link_to "Verify insurance", edit_patient_path(p), class: "text-[#2B4A7A] hover:underline" %>
                <%= link_to "Schedule visit", new_visit_path(patient_id: p.id), class: "text-[#2F6F4E] hover:underline" %>
                <%= link_to "Open chart", patient_path(p), class: "text-[#6B665F] hover:underline" %>
              </div>
            </li>
          <% end %>
        </ul>
      <% end %>
    </section>
  </div>
</div>
