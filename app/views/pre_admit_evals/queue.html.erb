<% content_for :title, "Admissions queue" %>

<div class="max-w-4xl mx-auto px-4 md:px-8 py-6" data-controller="admissions-filter">
  <%# Back to the Mission Stage (this page has no persistent sidebar). %>
  <%= link_to dashboard_path,
        class: "inline-flex items-center gap-1.5 text-[12px] text-[#6B665F] hover:text-[#D97757] font-medium transition mb-4" do %>
    <i class="ri-arrow-left-line"></i> Mission Stage
  <% end %>

  <div class="mb-5 text-center">
    <div class="text-[11px] uppercase tracking-[0.2em] text-[#6B665F] font-bold">Admissions</div>
    <h1 class="font-serif text-[24px] text-[#1D1C1A]">Admissions queue</h1>
    <div class="text-[12px] text-[#6B665F]">
      <%= @agency&.name.presence || "Your agency" %> · in-flight admission evals across all patients
    </div>
  </div>

  <%# Instant search + status filter (client-side; no reload). %>
  <div class="mb-5 space-y-3">
    <div class="relative">
      <i class="ri-search-line absolute left-3.5 top-1/2 -translate-y-1/2 text-[#6B665F]"></i>
      <input type="search" placeholder="Search patient or diagnosis…"
             data-admissions-filter-target="query"
             data-action="input->admissions-filter#filter"
             class="w-full pl-10 pr-3 py-2.5 rounded-full border border-[#EFECE6] bg-white text-[14px] placeholder-[#6B665F] focus:outline-none focus:border-[#D97757] transition">
    </div>
    <div class="flex flex-wrap items-center justify-center gap-1.5">
      <% [
           [ "All",          "draft,final,certified" ],
           [ "Draft",        "draft" ],
           [ "Awaiting MD",  "final" ],
           [ "Awaiting NOE", "certified" ],
           [ "Admitted",     "admitted" ],
           [ "Cancelled",    "cancelled" ]
         ].each_with_index do |(clabel, groups), i| %>
        <button type="button"
                data-admissions-filter-target="chip"
                data-action="admissions-filter#status"
                data-groups="<%= groups %>"
                data-on="<%= i.zero? %>"
                class="text-[12px] px-3 py-1 rounded-full border border-[#EFECE6] text-[#6B665F] hover:bg-[#FBF9F5] transition data-[on=true]:bg-[#D97757] data-[on=true]:text-white data-[on=true]:border-[#D97757]">
          <%= clabel %>
        </button>
      <% end %>
    </div>
  </div>

  <%# No in-flight work (drafts / awaiting MD / awaiting NOE) — the resting
      "all caught up" state. Terminal Admitted/Cancelled evals may still exist
      under their chips. %>
  <% if (@drafts + @awaiting_md + @awaiting_noe).empty? %>
    <div class="rounded-2xl border border-[#EFECE6] bg-white p-8 text-center text-[13px] text-[#6B665F]">
      <i class="ri-checkbox-circle-line text-[#2F6F4E]"></i> No in-flight admissions — all caught up.
    </div>
  <% end %>

  <%# Shown by the controller when nothing matches the search/filter. %>
  <div data-admissions-filter-target="empty"
       class="hidden rounded-2xl border border-[#EFECE6] bg-white p-8 text-center text-[13px] text-[#6B665F]">
    <i class="ri-search-line text-[#6B665F]"></i> No admissions match your search.
  </div>

  <% [
       [ "Draft · RN capturing",      @drafts,       "#6B665F" ],
       [ "Awaiting MD certification", @awaiting_md,  "#2B4A7A" ],
       [ "Awaiting NOE filing",       @awaiting_noe, "#2F6F4E" ],
       [ "Admitted · on the benefit", @admitted,     "#2F6F4E" ],
       [ "Cancelled · revoked",       @cancelled,    "#C1403A" ]
     ].each do |label, evals, accent| %>
    <% next if evals.empty? %>
    <section class="mb-6" data-admissions-filter-target="section">
      <h2 class="text-[11px] uppercase tracking-widest font-bold mb-2" style="color: <%= accent %>;">
        <%= label %> (<%= evals.size %>)
      </h2>
      <ul class="space-y-2">
        <%= render partial: "eval_row", collection: evals, as: :record, locals: { show_patient: true } %>
      </ul>
    </section>
  <% end %>
</div>
