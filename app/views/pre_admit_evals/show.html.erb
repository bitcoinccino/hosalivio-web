<% content_for :title, "Pre-admit eval · #{@eval.patient.full_name}" %>
<%
  pae   = @eval.raw_json["pre_admit_eval"] || {}
  hd    = @eval.header
  gc    = @eval.general_comments
  dx    = @eval.diagnosis_section
  meds  = @eval.current_medications
  disc  = @eval.discontinued_meds
  sx    = @eval.other_symptoms
  cog   = @eval.cognitive_decline
  nut   = @eval.nutritional_decline
  fd    = @eval.functional_decline
  gen   = @eval.general

  pps   = fd["pps"]
  pps_h = pps.is_a?(Hash) ? pps : { "score" => pps.to_i, "source" => "clinician", "justification" => "" }

  card  = "rounded-2xl bg-white border border-[#EFECE6] p-5"
  h2    = "text-[11px] uppercase tracking-widest text-[#6B665F] font-bold mb-3 flex items-center gap-2"
  yes_ = ->(v) { v ? %Q(<span class="text-[#2F6F4E] font-medium">✓ yes</span>) : %Q(<span class="text-[#C1403A] font-medium">— no</span>) }
%>
<%
  agency      = @eval.agency
  visit       = @eval.visit
  scheduler   = visit&.created_by_user || (visit&.agent_authored ? nil : visit&.user)
  scheduler_role = scheduler ? (scheduler.role_names & %w[admin don admissions rn md sw social_worker chaplain aide]).first : nil
  evaluator   = @eval.evaluator || visit&.user
  evaluator_role = evaluator ? (evaluator.role_names & %w[rn md sw social_worker chaplain aide don admissions]).first : nil

  # Branch resolution for the print address. Order:
  #   1. The patient's assigned branch (most specific)
  #   2. The evaluating clinician's home branch
  #   3. The agency's first / main office branch
  # When everything's null we fall back to the agency's mailing address.
  branch =
    @eval.patient&.branch ||
    evaluator&.branch ||
    agency&.branches&.order(:created_at)&.first

  branch_label =
    if branch
      branch.name.to_s.match?(/main|head|corporate/i) ? "Main Office" : "#{branch.name} Branch"
    else
      "Main Office"
    end

  # Postal layout: street lines stack, then city/state/zip on its own
  # line, matching how addresses are read aloud and printed on
  # envelopes. Empty parts drop out cleanly.
  source = branch || agency
  if source
    address_lines = [source.address_line1, source.address_line2].compact_blank
    csz_line      = [source.city.presence, [source.state.presence, source.zip.presence].compact_blank.join(" ").presence].compact_blank.join(", ")
    address_lines << csz_line if csz_line.present?
  else
    address_lines = []
  end

  address_phone =
    branch&.phone.presence || agency&.phone
%>
<%# Print stylesheet for the pre-admit eval show page. Browser's
    native Print → Save as PDF turns this into a clean clinical
    document. Hides screen chrome, drops backgrounds, forces page
    breaks between major sections, reveals the print-only banner
    and signature footer. Inline so it's scoped to this view. %>
<style>
  @media print {
    @page { margin: 0.6in; size: letter; }
    body { background: white !important; color: black !important; }
    .no-print, .no-print * { display: none !important; }
    .print-only { display: block !important; }
    .print-only-flex { display: flex !important; }
    .print-page-break { break-before: page; page-break-before: always; }

    /* Drop the cream background + page padding */
    .pae-show-root { background: white !important; padding: 0 !important; min-height: 0 !important; }
    .pae-show-card { background: white !important; }

    /* Avoid awkward splits inside cards and list items */
    section { break-inside: avoid; page-break-inside: avoid; }
    li      { break-inside: avoid; }

    /* Force black text + neutral borders for crisp printing */
    .pae-show-root, .pae-show-root * {
      color: black !important;
      border-color: #999 !important;
    }
    .pae-show-root [style*="background"] {
      background: white !important;
    }

    a, a:visited { text-decoration: none !important; color: black !important; }
    img { max-width: 100% !important; }
  }
  .print-only      { display: none; }
  .print-only-flex { display: none; }
</style>

<div class="min-h-screen bg-[#FBF9F5] py-8 px-4 md:px-10 pae-show-root">
  <div class="max-w-3xl mx-auto pae-show-card">
    <div class="flex items-center justify-between mb-4 no-print">
      <a href="<%= patient_path(@eval.patient) %>" class="inline-flex items-center gap-1 text-[12px] text-[#6B665F] hover:text-[#1D1C1A]">
        <i class="ri-arrow-left-line"></i> Back to <%= @eval.patient.full_name %>
      </a>
      <button type="button" onclick="window.print()"
              class="inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 rounded-full bg-white border border-[#D9D5CD] text-[#1D1C1A] hover:bg-[#F0F4FA] hover:border-[#2B4A7A] transition">
        <i class="ri-printer-line text-[#2B4A7A]"></i>
        Print / Download PDF
      </button>
    </div>

    <%# Print-only document header. Browsers show this only inside
        the print preview / saved PDF, never on screen. Gives the
        printed sheet an official-looking title strip + patient banner
        so it can stand alone in a paper chart. %>
    <div class="print-only mb-6" style="border-bottom: 2px solid #1D1C1A; padding-bottom: 12px;">
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 16px;">
        <div style="display: flex; align-items: center; gap: 12px;">
          <% if agency&.logo&.attached? %>
            <%= image_tag agency.logo, style: "width: 56px; height: 56px; object-fit: contain;" %>
          <% end %>
          <div>
            <div style="font-size: 18px; font-weight: 700;"><%= agency&.dba_name.presence || agency&.name %></div>
            <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: #444; margin-top: 2px;"><%= branch_label %></div>
            <% address_lines.each do |line| %>
              <div style="font-size: 11px; color: #444; line-height: 1.4;"><%= line %></div>
            <% end %>
            <% if address_phone.present? %>
              <div style="font-size: 11px; color: #444; margin-top: 2px;"><%= address_phone %></div>
            <% end %>
          </div>
        </div>
        <div style="text-align: right;">
          <div style="font-size: 22px; font-weight: 700;">Pre-Admit Evaluation</div>
          <div style="font-size: 11px; color: #444; text-transform: uppercase; letter-spacing: 0.1em;">Final Review · <%= @eval.status.to_s.tr("_", " ") %></div>
          <% if (gen_print = @eval.general)["election_of_benefits_signed_attested_at"].present? %>
            <div style="font-size: 10px; color: #444;">Generated <%= Time.current.strftime("%b %-d, %Y · %-l:%M %p") %></div>
          <% end %>
        </div>
      </div>
    </div>

    <%# === Header strip ============================================
        Includes the agency logo (when uploaded on the agency profile)
        + a clear scheduled-by / performed-by line, so the printed
        version is self-identifying without needing the page chrome. %>
    <div class="flex items-start gap-4 mb-6">
      <div class="w-16 h-16 rounded-xl border border-[#EFECE6] bg-white flex items-center justify-center overflow-hidden flex-shrink-0">
        <% if agency&.logo&.attached? %>
          <%= image_tag agency.logo, class: "max-w-full max-h-full object-contain" %>
        <% else %>
          <span class="text-[28px] leading-none"><%= agency&.emoji || "🩺" %></span>
        <% end %>
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex items-start justify-between gap-3 flex-wrap">
          <div class="min-w-0">
            <div class="text-[11px] uppercase tracking-widest text-[#6B665F] font-bold"><%= agency&.dba_name.presence || agency&.name %> · Pre-admit eval</div>
            <h1 class="font-serif text-[28px] text-[#1D1C1A] leading-tight"><%= hd["patient_name"].presence || @eval.patient.full_name %></h1>
            <div class="text-[12px] text-[#6B665F] mt-1 font-mono space-x-2">
              <% if hd["mrn"].present? || @eval.patient.mrn.present? %><span>MRN <%= hd["mrn"].presence || @eval.patient.mrn %></span><% end %>
              <% if hd["dob"].present? || @eval.patient.dob.present? %><span>· DOB <%= hd["dob"].presence || @eval.patient.dob&.iso8601 %></span><% end %>
              <% if visit&.visit_type.present? %><span>· <%= visit.visit_type.to_s.tr("_", " ").titleize %> visit</span><% end %>
              <% if hd["start_of_care_date"].present? %><span>· SOC <%= hd["start_of_care_date"] %></span><% end %>
            </div>
            <div class="text-[12px] text-[#6B665F] mt-1">
              <% if visit&.agent_authored %>
                🤖 Scheduled by HosAlivio (AI Admin)
              <% elsif scheduler %>
                Scheduled by <%= scheduler_role&.tr("_", " ")&.titleize&.then { |r| "#{r} " } %><span class="text-[#1D1C1A] font-medium">@<%= scheduler.full_name.split.first %></span>
              <% end %>
              <% if evaluator %>
                · Performed by <%= evaluator.full_name %><%= " (#{evaluator_role.upcase})" if evaluator_role.present? %>
              <% end %>
              <% if (date_of_visit = hd["date_of_visit"].presence || @eval.evaluated_at&.strftime("%b %-d, %Y")) %>
                · <%= date_of_visit %>
              <% end %>
            </div>
          </div>
          <%
            pill_bg = { "draft" => "#EFECE6", "final" => "#2B4A7A", "certified" => "#2F6F4E", "noe_filed" => "#2F6F4E", "revoked" => "#C1403A" }[@eval.status.to_s] || "#6B665F"
            pill_fg = %w[draft].include?(@eval.status.to_s) ? "#1D1C1A" : "white"
          %>
          <span class="inline-block text-[11px] font-bold px-3 py-1 rounded-full uppercase tracking-wider flex-shrink-0"
                style="background: <%= pill_bg %>; color: <%= pill_fg %>;">
            <%= @eval.status.to_s.tr("_", " ") %>
            <% if @eval.status_draft? && @eval.certification_blockers.any? %>
              <span class="ml-1 text-[#C1403A]">· needs MD cert</span>
            <% end %>
          </span>
        </div>
      </div>
    </div>

    <%# === Cert gate ==============================================
        Each blocker shows the underlying reason + a one-tap action
        when one is available (the two boolean attestations resolve in
        place via #quick_set; the diagnosis / LCD blockers still need
        the edit form because they require typed values). %>
    <% blockers = @eval.certification_blockers %>
    <% if blockers.any? %>
      <div class="mb-5 rounded-2xl border border-[#D97757] bg-[#FFF3EC] p-4">
        <div class="flex items-center justify-between gap-2 mb-2">
          <div class="text-[11px] uppercase tracking-widest text-[#C1403A] font-bold">Certification blockers</div>
          <span class="text-[10px] uppercase tracking-widest text-[#C1403A] font-bold bg-white border border-[#D97757] rounded-full px-2 py-0.5"><%= blockers.size %> <%= "issue".pluralize(blockers.size) %></span>
        </div>
        <ul class="space-y-2">
          <% blockers.each do |b| %>
            <li class="flex items-center justify-between gap-3 text-[13px] text-[#1D1C1A]">
              <span class="flex items-center gap-2 min-w-0">
                <i class="ri-alert-line text-[#C1403A] flex-shrink-0"></i>
                <span><%= b %></span>
              </span>
              <% case b
                 when "Election of benefits not signed" %>
                <%= button_to quick_set_pre_admit_eval_path(@eval, key: "election_of_benefits_signed"), method: :post,
                      data: { turbo_confirm: "Confirm: patient (or representative) signed the Notice of Election of Benefits?" },
                      form: { class: "inline-block no-print" },
                      class: "text-[11px] px-3 py-1 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white font-medium whitespace-nowrap" do %>
                  Mark as signed
                <% end %>
              <% when "Patient rights not reviewed" %>
                <%= button_to quick_set_pre_admit_eval_path(@eval, key: "patient_rights_reviewed"), method: :post,
                      data: { turbo_confirm: "Confirm: patient rights and responsibilities reviewed with patient/family?" },
                      form: { class: "inline-block no-print" },
                      class: "text-[11px] px-3 py-1 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white font-medium whitespace-nowrap" do %>
                  Mark as reviewed
                <% end %>
              <% else %>
                <%= link_to "Open editor", edit_pre_admit_eval_path(@eval),
                      class: "text-[11px] px-3 py-1 rounded-full bg-white border border-[#D97757] text-[#C1403A] hover:bg-[#FFF3EC] font-medium whitespace-nowrap no-print" %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @eval.status_certified? || @eval.status_final? %>
      <div class="mb-5 rounded-2xl bg-[#F0F4FA] border border-[#2B4A7A] p-4">
        <div class="text-[11px] uppercase tracking-widest text-[#2B4A7A] font-bold">NOE filing deadline</div>
        <div class="text-[16px] text-[#1D1C1A] mt-1">
          <%= @eval.noe_deadline_at&.strftime("%a %b %-d, %Y") %>
          <% if @eval.noe_overdue? %>
            <span class="text-[#C1403A] font-bold ml-2">OVERDUE</span>
          <% else %>
            <span class="text-[#6B665F] ml-2">(<%= @eval.days_until_noe_deadline %>d remaining)</span>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# MD certification panel — visible when the eval is RN-finalized
        and the viewer is the on-call MD able to certify. Uses the
        shared signature_panel so the legal flow + audit row matches
        every other sign-off in the app. %>
    <% if @eval.status_final? && @eval.can_certify? && current_user.role_names.include?("md") %>
      <div class="mb-5 space-y-3 no-print">
        <div class="rounded-2xl bg-[#E6F0EE] border border-[#2F6F4E] p-4 flex items-start gap-3">
          <i class="ri-shield-check-line text-[#2F6F4E] text-lg mt-0.5 flex-shrink-0"></i>
          <div class="flex-1 min-w-0">
            <div class="text-[11px] uppercase tracking-widest text-[#2F6F4E] font-bold">Awaiting your certification</div>
            <div class="text-[12px] text-[#1D1C1A] mt-1">
              RN sign-off received. Review the eval below; once you're ready, sign to certify hospice eligibility and route to Insurance for NOE filing.
            </div>
          </div>
        </div>

        <%= render "shared/signature_panel",
              submit_path:   certify_pre_admit_eval_path(@eval),
              submit_method: :post,
              submit_label:  "Sign certification",
              headline:      "Sign · MD certification",
              intent_text:   "I, the on-call physician, certify this pre-admit evaluation as supporting hospice eligibility and authorize the application of my electronic signature.",
              confirm:       "Apply your signature and certify hospice eligibility for #{@eval.patient.full_name}?",
              tone:          :certify %>

        <%# Send back for revision — the MD's escape hatch when
            something needs to change before they can certify. The
            eval flips back to :draft, the RN sees a banner with
            this comment on the visit edit page, and the round
            trip is logged in eval_revision_requests for audit. %>
        <details class="rounded-2xl border border-[#D97757] bg-[#FFF3EC] p-4 group">
          <summary class="cursor-pointer list-none flex items-center justify-between gap-2 [&::-webkit-details-marker]:hidden">
            <span class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-widest text-[#D97757] font-bold">
              <i class="ri-arrow-go-back-line"></i> Need changes before you sign?
            </span>
            <i class="ri-arrow-down-s-line text-[#D97757] group-open:rotate-180 transition-transform"></i>
          </summary>
          <div class="mt-3">
            <%= form_with url: request_changes_pre_admit_eval_path(@eval), method: :post, local: true,
                  data: { turbo_confirm: "Send this eval back to the RN with your comment? It will leave your queue until they re-route." },
                  class: "space-y-3" do |f| %>
              <label class="block text-[11px] uppercase tracking-widest text-[#4A4A45] font-bold">
                What needs to change?
              </label>
              <textarea name="comment" rows="3" required minlength="5"
                        placeholder="e.g. PPS justification doesn't match the narrative — clarify recent functional decline."
                        class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-white focus:bg-white focus:border-[#D97757] focus:outline-none text-[13px]"></textarea>
              <button type="submit"
                      class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-full bg-white border border-[#D97757] hover:bg-[#FFF3EC] text-[#D97757] text-sm font-semibold">
                <i class="ri-arrow-go-back-line"></i> Send back to RN
              </button>
            <% end %>
          </div>
        </details>
      </div>
    <% end %>

    <div class="space-y-4">
      <%# === General Comments + Chief Complaint + HPI ============== %>
      <section class="<%= card %>">
        <h2 class="<%= h2 %>"><i class="ri-edit-line text-[#6B665F]"></i> General comments</h2>
        <% if gc["chief_complaint"].to_s.strip.present? %>
          <div class="mb-3">
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Chief complaint</div>
            <div class="text-[13px] text-[#1D1C1A] mt-0.5"><%= gc["chief_complaint"] %></div>
          </div>
        <% end %>
        <% if gc["history_of_present_illness"].to_s.strip.present? %>
          <div class="mb-3">
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">History of present illness</div>
            <p class="text-[13px] text-[#1D1C1A] leading-relaxed whitespace-pre-wrap mt-0.5"><%= gc["history_of_present_illness"] %></p>
          </div>
        <% end %>
        <% if gc["narrative_summary"].to_s.strip.present? %>
          <div class="<%= "mb-3" if gc["chief_complaint"].present? || gc["history_of_present_illness"].present? %>">
            <% if gc["chief_complaint"].present? || gc["history_of_present_illness"].present? %>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Narrative summary</div>
            <% end %>
            <p class="text-[13px] text-[#1D1C1A] leading-relaxed whitespace-pre-wrap mt-0.5"><%= gc["narrative_summary"] %></p>
          </div>
        <% end %>
        <% if gc["chief_complaint"].blank? && gc["history_of_present_illness"].blank? && gc["narrative_summary"].blank? %>
          <p class="text-[12px] text-[#6B665F] italic">No narrative captured.</p>
        <% end %>
        <div class="grid grid-cols-2 gap-3 mt-3 text-[12px]">
          <div>
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Family / caregiver</div>
            <div class="text-[#1D1C1A]"><%= gc["family_caregiver_status"].presence || "—" %></div>
          </div>
          <div>
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Immediate safety risks</div>
            <div class="text-[#1D1C1A]"><%= Array(gc["immediate_safety_risks"]).join(", ").presence || "None reported" %></div>
          </div>
        </div>
      </section>

      <%# === Diagnosis ============================================= %>
      <section class="<%= card %>">
        <div class="flex items-center justify-between gap-2 mb-3">
          <h2 class="<%= h2 %> mb-0"><i class="ri-stethoscope-line text-[#2B4A7A]"></i> Diagnosis</h2>
          <% unless dx["hospice_eligible"].nil? %>
            <% if dx["hospice_eligible"] == true %>
              <span class="inline-flex items-center gap-1 text-[10px] uppercase tracking-widest font-bold rounded-full px-2 py-0.5 bg-[#E6F0EE] border border-[#2F6F4E] text-[#2F6F4E]">
                <i class="ri-check-line"></i> Hospice eligible
              </span>
            <% else %>
              <span class="inline-flex items-center gap-1 text-[10px] uppercase tracking-widest font-bold rounded-full px-2 py-0.5 bg-[#FFF3EC] border border-[#C1403A] text-[#C1403A]">
                <i class="ri-close-line"></i> Not eligible
              </span>
            <% end %>
          <% end %>
        </div>
        <% pdx = dx["primary_terminal_diagnosis"].is_a?(Hash) ? dx["primary_terminal_diagnosis"] : {} %>
        <div class="text-[13px] mb-2">
          <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Primary terminal</div>
          <div>
            <% if pdx["icd10"].present? %><strong class="font-mono"><%= pdx["icd10"] %></strong> · <% end %>
            <%= pdx["description"].presence || "—" %>
          </div>
        </div>
        <% if Array(dx["secondary_diagnoses"]).any? %>
          <div class="text-[12px]">
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Secondary</div>
            <ul class="list-disc ml-5 mt-1 text-[#1D1C1A] space-y-0.5">
              <% Array(dx["secondary_diagnoses"]).each do |s| %>
                <% next unless s.is_a?(Hash) %>
                <li>
                  <% if s["icd10"].present? %><strong class="font-mono"><%= s["icd10"] %></strong> · <% end %><%= s["description"] %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <% related = Array(dx["related_conditions"]); unrelated = Array(dx["unrelated_conditions"]) %>
        <% if related.any? || unrelated.any? %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-3 pt-3 border-t border-[#EFECE6]">
            <% if related.any? %>
              <div class="text-[12px]">
                <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-1">Related conditions</div>
                <ul class="list-disc ml-5 text-[#1D1C1A] space-y-0.5">
                  <% related.each do |c| %><li><%= c %></li><% end %>
                </ul>
              </div>
            <% end %>
            <% if unrelated.any? %>
              <div class="text-[12px]">
                <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-1">Unrelated conditions</div>
                <ul class="list-disc ml-5 text-[#1D1C1A] space-y-0.5">
                  <% unrelated.each do |c| %><li><%= c %></li><% end %>
                </ul>
              </div>
            <% end %>
          </div>
        <% end %>
        <% lcd = @eval.medicare_lcd %>
        <% if Array(dx["lcd_criteria_met"]).any? || lcd["lcd_type"].present? || lcd["supporting_documentation"].present? %>
          <div class="text-[12px] mt-3 pt-3 border-t border-[#EFECE6]">
            <div class="flex items-baseline justify-between gap-2 mb-1.5">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Medicare LCD criteria met</div>
              <% if lcd["lcd_type"].present? %>
                <span class="text-[10px] text-[#6B665F] font-mono">LCD: <%= lcd["lcd_type"] %></span>
              <% end %>
            </div>
            <div class="flex flex-wrap gap-1.5">
              <% Array(dx["lcd_criteria_met"]).each do |c| %>
                <span class="inline-flex items-center gap-1 text-[11px] px-2 py-0.5 rounded-full bg-[#E6F0EE] border border-[#2F6F4E] text-[#2F6F4E]">
                  <i class="ri-check-line"></i> <%= c %>
                </span>
              <% end %>
            </div>
            <% if lcd["supporting_documentation"].to_s.strip.present? %>
              <div class="mt-2 pt-2 text-[11px] text-[#3A3936] italic leading-relaxed pl-3 border-l-2 border-[#D9D5CD]">
                <%= lcd["supporting_documentation"] %>
              </div>
            <% end %>
          </div>
        <% end %>
      </section>

      <%# === Current Medications =================================== %>
      <% if meds.any? || disc.any? %>
        <section class="<%= card %>">
          <h2 class="<%= h2 %>"><i class="ri-capsule-line text-[#7A4A8C]"></i> Current medications</h2>
          <% if meds.any? %>
            <ul class="space-y-2 text-[13px]">
              <% meds.each do |m| %>
                <% next unless m.is_a?(Hash) %>
                <li class="flex items-baseline justify-between gap-2 border-b border-[#EFECE6] pb-2 last:border-0 last:pb-0">
                  <div class="min-w-0">
                    <div class="font-medium text-[#1D1C1A]"><%= m["name"] %> <span class="font-mono text-[12px] text-[#6B665F]"><%= m["dose"] %></span></div>
                    <div class="text-[11px] text-[#6B665F] font-mono"><%= [m["route"], m["frequency"]].compact_blank.join(" · ") %></div>
                  </div>
                  <div class="text-[11px] text-[#6B665F] italic flex-shrink-0"><%= m["indication"] %></div>
                </li>
              <% end %>
            </ul>
          <% end %>
          <% if disc.any? %>
            <div class="mt-3 pt-3 border-t border-[#EFECE6]">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-1">Discontinued</div>
              <ul class="list-disc ml-5 text-[12px] text-[#3A3936] space-y-0.5">
                <% disc.each do |d| %><li><%= d %></li><% end %>
              </ul>
            </div>
          <% end %>
        </section>
      <% end %>

      <%# === Other Symptoms ======================================== %>
      <% if sx.any? %>
        <section class="<%= card %>">
          <h2 class="<%= h2 %>"><i class="ri-pulse-line text-[#C1403A]"></i> Other symptoms</h2>
          <%
            pain = sx["pain"] || {}
            dyspnea = sx["dyspnea"] || {}
            gi = sx["gi_symptoms"] || {}
            psy = sx["psychosocial"] || {}
          %>
          <div class="grid grid-cols-2 gap-4 text-[12px]">
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Pain</div>
              <% if pain["score"].to_i.positive? %>
                <div class="text-[#1D1C1A]">
                  <span class="font-mono"><%= pain["score"] %>/10</span>
                  <% if pain["location"].present? %> · <%= pain["location"] %><% end %>
                </div>
                <% if pain["characteristics"].present? %>
                  <div class="text-[11px] text-[#6B665F]"><%= pain["characteristics"] %></div>
                <% end %>
                <% if pain["management"].present? %>
                  <div class="text-[11px] text-[#3A3936] italic mt-0.5"><%= pain["management"] %></div>
                <% end %>
              <% else %>
                <div class="text-[#6B665F]">—</div>
              <% end %>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Dyspnea</div>
              <div class="text-[#1D1C1A]"><%= dyspnea["severity"].presence || "—" %></div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">GI</div>
              <div class="text-[#1D1C1A] space-y-0.5">
                <% %w[nausea vomiting constipation].each do |k| %>
                  <% next if gi[k].to_s.empty? %>
                  <div><span class="text-[#6B665F]"><%= k.titleize %>:</span> <%= gi[k] %></div>
                <% end %>
                <% if gi.values.compact_blank.empty? %><div class="text-[#6B665F]">—</div><% end %>
              </div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Psychosocial</div>
              <div class="text-[#1D1C1A] space-y-0.5">
                <% %w[anxiety depression agitation].each do |k| %>
                  <% next if psy[k].to_s.empty? %>
                  <div><span class="text-[#6B665F]"><%= k.titleize %>:</span> <%= psy[k] %></div>
                <% end %>
                <% if psy.values.compact_blank.empty? %><div class="text-[#6B665F]">—</div><% end %>
              </div>
            </div>
          </div>

          <%# Additional symptom flags — delirium, active wounds,
              infections. Render only when populated. %>
          <% extra_sx = %w[delirium wounds infections].select { |k| sx[k].to_s.strip.present? } %>
          <% if extra_sx.any? %>
            <div class="grid grid-cols-3 gap-3 mt-3 pt-3 border-t border-[#EFECE6] text-[12px]">
              <% extra_sx.each do |key| %>
                <div>
                  <div class="text-[10px] uppercase tracking-widest text-[#6B665F]"><%= key.titleize %></div>
                  <div class="text-[#1D1C1A]"><%= sx[key] %></div>
                </div>
              <% end %>
            </div>
          <% end %>
        </section>
      <% end %>

      <%# === Cognitive Decline ===================================== %>
      <% if cog.any? %>
        <section class="<%= card %>">
          <h2 class="<%= h2 %>"><i class="ri-brain-line text-[#5A2F7A]"></i> Cognitive decline</h2>
          <div class="grid grid-cols-3 gap-3 text-[12px]">
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Mental status</div>
              <div class="text-[#1D1C1A]"><%= cog["mental_status"].presence || "—" %></div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">FAST score</div>
              <div class="text-[#1D1C1A] font-mono"><%= cog["fast_score"].presence || "—" %></div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">BIMS / MMSE</div>
              <div class="text-[#1D1C1A] font-mono"><%= cog["bims_mmse_score"].presence || "—" %></div>
            </div>
          </div>
          <% extra_cog = %w[orientation memory_loss decision_making_ability sundowning].select { |k| cog[k].to_s.strip.present? } %>
          <% if extra_cog.any? %>
            <div class="grid grid-cols-2 gap-3 mt-3 pt-3 border-t border-[#EFECE6] text-[12px]">
              <% extra_cog.each do |key| %>
                <div>
                  <div class="text-[10px] uppercase tracking-widest text-[#6B665F]"><%= key.tr("_", " ").titleize %></div>
                  <div class="text-[#1D1C1A]"><%= cog[key] %></div>
                </div>
              <% end %>
            </div>
          <% end %>
          <% if Array(cog["behavioral_symptoms"]).any? %>
            <div class="text-[11px] text-[#6B665F] mt-2">Behaviors: <%= Array(cog["behavioral_symptoms"]).join(", ") %></div>
          <% end %>
        </section>
      <% end %>

      <%# === Nutritional Decline =================================== %>
      <% if nut.any? %>
        <section class="<%= card %>">
          <h2 class="<%= h2 %>"><i class="ri-restaurant-line text-[#8C6A2F]"></i> Nutritional decline</h2>
          <div class="grid grid-cols-2 md:grid-cols-5 gap-3 text-[12px]">
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Current weight</div>
              <div class="text-[#1D1C1A] font-mono"><%= nut["current_weight_lbs"].present? ? "#{nut["current_weight_lbs"]} lb" : "—" %></div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Weight loss</div>
              <div class="text-[#1D1C1A] font-mono">
                <% loss = [(nut["weight_loss_lbs"].present? ? "#{nut["weight_loss_lbs"]} lb" : nil),
                            (nut["weight_loss_pct"].present? ? "#{nut["weight_loss_pct"]}%" : nil)].compact_blank.join(" · ") %>
                <%= loss.presence || "—" %>
              </div>
              <% if nut["weight_loss_timeframe"].present? %>
                <div class="text-[11px] text-[#6B665F]">over <%= nut["weight_loss_timeframe"] %></div>
              <% end %>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Albumin</div>
              <div class="text-[#1D1C1A] font-mono"><%= nut["albumin_g_dl"].present? ? "#{nut["albumin_g_dl"]} g/dL" : "—" %></div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">MAC</div>
              <div class="text-[#1D1C1A] font-mono"><%= nut["mac_cm"].present? ? "#{nut["mac_cm"]} cm" : "—" %></div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Intake</div>
              <div class="text-[#1D1C1A]"><%= nut["intake"].presence || "—" %></div>
            </div>
          </div>

          <%# Additional nutritional risk indicators — appetite,
              dysphagia, tube feeding, hydration. Each renders only
              when populated so a sparse intake-stage eval doesn't
              show a wall of "—". %>
          <% extra_nut = %w[appetite dysphagia tube_feeding hydration_status].select { |k| nut[k].to_s.strip.present? } %>
          <% if extra_nut.any? %>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-3 pt-3 border-t border-[#EFECE6] text-[12px]">
              <% extra_nut.each do |key| %>
                <div>
                  <div class="text-[10px] uppercase tracking-widest text-[#6B665F]"><%= key.tr("_", " ").titleize %></div>
                  <div class="text-[#1D1C1A]"><%= nut[key] %></div>
                </div>
              <% end %>
            </div>
          <% end %>

          <%# Decline trajectory since referral. Surveyors specifically
              look for documented decline between referral and admission
              to support hospice eligibility. %>
          <% nut_change = nut["change_from_referral"].is_a?(Hash) ? nut["change_from_referral"] : {} %>
          <% if nut_change.values.compact_blank.any? %>
            <div class="mt-3 pt-3 border-t border-[#EFECE6]">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-1.5 flex items-center gap-1">
                <i class="ri-arrow-down-line text-[#C1403A]"></i> Change from referral
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-[12px]">
                <% if nut_change["weight_loss_lbs_delta"].present? %>
                  <div>
                    <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Additional weight loss</div>
                    <div class="text-[#C1403A] font-mono"><%= nut_change["weight_loss_lbs_delta"] %> lb since referral</div>
                  </div>
                <% end %>
                <% if nut_change["intake_change"].present? %>
                  <div>
                    <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Intake change</div>
                    <div class="text-[#1D1C1A]"><%= nut_change["intake_change"] %></div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>

      <%# === Functional Decline (PPS spotlight) ==================== %>
      <% if fd.any? %>
        <section class="<%= card %>">
          <h2 class="<%= h2 %>"><i class="ri-walk-line text-[#2F6F4E]"></i> Functional decline</h2>
          <%# PPS card with the suggested-vs-confirmed treatment. %>
          <%
            calculated = pps_h["source"] == "calculated"
            score      = pps_h["score"].to_i
          %>
          <div class="rounded-xl <%= calculated ? "bg-[#F0F4FA] border border-dashed border-[#2B4A7A]" : "bg-[#FBF9F5] border border-[#EFECE6]" %> p-4 mb-4">
            <div class="flex items-baseline justify-between gap-3">
              <div>
                <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-0.5">Palliative Performance Scale</div>
                <div class="font-serif text-[28px] text-[#1D1C1A] leading-none"><%= score.positive? ? "#{score}%" : "—" %></div>
                <% if calculated %>
                  <div class="inline-flex items-center gap-1 mt-1 text-[10px] uppercase tracking-[0.18em] text-[#2B4A7A] font-bold">
                    <i class="ri-sparkling-2-line"></i> Suggested based on narrative
                  </div>
                <% elsif score.positive? %>
                  <div class="inline-flex items-center gap-1 mt-1 text-[10px] uppercase tracking-[0.18em] text-[#2F6F4E] font-bold">
                    <i class="ri-check-line"></i> Confirmed by clinician
                  </div>
                <% end %>
              </div>
              <% if calculated && (@eval.status_draft? || @eval.status_final?) %>
                <%= button_to confirm_pps_pre_admit_eval_path(@eval), method: :post,
                      data: { turbo_confirm: "Confirm PPS at #{score}%? Status will flip to clinician-confirmed." },
                      form: { class: "no-print" },
                      class: "inline-flex items-center gap-1 text-[12px] px-3 py-1.5 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white font-medium cursor-pointer" do %>
                  <i class="ri-check-double-line"></i> Confirm
                <% end %>
              <% end %>
            </div>
            <% if pps_h["justification"].to_s.strip.present? %>
              <details class="mt-3 group">
                <summary class="cursor-pointer list-none text-[11px] text-[#6B665F] hover:text-[#1D1C1A] [&::-webkit-details-marker]:hidden">
                  <i class="ri-arrow-right-s-line group-open:rotate-90 transition-transform inline-block"></i>
                  Why this score
                </summary>
                <p class="text-[12px] text-[#3A3936] mt-2 leading-relaxed pl-4 border-l-2 border-[#D9D5CD]"><%= pps_h["justification"] %></p>
              </details>
            <% end %>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-[12px]">
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">KPS</div>
              <div class="text-[#1D1C1A] font-mono"><%= fd["kps"].present? ? "#{fd["kps"]}%" : "—" %></div>
            </div>
            <div class="md:col-span-2">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Mobility</div>
              <div class="text-[#1D1C1A]"><%= fd["mobility"].presence || "—" %></div>
            </div>
          </div>

          <% if fd["fall_history"].present? || fd["recent_functional_changes"].present? %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-3 text-[12px]">
              <% if fd["fall_history"].present? %>
                <div>
                  <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Fall history</div>
                  <div class="text-[#1D1C1A]"><%= fd["fall_history"] %></div>
                </div>
              <% end %>
              <% if fd["recent_functional_changes"].present? %>
                <div>
                  <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Recent functional changes</div>
                  <div class="text-[#1D1C1A]"><%= fd["recent_functional_changes"] %></div>
                </div>
              <% end %>
            </div>
          <% end %>

          <% adl = fd["adl_dependencies"].is_a?(Hash) ? fd["adl_dependencies"] : {} %>
          <% if adl.values.compact_blank.any? %>
            <div class="mt-3 pt-3 border-t border-[#EFECE6]">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-2">ADL dependencies</div>
              <div class="grid grid-cols-2 md:grid-cols-5 gap-2 text-[11px]">
                <% %w[bathing dressing feeding toileting transferring].each do |task| %>
                  <%
                    val   = adl[task].to_s
                    color = case val
                            when "Dependent"  then "#C1403A"
                            when "Assist"     then "#D97757"
                            when "Independent" then "#2F6F4E"
                            else                    "#6B665F"
                            end
                  %>
                  <div>
                    <div class="text-[9px] uppercase tracking-widest text-[#6B665F]"><%= task.titleize %></div>
                    <div style="color: <%= color %>;" class="font-medium"><%= val.presence || "—" %></div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# Functional decline trajectory since referral — pairs
              with the nutritional change_from_referral block to give
              surveyors a clear "why now" story. %>
          <% fd_change = fd["change_from_referral"].is_a?(Hash) ? fd["change_from_referral"] : {} %>
          <% if fd_change.values.compact_blank.any? %>
            <div class="mt-3 pt-3 border-t border-[#EFECE6]">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-1.5 flex items-center gap-1">
                <i class="ri-arrow-down-line text-[#C1403A]"></i> Change from referral
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-[12px]">
                <% if fd_change["pps_delta"].present? %>
                  <div>
                    <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">PPS delta</div>
                    <% pps_delta_int = fd_change["pps_delta"].to_i %>
                    <div class="<%= pps_delta_int.negative? ? "text-[#C1403A]" : "text-[#1D1C1A]" %> font-mono">
                      <%= pps_delta_int.positive? ? "+" : "" %><%= pps_delta_int %>% since referral
                    </div>
                  </div>
                <% end %>
                <% if fd_change["mobility_change"].present? %>
                  <div>
                    <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Mobility change</div>
                    <div class="text-[#1D1C1A]"><%= fd_change["mobility_change"] %></div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>

      <%# === General (consents, AD, DME, spiritual) ================= %>
      <section class="<%= card %>">
        <h2 class="<%= h2 %>"><i class="ri-shield-check-line text-[#2F6F4E]"></i> General</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-y-2 text-[12px]">
          <div class="text-[#6B665F]">Election of benefits signed</div>
          <div><%= yes_.call(gen["election_of_benefits_signed"] == true).html_safe %></div>
          <div class="text-[#6B665F]">Patient rights reviewed</div>
          <div><%= yes_.call(gen["patient_rights_reviewed"] == true).html_safe %></div>
          <div class="text-[#6B665F]">Advance directives</div>
          <div class="text-[#1D1C1A]"><%= gen["advance_directives"].presence || "—" %></div>
          <div class="text-[#6B665F]">Spiritual / bereavement risk</div>
          <div class="text-[#1D1C1A]"><%= gen["spiritual_bereavement_risk"].presence || "—" %></div>
        </div>
        <% if Array(gen["dme_needs"]).any? %>
          <div class="mt-3 pt-3 border-t border-[#EFECE6]">
            <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-1">DME needs</div>
            <div class="flex flex-wrap gap-1.5">
              <% Array(gen["dme_needs"]).each do |d| %>
                <span class="inline-flex items-center gap-1 text-[11px] px-2 py-0.5 rounded-full bg-[#FBF9F5] border border-[#D9D5CD] text-[#1D1C1A]">
                  <i class="ri-tools-line text-[#6B665F]"></i> <%= d %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
        <% if gen["notes"].to_s.strip.present? %>
          <p class="text-[12px] text-[#3A3936] mt-3 italic"><%= gen["notes"] %></p>
        <% end %>
      </section>

      <%# === Equipment ============================================
          Granular equipment status (oxygen / hospital_bed / walker /
          wheelchair / commode etc.). Renders only when at least one
          item has a value. Complements the lighter `dme_needs` array
          which captures upcoming requests. %>
      <% eq = @eval.equipment %>
      <% if eq.values.compact_blank.any? %>
        <section class="<%= card %>">
          <h2 class="<%= h2 %>"><i class="ri-tools-line text-[#6B665F]"></i> Equipment</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-[12px]">
            <% %w[oxygen hospital_bed walker wheelchair commode other].each do |item| %>
              <% val = eq[item].to_s.strip %>
              <% next if val.empty? %>
              <div>
                <div class="text-[10px] uppercase tracking-widest text-[#6B665F]"><%= item.tr("_", " ").titleize %></div>
                <div class="text-[#1D1C1A]"><%= val %></div>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <%# === Final review =========================================
          Free-text fields the RN writes to summarize eligibility,
          prognosis, and the recommendation to the MD. These show up
          on the printed PDF + travel into the certification packet. %>
      <% fr = @eval.final_review_section %>
      <% if fr["hospice_eligibility_statement"].present? || fr["prognosis_estimate"].present? || fr["rn_recommendation"].present? %>
        <section class="<%= card %>">
          <h2 class="<%= h2 %>"><i class="ri-quill-pen-line text-[#2B4A7A]"></i> RN final review</h2>
          <% if fr["hospice_eligibility_statement"].present? %>
            <div class="mb-3">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-0.5">Hospice eligibility statement</div>
              <p class="text-[13px] text-[#1D1C1A] leading-relaxed whitespace-pre-wrap"><%= fr["hospice_eligibility_statement"] %></p>
            </div>
          <% end %>
          <% if fr["prognosis_estimate"].present? %>
            <div class="mb-3">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-0.5">Prognosis estimate</div>
              <p class="text-[13px] text-[#1D1C1A] leading-relaxed"><%= fr["prognosis_estimate"] %></p>
            </div>
          <% end %>
          <% if fr["rn_recommendation"].present? %>
            <div>
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-0.5">RN recommendation</div>
              <p class="text-[13px] text-[#1D1C1A] leading-relaxed whitespace-pre-wrap"><%= fr["rn_recommendation"] %></p>
            </div>
          <% end %>
        </section>
      <% end %>

      <%# === Referral context =====================================
          Operational metadata from the referral that triggered the
          eval (referring physician, location, insurance, family
          caller). Useful for the MD reading the cert and for
          future surveyor audit ("where did this patient come from?"). %>
      <% rc = @eval.referral_context %>
      <% if rc["referral_id"].present? || rc["referring_physician"].present? || rc["caller"].is_a?(Hash) %>
        <section class="<%= card %>">
          <h2 class="<%= h2 %>"><i class="ri-mail-send-line text-[#6B665F]"></i> Referral context</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-[12px]">
            <% if rc["referral_id"].present? %>
              <div>
                <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Referral ID</div>
                <div class="text-[#1D1C1A] font-mono"><%= rc["referral_id"] %></div>
              </div>
            <% end %>
            <% if rc["case_id"].present? %>
              <div>
                <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Case ID</div>
                <div class="text-[#1D1C1A] font-mono"><%= rc["case_id"] %></div>
              </div>
            <% end %>
            <% if rc["referring_physician"].present? %>
              <div>
                <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Referring MD</div>
                <div class="text-[#1D1C1A]"><%= rc["referring_physician"] %></div>
              </div>
            <% end %>
            <% if rc["location"].present? %>
              <div>
                <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Location</div>
                <div class="text-[#1D1C1A]"><%= rc["location"] %></div>
              </div>
            <% end %>
            <% if rc["insurance"].present? %>
              <div>
                <div class="text-[10px] uppercase tracking-widest text-[#6B665F]">Insurance</div>
                <div class="text-[#1D1C1A]"><%= rc["insurance"] %></div>
              </div>
            <% end %>
          </div>
          <% caller = rc["caller"].is_a?(Hash) ? rc["caller"] : {} %>
          <% if caller.values.compact_blank.any? %>
            <div class="mt-3 pt-3 border-t border-[#EFECE6] text-[12px]">
              <div class="text-[10px] uppercase tracking-widest text-[#6B665F] mb-1">Caller</div>
              <div class="text-[#1D1C1A]">
                <%= caller["name"] %><% if caller["relationship"].present? %> <span class="text-[#6B665F]">(<%= caller["relationship"] %>)</span><% end %>
                <% if caller["phone"].present? %><span class="ml-2 font-mono text-[#6B665F]">· <%= caller["phone"] %></span><% end %>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>
    </div>

    <%# Print-only signature footer. Renders only inside the printed
        PDF. Shows the RN evaluator's name + date for any status; the
        MD signature line appears certified-only and reads from the
        actual certified_by + certified_at fields (no fake signature
        for un-certified evals). %>
    <div class="print-only mt-8 pt-6" style="border-top: 1px solid #999;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px; font-size: 11px;">
        <div>
          <div style="border-bottom: 1px solid #1D1C1A; padding-bottom: 4px; min-height: 28px;">
            <span style="font-weight: 600;"><%= evaluator&.full_name %></span>
            <% if evaluator_role.present? %><span style="color: #444;">, <%= evaluator_role.upcase %></span><% end %>
          </div>
          <div style="text-transform: uppercase; letter-spacing: 0.1em; font-size: 9px; color: #444; margin-top: 4px;">Evaluating clinician</div>
          <div style="font-size: 10px; color: #444; margin-top: 2px;">Date: <%= (@eval.evaluated_at || @eval.created_at).strftime("%b %-d, %Y") %></div>
        </div>
        <div>
          <% if @eval.status_certified? && @eval.certified_by.present? %>
            <div style="border-bottom: 1px solid #1D1C1A; padding-bottom: 4px; min-height: 28px;">
              <span style="font-weight: 600;"><%= @eval.certified_by.full_name %>, MD</span>
            </div>
            <div style="text-transform: uppercase; letter-spacing: 0.1em; font-size: 9px; color: #444; margin-top: 4px;">Certifying physician (electronically signed)</div>
            <div style="font-size: 10px; color: #444; margin-top: 2px;">Signed: <%= @eval.certified_at.strftime("%b %-d, %Y · %-l:%M %p") %></div>
          <% else %>
            <div style="border-bottom: 1px solid #999; padding-bottom: 4px; min-height: 28px;">
              <span style="color: #999;">Pending MD certification</span>
            </div>
            <div style="text-transform: uppercase; letter-spacing: 0.1em; font-size: 9px; color: #444; margin-top: 4px;">Certifying physician</div>
            <div style="font-size: 10px; color: #444; margin-top: 2px;">Date: __________________</div>
          <% end %>
        </div>
      </div>
    </div>

    <%# === Action bar =============================================
        Layered by status:
          draft       — Edit eval (always) + Mark Complete & Route to MD (gated on no blockers)
          final       — Edit eval (always) + Certify (MD only, gated on no blockers)
          certified+  — read-only, just the back link %>
    <div class="mt-6 flex items-center justify-between gap-2 flex-wrap no-print">
      <% if (@eval.status_draft? || @eval.status_final?) %>
        <%= link_to edit_pre_admit_eval_path(@eval),
              class: "inline-flex items-center gap-1 text-[13px] px-4 py-2 rounded-full border border-[#D9D5CD] text-[#1D1C1A] hover:bg-white" do %>
          <i class="ri-edit-line"></i> Edit eval
        <% end %>
      <% else %>
        <span></span>
      <% end %>

      <div class="flex items-center gap-2">
        <% if @eval.status_draft? %>
          <% if @eval.can_certify? %>
            <%= button_to finalize_pre_admit_eval_path(@eval), method: :post,
                  data: { turbo_confirm: "Mark this eval complete and route to MD for certification?" },
                  class: "inline-flex items-center gap-1.5 text-[13px] px-4 py-2 rounded-full bg-[#2F6F4E] hover:bg-[#265a3d] text-white font-medium cursor-pointer" do %>
              <i class="ri-send-plane-line"></i> Mark Complete &amp; Route to MD
            <% end %>
          <% else %>
            <button type="button" disabled
                    title="Resolve <%= blockers.size %> blocker#{'s' if blockers.size != 1} above first"
                    class="inline-flex items-center gap-1.5 text-[13px] px-4 py-2 rounded-full bg-[#EFECE6] text-[#6B665F] font-medium cursor-not-allowed">
              <i class="ri-lock-2-line"></i> Mark Complete &amp; Route to MD
            </button>
          <% end %>
        <% end %>

        <%# MD certification entry point lives in the top "Awaiting
            your certification" panel above (the shared signature
            panel). Keeping it in one place prevents an unsigned
            shortcut around the intent checkbox + audit logging. %>
      </div>
    </div>
  </div>
</div>
