<% content_for :title, "Admissions · #{@patient.full_name}" %>

<div class="max-w-3xl mx-auto px-4 md:px-8 py-6">
  <div class="flex items-start justify-between gap-3 mb-5">
    <div>
      <div class="text-[11px] uppercase tracking-[0.2em] text-[#6B665F] font-bold">Admission history</div>
      <h1 class="font-serif text-[24px] text-[#1D1C1A]"><%= @patient.full_name %></h1>
      <div class="text-[12px] text-[#6B665F]"><%= pluralize(@evals.size, "admission eval") %></div>
    </div>
    <%= link_to patient_path(@patient),
          class: "text-[13px] text-[#2B4A7A] hover:underline inline-flex items-center gap-1 flex-shrink-0" do %>
      <i class="ri-arrow-left-line"></i> Back to patient
    <% end %>
  </div>

  <% if @evals.empty? %>
    <div class="rounded-2xl border border-[#EFECE6] bg-white p-8 text-center text-[13px] text-[#6B665F]">
      No admission evals on file for this patient yet.
    </div>
  <% else %>
    <ul class="space-y-2">
      <%= render partial: "eval_row", collection: @evals, as: :record, locals: { show_patient: false } %>
    </ul>
  <% end %>
</div>
