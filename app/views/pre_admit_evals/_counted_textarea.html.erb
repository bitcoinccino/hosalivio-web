<%# Char-counted textarea for the eval edit modals.
    Locals: name, value; optional label, rows (3), max (500), placeholder, hint. %>
<%
  rows        = local_assigns.fetch(:rows, 3)
  max         = local_assigns.fetch(:max, 500)
  label       = local_assigns[:label]
  hint        = local_assigns[:hint]
  placeholder = local_assigns[:placeholder]
%>
<div data-controller="char-counter" data-char-counter-max-value="<%= max %>">
  <% if label %><label class="block text-[10px] uppercase tracking-widest text-[#6B665F] font-medium mb-1"><%= label %></label><% end %>
  <textarea name="<%= name %>" rows="<%= rows %>" maxlength="<%= max %>"
            <%= "placeholder=\"#{placeholder}\"".html_safe if placeholder %>
            data-char-counter-target="field" data-action="input->char-counter#update"
            class="w-full px-3 py-2 rounded-lg border border-[#D9D5CD] bg-[#FBF9F5] focus:bg-white focus:border-[#2B4A7A] focus:outline-none text-[13px]"><%= value %></textarea>
  <div class="flex items-center justify-between mt-0.5">
    <span class="text-[10px] text-[#6B665F]"><%= hint %></span>
    <span class="text-[10px] text-[#6B665F]" data-char-counter-target="count">0/<%= max %></span>
  </div>
</div>
